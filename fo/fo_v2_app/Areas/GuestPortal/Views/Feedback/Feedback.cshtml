                                                    scales: {
                                                        y: {
                                                            beginAtZero: true
                                                        }
                                                    },
                                                    plugins: {
                                                        legend: {
                                                            display: true,
                                                            position: 'right',
                                                        },
                                                        title: {
                                                            display: false,
                                                            position: 'top',
                                                            text: 'Bar Chart'
                                                        }
