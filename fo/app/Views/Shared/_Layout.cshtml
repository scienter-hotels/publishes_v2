            datatype: 'json',
            beforeSend: function () {
                $('<div class="input-group searchdiv" style="width:94%;margin-top: -10px;"><div class="form-group is-empty"><input type="text" class="form-control reservation-text-box reservation-single-line" placeholder="Search" onkeyup="textsearch()" id="TextSearch"><span class="material-input"></span></div></div>'
                ).appendTo("#reservationNumbersLoadingArea");
            },
            success: function (data) {
                $.each(data, function (index, item) {

                    var reservations = "";
                    var reservationStatus = "";
                    var resNumbers = "";

                    if (item.ReservationNumbers != "") {

                        reservations = $.parseJSON(item.ReservationNumbers);

