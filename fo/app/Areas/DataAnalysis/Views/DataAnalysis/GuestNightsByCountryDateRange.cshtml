<input type="hidden" name="From" id="FromDate" value="@DateTime.Now.AddDays(-365).ToString("dd/MM/yyyy")" />
<input type="hidden" name="To" id="ToDate" value="@DateTime.Now.ToString("dd/MM/yyyy")" />
<script src='https://cdn.plot.ly/plotly-latest.min.js'></script>

<script>

    $(function () {
       
        var fromDate = $('#FromDate').val();
        var toDate = $('#ToDate').val();

        var fromFormatted = ChangeDateFormat(fromDate);
        var toFormatted = ChangeDateFormat(toDate);


        GetOccupancyOnDateChange(fromFormatted, toFormatted);
    });

    function dateFormatChanger(d) {
        var splitedDate = d.split('/');
        var changedDate = splitedDate[1] + "/" + splitedDate[0] + "/" + splitedDate[2];
        return changedDate;
    }

    $('body').on('click', '.applyBtn', function () {
        $('#RoomAvailabilityGrid').html('');

        var fromDate = $('#FromDate').val();
        var toDate = $('#ToDate').val();

        var fromFormatted = ChangeDateFormat(fromDate);
        var toFormatted = ChangeDateFormat(toDate);


        GetOccupancyOnDateChange(fromFormatted, toFormatted);

    });


    function unpack(rows, key) {
        return rows.map(function (row) { return row[key]; });
    }


    function GetOccupancyOnDateChange(fromDate, toDate) {
       
        $.ajax({
            method: 'post',
            url: '/DataAnalysis/DataAnalysis/AnalysisInformation?fromDate=' + fromDate + '&todate=' + toDate + '&area=' + 'CO',
            datatype: 'json',
            success: function (AnalysisInformation) {
                //console.log(AnalysisInformation);
                occupancyObj = JSON.parse(AnalysisInformation.RoomAvailabilityWithOccupancyAsJson);
                var countryArray = [];
                var countryCode = [];
                var countryRoomNights= [];
                $(occupancyObj).each(function (index, item) {
                    countryArray.push(item.COUNTRY);
                    countryCode.push(item.COUNTRYCODE);
                    countryRoomNights.push(item.GUESTNIGHTS);
                });


                var headerNamesRNYBYTable = ['COUNTRY', 'MONTH', 'GUESTNIGHTS'];

                var headerValuesRNYBYTable = [];
                var cellValuesRNYBYTable = [];
                for (i = 0; i < headerNamesRNYBYTable.length; i++) {
                    headerValue = [headerNamesRNYBYTable[i]];
                    headerValuesRNYBYTable[i] = headerValue;
                    cellValue = unpack(occupancyObj, headerNamesRNYBYTable[i]);
                    cellValuesRNYBYTable[i] = cellValue;
                }

                var dataRNYBYTable = [{
                    type: 'table',
                    columnwidth: [1000, 600, 600, 600],
                    columnorder: [0, 1, 2, 3],
                    header: {
                        values: headerValuesRNYBYTable,
                        align: "center",
                        line: { width: 1, color: 'white' },
                        fill: { color: ['#2c3e50'] },
                        font: { family: "Arial", size: 12, color: "white" }
                    },
                    cells: {
                        values: cellValuesRNYBYTable,
                        align: ["center", "center", "right"],
                        line: { color: "white", width: 1 },
                        fill: { color: ['#e67e22', '#e67e22', 'rgba(231, 76, 60,1.0)'] },
                        font: { family: "Arial", size: 12, color: ["white"] }
                    }
                }]

                var layoutRNYBYTable = {
                    margin: {
                        "b": 0,
                        "l": 0,
                        "r": 0,
                        "t": 0,
                    }
                }

                Plotly.newPlot('DivDataTable', dataRNYBYTable, layoutRNYBYTable, { responsive: true });



                //GRAPH

                var data = [{
                    type: 'choropleth',
                    locationmode: countryArray,
                    locations: countryCode,
                    z: countryRoomNights,
                    text: countryArray,
                    autocolorscale: false,
                    reversescale: true,
                    colorscale: 'Portland',
                    transforms: [{
                        type: 'aggregate',
                        groups: countryCode,
                        aggregations: [
                            { target: 'z', func: 'sum', enabled: true },
                        ]
                    }]
                }];

                var layout = {
                    autosize: true,
                    margin: {
                        "b": 10,
                        "l": 0,
                        "r": 0,
                        "t": 50,
                    },
                    geo: {
                        showcountries: true,
                        showcoastlines: false,
                        showframe: false,
                        showocean: true,
                        oceancolor: '#4bcffa',
                        showcountries: true,
                        projection: {
                            type: 'orthographic'
                        }
                    },
                    updatemenus: [{
                        x: 0.65,
                        y: 1.10,
                        xref: 'paper',
                        yref: 'paper',
                        yanchor: 'top',
                        active: 0,
                        showactive: true,
                        buttons: [{
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'sum'],
                            label: 'Total Room Nights '
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'avg'],
                            label: 'Mean - Room Nights per Month'
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'min'],
                            label: 'Min. Room Nights'
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'max'],
                            label: 'Max. Room Nights'
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'mode'],
                            label: 'Mode -(Room Nights Appears Most Often) '
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'median'],
                            label: 'Median - (the Higher from the Lower Half)'
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'First Month'],
                            label: 'First'
                        }, {
                            method: 'restyle',
                            args: ['transforms[0].aggregations[0].func', 'Last Month'],
                            label: 'Last'
                        }]
                    }]
                };

                Plotly.newPlot('graph', data, layout, { responsive: true });

            }
        });
    }

    function getDateforHeader(date, thOrHidden) {

        var weekday = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
        var monthsArr = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var returnDate;
        var year, dayName, dayNumStr = '';

        dayName = weekday[date.getDay()];

        var dateVar = new Date(date).getDate();
        if (dateVar.toString().length <= 1) {
            ;
            dayNumStr = '0' + dateVar.toString();
        } else {
            dayNumStr = dateVar.toString();
        }

        var month = new Date(date).getMonth() + 1
        if (month.toString().length <= 1) {
            month = '0' + month.toString();
        }

        year = new Date(date).getFullYear().toString();
        if (thOrHidden == 'hid') {
            returnDate = dayNumStr + '/' + month + '/' + year;
        } else if (thOrHidden == 'th') {
            returnDate = dayName + '<br />' + '<p style="font-size:24px">' + dayNumStr + '<p>' + monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'ywm') {
            returnDate = monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'mon') {
            returnDate = month;
        } else if (thOrHidden == 'withdash') {
            returnDate = month + '/' + dateVar + '/' + year;
        }

        return returnDate;
    }


    // new Date("dateString") is browser-dependent and discouraged, so we'll write
    // a simple parse function for U.S. date format (which does no error checking)
    function parseDate(str) {
        var mdy = str.split('/');
        return new Date(mdy[2], mdy[0] - 1, mdy[1]);
    }

    // Take the difference between the dates and divide by milliseconds per day.
    // Round to nearest whole number to deal with DST.
    function datediff(first, second) {
        return Math.round((second - first) / (1000 * 60 * 60 * 24));
    }

    Date.prototype.addDays = function (days) {
        var dat = new Date(this.valueOf());
        dat.setDate(dat.getDate() + days);
        return dat;
    }
</script>


