                    <th class="text-primary " input type="text">
                        Fri
                    </th>
                    <th class="text-primary " input type="text">
                        Sat
                    </th>
                </tr>
                <tr>
                    <td class="Sun"></td>
                    <td class="Mon"></td>
                    <td class="Tue"></td>
                    <td class="Wed"></td>
                    <td class="Thu"></td>
                    <td class="Fri"></td>
                    <td class="Sat"></td>
                </tr>
            </table>
        </div>
    </div>

</div>
