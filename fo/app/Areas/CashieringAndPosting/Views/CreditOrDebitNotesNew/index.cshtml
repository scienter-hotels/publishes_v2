@{
    ViewBag.Title = "Credit Or Debit Notes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<body>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" data-background-color="purple">
                    <div class="row">
                        <div class="col-md-8">
                            <h4 class="title">
                                @ViewBag.Title
                                <hr class="visible-print" />
                            </h4>
                        </div>
                        <div class="col-md-4 text-right hidden-print">
                        </div>
                    </div>
                </div>
                <style>
                    .search input {
                        border: 2px solid #d6d4d4;
                    }

                    .search .fa-search {
                        position: absolute;
                        top: 20px;
                        left: 16px;
                    }

                    .search button {
                        position: absolute;
                        top: 5px;
                        right: 5px;
                        width: 110px;
                    }
                </style>

                
                <div class="container" style="padding-top: 28px;">
                    <div class="row height d-flex justify-content-center align-items-center">
                        <div class="col-md-8" style="margin-left: 28px;">
                            <label class="form-label" for="datatable-search-input" style="color:black!important;border:none;font-weight:120;">
                                Search By Reservation No or Invoice No:
                            </label><br />
                            <div class="search">
                                <input type="text" name="search" id="searchKeyWord" class="form-control searchKeyWord" placeholder="Search...." style="margin-top: -26px;width: 663px;">
                                <button type="button" id="btn-SearchKeyWord" class="btn btn-primary btn-SearchKeyWord" style="margin-right: 146px;margin-top: 19px;">Search</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div id="FolioDetailsTB" style="height:420px; overflow-x:hidden; overflow-y:scroll;">
                            <table class="table table-striped" id="tblDetails" cellspacing="5" style="margin-left: 13px;">
                                <tr>
                                    <th class="text-primary ">
                                        Reservation No
                                    </th>
                                    <th class="text-primary ">
                                        Invoice No
                                    </th>
                                    <th class="text-primary ">
                                        Payment Type
                                    </th>
                                    <th class="text-primary ">
                                        Paid Amount
                                    </th>
                                    <th class="text-primary " ">
                                        Currency
                                    </th>
                                    <th>
                                    </th>
                                </tr>

                                <tbody class="all-transaction">
                                    <tr>
                                        <td class="" colspan="5">
                                            <center id="imgLoadingPot">
                                                <br />
                                                <br />
                                                <br />
                                                <img src="/Images/loading_pot.gif" width="200px" id="2"/>
                                            </center>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>            
            </div>
        </div>
    </div>
</body>

