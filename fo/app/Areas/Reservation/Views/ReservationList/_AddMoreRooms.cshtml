<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>


<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>

<form id="addNewRoomForm">
    <input type="hidden" id="groupReservationNo" name="groupReservationNo" value="@ViewBag.GroupReservationNo" required />
    <input type="hidden" id="reservationHeaderId" name="reservationHeaderId" value="@ViewBag.ReservationHeaderId" required />

    <input type="hidden" id="existRoomCategory" name="existRoomCategory" value="@ViewBag.RoomCategoryId" required />
    <input type="hidden" id="existRoomType" name="existRoomType" value="@ViewBag.RoomTypeId" required />
    <input type="hidden" id="existMealPlan" name="existMealPlan" value="@ViewBag.MealPlanId" required />
    <input type="hidden" id="isDormitory" name="isDormitory" value="@ViewBag.IsDormitory" required />
    <input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />

    <input type="hidden" name="Arrival" id="Arrival" value="@ViewBag.Arrival" />
    <input type="hidden" name="Departure" id="Departure" value="@ViewBag.Departure" />

    <div class="row">
        <div class="col-md-2">
            <div class="form-group label-floating">
                <label class="required control-label">Status</label>
                <select name="ReservationStatusId" id="ReservationStatusId" class="select2 form-control label-data" required>           
                </select>
                @*@{Html.RenderAction("ReservationStatusCombo", "ReservationStatus", new { area = "Administration", name = "ReservatonStatusId", requiered = true, });}*@
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-group label-floating">
                <label class="required control-label">Room Category</label>
                <select name="NewRoomCategory" id="NewRoomCategory" class="select2 form-control" required>
                    <option value="-1">Select Res Type</option>
                </select>
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-group  label-floating">
                <label class="required control-label">Room Type</label>
                <select name="NewRoomType" id="NewRoomType" class="select2 form-control" required>
                    <option value="-1">Select Res Type</option>
                </select>
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-group  label-floating">
                <label class="required control-label">Meal Plan</label>
                <select name="NewMealPlan" id="NewMealPlan" class="select2 form-control" required>
                    <option></option>
                </select>
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-group  label-floating">
                <label class="required control-label">No Of Rooms</label>
                <input type="number" class="form-control NewNoOfRooms" min="1" max="" required />
            </div>
        </div>

        <div class="col-md-2" style="padding-top: 25px;">
            <input type="button" id="btnAddRecord" value="Add" class="btn btn-primary btn-width-100" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="loading-area">
                <table class="table font-size-12px" id="selectedRecords">
                    <tr>
                        <th>Room Cat</th>
                        <th>Room Type</th>
                        <th>Meal Plan</th>
                        <th class="text-right col-sm-2">No Of Rooms</th>
                        <th class="col-sm-2"></th>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary btnSaveRoom"> Save</button>
        </div>
    </div>
</form>

<script src="~/Scripts/ui/reservation-list/side-buttons/add-room2.js"></script>


