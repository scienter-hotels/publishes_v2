    //NEW
    $('body').on('submit', '#RoomToRoomTransfer', function (e) {
        e.preventDefault();
        var reservationheaders = [];
        var transferToRoomId;
        var folioNo = 1;
        var currentTab;

        currentTab = $('.nav-tabs li.active a').attr('href');

        //if ($('.merge-reservation:checked').length > 0)

        if (currentTab === '#groupFolioMerge') {

            if ($('.merge-reservation:checked').length > 0) {
                $.each($('.merge-reservation:checked'), function (index, item) {

                    reservationheaders.push({
                        Id: $(item).data('reservationheaderid')
                    })
                });
            }

            transferToRoomId = $('.master-reservation:checked').data('roomid');
            folioNo = 0;
        }
        else {
            reservationheaders.push({
                Id: $('.reservation-header-id').val()
            });
            transferToRoomId = $('#data-rooms').val();
            folioNo = $('#folioNo').val();

        }


        if (reservationheaders.length === 0) {
            ShowWarningMessage("No reservations selected for transfer. Please select one or more reservations to transfer out.");
        }

        else if (!transferToRoomId) {
            ShowWarningMessage("No room selected for the transfer. Please select a room to transfer the folios.");
        }
        else {
            $.ajax({
                url: '/CashieringandPosting/FolioManagement/RoomToRoomTransferSave',
                dataType: 'JSON',
                data: {
                    inhouseReservations: reservationheaders,
                    transferToRoomId: transferToRoomId,
                    folioNo: folioNo
                },
                method: 'POST',
                success: function (data) {

                    if (data == "success") {
                        ShowSuccessMessage("Transferred Successfully.");
                        setTimeout(function () {
                            window.location.reload();
                        }, 3000);
                    } else {
                        ShowWarningMessage(data);
                        setTimeout(function () {
                            window.location.reload();
                        }, 3000);
                    }
                },
                error: function (error) {
                }
            });

        }

    });

