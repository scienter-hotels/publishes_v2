<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------

        $('#GuestProfileTypeId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });


        //-------------------------------------------------------------------------------------------

        $('.btnStep02Next').hide();
        $('.addGuestDiv').hide();
        $('.div-scroll').css('height', 290);
        LoadExistingGuests();
    });

    $(document).on("click", "#guestAllergyTabs .tab-link", function () {

        // activate the clicked tab
        $("#guestAllergyTabs li").removeClass("active");
        $(this).parent().addClass("active");

        var target = $(this).data("target");

        // hide both tab sections
        $("#guestSection").hide();
        $("#allergySection").hide();

        // show selected one
        $(target).show();

        // collapse logic and loading
        if (target === "#guestSection") {
            $("#editAllergyDiv").collapse("hide");
            $("#editGuestDiv").collapse("show");
        } else {
            $("#editGuestDiv").collapse("hide");
            $("#editAllergyDiv").collapse("show");

            // load predefined allergies only once
            //if (!allergiesLoaded) {
            //    LoadPredefinedAllergies(guestProfileId);
            //}
        }
    });


    function FillGrid() {
        LoadExistingGuests();
    }
    //AddToggle

    $('body').off('click', '#AddToggle').on('click', '#AddToggle', function (e) {
        $('#guest-detail-with-allergies').addClass('hidden');
        if ($('#editGuestDiv').hasClass('in')) {
            $('#editGuestDiv').collapse('hide');
        }
        
        if ($('#editAllergyDiv').hasClass('in')) {
            $('#editAllergyDiv').collapse('hide');
        }

        setTimeout(function () { PopupModalScrollTo(".SearchWindow"); }, 1000)

    });


    //Add new Existing Guest----------------------------------------------------------------------
    $('body').off('click', '#btnNewGuest').on('click', '#btnNewGuest', function (e) {
        if ($('#editGuestDiv').hasClass('in')) {
            $('#editGuestDiv').collapse('hide');
        }

        if ($('#editAllergyDiv').hasClass('in')) {
            $('#editAllergyDiv').collapse('hide');
        }

        AddGuest(e);
    });

    //Create new Guest----------------------------------------------------------------------
    $('body').off('click', '#btnCreateGuest').on('click', '#btnCreateGuest', function () {
        $('.guest-checkBox').each(function (index, element) {
            $(element).prop('checked', false);
        });
        AddGuest();
    });

    $('body').on('click', '#AddToggle', function () {
        $(this).closest('.modal-dialog').css('margin-top', 0);
    });

    function AddGuest(e) {

        var isValid = true;
        if ($('#SalutationId').val() == '') {
            $('#SalutationId').focus();
            isValid = false;
            ShowWarningMessage('Salutation required.');
        }
        else if ($('#FirstName').val() == '') {
            $('#FirstName').focus();
            isValid = false;
            ShowWarningMessage('First Name required.');
        }
        else if ($('#LastName').val() == '') {
            $('#LastName').focus();
            isValid = false;
            ShowWarningMessage('Last Name required.');
        }
        else if ($('#NICPassport').val() == '') {
            $('#NICPassport').focus();
            isValid = false;
            ShowWarningMessage('Nic / Passport required.');
        }

        else if ($('#CountryId').val() == '') {
            $('#CountryId').focus();
            isValid = false;
            ShowWarningMessage('Country required.');
        }
        else if ($('#NationalityId').val() == '') {
            $('#NationalityId').focus();
            isValid = false;
            ShowWarningMessage('Nationality required.');
        }

        //else if ($('#Email').val() == '') {
        //    $('#Email').focus();
        //    isValid = false;
        //    ShowWarningMessage('Email required.');
        //}
        //else  if ($('#ContactNo').val() == '') {
        //    $('#ContactNo').focus();
        //    isValid = false;
        //    ShowWarningMessage('Contact No required.');
        //}

        if (isValid) {
            var guestId = -1;
            $('.guest-checkBox').each(function (index, element) {
                if ($(element).prop('checked')) {
                    guestId = $(element).val();
                    return false;
                }
            });

            if ($('#GuestProfileTypeId').val() == '') {
                ShowWarningMessage('Please select guest profile type.');
                return false;
            }

            var email = '';
            var contactNo = '';

            email = $('#Email').val();
            contactNo = $('#ContactNo').val();

            var SelectedGuest = {
                Id: guestId,
                SalutationId: $('#SalutationId').val(),
                FirstName: $('#FirstName').val(),
                LastName: $('#LastName').val(),
                NICPassport: $('#NICPassport').val(),
                NicPassport2: $('#NICPassport').val(),
                CountryId: $('#CountryId').val(),
                NationalityId: $('#NationalityId').val(),
                Email: email,
                ContactNo: contactNo,
                ReservationHeaderId: $('#reservationNo').val(),
                GuestProfileTypeId: $('#GuestProfileTypeId').val()
            }

            var guestExists = false;

            //$('.guestDetails').each(function () {
            //    if ($(this).find('#btnEditGuest').attr('data-id') == guestId) {
            //        guestExists = true;
            //        return false;
            //    }
            //});
            debugger;
            console.log(SelectedGuest);
            if (guestExists) {
                ShowWarningMessage('Guest already exists.');
            } else {
                $.ajax({
                    url: '/reservation/ReservationList/AddNewGuest',
                    dataType: 'json',
                    method: 'POST',
                    data: { SelectedGuest: SelectedGuest },
                    //data: {SelectedGuest },
                    success: function (data) {
                        var Type = $('#resType').val();
                        if (data.startsWith('300-')) {
                            ShowErrorMessage(data.replace("300-", ""));

                        } else {
                            //$('#addGuestDiv').collapse('hide');
                            ShowSuccessMessage(data);
                            //var EventCode = "GC";
                            //var ReservationNo = $('#ReservationNumber').val();
                            //var propertyId = $('#PropertyId').val();
                            //var userId = $('#UserId').val();
                            //var printURL = $('#DirectPrintURL').val();
                            //var FromRoom = $('#roomNo').val();
                            //var ToRoom = "-1";
                            //var GuestName = $('#FirstName').val() + ' '+$('#LastName').val();
                            //var ajaxUrl = printURL + 'PABX/' + EventCode + '/' + ReservationNo + '/' + propertyId + '/' + userId + '/' + FromRoom + '/' + ToRoom + '/' + GuestName + '/'
                            //console.log(ajaxUrl);
                            //PABXAjaxRequest(ajaxUrl);
                            //FillGrid();
                            LoadExistingGuests();
                            setTimeout(function () {
                                if (Type == "reservation") {
                                    // closeFullContent();
                                    LoadReservationGrid();
                                } else {
                                    location.reload()
                                }


                            }, 2500);

                        }
                    },
                    error: function (error) {
                        ShowErrorMessage('There is an error in saving this record.')
                    }
                });
            }
        }
        return isValid;
    }

    function LoadExistingGuests() {
        $.ajax({
            url: '/reservation/ReservationList/LoadExistingGuests?reservationHeaderId=' + $('#reservationNo').val(),
            dataType: 'html',
            method: 'POST',
            success: function (data) {
                $('#ExistingGuestProfiles').html('');
                $('#ExistingGuestProfiles').html(data);
            },
            error: function (error) {
                ShowErrorMessage('There is an error in loading existing guests.')
            }
        });
    }

    //----------------------------------------------------------------------------------------------
    //$('.success-popup-ok').closest('.modal').on('hide.bs.modal', function (e) {
    //    location.reload();
    //});

    var guestProfileId = 0
    var reservationHeaderId = 0

    $('body').off('click', '#btnEditGuest').on('click', '#btnEditGuest', function () {

        if ($('#addGuestDiv').hasClass('in')) {
            $('#addGuestDiv').collapse('hide');
        }

        guestProfileId = $(this).attr('data-id');
        reservationHeaderId = $('#reservationNo').val();

        $('#guest-detail-with-allergies').removeClass('hidden');

        // $('#editGuestDiv').toggle();
        // $('.addGuestDiv').hide();
        $(this).closest('.modal-dialog').css('margin-top', 0);
        var profileType = $(this).attr('data-profiletype');
        $.ajax({
            url: '/reservation/ReservationList/GuestUpdateProfileSelect?guestProfileId=' + $(this).attr('data-id') + '&reservationNumber=' + $('#ReservationNumber').val() + '&roomNo=' + $('#roomNo').val() + '&Uuid=' + $('#hidden-Uuid').val(),
            dataType: 'html',
            method: 'POST',
            success: function (data) {

                $('#guestProfileContainer').html('');
                $('#guestProfileContainer').html(data);
                $('.GuestProfileTypeId').val(profileType);
            },
            error: function (error) {
                ShowErrorMessage('There is an error in loading this record.')
            },
            complete: function () {
                LoadPredefinedAllergies(guestProfileId);
            }
        });
    });


    //$('body').off('click', '#AddToggle').on('click', '#AddToggle', function () {
    //    $('.guestDetails .gPTypeId').each(function (index, element) {
    //        if ($(element).val(1)){
    //            $("#GuestProfileTypeId option[value='1']").remove();
    //        }
    //    });
    //});


    $('#DOB').daterangepicker({
        "showDropdowns": true,
        "showWeekNumbers": true,
        "showISOWeekNumbers": true,
        "singleDatePicker": true,
        "minDate": new Date('1900-01-01'),
        //'Custom Range': 'custom',
        //"yearRange": '1980:2018',
        "changeYear": true,
        "changeMonth": true,
        "opens": "right",
        "applyClass": "btn-primary",
        "dateLimit": {
            "days": false
        },
        locale: {
            format: 'DD/MM/YYYY'
        }
    });


    var allergiesLoaded = false;

    function LoadPredefinedAllergies(guestProfileId) {

        $.ajax({
            url: '/reservation/ReservationList/PredefinedAllergies?guestProfileId=' + guestProfileId,
            dataType: 'json',
            method: 'POST',
            success: function (data) {

                var $container = $('#predefinedAllergiesContainer');
                $container.empty();

                if (!data || data.length === 0) {
                    $container.append(
                        '<div class="col-md-12"><span>No predefined allergies found.</span></div>'
                    );
                    return;
                }

                $.each(data, function (i, item) {
                    var id = item.Id;
                    var name = item.Name || '';
                    var allergiesJson = item.AllergiesJson || '';
                    var isHave = item.IsHave == 1 ? "checked" : "";

                    var html =
                        '<div class="col-md-4 allergy-item" style="margin-bottom:5px;">' +
                        '  <div class="checkbox">' +
                        '    <label>' +
                        '      <input type="checkbox" ' +
                        '             class="chk-predefined-allergy" ' +
                        '             data-id="' + id + '" ' +
                        '             data-json=\'' + (allergiesJson || '') + '\' ' +
                        '             value="' + id + '" ' + isHave + ' />' +
                        '      <span>' + name + '</span>' +
                        '    </label>' +
                        '  </div>' +
                        '</div>';

                    $container.append(html);
                });

                allergiesLoaded = true;
            },
            error: function (error) {
                console.log(error);
                ShowErrorMessage('There is an error in loading predefined allergies.');
            }
        });
    }

    $('body').off('click', '#btnSaveAllergies').on('click', '#btnSaveAllergies', function () {

        var selected = [];

        // collect all checked predefined allergies
        $('.chk-predefined-allergy:checked').each(function () {
            selected.push({
                Id: parseInt($(this).data('id'))
            });
        });

        if (selected.length === 0) {
            ShowWarningMessage("Please select at least one allergy.");
            return;
        }

        // build JSON string to send to backend
        var allergiesJson = JSON.stringify(selected);

        //// collect current guest IDs
        //var reservationHeaderId = $('#reservationNo').val();   // already exists in your view
        //var guestProfileId = $('#editGuestDiv').attr('data-id') || $('#SelectedGuestProfileId').val();

        if (!guestProfileId || guestProfileId === "0") {
            ShowWarningMessage("No guest selected.");
            return;
        }

        var payload = {
            Id: 0,                         // unused on backend, but required in class
            Name: "",
            AllergiesJson: allergiesJson,
            ReservationHeaderId: reservationHeaderId,
            GuestProfileId: guestProfileId
        };

        console.log("Saving allergies →", payload);

        $.ajax({
            url: '/reservation/ReservationList/SaveAllergies',
            method: 'POST',
            dataType: 'json',
            data: payload,
            success: function (result) {

                if (typeof result === "string" && result.startsWith("ERR-")) {
                    ShowErrorMessage(result.replace("ERR-", ""));
                    return;
                }

                ShowSuccessMessage("Allergies saved successfully.");
            },
            error: function (xhr) {
                ShowErrorMessage("There was an error saving allergies.");
            }
        });

    });


</script>