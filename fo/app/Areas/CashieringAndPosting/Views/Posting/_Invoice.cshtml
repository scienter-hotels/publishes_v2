<script>
    $('#btnlatersettlements').click(function () {
        $('#ExtraPostingType').val('P');

        setTimeout(function () {
            CallPasswordModel(function (e) {
                // Billtotal = parseFloat($('#taxCalculationTable tr:last td:eq(1)').text().trim().replace(/,/g, '')).toFixed(2);
                var url = '/CashieringAndPosting/Posting/BillPayment/';
                Billtotal = $('#taxCalculationTable tr:last td:eq(1)').text().trim();
                AllowCreditPostingInWalkingPosting = 0;
                CallDetailModelSimple('Payments', url, 800);
            });
        }, 500);
    });
</script>
