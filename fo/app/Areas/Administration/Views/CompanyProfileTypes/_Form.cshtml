@model Scienter.HotelERP.Common.Domain.CompanyProfileType

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="companyProfileTypes">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Companies *</label>
                        @{Html.RenderAction("CompaniesCombo", "Companies", new { name = "CompanyId", requiered = true, value = Model?.CompanyId });}
                    </div>


                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            @*<input type="checkbox" checked name="IsActive" value="True" />*@ Is Active
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })

                    </div>

                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
                <div class="col-md-1">

                </div>
                <div class="col-md-5">
                    @{Html.RenderAction("ListSegmentsVertical", "Segments", new { selectedPoperties = Model.Segments }); }
                </div>
            </div>
        </div>
    </form>
    <input type="hidden" value="@Model.SegmentsJson" name="selectedSegments" id="selectedSegmentss" />
</div>

<script>
    $(document).ready(function () {
        debugger;
        var seelctedSegments = $.parseJSON($('#selectedSegmentss').val());
        $('.data-segment-checkbox').prop('checked', false)

        $.each(seelctedSegments, function (index, item1) {
            var Segment = 'input.data-segment-checkbox[value=' + item1.SegmentId + ' ]'
            $(Segment).prop('checked', true);
        });
    });
</script>
