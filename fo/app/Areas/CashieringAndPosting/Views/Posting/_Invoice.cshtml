<fieldset class="the-fieldset invoiceBox ribbonbox" style="min-height:475px; margin-top:8px;">
    <div class="pritableArea">
        <div class="ribbon hidden-print"><span>Bill Preview</span></div>

        <div id="ReportLoadingArea" class="col-md-12"  style="max-height:412px; overflow-y:auto; overflow-x:hidden;">
            <div id="ReportHeader">
                <table class="col-md-12" style="width:100%;margin-bottom:10px!important; margin-top:5px!important;">
                    <tr>
                        @if (ViewBag.postingType == "rebate")
                        {
                            <th style="text-align:center; font-weight:bold; font-size:16px;" colspan="5">REBATE BILL</th>

                        }
                        else
                        {
                            <th style="text-align:center;font-weight:bold; font-size:16px;" colspan="5">SUNDRY BILL</th>
                        }
                    </tr>
                </table>
                <hr />
                @if ((ViewBag.postingType == "inhouse") || (ViewBag.postingType == "rebate"))
                {
                    <table style="width:100%">
                        <tr>
                            <td id="easyPaginate2" style="width:100%"></td>
                        </tr>

                    </table>


                }
                else if (ViewBag.postingType == "LaterSettlements")
                {
                    <table style="width:100%">
                        <tr>
                            <td id="easyPaginate2" style="width:100%"></td>
                        </tr>

                    </table>
                }
                else
                {


                    <table id="walkin-billheader" style="width:100%"></table>
                }
                <input type="hidden" value="@ViewBag.postingType" name="" id="PosringTypehdn" />
            </div>
            <hr />
            <div id="ReportBody1" style="width:100%;margin-top:20px;">

                <label style="width:75%; padding-left:10px;" id="remarkArea"></label>
            </div>
            <hr />
            <div id="ReportTaxCalCulationArea" style="width:100%;">

                <div class="row" style="margin-top:10px;">
                    <div class="col-md-5"></div>
                    <div class="col-md-7 report-width60perc report-float-right" id="TaxLoadingArea">
                        @Html.Partial("_TaxCalculation", new List<Scienter.HotelERP.Common.Domain.ViewModels.TaxCalculationsViewModel>())
                    </div>
                </div>
                <hr />
                <div class="row" style="margin-top:10px;">
                    <div class="col-md-5"></div>
                    <div class="col-md-7 report-width60perc report-float-right">
                        <table class="table hidden" id="paymentTable" style="width:100%">
                            <tr></tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div id="ReportFooter" style="height:100px; margin-top:5px;">
