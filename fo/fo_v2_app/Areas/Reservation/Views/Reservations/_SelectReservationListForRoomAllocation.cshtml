<div class="manage-room" style="max-height:500px; overflow-y:scroll; padding-right: 15px;">
    <div class="table-responsive">
        <form id="roomAllocationForm">
            <div class="row">
                <div col-md-6>
                    <table class="table table-striped table-hover" id="guestRoomGrid" cellspacing="5">
                        <tr>
                            <th></th>
                            <th class="text-primary " input type="text" width="100px">
                                Res.No
                            </th>
                            <th class="text-primary " input type="text" width="80px">
                                Guest
                            </th>
                            <th class="text-primary " input type="text" width="80px">
                                Room No
                            </th>
                        </tr>
                    </table>
</div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-room" style="padding-left: 0px;">
                        <input type="submit" id="btnUpdate" disabled="disabled" value="Allocate" class="btn btn-primary do-not-disable" />
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

        <script type="text/javascript">
            $(document).ready(function () {
                loadData();
                $('#btnUpdate').prop('disabled', true);
            });

            function loadData() {
                $.ajax({
                    url: "/Reservation/Reservations/RoomAllocationGroupBookingCombo",
                    type: "GET",
                    dataType: "html",
                    success: function (result) {
                        $(".roomAllocation").html(result);
                        $("select").not('.room-checkBox').prop("disabled", true);
                    }
                });
            }

            $('body').off('change', '.room-checkBox').on('change', '.room-checkBox', function (e) {
                $('#btnUpdate').prop('disabled', true);
                $('.room-checkBox').each(function (index, item) {
                    if ($(item).prop('checked')) {
                        $('#btnUpdate').prop('disabled', false);
                        return false;
                    }
                });

                if ($(this).prop('checked')) {
                    $(this).closest('.single-reservation').find('select').prop('disabled', false);


                    $('body').off('change', '.roomId').on('change', '.roomId', function (e) {

                        var currentValue = $(this).val();
                        var loopingValue = 0;
                        var currentElement = $(this);

                        $('.roomId').not($(this)).each(function (index, item) {

                            loopingValue = $(item).val();
                            if (currentValue == loopingValue) {

                                $(currentElement).val('');
                                ShowWarningMessage("This room already allocated.");
                                console.log($(this).val());
                                return false;
                            } else {

                            }
                        });

                    });
                }
                else {
                    $(this).closest('.single-reservation').find('select').prop('disabled', true);
                }
            });

            $('body').off('submit', '#roomAllocationForm').on('submit', '#roomAllocationForm', function (e) {
                console.log("Update");
                e.preventDefault();
                var selectedRoomListForGuestGroup = [];

                var isRoomRecordSelected = false;

                $('.single-reservation').each(function (index, item) {
                    if ($($(item).find('.room-checkBox')).prop('checked')) {
                        isRoomRecordSelected = true;
                        return false;
                    }
                });

                if (isRoomRecordSelected == false) {
                    ShowWarningMessage('Please select at least one record.');
                } else {
                    $('.single-reservation').each(function (index, item) {
                        var room = {};
                        if ($($(item).find('.room-checkBox')).prop('checked')) {
                            room = {
                                Id: $($(item).find('.room-checkBox')).val(),
                                ReservationNo: $($(item).find('.room-reservation-no')).val(),
                                RoomId: $($(item).find('.roomId')).val(),
                            }
                            selectedRoomListForGuestGroup.push(room);
                        }
                    });

                    $.ajax({
                        url: '/reservation/reservations/AllocatedRoomsforGroupReservation',
                        dataType: 'JSON',
                        data: { selectedRoomListForGuestGroup: selectedRoomListForGuestGroup },
                        method: 'POST',
                        success: function (response) {
                            ShowSuccessMessage('Saved successfully.');
                            setTimeout(function () {
                                window.location.reload();
                            }, 2500);
                        }
                    });
                }
            });

        </script>
