@model IEnumerable<Scienter.HotelERP.Common.Domain.FolioHeader>
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>
<div class="row">
    <div class="col-md-12" style="padding-left:0px; padding-right:0px;">
        <div class="hidden-print">
            <input type="hidden" id="ResId" /> @*value="@Model.ReservationHeaderId">*@
            <input type="hidden" id="RoomId" /> @*value="@Model.RoomNo">*@
            <div class="row">
                <div class="form-group col-md-10" style="margin-top:0px; padding-left:30px;">
                    <label class="control-label"></label>
                    <select class="select2 form-control" id="folioNoList">

                        <option value="0">Select Folio NO</option>
                        @foreach (var item in Model)
                        {
                            <option value="@item.FolioNo">Folio No: @item.FolioNo | Company : @item.FolioCompanyName  | Address:  @item.FolioAddress</option>

                        }
                    </select>
                </div>
            </div>
            <div class="col-md-12">
                <input type="button" value="Transfer" id="transferFolioBtn" class="btn btn-primary" />

            </div>
        </div>
    </div>
</div>
<script>

    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });
    // FOLIO EXCHANGE
    var nextFolio;

    $('#transferFolioBtn').on('click', function (e) {


        // check if checkbox is clicked
        //var thisFolio;
        //var thisFolioDetailId
        var TransferDetailArray = []

        nextFolio = $('#folioNoList').val()

        $('.folio-detail-id').each(function (index, item) {
            if ($(this).is(':checked', true)) {
                TransferDetailArray.push({
                    FolioNo: $('.folio-detail-id').eq(index).closest('tr').find('td.td-folio-nos').text(),
                    FolioDetailID: $(this).val()
                });
            }
        });

        if (TransferDetailArray.length > 0 && nextFolio != null) {
            ExchangeFolio(nextFolio, TransferDetailArray);
        }

    });

</script>