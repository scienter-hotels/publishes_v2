                                            var data = [];
                                            var ids = [];
                                            $(response).each(function (index, item) {
                                                var color = item.Color;
                                                colours.push(color);

                                                var label = item.Label;
                                                labels.push(label);

                                                var count = item.Count;
                                                data.push(count);

                                                var id = item.Id;
                                                ids.push(id);
