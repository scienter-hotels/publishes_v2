<script>
    //Changes 22
    var reservationDetail = {};
    var reservation = {};

    $(function (data) { // document ready
       

        LoadRoomNumbers();
        SetTableHeight();

        setInterval(function () {
            $('.fc-ooo-content').closest('.fc-timeline-event').css('border-color', '#4d4d4d');
            $('.fc-ooo-content').closest('.fc-timeline-event').css('background-color', '#4d4d4d');
            $('[data-toggle="tooltip"]').tooltip();
        }, 1000);

        var ledHeight = $(window).height() - 120;
        $('#ledgen_menu_').css('height', ledHeight);

        var width = $('#calendar').width();
        //$('#Change').css('margin-left', width - 95);
        //$('#ledgen_button').css('margin-left', width - 67);
        //$('#Maximize').css('margin-left', width - 35);

        $('#Change').css('margin-left', width - 99);
        $('#ledgen_button').css('margin-left', width - 67);
        $('#full_screen_button').css('margin-left', width - 35);

        $('#container').hide();
        setTimeout(function () {
            $('#container').css('top', 0);
        }, 5000)

        $('#From').val($('#FromDate').val())
        $('#To').val($('#ToDate').val())
        $('#To').prop('disabled', true);

        $('#From').change(function () {
            var fromDate = new Date($('#From').val());
            fromDate.setDate(fromDate.getDate() + 28);
            $('#To').val(fromDate.toISOString().slice(0, 10));
        });

        LoadCalenderByDateRange();
        LoadRateCodes();

    });


    function LoadRoomNumbers() {
        $.ajax({
            url: '/Administration/GuestComplain/SelectRoom',
            dataType: 'json',
            method: 'get',
            success: function (data) {
                $(data).each(function (index, item) {
                    $('<option value="' + item.Id + '" >' + item.RoomCode + '</optoin>').appendTo($('#roomCodes'));
                });
