@{
    ViewBag.Title = "Active Spa Reservation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>
<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/

    .card form [class*="col-"] {
        padding: 0px;
    }

    .form-group {
        padding-bottom: 0px;
    }


    .the-fieldset .test {
        border: 1px solid #bebebe;
        padding: 20px;
        border-radius: 5px;
        margin-bottom: 0px;
    }


    .btn-padding-override {
        padding-left: 5px;
        padding-right: 5px;
        margin-bottom: 0px !important;
        font-size: 10.5px !important;
    }

    .btn-right-padding5px {
        padding: 0px;
        padding-right: 5px;
    }

    .row-padding0px {
        padding: 0px;
    }

    .dataTables_filter {
        width: 30% !important;
        float: left !important;
    }

    .dt-buttons {
        width: 70% !important;
    }


    .card .card-content {
        padding: 2px 20px;
        min-height: 530px !important;
        min-height: 530px !important;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>

                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div id="content">

                </div>

            </div>
        </div>
    </div>
</div>

@*<script src="~/Scripts/ui/common/scienter.grid2.js"></script>*@
<script src="~/Scripts/jquery.validate.js"></script>

<script>

    $(document).ready(function () {
        FillGrid();
    });

    function FillGrid() {
        var gridId = "#spaReservationGrid"; // change this - relevent grid id
        var paginations = {
            PageIndex: $(gridId).attr('data-page-index'),
            PageSize: $(gridId).attr('data-page-size'),
            FilterType: $(gridId).attr('data-filter-type'),
            SearchKeyword: $(gridId).attr('data-search-keyword')
        }
        $.ajax({
            url: '/spareservation/activespareservation/grid',
            dataType: 'html',
            //data: paginations,
            method: 'POST',
            success: function (response) {
                if ($('.grid-container').length > 0) {
                    $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                    $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                } else {
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }
                GridFunctionalities();
            }

        });
    }

</script>
