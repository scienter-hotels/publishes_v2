@model Scienter.HotelERP.Common.Domain.ViewModels.GuestProfileView

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>

    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    .required:after {
        content: " *";
        color: #e32;
    }

    .row-mt-custom {
        margin-bottom: -16px;
    }

    .searchBox {
        margin-top: -26px;
    }

    .form-group {
        padding-bottom: 10px;
        margin: 24px 0 0 0;
    }
</style>

<div class="searchBox">

    <div class="row row-mt-custom">
        <div class="col-md-12">
            <div class="form-group label-floating">
                <label class="control-label required">First Name</label>
                <input type="text" name="FirstName" id="FirstName" class="form-control ignore-textfeild-special-characters" value="@Model.FirstName" />
            </div>
        </div>
    </div>

    <div class="row row-mt-custom">
        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label required">Last Name</label>
                <input type="text" name="LastName" id="LastName" class="form-control ignore-textfeild-special-characters" value="@Model.LastName" />
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label">VIP Levels  </label>
                <select id="VipLevelId" class="form-control" data-select-vip="@Model.VipLevelId" required></select>
                @*@{Html.RenderAction("VIPLevelCombo", "VIPLevels", new { area = "Administration", name = "VipLevelId", requiered = false, value = Model?.VipLevelId });}*@
            </div>

            @*<div class="form-group label-floating">
                    <label class="control-label required">VIP Level</label>
                    @{Html.RenderAction("SalutationCombo", "Salutations", new { area = "Administration", name = "SalutationId", requiered = true, value = Model.SalutationId });}
                </div>*@
        </div>
    </div>

    <div class="row row-mt-custom">
        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label required">Salutation</label>
                <select id="SalutationId" class="form-control" data-select-salutation="@Model.SalutationId" required></select>
                @*@{Html.RenderAction("SalutationCombo", "Salutations", new { area = "Administration", name = "SalutationId", requiered = true, value = Model.SalutationId });}*@
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label">NIC / Passport</label>
                @{
                    string nICPassport = Model.PassportNo.Length == 0 ? Model.IdNum : Model.PassportNo;
                }
                <input type="text" name="NICPassport" id="NICPassport" class="form-control" value="@nICPassport" />
            </div>
        </div>
    </div>

    <div class="row row-mt-custom">
        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label required">Country</label>
                <select id="CountryId" class="form-control country-combo" data-select-country="@Model.CountryId" required></select>
                @*@{Html.RenderAction("CountriesCombo", "Countries", new { area = "Administration", name = "CountryId", requiered = true, value = Model.CountryId });}*@
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label required">Nationality</label>
                <select id="NationalityId" class="form-control nationality" data-select-nationality="@Model.NationalityId" required></select>
                @*@{Html.RenderAction("NationalityCombo", "Nationalities", new { area = "Administration", name = "NationalityId", requiered = true, value = Model.NationalityId });}*@
            </div>
        </div>
    </div>

    <div class="row row-mt-custom">
        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label">Email</label>
                <input type="email" name="Email" id="Email" class="form-control" value="@Model.Email" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label">Contact No</label>
                <input type="text" name="ContactNo" id="ContactNo" class="form-control data-telephone" value="@Model.ContactNo" />
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <button type="button" id="btnSearch" class="btn btn-warning">
                Search  <span class="glyphicon glyphicon-search"></span>
            </button>
        </div>
        <div class="col-md-6">
            <input type="reset" id="resetBtn" class="resetBtn btn btn-default" value="Clear" />
        </div>
        @*<button type="button" id="btnCreateGuest" class="btn theme-bg-color-1">
                Create <span class="glyphicon glyphicon-floppy-saved"></span>
            </button>*@
        <input type="hidden" id="data-guest-id" value="@Model.Id" />
    </div>
    <div class="row">
        <div class="col-md-12">
            <i style="font-size: 8px;font-weight: bold;">*Please press the 'Search' button or the 'Enter' key to initiate the search.</i>
        </div>
    </div>

</div>
