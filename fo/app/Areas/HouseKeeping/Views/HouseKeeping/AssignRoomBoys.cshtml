@model Scienter.HotelERP.Common.Domain.ViewModels.HouseKeepingRoomBoyViewModel
@{

    ViewBag.Title = "Housekeeping Task Sheet";
}


<style>
    .search-col {
        margin-top: 20px;
        padding-left: 5px !important;
    }
</style>
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                </div>
            </div>

            <div class="card-content" id="contentLoadingArea">
                <div id="content">

                    <div class="row">
                        <div class=" col-md-3">
                            <div class="form-group label-floating">
                                <label class="control-label">Hotel Date *</label>
                                <input type="date" id="HotelDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                        <div class=" col-md-3">
                            <div class="form-group label-floating">
                                <label class="required control-label">Inspection Time</label>
                                @{Html.RenderAction("RoomInspectionTimesCombo", "RoomInspection", new { name = "RoomInspectionId", requiered = true });}
                            </div>
                        </div>
                        <div class=" col-md-4">
                            <div class="form-group label-floating">
                                <label class="control-label">Room Boy *</label>

                                <select id="RoomBoyId" name="" class="form-control" required>
                                    <option value=""></option>

                                    @foreach (var option in Model.RoomBoys)
                                    {
                                        <option value="@option.Id" selected>@option.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button id="btnSearch" value="Search" class="btn btn-primary" style="margin:30px 0 0 0;width:100%;">SEARCH<div class="ripple-container"></div></button>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-2">
                            <fieldset class="the-fieldset" style="padding:3px; ">
                                <legend class="the-legend">Floors</legend>
                                <div class="input-group searchdiv col-md-12" style="width:97%;margin-top: -20px; margin-bottom: 10px;">
                                    <input type="text" class="form-control text-box single-line" placeholder="Search Floors" onkeyup="searchFloor()" id="floorSearch" />
                                </div>
                                <div class="col-md-12 label-data" id="Floors-Area" style="overflow-y:auto;"></div>
                            </fieldset>
                        </div>
                        <div class="col-md-6">
                            <fieldset class="the-fieldset" style="padding:3px;">
                                <legend class="the-legend">Rooms</legend>
                                <div class="input-group searchdiv col-md-12" style="width:97%;margin-top: -20px; margin-bottom: 10px;">
                                    <input type="text" class="form-control text-box single-line" placeholder="Search Rooms" onkeyup="searchRoom()" id="roomSearch" />
                                </div>
                                <div class="col-md-12 label-data" id="Existing-Rooms-Area" style="overflow-y:auto;">
                                    <table class="table table-striped" id="Data-Existing-Rooms">

                                        <tr>
                                            <th>Room</th>
                                            <th>Category</th>
                                            <th>Type</th>
                                            <th>House Keeping Status</th>
                                            <th>Floor</th>
                                            <th></th>
                                        </tr>

                                        <tbody class="all-existing-rooms">
                                            <tr>
                                                <td class="" colspan="5">No records available.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </fieldset>
                        </div>
                        <div class="col-md-4">
                            <fieldset class="the-fieldset" style="padding:3px;">
                                <legend class="the-legend">Added Rooms</legend>
                                <div class="input-group searchdiv col-md-12" style="width:96%;margin-top: -20px; margin-bottom: 10px;">
                                    <input type="text" class="form-control text-box single-line" placeholder="Search Rooms" onkeyup="searchAddedRoom()" id="addedRoomSearch" />
                                </div>
                                <div class="col-md-12 label-data" id="Added-Rooms-Area" style="overflow-y:auto;">
                                    <table class="table table-striped" id="Data-Added-Rooms">

                                        <tr>
                                            <th>Room</th>
                                            <th>Category</th>
                                            <th>Pattern</th>
                                            <th></th>
                                        </tr>


                                        <tbody class="all-Added-rooms">
                                            <tr class="data-row-c">
                                                <td colspan="3">No records available.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </fieldset>
                            <div class="row">
                                <div class="col-md-8">
                                    <button type="submit" class="btn btn-primary btn-save" style="width:100%;">Save</button>
                                </div>
                                <div class="col-md-4">
                                    <button type="button" class="btn btn-info btn-print" id="btnPrint" style="width:100%;">Print</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    var ddlHousekeepingCleaningPatterns = $('<select class="hk-pattern-ddl form-control"></select>');

    $(document).ready(function () {
        var windowHeight = window.innerHeight;
        var windowOuterHeight = window.outerHeight - 77;
        var bookmarkBarHeight = windowOuterHeight - windowHeight-30;

        console.log(windowHeight)
        console.log(windowOuterHeight)
        console.log(bookmarkBarHeight)
        console.log($('.card').height())

        if (windowHeight === windowOuterHeight) {
            $('#Floors-Area').height(windowHeight - 315);
            $('#Existing-Rooms-Area').height(windowHeight - 315);
            $('#Added-Rooms-Area').height(windowHeight - 365);
        }
        else {
            $('#Floors-Area').height(windowHeight - 315 + bookmarkBarHeight);
            $('#Existing-Rooms-Area').height(windowHeight - 315 + bookmarkBarHeight);
            $('#Added-Rooms-Area').height(windowHeight - 365 + bookmarkBarHeight);
        }
        
        if (windowHeight > 661) {
            $('#roomSearch').parent('div').css('width','98%')
            $('#addedRoomSearch').parent('div').css('width','100%')
        }

        $('#RoomBoyId').val('');
        $('.room-id').prop('checked', false);
        setTimeout(function () {
            $('#btnPrint').prop("disabled", true);
        }, 1000);

        LoadFloors();
        LoadRooms();

        var HousekeepingCleaningPatterns = localStorage.getItem("HousekeepingCleaningPatterns");

        if (HousekeepingCleaningPatterns) {
            var patterns = JSON.parse(HousekeepingCleaningPatterns);

            $.each(patterns, function (index, item) {
                ddlHousekeepingCleaningPatterns.append(
                    $('<option>', { value: item.Id, text: item.Name })
                );
            });
        }
 
    });

    function searchFloor() {
        var searchTerm = $("#floorSearch").val().toUpperCase();

        $("#myUL li").each(function () {
            var label = $(this).find("label").eq(0);
            var listItem = $(this);

            if (searchTerm === "") {
                listItem.show();
            } else {
                if (label.text().toUpperCase().indexOf(searchTerm) > -1) {
                    listItem.show();
                } else {
                    listItem.hide();
                }
            }
        });
    }

    function searchRoom() {
        var searchTerm = $("#roomSearch").val().toUpperCase();

        $("#Data-Existing-Rooms tr").each(function () {
            var row = $(this);
            var rowMatch = false;

            if (searchTerm === "") {
                row.show();
            } else {
                row.find("td").each(function () {
                    var cellContent = $(this).text().toUpperCase();
                    if (cellContent.indexOf(searchTerm) > -1) {
                        rowMatch = true;
                        return false;
                    }
                });
                if (rowMatch) {
                    row.show();
                } else {
                    row.hide();
                }
            }
        });
    }

    function searchAddedRoom() {
        var searchTerm = $("#addedRoomSearch").val().toUpperCase();

        $("#Data-Added-Rooms tr").each(function () {
            var row = $(this);
            var rowMatch = false;

            if (searchTerm === "") {
                row.show();
            } else {
                row.find("td").each(function () {
                    var cellContent = $(this).text().toUpperCase();
                    if (cellContent.indexOf(searchTerm) > -1) {
                        rowMatch = true;
                        return false;
                    }
                });
                if (rowMatch) {
                    row.show();
                } else {
                    row.hide();
                }
            }
        });
    }

    $('#btnSearch').off('#btnSearch').on('click', function () {
        $('.data-added-rows').remove();
        LoadSavedRooms();

        setTimeout(function () {
            if ($('.data-added-rows').length === 0) {
                $('.data-row-c').show();
                $('#btnPrint').prop("disabled", true);
            }
        },500);
    });

    $('.btn-save').off('click').on('click', function () {
       
        var selectedRoomIds = [];
        if ($('#HotelDate').val() == undefined || $('#HotelDate').val().length == 0) {
            ShowWarningMessage('Please select hotel date.');
            return false;
        }
        else if ($('#RoomBoyId').val() == undefined || $('#RoomBoyId').val().length == 0) {
            ShowWarningMessage('Please select room boy.');
            return false;
        }
        else if ($('#RoomInspectionId').val() == undefined || $('#RoomInspectionId').val().length == 0) {
            ShowWarningMessage('Please select inspection time.');
            return false;
        } else {
            $('.data-added-rows').each(function (index, item) {
                var selectedRoom = {};
                selectedRoom.RoomId = $(item).find('.room-id').attr('data-added-roomid');
                selectedRoom.CleaningPatternId = $(item).find('.hk-pattern-ddl').val();
                selectedRoom.RoomBoyId = $('#RoomBoyId').val();
                selectedRoom.InspectionTimeId = $('#RoomInspectionId').val();
                selectedRoom.HotelDate = $('#HotelDate').val();
                selectedRoomIds.push(selectedRoom);
            });

            console.log(selectedRoomIds);

            $.ajax({
                url: '/HouseKeeping/HouseKeeping/SaveHouseKeepingRoomBoys',
                method: 'POST',
                data: { roomWiseRoomBoys: selectedRoomIds },
                success: function (response) {
                    if (response.startsWith("ERR-")) {
                        ShowErrorMessage(response);
                    } else {

                        ShowSuccessMessage('Saved Successfully');
                        window.location.reload();
                    }

                    $('#RoomBoyId').val('');
                    $('#btnPrint').prop('disabled', false);
                },
                error: function () {
                    ShowErrorMessage('Sorry there is an error.');
                }
            });

        }
    });

    $('.btn-print').off('.btn-print').on('click', function () {
        alert('print')
    });

    $(document).on('click', '.remove-room', function () {
        $(this).closest('.data-added-rows').remove();
    });

    $(document).on('change', '.checkBoxGroup', function () {
        filterData();
    });
    
    function filterData() {
        var selectedValues = $('.checkBoxGroup:checked').map(function () {
            return $(this).val();
        }).get();

        if (selectedValues.length === 0) {
            $('#Data-Existing-Rooms tr').show();
            return;
        }

        $('#Data-Existing-Rooms tr').hide();

        $.each(selectedValues, function (index, value) {
            console.log(value);
            $('#Data-Existing-Rooms').find('.roomfloorname[data-roomfloorid="' + value + '"]').closest('tr').show();
        });
    }


    //$('#HotelDate').change(function () {
    //    LoadSavedRooms();
    //});

    //$('#RoomBoyId').change(function () {
    //    LoadSavedRooms();
    //});

    function LoadSavedRooms() {
        debugger;
        $('.room-id').prop('checked', false);
        var roomBoyId = $('#RoomBoyId').val();
        var hotelDate = $('#HotelDate').val();
        var inspectionTimeId = $('#RoomInspectionId').val();

        if (roomBoyId == undefined || roomBoyId == "") {
            roomBoyId = 0;
        }

        if (hotelDate == undefined || hotelDate == "") {
            hotelDate = '2000-01-01';
        }

        if (inspectionTimeId == undefined || inspectionTimeId == "") {
            inspectionTimeId=0
        }

        $.ajax({
            url: '/HouseKeeping/HouseKeeping/SelectHouseKeepingRoomBoysByRoomBoyId?roomBoyId=' + roomBoyId + '&hotelDate=' + hotelDate + '&inspectionTimeId=' + inspectionTimeId,
            method: 'POST',
            success: function (data) {
                LoadAddedRooms(data);
            },
            error: function () {
                ShowErrorMessage('Sorry there is an error.');
            }
        });
    }

    function LoadFloors() {
        $.ajax({
            method: 'GET',
            url: '/Administration/Floors/SelectFloor',
            datatype: 'html',
            success: function (data) {
                $.each(data, function (index, item) {
                    $(
                        '<ul id="myUL">' +
                        '<li>' +
                        '<div class="checkbox">' +
                        '<label>' +
                        '<input type="checkbox" class="checkBoxGroup checbox-floor" id="FloorId" value="' + item.Id + '" />' +
                        item.Name +
                        '</label>' +
                        '</div>' +
                        '</li>' +
                        '</ul>'
                    ).appendTo("#Floors-Area");
                });

            }
        });
    }

    function LoadRooms() {
        $.ajax({
            method: 'GET',
            url: '/Administration/RoomDetails/SelectRoomsJson',
            datatype: 'html',
            beforeSend: function () {
                $('.all-existing-rooms tr').remove();
            },
            success: function (data) {
                $.each(data, function (index, item) {
                    $('.all-existing-rooms').append(
                        '<tr class="data-existingroom-rows">'+
                        '<td class="roomcode">' + item.RoomCode + '</td>' +
                        '<td class="roomcategory">' + item.RoomCategoryCode + '</td>' +
                        '<td class="roomtype">' + item.RoomTypeCode + '</td>' +
                        '<td class="HKStatus">' + item.HKStatus + '</td>' +
                        '<td class="roomfloorname" data-roomfloorid=' + item.RoomFloorId +'>' + item.RoomFloorName + '</td>' +
                        '<td><button class="btn btn-sm btn-primary add-room" data-roomcategory="' + item.RoomCategoryCode+'" data-roomCode="' + item.RoomCode + '" data-roomId="' + item.Id+'">Add</button></td>'+
                        '</tr>'
                    );
                });
            }
        });
    }

    var arrAddedRooms = [];
    $('body').off('click', '.add-room').on('click', '.add-room', function () {
        arrAddedRooms = [];
        var obj = {
            RoomId: $(this).attr('data-roomId'),
            RoomCode: $(this).attr('data-roomCode'),
            RoomCategory: $(this).attr('data-roomcategory')
        }
        arrAddedRooms.push(obj);

        LoadAddedRooms(arrAddedRooms);
        
    });

   

    

    //function LoadAddedRooms(arrAddedRooms) {
    //    $('.data-row-c').remove();
    //    console.log(arrAddedRooms);
    //    $.each(arrAddedRooms, function (index1, item1) {
    //        var clonedDDL = ddlHousekeepingCleaningPatterns.clone();

    //        $('.all-Added-rooms').append(
    //            '<tr class="data-added-rows">' +
    //            '<td class="roomcode">' + item1.RoomCode + '</td>' +
    //            '<td class="roomcategory">' + item1.RoomCategory + '</td>' +
    //            '<td class="cleaningpattern">' + clonedDDL.prop("outerHTML") + '</td>' +
    //            '<td><button class="btn btn-sm btn-danger remove-room room-id" data-added-roomId="' + item1.RoomId + '"><span class="glyphicon glyphicon-trash"></span></button></td>' +
    //            '</tr>'
    //        );
    //    });
    //}

    function LoadAddedRooms(arrAddedRooms) {
        $('.data-row-c').remove();

        $.each(arrAddedRooms || [], function (_, item) {
            var $ddl = ddlHousekeepingCleaningPatterns.clone()
                .removeAttr('id')                          
                .addClass('cleaning-pattern-ddl');

            // select the option that matches CleaningPatternId
            var valToSet = String(item.CleaningPatternId); // .val() uses string
            $ddl.find('option').prop('selected', false);
            $ddl.find('option[value="' + valToSet + '"]').prop('selected', true);

            // build the row with jQuery so we can append the element (not outerHTML)
            var $tr = $('<tr class="data-added-rows">')
                .append($('<td class="roomcode">').text(item.RoomCode))
                .append($('<td class="roomcategory">').text(item.RoomCategory))
                .append($('<td class="cleaningpattern">').append($ddl))
                .append(
                    $('<td>').append(
                        $('<button class="btn btn-sm btn-danger remove-room room-id">')
                            .attr('data-added-roomId', item.RoomId)
                            .html('<span class="glyphicon glyphicon-trash"></span>')
                    )
                );

            $('.all-Added-rooms').append($tr);
        });
    }

