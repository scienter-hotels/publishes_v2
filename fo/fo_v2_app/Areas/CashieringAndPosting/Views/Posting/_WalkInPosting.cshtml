@model Scienter.HotelERP.Common.Domain.Posting
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>
<div class="col-md-12">
    <form id="Posting-walkin">
        @Html.AntiForgeryToken()

        <div class="form-horizontal row">

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating col-md-7">
                        <label class="control-label">Company</label>
                        <div id="PostingCompanyComboContainer">
                            @{Html.RenderAction("CompaniesCombo", "Companies", new { area = "Administration", name = "CompanyId", required = true, value = Model.BillTypeId }); }
                        </div>
                        @Html.ValidationMessageFor(model => model.BillTypeId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-1"></div>
                    <div class="form-group label-floating col-md-4">
                        <label class="control-label">Currency Type</label>
                        @{Html.RenderAction("CurrenciesConvertionCombo", "Currencies", new { area = "Administration", name = "CurrencyId", required = true, ChargeTypeCode = "PT" }); }
                        @Html.ValidationMessageFor(model => model.CurrencyId, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group label-floating col-md-7">
                        <label class="control-label">Charge Type</label>
                        <div id="PostingBillTypeComboContainer">
                            @{Html.RenderAction("PostingBillTypeCombo", "PostingBillType", new { name = "BillTypeId", required = true, value = Model.BillTypeId }); }
                        </div>
                        @Html.ValidationMessageFor(model => model.BillTypeId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-1"></div>
                    <div class="form-group label-floating col-md-4" id="amountField">
                        <label class="control-label">Amount</label>
                        <input autocomplete="off" class="form-control text-box single-line number number-only" id="Amount" name="Amount" required type="text" value="" maxlength="10" style="text-align:left !important;">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating col-md-10">
                        <label class="control-label">Folio Text</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="150" id="FolioText" name="FolioText" type="text" value="">
                    </div>
                    <div class="form-group  label-floating col-md-10">
                        <label class="required control-label">Name</label>
                        @{Html.RenderAction("GuestProfileCombo", "GuestProfiles", new { area = "Administration", name = "GuestId", requiered = true });}
                        @*@Html.ValidationMessageFor(model => model.GuestId, "", new { @class = "text-danger" })*@
                    </div>


                    <div class="form-group  label-floating col-md-10">
                        <label class="control-label">Address</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="150" required id="WalkInGuestAddress" name="WalkInGuestAddress" type="text" value="">
                        @Html.ValidationMessageFor(model => model.WalkInGuestAddress, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group label-floating col-md-10">
                        <label class="control-label">Remarks</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="150" id="Remarks" name="Remarks" type="text" value="">
                        @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

        </div>
        <div class="row">
            <div class="form-group col-md-12">
                <input type="submit" id="btnAddwalking" value="Add" class="btn btn-primary" isAllowCreditPosting="" />  &nbsp;
                <input type="button" id="btnClear" value="Clear" class="btn btn-primary" />
            </div>
        </div>
    </form>
    <input type="hidden" name="FIT" value="" id="FITId" />
</div>

<style>
    #Posting-walkin .form-group {
        margin: 15px 0 0 0;
    }
</style>

<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('#CurrencyId').addClass('select2');
        $('#CompanyId').addClass('select2');
        $('#BillTypeId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });

    $('#CompanyId').change(function () {//----*
        debugger;
        let CompanyId = $('#CompanyId').val();
        var Name = $('option:selected', this).attr('data-Name');
        var Address = $('option:selected', this).attr('data-Address');
        var FITProfile = $('option:selected', this).attr('data-FIT');

        //$('#WalkInGuestName').val(Name);
        $('#WalkInGuestAddress').val(Address);
        $('#FITId').val(FITProfile);
        console.log(Name);
        console.log(Address);
        console.log(FITProfile);

        if (FITProfile == 'False') {
            $("#WalkInGuestName").attr("disabled", "disabled");
            $("#WalkInGuestAddress").attr("disabled", "disabled");
        } else {
            $("#WalkInGuestName").removeAttr("disabled");
            $("#WalkInGuestAddress").removeAttr("disabled");
        }
    });

</script>
