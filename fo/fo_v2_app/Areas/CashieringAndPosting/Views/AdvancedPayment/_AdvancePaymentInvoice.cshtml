@using Scienter.HotelERP.Common.Domain.ViewModels
@using Scienter.HotelERP.Common.Domain

<style>
    .easyPaginateNav a {
        padding: 5px;
        /*background-color:#fff!important;*/
    }

        .easyPaginateNav a.current {
            font-weight: bold;
            text-decoration: underline;
        }

    .invoiceBox {
        margin-top: 9px;
    }

    #ReportLoadingArea hr {
        margin-bottom: 10px !important;
        margin-top: 10px !important;
    }

    #ReportLoadingArea tr {
        background-color: #fff !important;
    }
</style>

<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("IsDirectPrint")" name="" id="IsDirectPrint" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />

<input type="hidden" value="@ViewBag.GResNo" name="" id="gresNo_AP" />
<input type="hidden" value="@ViewBag.ResNo" name="" id="resNo_AP" />
<input type="hidden" value="@ViewBag.GuestName" name="" id="guestName_AP" />
<input type="hidden" value="@ViewBag.RoomNo" name="" id="roomNo_AP" />
<input type="hidden" value="@ViewBag.RoomId" name="" id="roomId_AP" />
<input type="hidden" value="@ViewBag.GuestProfileId" name="" id="guestProf_AP" />
<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />

@if (@ViewBag.fromReservationScreen != null)
{
    <input type="hidden" value="fromRes" name="" id="advancePaymentVia" />
}
else
{
    <input type="hidden" value="Other" name="" id="advancePaymentVia" />
}


<link href="~/Content/ConerRibbon.css" rel="stylesheet" />


<fieldset class="the-fieldset ribbonbox " style="min-height:484px; margin-top:8px;">
   
        <div class="pritableArea">
            <div class="ribbon hidden-print"><span>Bill Preview</span></div>
            <div id="ReportLoadingArea" class="col-md-12" style="min-height:300px;">
                <div id="ReportHeader">
                    <table class="col-md-12" style="width:100%; margin-bottom:10px!important; margin-top:10px!important;">
                        <tr style="padding-bottom:20px;">
                            <th style="text-align:center; font-weight:bold; font-size:16px;" colspan="5">ADVANCE RECEIPT</th>
                        </tr>
                    </table>
                    <hr />
                    <table id="Advancedpayment-billheader" style="width:100%"></table>

                </div>
                <hr />

                <div id="AdvancePaymentReportBody" style="width:100%">
                    <table class="col-md-12" id="itemtable" style="width:100%">
                        <tr class="" style="width:100%">
                            <th style="padding-left:10px;">@*Payment Type*@</th>
                            <th style="text-align:right">@*Amount*@</th>
                        </tr>
                        <tr></tr>
                    </table>
                    <div class="row" style="padding-left:10px;">
                        <div class="col-md-6">
                            Advance Amount
                        </div>
                        @*<div>
                            <div class="form-group label-floating col-md-4">
                                <label class="control-label">Currency Type</label>
                                @{Html.RenderAction("CurrenciesConvertionCombo", "Currencies", new { area = "Administration", name = "CurrencyId", required = true, value = 86 }); }
                            </div>*@
                        @*</div>*@
                        <div style="text-align:right">
                            <input type="text" class="number number-only" id="AdvancedPayAmount" value="" style="border-style: solid; border-color:#e0e0e0; border-width: 0px 0px 1px 0px; text-align:right;background-color: #ffffff;" maxlength="10" />

                        </div>
                    </div>

                </div>

                <div class="row">
                    <div class="form-group col-md-12" style="margin-top:10px;">
                        <label class="control-label" style="padding-left:10px;">
                            Remarks:
                        </label>
                        <textarea maxlength="150" name="Message" id="AdvancedPayRemark" class="form-control" style="width:100%; font-size:12px; margin-left:10px; text-align:left; overflow:hidden;"></textarea>
                    </div>

                </div>
            </div>
            <div id="ReportTaxCalCulationArea" style="width:100%;">
                <div class="row" style="margin-top:10px;">
                    <div class="col-md-5"></div>
                    <div class="col-md-7 report-width60perc report-float-right">
                        <table class="table hidden" id="paymentTable" style="width:100%">
                            <tr></tr>
                        </table>
                    </div>

                </div>

            </div>
        </div>
       
        @if (ViewBag.fromReservationScreen != null)
        {
            <div id="billPayment" class="billpaymentClass" style="display:none;">
                @Html.Partial("_BillPayment", new BillPaymentView())
            </div>
        }
        <div id="ReportFooter" style="height:100px; margin-top:5px;">
            <div class="row col-md-12 report-width100perc">
                <div class="col-md-9">
                    <span class="currencyTc  report-width100perc">
                        * All currency amounts are in
                       
                    </span>
                </div>
                <div class="col-md-3" style="margin-top: -32px; margin-left: -120px;">
                    <select name="MultiCurrencyAdvanceCurrencyId" id="MultiCurrencyAdvanceCurrencyId" class="form-control label-data" required>
                       
                    </select>
                </div>
                @*<span class="currencyTc  report-width100perc"> * All currency amounts are in @SessionObjects.LocalCurrency.Name (@SessionObjects.LocalCurrency.ISOCode)</span>*@
                @*<span class="currencyTc  report-width100perc">
                    * All currency amounts are in
                    <select name="MultiCurrencyAdvanceCurrencyId" id="MultiCurrencyAdvanceCurrencyId" class="form-control label-data" required>
                        <option value="86">LKR</option>
                    </select>
                </span>*@
            </div>
            <div class="row" style="padding-top:30px; width:100%;">
                <div class="col-md-12">
                    <table style="width:100%" class="report-width100perc">
                        <tr>
                            <td>
                                <div class="col-md-4" style="padding-right:10px; ">
                                </div>
                            </td>
                            <td style="padding-right:20px;width:35%;">
                                <hr />
                            </td>
                            <td style="padding-right:20px;width:35%;">
                                <hr />
                            </td>
                        </tr>

                        <tr>
                            <td class="">
                                <div style="padding-right:10px;"></div>
                            </td>
                            <td class="report-width30px" style="width:33.3%">

                                <div style="padding-right:10px;text-align:center;">Prepared By</div>

                            </td>
                            <td>
                                <div style="padding-right:10px;text-align:center;">Guest Signature</div>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">

                    @if (ViewBag.fromReservationScreen == null)
                    {
                        <button class="btn btn-primary hidden-print hidden" id="btnbillpayment">
                            Settle Now
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary disabled hidden-print" id="btnbillpaymentforreservation">
                            Settle Now
                        </button>
                    }

                    &nbsp;

                    @if (Scienter.HotelERP.Common.Utility.Configs.GetAppSettingBoolValue("IsDirectPrint"))
                    {
                        <button id="btnprint" class="btn btn-primary disabled hidden-print" target="">
                            <span class="glyphicon glyphicon-print"></span>
                        </button>
                    }
                    else
                    {
                        <a id="btnprint" class="btn btn-primary disabled hidden-print" target="">
                            <span class="glyphicon glyphicon-print"></span>
                        </a>
                    }

                    <input type="hidden" value="" name="" id="Ad_pTaxId" />
                    <input type="hidden" value="" name="" id="Ad_pPostingCatgId" />
                    <input type="hidden" value="" name="" id="Ad_pChargeCodeId" />
                    <input type="hidden" value="" name="" id="Ad_pPostingTypeId" />
                    <input type="hidden" value="" name="" id="Ad_Name" />
                    <input type="hidden" name="AdvInvoiceNo" id="AdvInvoiceNo" value="" />        
                </div>
            </div>
        </div>
        </div>
    @*</form>*@
</fieldset>
<script src="~/Scripts/ui/reservation-list/side-buttons/advance-payment.js"></script>

