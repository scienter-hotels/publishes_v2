    //Date range date load and date diffrence-------------------------------------------------------------
    $('body').on('change', '.dateRangePicker', function (e) {
       
        var r = $(this).val().split('-')[0].trim();
        $('.FromDate').val($(this).val().split('-')[0].trim());
        $('.ToDate').val($(this).val().split('-')[1].trim());

        var FromDate = $('.FromDate').val();
        var ToDate = $('.ToDate').val();

        FromDate_obj = new Date(Date.parse(FromDate, "dd/mm/yyyy"));
        ToDate_obj = new Date(Date.parse(ToDate, "dd/mm/yyyy"));
    
        console.log(FromDate_obj);
        console.log(ToDate_obj);

        var utc1 = Date.UTC(FromDate_obj.getFullYear(), FromDate_obj.getMonth(), FromDate_obj.getDate());
        var utc2 = Date.UTC(ToDate_obj.getFullYear(), ToDate_obj.getMonth(), ToDate_obj.getDate());
        var noOfNights = 1; // Math.floor((utc2 - utc1) / (1000 * 60 * 60 * 24))

        $('.noOfNights').val(noOfNights);

    });

    //Room info load------------------------------------------------------------------

    function FillTable() {
        var reservationTrDetails = JSON.parse($('.hidden-stringify-json-reservation').val());
        $.each(reservationTrDetails, function (index, eachTrDetail) {
            $.each(eachTrDetail.roomTypeArrineachTr, function (index, eachRoomDetail) {
                
                $('<tr><td>' + eachTrDetail.RoomCategoryName + '</td><td>' + eachRoomDetail.roomType + '</td><td>' + eachRoomDetail.count + '</td></tr>').appendTo($('.roomCategoryWise-roomTypeWise-details'));
            })
        })
    }

    //Guest Search and Create ------------------------------------------------------
    $('body').on('click', '#btnCreateGuest', function () {
       
        $('.guest-checkBox').each(function (index, element) {
            $(element).prop('checked', false);
        });
       
        FillGuestDetail();
    });

    function FillGuestDetail() {
        if (ValidateGuest()) {
            ShowSuccessMessage('Guest added successfully, click NEXT to continue.');
        } else {
            ShowWarningMessage('All fields are mandatory!');
        }
    }

    function ValidateGuest() {
        var isValid = true;
        if ($('#SalutationId').val() == '') {
            $('#SalutationId').focus();
            isValid = false;
        }
        if ($('#FirstName').val() == '') {
            $('#FirstName').focus();
            isValid = false;
        }
        if ($('#LastName').val() == '') {
            $('#LastName').focus();
            isValid = false;
        }
        if ($('#NICPassport').val() == '') {
            $('#NICPassport').focus();
            isValid = false;
        }

        if ($('#CountryId').val() == '') {
            $('#CountryId').focus();
            isValid = false;
        }
        if ($('#NationalityId').val() == '') {
            $('#NationalityId').focus();
            isValid = false;
        }

        //if ($('#Email').val() == '') {
        //    $('#Email').focus();
        //    isValid = false;
        //}
        //if ($('#ContactNo').val() == '') {
        //    $('#ContactNo').focus();
        //    isValid = false;
        //}

        if (isValid) {
            var guestId = -1;
            $('.guest-checkBox').each(function (index,element) {
                if ($(element).prop('checked')) {
                    guestId = $(element).val();
                    return false;
                }
            });
           
            var SelectedGuest = {
                Id: guestId,
                SalutationId: $('#SalutationId').val(),
                FirstName: $('#FirstName').val(),
                LastName: $('#LastName').val(),
                NICPassport: $('#NICPassport').val(),
                CountryId: $('#CountryId').val(),
                NationalityId: $('#NationalityId').val(),
                Email: $('#Email').val(),
                ContactNo: $('#ContactNo').val()
            }


            $('.hidden-stringify-json-guest').val(JSON.stringify(SelectedGuest));
           

        }
        else {
            ShowWarningMessage('You have missed some mandatory fields.');
        }
        return isValid;
    }


    function LoadStep04() {
        $.ajax({
            url: '/reservation/reservations/bookingconfirmation',
            dataType: 'html',
            method: 'POST',
            success: function (response) {
                $('#step03').find($("span")).removeClass("glyphicon-record");
                $('#step03').find($("span")).addClass("glyphicon-ok");
                $('#step03').find($(".formWizardNumbers")).removeClass("theme-bg-color-2");
                $('#step03').find($(".formWizardNumbers")).addClass("theme-bg-color-3");

                $('#step04').find($("span")).addClass("glyphicon-record");
                $('#contentLoadingArea').html('').fadeOut();
                $('#contentLoadingArea').html(response).fadeIn();
            },
            error: function (error) {
            }
        });
    }

