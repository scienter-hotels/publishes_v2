            <div class="modal-content" id="grid-detail-popup-container">
                <div class="modal-body">
                    <div data-dismiss="modal" style="float: right;margin-top: -20px;margin-right: -20px;background-color: #fff;border-radius: 50px;padding: 4px; cursor:pointer;" class="closeModel" id="grid-record-detail-model-close">
                        <img src="~/Images/close-btn.png" class="hidden-print" style="width:28px;" />
                    </div>
                    <div class="model-popup-title">
                        <h4 id="grid-record-detail-header" class="hidden-print" style="margin-bottom:10px;"></h4>
                    </div>
                    <div id="grid-record-detail-body" style="max-height:520px; overflow-x:hidden; overflow-y:auto; padding-right:10px;">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="grid-record-detail-model-lost-and-found" class="modal fade" role="dialog">
