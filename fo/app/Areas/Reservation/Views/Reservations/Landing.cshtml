
@{
    ViewBag.Title = "Guest Reservation";
}

<style>
    .formWizardNumbers {
        border-radius: 300px;
        padding: 8px;
        margin: 0 auto !important;
        color: white;
        width: 35px;
        text-align: center;
    }

    .formWizardText {
        margin-top: 15px;
        color: #808080;
        text-align: center;
        font-size: 13px;
        text-decoration: none;
        text-transform: uppercase;
        margin-left: 5px;
    }

    .step {
        background-color: #f2f2f2;
    }

    .selectedStep {
        background-color: #f2f2f2;
    }

    .stepSmallText {
        font-size: 9px;
        display: block;
    }

    #contentLoadingArea {
        padding-left: 20px !important;
        padding-right: 20px !important;
    }

    .reservation-detail-table {
        height: 100px;
        overflow-y: scroll;
    }

    .disabled {
        cursor: not-allowed;
    }

</style>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 ">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <a class="btn btn-sm  btn-theme-color-2 showGrid" href="~/reservation/reservations/list">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </a>

                    </div>
                </div>
            </div>

            <br />
            <div class="row">

                <input type="hidden" name="From" id="FromDateId" class="FromDate" /> <input type="hidden" id="ToDateId" name="To" class="ToDate" />
                <input type="hidden" name="noOfNights" class="noOfNights" />
                <input type="hidden" name="reservation-details" class="hidden-stringify-json-reservation" />
                <input type="hidden" name="guest-details" class="hidden-stringify-json-guest" />
                <input type="hidden" name="guest-details" class="hidden-stringify-json-SelectedStay" />
                <input type="hidden" name="guest-OtherDetails" class="hidden-stringify-json-SelectedStay" />

                <div class="col-md-3 redda col-sm-3 col-xs-3 text-center hidden-print" id="step01">
                    <a href="javacript:preventDefault();">
                        <div class="formWizardNumbers theme-bg-color-2"> 1 </div>

                        <div class="formWizardText">
                            Select Stay <span class="glyphicon"></span>
                            <i class="stepSmallText"></i>
                        </div>

                    </a>
                </div>
                <div class="col-md-3 col-sm-3 col-xs-3 text-center hidden-print" id="step02">
                    <a href="javacript:preventDefault();">
                        <div class="formWizardNumbers theme-bg-color-2"> 2 </div>

                        <div class="formWizardText">
                            Guest Details <span class="glyphicon"></span>
                            <i class="stepSmallText"></i>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-sm-3 col-xs-3 text-center hidden-print" id="step03">
                    <a href="javacript:preventDefault();">
                        <div class="formWizardNumbers theme-bg-color-2"> 3 </div>

                        <div class="formWizardText">
                            Other Details <span class="glyphicon"></span>
                            <i class="stepSmallText"></i>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-sm-3 col-xs-3 text-center hidden-print" id="step04">
                    <a href="javacript:preventDefault();">
                        <div class="formWizardNumbers theme-bg-color-2"> 4 </div>

                        <div class="formWizardText">
                            Confirmation  <span class="glyphicon"></span>
                            <i class="stepSmallText"></i>
                        </div>
                    </a>
                </div>

            </div><hr style="margin-bottom:0px;" />
            <div class="card-content div-scroll reservation-form-height" id="contentLoadingArea">  
                            
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
    // form load --------------------------------
    $(document).ready(function () {
        //ScorelToTop60px();
        $('.showForm').click();
        $('#step01').find($("span")).addClass("glyphicon-record");
       
    });

    // SELECT ROOM AVAILABILITY --------------------------------

    $('body').on('click', '#btnCheckRoomAvailability', function (e) {
        SelectRoomAvailability();
    });

    $('body').on('click', '.applyBtn', function (e) {
        SelectRoomAvailability();
    });

    function SelectRoomAvailability() {

        $('#step01').find($("span")).removeClass("glyphicon-ok");

        if ($('#From').val() == "undefined" || $('#To').val() == "undefined" || $('#From').val().length == 0 || $('#To').val().length == 0) {
            ShowErrorMessage("Please select the stay to continue.");
            $('#reservationDateRange').focus();
        }
        else {
           
            CountryId = $('#CountryCombo').val(),
            From = $('#From').val(),
            To = $('#To').val()
            $('#ArrivalDate').val(From);
            $('#DepartureDate').val(To);
        }

        $.ajax({
            url: '/reservation/reservations/GetAvailability',
            dataType: 'html',
            method: 'POST',
            data: { CountryId: CountryId, fromDate: From, toDate: To },
            success: function (response) {
              
                $('#roomAvailabilityContainer').html('').fadeOut();
                $('#roomAvailabilityContainer').html(response).fadeIn();
            },
            error: function (error) {            
            }
        });
    }

   //--- coppied form here

    // Step 01 Click --------------------------------
    $('body').on('click', '#step01', function (e) {
        LoadStep01();
    });

    // Step 02 Click --------------------------------
    $('body').on('click', '#step02', function (e) {
        LoadStep02();
    });

    // Step 03 Click --------------------------------
    $('body').on('click', '#step03', function (e) {
        LoadStep03();
    });

    // Step 04 Click --------------------------------
    $('body').on('click', '#step04', function (e) {
        LoadStep04();
    });

    //Room Count-------------------------------------

    $('body').on('change', '.room-count', function (e) {

        if ($(this).length == 0) {
            $(this).val(0);
        }

        var sum = 0;        
        $(".room-count").each(function () {
            sum += +$(this).val();
        });
        if (parseInt($('#NoOfChildrens').val()) > 0) {
            $("#NoOfAdults").val(sum - parseInt($('#NoOfChildrens').val()));
        }
        else
        {
            $("#NoOfAdults").val(sum);
        }

    });

