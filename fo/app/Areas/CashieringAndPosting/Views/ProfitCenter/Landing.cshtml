    function LoadItemPrice() {
        //debugger;
        var ProfitCenterId = 0
        var ChargeTypeId = 0;
        var ItemId = 0;
        var PriceType = 0;
        var ItemCategoryId = 0;

        if ($('#ProfitCenterId').val() != undefined && $('#ProfitCenterId').val() != "") {
            var ProfitCenterId = Number($('#ProfitCenterId').val());
        }

        if ($('#ChargeTypeId').val() != undefined && $('#ChargeTypeId').val() != "") {
            var ChargeTypeId = Number($('#ChargeTypeId').val());
        }


        if ($('#ItemId').val() != undefined && $('#ItemId').val() != "") {
            var ItemId = Number($('#ItemId').val());
        }

        if ($('.price-type').val() != undefined && $('.price-type').val() != "") {
            var PriceType = Number($('.price-type').val());
        }

        if ($('#ItemCategoryId').val() != undefined && $('#ItemCategoryId').val() != "") {
            var ItemCategoryId = Number($('#ItemCategoryId').val());
        }

        //if (ChargeTypeId != 0 && ItemId != 0 && PriceType != 0) {
            //debugger;
            $.ajax({
                url: '/CashieringAndPosting/ProfitCenter/SelectPriceCenterPrices',
                dataType: 'Json',
                data: { ProfitCenterId: ProfitCenterId, ItemId: ItemId, ChargeTypeId: ChargeTypeId, PriceType: PriceType, ItemCategoryId: ItemCategoryId },
                method: 'POST',
                success: function (data) {

                    $('#RateId').val(data.Price)
                },
            });
       // }
    }
    ///--------------------------------Add Button -------------------------
    //debugger;
    var LaundryDetailArrray = [];
    var LaundryDetail = "";
    var total = 0;
    var TaxGroupDetailArray = [];
    var CompanyId = 0;

    $('body').on('submit', '#ProfitCenterPostingForm', function (e) {
        debugger;
        e.preventDefault();
        $('#hdnAllowCreditPosting').val($("#CompanyId option:selected").attr('data-allowCreditPosting'));


        if ($('#postingTypeTitle').val() == "walkin") {
            $('#hdnAllowCreditPosting').val($("#CompanyId option:selected").attr('data-allowCreditPosting').toString());
            let CompanyId = $('#CompanyId').val();
        } else if ($('#postingTypeTitle').val() == "guest") {
            $('#hdnAllowCreditPosting').val($("#RoomId option:selected").attr('data-allowCreditPosting').toString());
            CompanyId = $("#RoomId option:selected").attr('data-companyId');
        }


        if ($('#Quantity').val() == '' || parseInt($('#Quantity').val()) < 1) {
            ShowWarningMessage('Quantity should be greated than zero.');
            return false;
        }

        CalculateTax();
        var rate = 0;
        if ($('#IsComplementary').is(":checked") == true) {
            rate = 0;
        } else {
            rate = $('#RateId').val().replace(/,/g, '');
        }


        debugger;
        if (rate < 0) {
            ShowWarningMessage('Invalid rate.');
        } else if ($('#Quantity').val() == '' || parseInt($('#Quantity').val()) < 1) {
            ShowWarningMessage('Quantity should be greated than zero.');
        } else {
            total = Number(total) + Number(parseFloat(rate) * parseInt($('#Quantity').val()));
            console.log(total);
            LaundryDetail = {//-----ProfitCenterId Need to passs
                CompanyId: $('#CompanyId').val(),//New add 2022-08-25
                ProfitCenterId: $('#ProfitCenterId').val(),
                ItemId: $('#ItemId').val(),
                ItemCategoryId: $('#ItemCategoryId').val(),
                ChargeTypeId: $('#ChargeTypeId').val(),
                //Rate: $('#Rate').val(),
                Rate: rate,
                Quantity: $('#Quantity').val(),
                //Discount: $('#Discount').val(),
                //Amount: total,
                Amount: rate * $('#Quantity').val(),
                TaxGroupId: $('#ItemId option:selected').attr('taxgroup-data'),
                Remarks: $('#Remarks').val(),
                IsDiscount:0
            }
            console.log(LaundryDetail);

            if ($('#categoryId').val() == "walkin") {
                $('#CusNameInGrid').html($('#Name').val());
                $('#CusAddrInGrid').html($('#Address').val());
            }

            
            LaundryDetailArrray.push(LaundryDetail);
            $('<tr><td><button type="button" class="hidden-print btn btn-danger btn-sm rowDelbtn"  data-item="' + 'item' + $('#ItemId option:selected').val() + '"> <span class="glyphicon glyphicon-minus"></span>  </button>' + '</td><td>' + $('#ItemId option:selected').text() + '</td><td>' + $('#ChargeTypeId option:selected').text() + '</td><td>' + $('#Remarks').val() + '</td><td class="formatNumber">' + rate + '</td><td style="text-align:right;">' + $('#Quantity').val() + '</td><td class="priceTd formatNumber" style="text-align:right;">' + parseFloat(rate) * parseInt($('#Quantity').val()) + '</td></tr>').appendTo($('#ProfitCenterWisePostingTable'));
           
            //var discount = $('#Discount').val();
            var discount = Number($('#Discount').val().replace(',', ''));
           
            if (discount > 0) {
                $('<tr><td><button type="button" class="hidden-print btn btn-danger btn-sm rowDelbtn ' + 'item' + $('#ItemId option:selected').val() + '" data-item="' + 'item' + $('#ItemId option:selected').val() + '"> <span class="glyphicon glyphicon-minus"></span>  </button>' + '</td><td>' + $('#ItemId option:selected').text() + '- Discount' + '</td><td>' + '' + '</td><td>' + 'Discount' + '</td><td class="formatNumber">' + '-' + discount + '</td><td style="text-align:right;">' + $('#Quantity').val() + '</td><td class="priceTd formatNumber" style="text-align:right;">' + '-' + parseFloat(discount) * parseInt($('#Quantity').val()) + '</td></tr>').appendTo($('#ProfitCenterWisePostingTable'));
             
                LaundryDetail = {//-----ProfitCenterId Need to passs
                    CompanyId: $('#CompanyId').val(),//New add 2022-08-25
                    ProfitCenterId: $('#ProfitCenterId').val(),
                    ItemId: $('#ItemId').val(),
                    ItemCategoryId: $('#ItemCategoryId').val(),
                    ChargeTypeId: $('#ChargeTypeId').val(),
                    //Rate: $('#Rate').val(),
                    Rate: discount * parseInt($('#Quantity').val()),
                    Quantity: $('#Quantity').val(),
                    //Discount: $('#Discount').val(),
                    //Amount: total,
                    Amount: discount * $('#Quantity').val(),
                    TaxGroupId: $('#ItemId option:selected').attr('taxgroup-data'),
                    Remarks: $('#Remarks').val(),
                    IsDiscount:1
                }
                LaundryDetailArrray.push(LaundryDetail);
            
            }

            var RoomNo = $('#RoomId option:selected').text()
            $('#RoomNoInGrid').html(RoomNo)

            var DocumentNo = $('#DocumentNo').val()
            $('#DocumentNoInGrid').text(DocumentNo)

            GetTotal();

            if (LaundryDetailArrray.length > 0) {
                $('#btnbillpayment').removeClass('disabled');
                $('#Save').removeClass('disabled');
            }

            if (RoomNo != "") {

                $('#roomNolabel').removeClass('hidden');
            }

            $('#ItemId').val('');
            $('#RateId').val('');
            $('#Quantity').val('0');
            $('#Remarks').val('');
            $('#Discount').val(''),

            $('#ProfitCenterId').prop('disabled', true);
        }
    });

    $('#ProfitCenterWisePostingTable').on('click', '.rowDelbtn', function () {
       //debugger;

        // erase from array
        var i = 0;
        i = $(this).closest('tr').index()

        var dataitem = $(this).closest('tr').find('.rowDelbtn').attr('data-item');
        
        if (i == 0) {
            LaundryDetailArrray.splice(i, 1);
            TaxGroupDetailArray.splice(i, 1);
        }
        else {
            LaundryDetailArrray.splice(i - 1, 1);
            TaxGroupDetailArray.splice(i - 1, 1);
        }

        if (LaundryDetailArrray.length > 0) {
            $('#btnbillpayment').removeClass('disabled');
