<input type="hidden" name="name" id="ReservationHeaderId" value="@ViewBag.ReservationId" />
<input type="hidden" name="name" id="ReservationType" value="@ViewBag.ReservationType" />
<input type="hidden" name="name" id="RoomId" value="@ViewBag.RoomId" />
@*Ishara*@

@{
    var firstRoomCode = "";
}

<style>
    #frmKeyCardRequest .form-group{
        margin:0px !important;
    }
</style>
<div style =" width:102%">
    <form method="post" id="frmKeyCardRequest">
        <div class="row">
            @*<div>*@
            <div class="col-md-12" style="font-size:12px;">
                <table width="100%" border="0" cellpadding="5" class="table table-striped">
                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td style="width:100px;">Reservation</td>
                        <td style="text-align:center; width:10px;"> : </td>
                        <td colspan="5">@ViewBag.resNo</td>
                        @*<td colspan="2"></td>*@
                    </tr>

                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td>Room</td>
                        <td style="text-align:center;"> : </td>
                        <td colspan="5">@ViewBag.room</td>
                        @*<td colspan="2"></td>*@
                    </tr>

                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td>Arrival</td>
                        <td style="text-align:center;"> : </td>
                        <td colspan="5">@ViewBag.arrival</td>
                        @*<td colspan="2"></td>*@
                    </tr>
                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td>Departure</td>
                        <td style="text-align:center;"> : </td>
                        <td colspan="5">@ViewBag.departure</td>
                        @*<td colspan="2"></td>*@
                    </tr>

                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td>Guest</td>
                        <td style="text-align:center;"> : </td>
                        <td colspan="5">@ViewBag.Guest</td>
                        @*<td colspan="2"></td>*@
                    </tr>

                    <tr>
                        <td style="text-align:center; width:20px;"> </td>
                        <td @*style="font-size:14px;*@ ">Key Code</td>
                        <td style="text-align:center;"> : </td>
                        <td style="width:20px;">
                            <select id="keyRequestSelect" class="form-control" style="width:120px; text-align:left; margin-top:10px;" required>
                                @foreach (var keyObject in ViewBag.KeyObjects)
                                {
                                    <option value="@keyObject.KeyCode">@keyObject.RoomKeyCodeName</option>
                                }
                            </select>
                        </td>
                        <td style="text-align:center; width:20px;"> </td>
                        <td>No of Card(s)</td>
                        <td style="text-align:center;"> : </td>
                        <td style="width:20px;">
                            <select id="NoOfCardsSelect" class="form-control" style="width:120px; text-align:left;  margin-top:10px;" required">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        </td>
                    </tr>
                </table>
                <input type="hidden" style="font-size: 15px; margin-top: 10px; color:#040404;" id="MachineIP" value="@ViewBag.MachineIP" />
            </div>
            @*@if (ViewBag.ReservationType == "inhouse")
                {
                    <div class="col-md-4" style="margin-left: 15px;">
                        @if (ViewBag.KeyObjects.Count > 0)
                        {
                            var firstKeyObject = ViewBag.KeyObjects[0];
                            firstRoomCode = firstKeyObject != null ? firstKeyObject.RoomCode : string.Empty;
                        }
                        else
                        {
                            firstRoomCode = "";
                        }
                        <div><label style="font-size: 30px; font-weight: bold;color:#040404;">@firstRoomCode</label></div>
                    </div>
                    <div class="col-md-3" style="">
                        <label style="font-size: 15px; margin-top: 10px;color:#040404;" for="keyRequestSelect">Key Code : </label>
                    </div>
                    <div class="col-md-4" style="margin-top: -23px;margin-left: 15px;">
                        <select id="keyRequestSelect" class="form-control" required style="font-size: 15px;">
                            @foreach (var keyObject in ViewBag.KeyObjects)
                            {
                                <option value="@keyObject.KeyCode">@keyObject.RoomKeyCodeName</option>
                            }
                        </select>
                        <input type="hidden" style="font-size: 15px; margin-top: 10px; color:#040404;" id="MachineIP" value="@ViewBag.MachineIP" />
                    </div>
                }*@
            @*</div>*@

        </div>
        <div class="row">
            <div class="col-md-4 col-md-offset-8">
                <input type="submit" id="roomkeyCode" value="SEND KEY REQUEST" class="btn btn-primary" style="width: 100%;" />
            </div>
        </div>
    </form>
</div>
<script>

    $(document).ready(function () {
        $('#grid-record-detail-body').css('overflow-y', 'hidden');
        //$('')
    });

    $('body').off('submit', '#frmKeyCardRequest').on('submit', '#frmKeyCardRequest', function (e) {
        e.preventDefault();
        var reservationHeaderId = $('#ReservationHeaderId').val();
        var reservationType = $('#ReservationType').val();
        var roomId = $('#RoomId').val();
        var keyCode = $('#keyRequestSelect').val();
        var machineIP = $("#MachineIP").val();
        var keyRequest = $('#NoOfCardsSelect').val();

        $.ajax({
            url: '/Reservation/Reservations/KeyRequestSave',
            method: 'POST',
            data: {
                reservationHeaderId: reservationHeaderId,
                reservationType: reservationType,
                roomId: roomId,
                keyCode: keyCode,
                machineIP: machineIP,
                keyRequest: keyRequest
            },
            dataType: 'json',
            success: function (response) {
                if (response === "OK") {
                    ShowSuccessMessage('Key card request sent successfully.');
                    //setTimeout(function () { window.location.reload(); }, 2000)
                    $('#grid-record-detail-model').modal('hide');
                    // Load new inhouse reservation grid
                    LoadInhouseReservationGrid();
                } else {
                    ShowWarningMessage(response);
                    // Load new inhouse reservation grid
                    LoadInhouseReservationGrid();
                }

            },
            error: function (e) {
                alert(e);
            }
        });
    });



</script>
