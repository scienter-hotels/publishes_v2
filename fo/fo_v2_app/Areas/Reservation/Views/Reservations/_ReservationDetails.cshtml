    var total = 0;

    $(document).off('click', '#addDiscounts').on('click', '#addDiscounts', function () {
        var ratecodeheaderId = $('#RateCodeHeaderId').val();
        var arrival = $('#ArrivalDate').val();
        var departure = $('#DepartureDate').val();

        getTotalRate();

        if (ratecodeheaderId > 0) {
            if (confirm('Discounts will be calculated on ' + total + ' ' + currencyForExtras+'. Click "Yes" to continue or "No" to adjust rates.')) {
                var url = '/reservation/reservations/Discounts?ratecodeheaderId=' + ratecodeheaderId + '&arrival=' + arrival + '&departure=' + departure+'&baseamount=' + total;
                CallDetailModelSimple('Discount(s) (Enter Amount in ' + currencyForExtras + ')', url, 800);
            } else {
                ShowWarningMessage('Please adjust the rate and continue.');
            }
        } else {
            ShowWarningMessage('Please select a rate code.');
        }
    });

    function getTotalRate() {
        total = 0;
        $('.roomCategoryWise-roomTypeWise-details tbody tr').each(function () {
            var rate = parseFloat($(this).find('input[type="number"]').val()) || 0;
            total += rate;
        });
    }
