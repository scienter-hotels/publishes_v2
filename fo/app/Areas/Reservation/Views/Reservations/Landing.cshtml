    function LoadStep01() {

        $.ajax({
            url: '/reservation/reservations/managestay',
            dataType: 'html',
            method: 'POST',
            beforeSend: function () {
                $("#btnStep01Next").prop('disabled', true).addClass("disabled");
            },
            success: function (response) {

                $('#contentLoadingArea').html('').fadeOut();
                $('#contentLoadingArea').html(response).fadeIn();
                SelectRoomAvailability();

               
                // fill back
                setTimeout(function () {
                    if ($('#FromDateId').val() != undefined && $('#FromDateId').val().length > 0) {

                        var stayObj = JSON.parse($('.hidden-stringify-json-SelectedStay').val());
                        $('#CountryCombo').val(stayObj.CountryId);
                        $('#NoOfAdults').val(stayObj.Adults);
                        $('#NoOfChildrens').val(stayObj.Kids);

                       
                        var dateRange = $('#selectedStayRange').html().replace(" ", "");
                        var startDate = dateRange.split('-')[0];
                        var endDate = dateRange.split('-')[1];

                        //var utc1 = Date.UTC(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
                        //var utc2 = Date.UTC(endDate.getFullYear(), endDate.getMonth(), endDate.getDate());
                        //var noOfNights = Math.floor((utc2 - utc1) / (1000 * 60 * 60 * 24))
                        //$('.noOfNights').val(noOfNights);
                        //$('#NoOfNights').val(

                        $('#reservationDateRange').data('daterangepicker').setStartDate(startDate);
                        $('#reservationDateRange').data('daterangepicker').setEndDate(endDate);

                        var reservationTrDetails = JSON.parse($('.hidden-stringify-json-reservation').val());

                        $('.roomDetail tr td').each(function () {
                            var currentTd = $(this);
                           
                            $.each(reservationTrDetails, function (index, eachTrDetail) {

                                $.each(eachTrDetail.roomTypeArrineachTr, function (index, eachRoomDetail) {

                                    if (currentTd.attr('data-cat-id') == eachTrDetail.roomCategoryId) {

                                        if (currentTd.attr('data-type-id') == eachRoomDetail.roomTypeId) {
                                            
                                            currentTd.find('.room-count').val(eachRoomDetail.count);
                                        }
                                    }
                                })
                            });
                        });


                        //$('#reservationDateRange').daterangepicker({ startDate: '03/05/2019', endDate: '03/06/2019' });
                    }
                }, 1000);
            },
            complete: function () {
                $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
            },
            error: function (error) {
            }
        });
    }




  

</script>

