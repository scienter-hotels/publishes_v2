<script>
    var countryId = 0;
    var maxChars = 500;

    $(document).ready(function () {
        var charCount = $('#RemarkId').val().length;
        $('#charCount').text(charCount + '/' + maxChars);
        //2023-08-10--------------------------------------------------------------------------

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display','none');
            $('#select2-DocNo-container').css({ 'margin-top':'-1px', 'cursor':'auto'});
        }, 100);
        //-------------------------------------------------------------------------------------------

        isCategoryGridLoaded = false;
        isReservationListLoaded = false;

        document.getElementById('StayChange-Remark').addEventListener('input', function () {
            var userInput = this.value;
            this.setAttribute('title', userInput)
        })

