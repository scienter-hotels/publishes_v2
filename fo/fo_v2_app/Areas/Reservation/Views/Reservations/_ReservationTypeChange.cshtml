    function GetDates(arrival, depature) {

        $.ajax({
            method: 'GET',
            url: '/CashieringAndPosting/SchedulePosting/GetReservationDates?arrivalDate=' + arrival + '&departureDate=' + depature,
            datatype: 'html',
            success: function (htmlContent) {
                $('#reservationDatesLoadingArea').html('');
                $('#reservationDatesLoadingArea').html(htmlContent);
                LoadExistingDates();
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in getting records.');
            }
        });

    }

