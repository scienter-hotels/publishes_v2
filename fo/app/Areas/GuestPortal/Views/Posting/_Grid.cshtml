

@model  IEnumerable<Scienter.HotelERP.Common.Domain.GuestPortal_Posting>
@{


    ViewBag.Title = "Guest Portal Posting";
}
<div class="table-responsive">
    <table class="table table-striped" id="GuestPortalPosting">
        <thead>
            <tr>
                <th class="col-md-1 text-primary">
                    Reservation No
                </th>
                <th class="col-md-1 text-primary">
                    Category
                </th>
                <th class="col-md-1 text-primary">
                    Amount
                </th>
                <th class="col-md-1 text-primary">
                    InhousePaymentAmount
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="height: 36px !important;">
                    <td>
                        @Html.DisplayFor(modelItem => item.ReservationNo)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.PostingCategoryName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Amount)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.InhousePaymentAmount)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    $(document).ready(function () {
        $('#GuestPortalPosting').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    'pdf',
                    'print'
                ],
                scrollY: '58vh',
            });
    });
</script>




