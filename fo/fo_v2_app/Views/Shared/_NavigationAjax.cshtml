<nav class="cd-nav hidden-print">
    <ul id="cd-primary-nav" class="cd-primary-nav is-fixed container" style="margin-right:50px;"></ul>
</nav>

<script>
    // 2023-08-23-Anuradha
    $(document).ready(function () {
        loadMenus();

        var menuHeight = $(window).height() - 65;
        var menuWidth = $(window).width() - 24;
        $('.cd-secondary-nav').css({
            'overflow-y': 'auto',
            'max-height': menuHeight,
            'width': menuWidth
        });

        // 2023-08-31-Anuradha
        $('[id^="search-"] #searchBox').on("input", function () {
            var searchTerm = $(this).val().toLowerCase();
            var ulliId = $(this).closest('[id^="search-"]').attr('id');

            $('#' + ulliId + ' .search').each(function () {
                var itemName = $(this).text().toLowerCase();
                $(this).toggle(itemName.includes(searchTerm));
            });
        });
    });

    // 2024-07-04-Anuradha
    function getLocalStorage(localStorageKey) {
        var localStorageValueStr = localStorage.getItem(localStorageKey);
        return JSON.parse(localStorageValueStr);
    }

    function loadMenus() {
        
        var mainNavigations = getLocalStorage('Z_FO_MainNavigations');

        $(mainNavigations).each(function (index, mainItem) {
            var subMainNavigations = getLocalStorage(mainItem.LocalStorageKey);
            var mainItemUrl = mainItem.Access ? mainItem.Url : "#";
            var mainItemAccessStyle = mainItem.Access ? "#094F70" : "#fff";
            var menuLvl2 = '';

            $(subMainNavigations).each(function (index1, subItemLvl1) {
                var subItemLvl1Navigations = subItemLvl1.Pages;
                var menuLvl3 = '';
                if (subItemLvl1.IsActive) {

                    $(subItemLvl1Navigations).each(function (index2, subItemLvl2) {
                        var subItemLvl2Url = subItemLvl2.Access ? subItemLvl2.Url : "#";
                        var subItemLvl2AccessStyle = subItemLvl2.Access ? "#094F70" : "#7f8c8d";

                        if (subItemLvl2.IsActive) {
                            menuLvl3 += `
                                <li class="search">
                                    <a class="linkNavigation" href="${subItemLvl2Url}" title="${subItemLvl2.Name}" hidefocus="hidefocus" style="color:${subItemLvl2AccessStyle} !important;" data-toggle="tooltip">${subItemLvl2.Name}</a>
                                </li>
                            `;
                        }
                    });
                    var subItemLvl1AccessStyle = subItemLvl1.Access ? "#094F70" : "#7f8c8d";

                    menuLvl2 += `
                        <li class="has-children search" style="margin-bottom:30px;">
                            <img src="${subItemLvl1.ImageUrl}" alt="${subItemLvl1.Name}" title="${subItemLvl1.Name}" class="navigation-area-image" />
                            <a style="color:${subItemLvl1AccessStyle} !important;">${subItemLvl1.Name}</a>
                            <ul class="is-hidden" id="secondUl">
                                <li class="go-back"><a href="javascript:preventDefault();">${subItemLvl1.Name}</a></li>
                                ${menuLvl3}
                            </ul>
                        </li>
                    `;
                }
            });

            var menuLvl1 = `
                    <li class="has-children top-menu-item" id="search-${mainItem.Id}">
                        <a href="${mainItemUrl}" style="cursor:pointer;color:${mainItemAccessStyle} !important;" class="data-main-navigation">${mainItem.Name}</a>
                        <ul class="cd-secondary-nav is-hidden data-main-navigation-areas">
                            <li class="go-back"><a href="">Menu</a></li>
                            <li class="" style="display:block; width:97.3%;margin-top: -20px; margin-bottom: 35px;">
                                <div class="row">
                                    <div class="col-md-3"></div>
                                    <div class="col-md-6">
                                        <div style="padding:5px; border-radius:50px; border:2px solid rgba(220, 223, 228, 0.75)">
                                            <table border="0" cellspacing="1" style="border:0px; width:100%;">
                                                <tbody>
                                                    <tr style="background-color:transparent;">
                                                        <td style="padding-right:10px; padding-left:10px; width:10%;">
                                                            <img src="/Images/assets/mag.png" alt="search" />
                                                        </td>
                                                        <td width="100%">
                                                            <input type="text" id="searchBox" placeholder="Search..." style="border:none; width:100%;" />
                                                        </td>
                                                        <td width="20%">
                                                            <button type="submit" class="btn btn-primary btn-sm" style="border-radius:30px !important;font-weight: 300;letter-spacing: 2px;font-size: 11px;padding: 7px 25px;margin: 7px 10px; line-height:15px;">Search</button>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <div class="col-md-3"></div>
                                </div>
                            </li>
                            ${menuLvl2}
                        </ul>
                    </li>
                `;

            $('#cd-primary-nav').append(menuLvl1);
        });
        
    }
	
	
