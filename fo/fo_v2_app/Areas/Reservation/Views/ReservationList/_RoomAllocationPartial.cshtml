                                    <div class="row searchBox">
                                        <div class="col-md-10">
                                            <input type="text" id="roomSearchBy" placeholder="Search by room code, name or housekeeping status" class="form-control" />
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" class="btn-primary btn btn-block searchByBtn" style="width: 100%;float: right;">Search<div class="ripple-container"></div></button>
                                        </div>
                                    </div>



                                    <div class="row rooms-container" style="margin-left: -13px;margin-right: 0px;margin-top:10px;">


                                        @foreach (var item in Model.RoomDetails)
                                        {
                                            if (item.Remark == "Same")
                                            {
                                                string wellColor = "",
                                                    buttonText = "",
                                                    buttonClass = "",
                                                    disabled = "",
                                                    btnType = "",
                                                     btnImage = "";

                                                if (item.IsOutOfOrder)
                                                {
                                                    wellColor = "outOfOrderWellColor";
                                                    buttonText = "OOO";
                                                    buttonClass = "outOfOrderButton";
                                                    disabled = "disabled";
                                                    btnImage = "/Images/close_icon.png";
                                                }
                                                else if (item.IsAllocatedForReservation)
                                                {
                                                    wellColor = "allocatedWellColor";
                                                    buttonText = "DE-ALLOCATE";
                                                    buttonClass = "deallocate-button";
                                                    btnType = "btn-danger";
                                                    btnImage = "/Images/bed.png";
                                                }
                                                else if (item.IsAllocatedForOtherReservation)
                                                {
                                                    wellColor = "reservedWellColor";
                                                    buttonText = "RESERVED";
                                                    buttonClass = "reservedButton";
                                                    disabled = "disabled";
                                                    btnType = "btn-danger";
                                                    btnImage = "/Images/bookmark.png";
                                                }
                                                else
                                                {
                                                    wellColor = "allocateWellColor";
                                                    btnType = "allocate-btn";
                                                    buttonText = "ALLOCATE";
                                                    buttonClass = "allocate-button";
                                                    btnImage = "/Images/tick.png";
                                                    //btnType = "btn-primary";
                                                    //buttonText = "ALLOCATE";
                                                    //buttonClass = "allocate-button";
                                                }


                                                <div class="custom-width col-md-2 @item.RoomFloorNameFormatted pad-l-r-0 room-block" data-room-text="@item.Name @item.Prefix">
                                                    <div class="well well-custom override-well @wellColor" style="margin-left: 13px;">
                                                        <div class="row mar-l-r-0">
                                                            <div class="col-md-7 pad-l-r-0">
                                                                <div class="row mar-l-r-0">
                                                                    <div class="col-md-12 pad-l-r-0 border-bottom" style="padding-top: 0px;">
                                                                        <span class="item-name" style="width:70px; font-size:14px;">@item.Name</span>
                                                                    </div>
                                                                    <div class="col-md-12 pad-l-r-0">
                                                                        <div class="col-md-6 pad-l-r-0">
                                                                            <span class="prefix" style="font-size:14px;">@item.Prefix</span>
                                                                        </div>
                                                                        @*house keeping status image*@
                                                                        <div class="col-md-6 pad-l-r-0">
                                                                            <img src="@item.HouseKeepingStatusImage" alt="" style="border: 1px solid #dddddd;padding: 3px;width:30px;height:30px;" title="@item.RoomStatus" />
                                                                        </div>
                                                                    </div>

                                                                </div>
                                                                <input type="hidden" class="hidden-roomId" id="hidden-roomId" value="@item.Id" />
                                                                <input type="hidden" class="isAllocatedforReservation" id="isAllocatedforThisReservation" value="@item.IsAllocatedForReservation.ToString()" />
                                                                <input type="hidden" class="isAllocatedforOtherReservation" id="isAllocatedforOtherReservation" value="@item.IsAllocatedForOtherReservation.ToString()" />
                                                            </div>
                                                            <div class="col-md-5 pad-l-r-0 border-left">
                                                                <div class="row mar-l-r-0">
                                                                    <div class="col-md-12 pad-l-r-0">

                                                                        <div class="form-group checkbox override-from-group-margin" style="padding-bottom: 3px;margin:0px;">
                                                                            <a class="btn btn-sm @btnType @disabled full-width-100perc same-cat @buttonClass custom-btn" id="popup-for-room-allocation-@item.Id" name="popup-for-room-allocation-@item.Id">
                                                                                <img src="@btnImage" alt="" style="border: 1px solid #dddddd;padding: 3px;cursor:pointer;" />
                                                                            </a>
                                                                            @*@buttonText*@
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                </div>
                            </div>
