    //------------------------------------------------------------------------------------------------
    function FillCustomerProfile(guestProfileId) {

        $.ajax({
            url: '/reservation/ReservationList/getguestdetails',
            dataType: 'html',
            method: 'POST',
            data: { id: guestProfileId },
            success: function (response) {

                $('#dataGuestProfileForm').html('').fadeOut();
                $('#dataGuestProfileForm').html(response).fadeIn();
            },
            error: function (error) {

            }
        });
    }
    //--------------------------------------------------------------------------------------------------
</script>

