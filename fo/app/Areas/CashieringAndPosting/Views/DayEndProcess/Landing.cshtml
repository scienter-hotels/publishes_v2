                                                                    <td>@item.Guest</td>
                                                                    <td>@item.Arrival.ToString("dd/MM/yyyy")</td>
                                                                    <td>@item.Departure.ToString("dd/MM/yyyy")</td>
                                                                    <td>@item.Category</td>
                                                                    <td>@item.RoomType</td>
                                                                    <td>@item.MealPlan</td>
                                                                    <td>@item.CurrencyCode</td>
                                                                    <td>
                                                                        @if (item.IsBillPaymentFromLKR)
                                                                        {
                                                                            if (item.IsDisable)
                                                                            {
                                                                                <input type="checkbox" disabled checked class="checkbox isBillPaymentFromLKR" value="@item.ReservationNo">
                                                                            }
                                                                            else
                                                                            {
                                                                                <input type="checkbox" checked class="checkbox isBillPaymentFromLKR" value="@item.ReservationNo">
                                                                            }

                                                                        }
                                                                        else
                                                                        {
                                                                            if (item.IsDisable)
                                                                            {
                                                                                <input type="checkbox" disabled class="checkbox isBillPaymentFromLKR" value="@item.ReservationNo">
                                                                            }
                                                                            else
                                                                            {
                                                                                <input type="checkbox" class="checkbox isBillPaymentFromLKR" value="@item.ReservationNo">
                                                                            }
                                                                        }
                                                                    </td>
                                                                    <td class="text-right">@item.ConvertionRate.ToString("#,###.00")</td>
                                                                    <td class="text-right">@item.OriginalRate.ToString("#,###.00")</td>
                                                                    <td class="text-right">@item.RoomRate.ToString("#,###.00")</td>

                                                                    <td>
                                                                        <input type="checkbox" style="width:20px; height:20px; margin-top: 20px;" />
                                                                    </td>

                                                                </tr>
                                                            }
                                                        </table>

                                                    </div>

                                                }
                                                else
