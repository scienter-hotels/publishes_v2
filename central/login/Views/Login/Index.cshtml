            <div class="card" style="margin-top:70px; border-radius:0px">
                <div class="card-header card-header-icon" style="padding-bottom:5px;border-radius:0px">
                    <div class="row">
                        <div class="col-md-12" style="padding-top:11px; text-align:right;">
                            <span href="http://www.scienter.lk" target="_blank">
                                <img src="~/Images/destinity-horizon-logo-full.png" width="280" class="img-responsive" style="margin-top:5px; margin-bottom:5px;" />
                            </span>
                        </div>
                    </div>
                </div>
                <div class="login-card-min-height card-content">
                    <form method="post" style="margin-bottom:5px;">
                        <input type="hidden" name="Id" id="id" />
                        <input type="hidden" name="IpAddress" id="Ipaddress" />
                        <div class="form-group label-floating  ">
                            <label class="control-label">Username</label>
                            <input type="text" class="form-control" name="UserName" id="username" autocomplete="off" required>
                            <span class="material-input"></span>
                        </div>
                        <div class="form-group label-floating ">
                            <label class="control-label">Password</label>
                            <input type="password" class="form-control" name="Password" id="password" autocomplete="off" required>
                            <span class="material-input"></span>
                        </div>
                        <div class="form-group checkbox" style="margin-top:10px;">
                            <label>
                                <input type="checkbox" value="true" name="RememberMe" /> Keep Login
                            </label>
                        </div>
                        <div class="form-group row" style="margin-top:0px;">
                            <button id="submit" type="submit" class="btn btn-fill btn-primary" style="border-radius:0px;width:100%;">Submit</button>
                        </div>

                    </form>

                    <fieldset class="the-fieldset" style="padding:20px 10px;">
                        <legend class="the-legend">Microsoft Login</legend>
                        @{
                            if (Configs.GetAppSettingBoolValue("IsAzureEntraIDEnable"))
                            {
                                //if (!Request.IsAuthenticated)
                                //{
                        <div class="row">
                            <div class="col-md-12">
                                <a href="/Login/SignIn" class="btn btn-primary" style="background-color:#000 !important;color:#fff; text-decoration: none; margin-left:0px;width:100%; display: flex; align-items: center;justify-content:center;">
