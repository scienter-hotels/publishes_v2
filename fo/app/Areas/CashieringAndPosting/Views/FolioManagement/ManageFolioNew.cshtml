            dataType: 'json',
            data: { RoomNo: roomNo, ReservationHeaderId: reservationHeaderId },
            success: function (data) {
                $('.btn-folio-numbers').html('')
                $.each(data, function (index, item) {
                    $('.btn-folio-numbers').append('<div value="' + item.FolioNo + '"  id="' + item.FolioNo + '" class="well-height well col-md-11  folio-btn"  style="cursor:pointer; margin-bottom:5px !important; padding-left:5px !important; width:100% !important; padding-right:5px !important; background-color: #57606f  !important; color:#ffffff; padding:8px; min-height:60px;">'
                        + '<div class="ribbon hidden" style="position:absolute;"><span style="width:80px !important; top:12px !important; right:-19px !important; background-color:#850272 !important" >selected</span></div>'
                        + '<div class="col-md-3 res-this-folio-no" style="color:#f1c40f; font-size:30px; padding:4px 20px 0px 5px !important;"><b>' + item.FolioNo + '</b></div>'
                        + '<input type="hidden" class="hidden-folio-header-Id" value="' + item.FolioHeaderID + '">'
                        + '<div class="col-md-6" style="text-align:left; padding:0px 5px 0px 5px !important;">' + item.FolioCompanyName + '</div>'
                        + '</div>');
                });


                // $($('.folio-btn')[0]).click();
            }
        });
    }

