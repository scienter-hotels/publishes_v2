@{
    ViewBag.Title = "Company Wise Rate Codes";
}

        
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header" data-background-color="purple">
                        <div class="row">
                            <div class="col-md-8">
                                <h4 class="title">@ViewBag.Title
                                <hr class="visible-print" />
                                </h4>  
                            </div>
                            <div class="col-md-4 text-right hidden-print">
                                <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                                    <span class="glyphicon glyphicon-plus"></span>
                                </button>

                                <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                                    <span class="glyphicon glyphicon-th-list"></span>
                                </button>
                                
                            </div>
                        </div>                                          
                    </div>
                    <div class="card-content" id="contentLoadingArea">
                        <div id="content">
                        
                        </div>
                        @Html.Partial("_Loading")
                    </div>
                </div>
            </div>
        </div>

    <script src="~/Scripts/ui/common/scienter.grid2.js"></script>
    <script>
        var companyId=0;
         // form load --------------------------------
        $(document).ready(function () {
             companyId = GetParameterValues("companyId");
           
            if (companyId != 0) {
                $('.showForm').click();

            } else {
                FillGrid();
            }
        });

        // show form --------------------------------
        $('body').on('click', '.showForm', function (e) {      
            $.ajax({
                url: '/administration/companywiseratecodes/form',
                dataType: 'html',        
                method: 'POST',                
                success: function (response) {
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                    $('#CompanyId').val(companyId);
                    $('#CompanyId').change();
                }
                
            });
        });

        // show grid --------------------------------

        $('body').on('click', '.showGrid', function (e) {
            FillGrid();
        });
        

        // save --------------------------------------
        $('body').on('submit', '#companyWiseRateCodes', function (e) {
           
            var RateCodeArray = [];
            $('.data-selected-rate-codes').each(function (index, item) {
                if ($(this).is(':checked')) {
                    RateCodeArray.push(
                       $(this).val()
                    );
                }
            });

            e.preventDefault();         
            var companyWiseRateCode = {
                __RequestVerificationToken: $('__RequestVerificationToken').val(),
                CompanyId: $('#CompanyId').val(),               
                SelectedRateCodeIds: RateCodeArray
            };
           
            if (companyWiseRateCode.SelectedRateCodeIds.length == 0) {
                ShowErrorMessage('Please select a RateCode.');
            }
            else {

                $.ajax({
                    url: '/administration/companywiseratecodes/save',
                    dataType: 'html',
                    data: companyWiseRateCode,
                    method: 'POST',
                    success: function (response) {

                        ShowSuccessMessage('Record has been saved successfully.');
                        FillGrid();
                    }


                });
            }
        });


        // fill grid -----------------------------------
        function FillGrid() {
            var gridId = "#existingCompanyWiseRateCodeGrid"; // change this - relevent grid id
            var paginations = {                                
                PageIndex: $(gridId).attr('data-page-index'),
                PageSize: $(gridId).attr('data-page-size'),
                FilterType: $(gridId).attr('data-filter-type'),
                SearchKeyword: $(gridId).attr('data-search-keyword') 
            }
            $.ajax({
                url: '/administration/companywiseratecodes/selectforgrid',
                dataType: 'html',
                data: paginations,
                method: 'POST',
                success: function (response) {
                    if ($('.grid-container').length > 0) {
                        $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                        $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                    } else {
                        $('#contentLoadingArea #content').html('').fadeOut();
                        $('#contentLoadingArea #content').html(response).fadeIn();
                    }
                 
                }
               
            });
        }

    </script>

