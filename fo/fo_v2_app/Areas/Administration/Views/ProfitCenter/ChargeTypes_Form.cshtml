@model Scienter.HotelERP.Common.Domain.ProfitCenterChargeType

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="ProfitCenterChargeType">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />
            <input type="hidden" value="@Model.ProfitCenterId" name="Id" id="hdn-ProfitCenterId" />
            <input type="hidden" value="@Model.CategoryId" name="Id" id="hdn-CategoryId" />

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group label-floating">
                        <label class="control-label">Profit Centers</label>
                        <select name="ProfitCenters" id="ProfitCenterId" class="form-control Profit-Centers" required></select>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Item Category</label>
                        <select name="ItemCategory" id="ItemCategoryId" class="form-control ItemCategory" required></select>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>

                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            @*<input type="checkbox" checked name="IsActive" value="True" />*@ Is Active
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
<script>
    // form load --------------------------------
    $(document).ready(function () {
        debugger;
        setTimeout(function () {
            LoadProfitCenterCombo();
        }, 1000);

        setTimeout(function () {
            let profitCenterId = $('#ProfitCenterId').val();
            profitCenterChange(profitCenterId);
        }, 500);
    });

    $('#ProfitCenterId').change(function () {
        debugger;
        let profitCenterId = $('#ProfitCenterId').val();
        profitCenterChange(profitCenterId);
    });

    function profitCenterChange(profitCenterId) {
        debugger;
        $.ajax({
            url: '/Administration/ProfitCenter/Select_ProfitCenterWise_ItemCategory_ForCombo?ProfitCenterId=' + profitCenterId,
            dataType: 'json',
            method: 'POST',
            //data: { ProfitCenterId: profitCenterId },

            success: function (modules) {
                if ($('.Profit-Centers').length > 0) {
                    $(".ItemCategory").empty();
                    //$(".ItemCategory").append('<Option>---Select---</Option>');

                    $.each(modules, function (index, type) {
                        $(' <option value="' + type.CategoryId + '"> ' + type.CategoryName + ' </option>').appendTo($('#ItemCategoryId'));
                        console.log(index);
                    });
                }
            },
            complete: function () {
                debugger;
                $('#ItemCategoryId').val($('#hdn-CategoryId').val());

            }
        });
    }

    function LoadProfitCenterCombo() {
        debugger;
        $.ajax({
            url: '/administration/profitCenter/Select_ProfitCenter_ForCombo',
            dataType: 'json',
            success: function (modules) {
                if ($('#ProfitCenterId').length > 0) {
                    $('#ProfitCenterId option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $('<option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#ProfitCenterId'));
                    });
                }
            },
            complete: function () {
                debugger;
                $('#ProfitCenterId').val($('#hdn-ProfitCenterId').val());
            }
        });
    }


</script>
