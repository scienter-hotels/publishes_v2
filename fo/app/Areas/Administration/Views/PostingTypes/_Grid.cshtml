@model IEnumerable<Scienter.HotelERP.Common.Domain.PostingType>

@{
    ViewBag.Title = "Segments";
}

<div class="table-responsive grid-container">
    <table class="table table-striped"
           id="existingPostingCategoryGrid">
        <thead>
            <tr>
                <th class="text-primary">
                    @Html.DisplayNameFor(model => model.Name)
                </th>

                <th class="text-primary">
                    Fiscal Code
                </th>

                <th class="col-md-1 text-primary">
                    Active
                </th>
                <th class="col-md-1 hidden-print"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.PostingwiseCurrencyJson)
                </td>
                <td class="col-md-1">
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsActive)
                            <span class="hidden">
                                @if (item.IsActive)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>
                </td>
                <td class="hidden-print text-right">
                    @*<a class="btn btn-theme-color-2 btn-sm call-popup-model" id="btnPrint" data-title="Posting Category - @item.Name" data-href="/administration/postingcategories/print/@item.Id">
                <span class="glyphicon glyphicon-print"></span>
            </a>*@

                    @*<a class="btn btn-theme-color-2 btn-sm btnEdit" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" data-id="@item.Id" href="/administration/postingtypes/edit/@item.Id">
                <span class="glyphicon glyphicon-pencil"></span>
            </a>*@
                    <button type="button" class="btn btn-theme-color-2 btn-sm btnEdit" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" data-id="@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </button>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/postingtypes/delete/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>
<script>
    $(document).ready(function () {
        $('#existingPostingCategoryGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                            'copy',
                            'excel',
                            'csv',
                            'pdf',
                            'print'
                ],
                scrollY: '58vh',
            } );
    });
</script>
