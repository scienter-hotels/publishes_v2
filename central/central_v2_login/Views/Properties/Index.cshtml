<input type="hidden" id="hdnEntraID" value="@ViewBag.Name" />

<script src="~/Scripts/jquery-3.2.1.min.js"></script>

<script>
    $(document).ready(function () {
        var EntraIDUserName = $('#hdnEntraID').val();
        localStorage.setItem('EntraIDUserName', EntraIDUserName);
        $.ajax({
            url: '/Properties/SelectUserWisePropertys',
            dataType: 'Json',
            method: 'GET',
            success: function (data) {
                debugger;
                $.each(data, function (index, item) {
                    $('#PropertyDiv').append('<li><span>' + item.Name +'</span><a href="#"><div class="property-select"><img id="companyName" data-propertyId="' + item.Id + '"  alt=""   src= "' + item.Images + '" /></div></a></li>');
                })
                //$.each(data, function (index, item) {
                //    $('#PropertyDiv').append('<div class="col-md-4 property-select"><image id="companyName" data-propertyId="' + item.Id + '"  alt=""   src= "' + item.Images + '" ></image></div>');
                //})
            },
            error: function () {
                ShowWarningMessage('Sorry, There is an error.');
            }

        });
        PasswordTerminationRemainder();
    });


    function PasswordTerminationRemainder() {
        $.ajax({
            url: "/Properties/PasswordTerminationRemainder",
            type: "GET",
            dataType: "json",
            success: function (data) {

                if (data.startsWith("ERR-")) {
                    alert(data.replace("ERR-", ""));

                }
            }
        });
    }

    $('body').on('click', '.property-select', function () {
        debugger;
        var propertyId = $($(this).find('#companyName')).data('propertyid');
        //window.location.href = '/Modules/Index';

        if (propertyId != 0) {

            $.ajax({
                url: '/Properties/PropertyAssign?PropertyId=' + propertyId,
                dataType: 'json',
                success: function (properties) {
                    debugger;
                    window.location.href = '/modules/index/';
                },
            });

        } else {
            ShowWarningMessage('Please Select Property to Proceed!');
        }
    });

</script>


