    function LoadComplimentaryReasons(reservationType) {

        $.ajax({
            method: 'GET',
            url: '/Reservation/Reservations/SelectReservationTypeWiseComplimentaryReasons?type=' + reservationType,
            datatype: 'json',
            success: function (data) {
                $('#complimentary-reason-id').html('');
                $('#complimentary-reason-id').append('<option value="0"> Select a reason </option>')
                $.each(data, function (index, item) {
                    $('#complimentary-reason-id').append('<option value="' + item.Id + '"> ' + item.Name + ' </option>')
                })
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in getting records.');
            }
        });
    }

    $('body').on('click', '.save-reservation-type-change', function () {
        var dates = [];
        var IsRemovedComplimentary = 0

        $.each($('.data-not-disabled-checkboxes'), function (index, checkbox) {
            dates.push({
                Sceduledate: $(checkbox).val(),
                IsDateChecked: $(checkbox).prop('checked')
            });
        });

        $.each($('.data-not-disabled-checkboxes'), function (index, checkbox) {
            if ($(this).prop('checked')) {
                //IsRemovedComplimentary = 0;
            } else {
                IsRemovedComplimentary = 1;
            }
        });

        selectedReservationHeaderIds = [];

        $('.checbox-item').each(function (index, date) {

            if ($(this).prop('checked')) {
                selectedReservationHeaderIds.push({
                    ReservationHeaderId: $(this).val()
                });
            }
        });

        console.log(selectedReservationHeaderIds);

        var reservationTypeChangeObj = {
            ReservationHeaderId: $('.data-reservationHeaderId').val(),
            ReservationDates: dates,
            ReservationTypeId: $('.data-ReservationTypeId').val(),
            ReasonId: $('#complimentary-reason-id').val(),
            Remarks: $('#complimentary-remark').val(),
            //SelectedReservationHeaderIds: JSON.stringify(selectedReservationHeaderIds)
            SelectedReservationHeaderIds: selectedReservationHeaderIds
        }
        console.log(reservationTypeChangeObj);
        $.ajax({
            url: '/Reservation/Reservations/SaveReservationTypeChange',
            method: 'POST',
            dataType: 'JSON',
            data: { reservationTypeChange: reservationTypeChangeObj },
            success: function (data) {
                var Type = $('#resType').val();
                if (data == 'success') {
                    if (IsRemovedComplimentary == 1) {
                        ShowSuccessMessage('Complimentary Removed, Please update the rates using manage folio.')
                    } else {
                        ShowSuccessMessage('Complimentary changed.')
                    }
                    setTimeout(function () {
                        if (Type == "reservation") {
                            //Update Uuid
                            //window.location.href = "/reservation/reservations/list/" + $('#hidden-Uuid').val();
                            //console.log("Uuid");

                            LoadInhouseReservationGrid();

                        } else {
                            //location.reload()
                            LoadInhouseReservationGrid();
                        }
                    }, 2000);
                } else {
                    ShowErrorMessage(data.split('-')[1])
                }
            },

        })

    })

