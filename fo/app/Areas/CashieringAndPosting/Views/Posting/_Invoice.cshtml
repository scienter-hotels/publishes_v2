            <div class="row">
                <div class="btn-margin">

                    <div class="col-md-10">
                        @if ((ViewBag.postingType == "walkin"))
                        {
                            <button class="btn btn-primary disabled hidden-print" id="btnbillpayment" data-title="Bill-Payment Posting" style="width:100%;">
