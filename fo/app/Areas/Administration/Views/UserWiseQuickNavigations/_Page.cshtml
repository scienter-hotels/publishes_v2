@model  List<Scienter.HotelERP.Common.Domain.ViewModels.UserWiseQuickNavigationView>

    <div class="table-responsive">
        <input type="hidden" Id="areasId" value="@Model.FirstOrDefault().AreaId" />
        <table class="table table-striped " id="UserPages">
            <tr>
                <th class="col-md-8 text-primary">
                    Page
                </th>
                <th class="col-md-2 text-primary">
                    Order
                </th>
                <th class="col-md-2 text-primary">
                    Visibility
                </th>
            </tr>
        </table>
            
        <div class="div-scroll" style="height:450px !important; border-top:1px #808080 solid; margin-top:5px;">
            
            <table class="table table-striped " id="UserPages">
                @foreach (var item in Model)
                {

                    <tr class="pagesDetails">
                        <td  class="col-md-8">
                            <h5><strong>@item.Page</strong></h5>

                            <input type="hidden" Id="pagesId" value="@item.PageId" />
                        </td>
                        <td class="col-md-2">
                            <input type="number" name="displayOrder" class="form-control displayOrder" value="@item.Order" />
                        </td>
                        <td class="col-md-2">
                            <div class="form-group checkbox">
                                @{
                                    string chk = "";
                                    if (item.IsActive)
                                    {
                                        chk = "checked";
                                    }
                                }
                                <label>
                                    <input type="checkbox" name="IsActive" id="IsActive" @chk />
                                </label>
                            </div>
                        </td>
                    </tr>
                 }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="3">NO RECORDS FOUND.</td></tr>
                }
            </table>
        </div>
    
  </div>                             

<button class="btn btn-primary btn-theme-color-2" id="pageSaveBtn">Save Pages</button>
    
