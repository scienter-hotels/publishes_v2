                //});
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error loading existing setups.');
            }
        });
    };

    //Preference Tab
    function FillOtherFolioDetails() {

        $.ajax({
            url: '/Administration/GuestHistory/LoadGuestExtraPosting?GuestProfileId=' + guestid,
            dataType: 'HTML',
            method: 'POST',
            beforeSend: function () {
                $('#pref .loader-load').show();
                $('#pref .show-hide').hide();
            },
            success: function (data) {

                $('#pref .loader-load').hide();
                $('#pref .show-hide').show();
                $('.data-row').remove();

                var preferences = JSON.parse(data);

                if (preferences.length != 0) {

                    $('.data-row-x').remove();
                    $(preferences).each(function (index, item) {
                        $(
                            '<tr class="data-row-x">' +
                            '<td><span>' + item.ItemName + '</span></td>' +
                            '<td style="text-align:right; width:60%;"><span>' + item.Quantity + '</span></td>' +
                            '</tr>'
                        ).appendTo('#existingFolioDetails');

                    })
                }
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error loading existing setups.');
            }
        });
    }

    //Allergies Tab
    function FillAllergies() {
        $.ajax({
            url: '/Administration/GuestHistory/GuestAlergic?GuestProfileId=' + guestid,
            dataType: 'HTML',
            method: 'POST',
            beforeSend: function () {
                $('#alg .loader-load').show();
                $('#alg .show-hide').hide();
            },
            success: function (data) {
                $('#alg .loader-load').hide();
                $('#alg .show-hide').show();
                $('.data-row').remove();

                var allergies = JSON.parse(data);

                if (allergies.length != 0) {

                    $(allergies).each(function (index, item) {


                        $('.data-row-a').remove();
                        $(
