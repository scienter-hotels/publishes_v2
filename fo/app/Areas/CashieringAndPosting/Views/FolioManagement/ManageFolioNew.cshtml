<script>
    // form load --------------------------------
    var reservationHeaderId;
    $(document).ready(function () {
        $('#imgLoadingPot').hide();
        //global var

        var selectedFolioNumber;
        var taxGroupIdArray = []
        var chargersAmountArray = []
        var SelectedFolioNumber = 0;
        var roomNo
        var ResID
        var selectedRoom
        var orderno;
        var reservationNo;

        setInterval(function () {
            $('.room-list-btn').css('background-color', '#000');
            $('.room-list-btn').each(function (index, item) {
                if ($(item).val() == $('.res-room-no').html()) {

                    $(item).css('background-color', '#094F70');
                }
            });
        }, 200);

        if ($('#grid-record-detail-model-close').hasClass('folio-settle-refresh') == true) {
            $('#grid-record-detail-model-close').removeClass('folio-settle-refresh');
        };
    });

    var lastSelectedRoom = '';

    //Load Reservations [1]
    $.ajax({
        url: '/CashieringAndPosting/FolioManagement/ReservationList',
        dataType: 'json',
