<style>
    .success-color {
        background-color: #4caf50 !important;
        border: none;
        color: #fff !important;
    }

    .connect-color {
        background-color: #ff9800 !important;
        color: #fff !important;
    }

    .failure-color {
        background-color: #bd0000 !important;
        color: #fff !important;
    }
</style>

