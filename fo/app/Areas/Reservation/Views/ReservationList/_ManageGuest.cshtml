
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    .form-group {
        margin-top: 15px;
    }
</style>

<input type="hidden" id="ReservationNumber" value="@ViewBag.reservationNumber" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />
<input type="hidden" id="roomNo" value="@ViewBag.roomNo" />
<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />
<input type="hidden" id="Path" class="Path" value="@ViewBag.Path" />

<div class="row">
    <div class="col-md-12">
        <fieldset class="the-fieldset padding-margin-bottom-override" style="padding-top:0px; padding-bottom:0px;">
            <legend class="the-legend">
                Guests Details
            </legend>
            <div class="col-md-12" style="padding:0;">
                <button type="button" id="AddToggle" data-toggle="collapse" data-target="#addGuestDiv" class="btn btn-sm theme-bg-color-2 pull-right" style="margin: 5px 0 15px 0;">
                    <span class="glyphicon glyphicon-plus"></span> Add New Guest
                </button>
                <div id="ExistingGuestProfiles">
                    @Html.Partial("_Loading")
                </div>
            </div>
        </fieldset>
    </div>
</div>

<div class="row collapse" id="addGuestDiv" style="margin-bottom:20px;">

    <div class="col-md-12">
        <input type="hidden" class="reservationNo" id="reservationNo" value="@ViewBag.reservationHeaderId" />
        <div class="col-md-12">
            @{Html.RenderAction("GuestProfile", "ReservationList");}
        </div>
    </div>

    <div class="col-md-6 col-md-offset-4">
        <div class="form-group label-floating">
            <label class="control-label">Guest Profile Type</label>
            @{Html.RenderAction("GuestProfileTypesCombo", "GuestProfileType", new { area = "Administration", name = "GuestProfileTypeId", requiered = true });}
        </div>
    </div>

    <div class="text-right col-md-2" style="padding: 20px 15px 0 0;">
        <button type="button" id="btnNewGuest" class="btn btn-primary btnNewGuest"> Add</button>
    </div>
</div>

<div class="row hidden" style="margin-bottom: 15px;" id="guest-detail-with-allergies">
    <div class="col-md-12">

        <ul class="nav nav-tabs" id="guestAllergyTabs">
            <li class="active">
                <a href="javascript:;" class="tab-link" data-target="#guestSection">
                    Guest Profile
                </a>
            </li>
            <li>
                <a href="javascript:;" class="tab-link" data-target="#allergySection">
                    Allergies
                </a>
            </li>
        </ul>

    </div>
</div>

<div id="guestSection" class="tab-section">

    <div class="collapse" id="editGuestDiv">
        <div class="row">
            <div class="col-md-12">
                <fieldset class="the-fieldset padding-margin-bottom-override" style="padding-top:0px; padding-bottom:0px;">
                    <legend class="the-legend">Edit Guest Profile</legend>
                    <div id="guestProfileContainer">
                        @Html.Partial("_Loading")
                    </div>
                </fieldset>
            </div>
        </div>
    </div>

</div> <!-- end guestSection -->

<div id="allergySection" class="tab-section" style="display:none;">

    <div class="collapse" id="editAllergyDiv">
        <div class="row">
            <div class="col-md-12">
                <fieldset class="the-fieldset padding-margin-bottom-override" style="padding-top:0px; padding-bottom:0px;">
                    <legend class="the-legend">Edit Allergies</legend>

                        <div id="predefinedAllergiesContainer" class="row">
                            @* Predefined allergies (with checkboxes) will be loaded here via jQuery *@
                        </div>

                    <hr />

                    <div class="text-right" style="margin-top:10px;">
                        <button type="button" id="btnSaveAllergies" class="btn btn-primary btn-sm">
                            <i class="fa fa-save"></i> Save Allergies
                        </button>
                    </div>

                </fieldset>
            </div>
        </div>
    </div>

</div>

