@model List<Scienter.HotelERP.Common.Domain.AllotmentDetails>

<style>
    element.style {
        width: 800px;
    }
</style>

<input type="hidden" id="ReservationHeaderIdForAllotment" value="@ViewBag.ReservationHeaderId" />
<input type="hidden" id="roomCategoryIdForAllotment" value="@ViewBag.roomCategoryId" />
<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />

<form id="allotmentDetailList">
    <div class="row">
        <div class="col-md-12">
            <fieldset class="the-fieldset">
                <legend class="the-legend"><font size="2"></font> Allotment Details</legend>
                <div id="AllotmentList" overflow-x:hidden; overflow-y:scroll;">
                    @if (Model.Count > 0)
                    {
                        <input type="hidden" id="AllotmentHeader" name="AllotmentHeader" value="@Model.FirstOrDefault().AllotmentHeaderId">
                        <input type="hidden" id="RoomCategory" name="RoomCategory" value="@Model.FirstOrDefault().RoomCategoryId">
                        <input type="hidden" id="ReservationRoomCategoryId" name="ReservationRoomCategoryId" value="@Model.FirstOrDefault().ReservationRoomCategoryId">
                        <input type="hidden" id="Model" name="Model" value="@Model">
                    }
                    else
                    {

                    }

                    <table class="table table-striped">
                        <tr>
                            <th>Allotment</th>
                            <th>Room Category</th>
                            <th>Tot.</th>
                            <th>Balance</th>
                            <th hidden></th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            if (Model.Count > 0)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td>@item.RoomCategoryName</td>
                                    <td>@item.NoOfRooms</td>
                                    <td>@item.RoomBalance</td>
                                    <td hidden>
                                        @if (item.IsAlreadyAttachedAllotment)
                                        {
                                            if (item.ReservationRoomCategoryId == item.RoomCategoryId)
                                            {
                                                <button class="btn btn-sm btn-danger btn-remove-allotment" RoomCategoryId="@item.RoomCategoryId" AllotmentHeaderId="@item.AllotmentHeaderId">Remove</button>
                                            }
                                        }
                                        else
                                        {
                                            if (item.RoomBalance <= 0 || item.ReservationRoomCategoryId != item.RoomCategoryId)
                                            {
                                                <button class="btn btn-sm btn-primary" style="text-decoration:line-through">Apply</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-primary btn-apply-allotment" RoomCategoryId="@item.RoomCategoryId" AllotmentHeaderId="@item.AllotmentHeaderId">Apply</button>
                                            }
                                        }

                                    </td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            </fieldset>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <fieldset class="the-fieldset">
                <legend class="the-legend"><font size="2"></font> Reservation Details </legend>
                <div id="ReservationList" overflow-x:hidden; overflow-y:scroll;">
                    <table class="table table-striped table-hover" id="reservationGridForAllotment" cellspacing="5">
                        <tr class="data-single-record">
                            <th><div><div class="form-group checkbox"><label><input type="checkbox" id="isAll" class="isAll" /></label></div></div></th>
                            <th class="text-primary " input type="text">
                                Reservation No
                            </th>
                            <th class="text-primary " input type="text">
                                Group Reservation No
                            </th>
                            <th class="text-primary " input type="text">
                                Company
                            </th>
                            <th class="text-primary " input type="text">
                                Market
                            </th>
                            <th class="text-primary " input type="text">
                                
                            </th>
                        </tr>
                    </table>
                    @*<div><div class="form-group checkbox"><label><input type="checkbox" id="isAll" class="isAll" /> Select All</label></div></div>*@
                </div>
            </fieldset>
        </div>
    </div>
    @if (Model.Count > 0)
    {
        if (Model.FirstOrDefault().IsAlreadyAttachedAllotment)
        {
            if (Model.FirstOrDefault().ReservationRoomCategoryId == Model.FirstOrDefault().RoomCategoryId)
            {
                <button class="btn btn-sm btn-danger btn-remove-allotment" style="visibility:hidden;" disabled RoomCategoryId="@Model.FirstOrDefault().RoomCategoryId" AllotmentHeaderId="@Model.FirstOrDefault().AllotmentHeaderId">Remove</button>
            }
        }
        else
        {
            if (Model.FirstOrDefault().RoomBalance <= 0 || Model.FirstOrDefault().ReservationRoomCategoryId != Model.FirstOrDefault().RoomCategoryId)
            {
                <button class="btn btn-sm btn-primary" style="text-decoration:line-through">Apply</button>
            }
            else
            {
                <button class="btn btn-sm btn-primary btn-apply-allotment" RoomCategoryId="@Model.FirstOrDefault().RoomCategoryId" AllotmentHeaderId="@Model.FirstOrDefault().AllotmentHeaderId">Apply</button>
            }
        }

    }
    else
    {
        <button class="btn btn-sm btn-primary" style="text-decoration:line-through">Apply</button>
    }
</form>

    <script>
        $(document).ready(function () {
            LoadReservationList();
        });

