@model  IEnumerable<Scienter.HotelERP.Common.Domain.ViewModels.ReservationHeaderView>

<table class="table table-striped table-hover" id="listWithFilterationGrid" cellspacing="5">
    <tr>
        <th class="text-primary " input type="text" width="150px">
            Stay
        </th>
        <th class="text-primary " input type="text">
            Res.#
        </th>
        <th class="text-primary " input type="text">
            Guest
        </th>
        <th class="text-primary " input type="text">
            Company
        </th>
        <th class="text-primary " input type="text">
            Cat.
        </th>
        <th class="text-primary " input type="text">
            Type
        </th>
        <th class="text-primary " input type="text">
            Basis
        </th>
        <th class="text-primary " input type="text">
            Room
        </th>
        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr class="data-single-filteration">
            <td>
                @item.ArrivalDate - @item.DepartureDate
            </td>
            <td>
                @item.ReservationNo
            </td>
            <td>
                @item.GuestName
            </td>
            <td>
                @item.AgentName
            </td>
            <td>
                @item.RoomCat
            </td>
            <td>
                @item.RoomType
            </td>
            <td>
                @item.MealPlanName
            </td>
            <td>
                @item.RoomNo
            </td>
            <td style="margin-right:0.2em">
                <div class="form-list checkbox">
                    <label>
                        <input class="list-checkBox chkSelectReservation" type="checkbox" value="@item.Id" data-room-category="@item.RoomCat" />
                    </label>
                </div>
            </td>
        </tr>
    }
</table>