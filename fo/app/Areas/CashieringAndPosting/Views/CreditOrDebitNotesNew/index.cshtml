    //----------------------------Step 01----------------------------------------------------
    $(".btn-SearchKeyWord").click(function () {
        //debugger;
        let searchKeyWord = $('#searchKeyWord').val();
        if (searchKeyWord.length==0) {
            ShowWarningMessage("Please enter reservation no or invoice no..!");
        }
        $('.all-transaction').html('')

        $("#DetailsTB").show();
        LoadBillSettlementDetails(searchKeyWord);
    });

    function LoadBillSettlementDetails(searchKeyWord) {
        $('#imgLoadingPot').show();
        $('#tblDetails .data-row').remove();
        
        $.ajax({
            url: '/CashieringAndPosting/CreditOrDebitNotesNew/SelectDetailsByReservationOrInvoiceNo',
            method: 'POST',
            data: { SearchKeyWord: searchKeyWord },
            beforeSend: function () {
                $('.all-transaction tr').remove();
                $('#imgLoadingPot').show();
            },
            success: function (response) {
                $(response).each(function (index, item) {
                    $('<tr class="data-row">' +
                        '<td>' + item.ReservationNo + '</td>' +
                        '<td>' + item.InvoiceNo + '</td>' +
                        '<td>' + item.PaymentType + '</td>' +
                        //'<td>' + item.PaidAmount.toFixed(2) + item.Currency+ '</th > ' +
                        '<td>' + item.PaidAmount.toFixed(2)+ '</td> ' +
                        '<td>' + item.Currency + '</td>' +
                        '<td>' +
                        '<button type="button" id="btnInvoiceNo" data-InvoiceNo="' + item.InvoiceNo + '" class="btn btn-primary btnInvoiceNo">Select <span class="glyphicon glyphicon-list-alt"</span>' +
                        '</button>' +
                        '</td>' +
                        '</tr>').appendTo('#tblDetails');
                });
            },
            error: function () {
                alert('There is an Error');
            },
            complete: function () {
                $('#imgLoadingPot').hide();
            }
        });
    };


    $('body').on('click', '#btnInvoiceNo', function () {
        //debugger;
        var inNo = $(this).attr('data-InvoiceNo');
        var url = '/CashieringAndPosting/CreditOrDebitNotesNew/Grid_FoliDetails?InvoiceNo=' + inNo;
        CallDetailModelSimple('Credit Or Debit Notes Folio Details', url,900);
    });
