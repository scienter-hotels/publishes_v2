    var reservationLevel = $('#customSelect').val();
    $(document).ready(function () {
        loadGridData()
        $('#hdnactionType').val($(this).attr('data-ActionTypeId'));
        $('#GuestPortalRoomRequest').DataTable(
            {
                searching: true,
                ordering: true,
                dom: 'frtipl',
                select: true,
                scrollY: '58vh',
            });
    });

    $(document).off('change').on('change', '#customSelect', function () {
        reservationLevel = $('#customSelect').val();
        loadGridData();
    });

    function loadGridData() {
        var rows = $('#GuestPortalRoomRequest tr');
        var noRecords = true;

        if (reservationLevel !== "A") {
            rows.each(function () {
                var reservationLevelTr = $(this).data('reservation_level');
                if (reservationLevel !== reservationLevelTr) {
                    $(this).hide();
                } else {
                    $(this).show();
                    noRecords = false;
                }
            });

            if (noRecords) {
                $('#GuestPortalRoomRequest tbody').append('<tr class="no-records"><td colspan="100%" style="text-align:center;">No Records Found</td></tr>');
            } else {
                $('#GuestPortalRoomRequest .no-records').remove();
            }
        } else {
            rows.show();
            $('#GuestPortalRoomRequest .no-records').remove();
        }
    }

