    function LoadCompaniesInMakeReservationOtherDetails() {
        var dataJson = localStorage.getItem("Companies");
        var data = JSON.parse(dataJson);
        $('#CompanyId option').remove();
        $('#CompanyId').append('<option value="" disabled selected></option>');
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" data-IsBillPaymentFromLKR="' + item.IsBillPaymentFromLKR + '" data-IsCreditEnable="' + item.IsCreditEnabled + '" data-allowCreditPosting="' + item.AllowCreditPosting + '"  data-Address="' + item.Address + '" data-Name="' + item.Name + '" data-FIT="' + item.FITProfile + '">' + item.Name + '</option>').appendTo($('#CompanyId'));
        });
        //$('#CompanyId').val($('#CompanyId').attr('data-select-company'));
        LoadDropdownsStep3()
    }

    function LoadSalesPersonsInMakeReservationOtherDetails() {
        var dataJson = localStorage.getItem("SalesPersons");
        var data = JSON.parse(dataJson);
        $('#SalesPersonId option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#SalesPersonId'));
        });
    }

    function LoadPackageCategoriesInMakeReservationOtherDetails() {
        var dataJson = localStorage.getItem("PackageCategories");
        var data = JSON.parse(dataJson);
        var packageCatIdForALL = $('#PackageCategoryId').val();
        if (packageCatIdForALL==null) {
            packageCatIdForALL =0;
        }
       
        $('#PackageCategoryId option').remove();
        if (data != null) {
            $(data).each(function (index, item) {
                $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#PackageCategoryId'));
            });
        }
        else {
            $('<option value="' + packageCatIdForALL + '" selected>ALL</option>').appendTo($('#PackageCategoryId'));
            $('#PackageCategoryId').trigger('change');
        }
        
    }

    $('body').on('change', '#PackageCategoryId', function (e) {
        LoadPackageHeadersInMakeReservationOtherDetails();
    });



    function LoadPackageHeadersInMakeReservationOtherDetails() {
        //debugger;
        $.ajax({
            url: '/administration/packageheaders/SelectAllPackageHeadersByPackageCategoryId?packageCategoryId=' + $('#PackageCategoryId option:selected').val(),
            dataType: 'json',
            success: function (data) {
                if ($('#PackageHeaderId').length > 0) {
                    $('#PackageHeaderId').html('');
                    $.each(data, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#PackageHeaderId'));
                    });
                }
            },
            complete: function (data) {
              
            }
        });
    }

