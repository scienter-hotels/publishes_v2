@*@model Scienter.HotelERP.Common.Domain.GuestPortal_HotelPromotion*@
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>
<style>
    .custom-file {
        position: relative;
        display: inline-block;
        width: 100%;
        height: calc(2.25rem + 2px);
        margin-bottom: 0;
    }

    .custom-file-input {
        position: relative;
        z-index: 2;
        width: 100%;
        height: calc(2.25rem + 2px);
        margin: 0;
        opacity: 0;
    }

    .custom-file-label {
        position: absolute;
        top: 0;
        right: 0;
        left: 0;
        z-index: 1;
        height: calc(2.25rem + 2px);
        padding: .375rem .75rem;
        font-weight: 400;
        line-height: 1.5;
        color: #495057;
        background-color: #fff;
        border: 1px solid #ced4da;
        border-radius: .25rem;
    }
</style>

<div class="col-md-12">
    <form id="guestPortalPromotion" enctype="multipart/form-data">
        @*@Html.AntiForgeryToken()*@
        <div>
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-12">

                    <!-- Name -->
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Name *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="50" id="Name" name="Name" type="text" value="@Model.Name" required>
                        </div>
                    </div>
                    <!-- From Date -->
                    <div class="row">
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">From Date *</label>
                            <input type="text" class="form-control text-box single-line" id="FromDate" name="FromDate" placeholder="dd/mm/yyyy" required autocomplete="off" >
                        </div>

                        <!-- To Date -->
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">To Date *</label>
                            <input type="text" class="form-control text-box single-line" id="ToDate" name="ToDate" placeholder="dd/mm/yyyy" required autocomplete="off" >
                        </div>
                    </div>

                    <!-- Upload Image -->
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label d-block">Upload Image *</label>

                            <div class="custom-file">
                                <input class="form-control custom-file-input" id="ImageUrl2" name="ImageUrl2" type="file" accept="image/*">
                                <label class="form-control custom-file-label" for="ImageUrl2">Choose file...</label>
                            </div>

                            <small class="form-text text-muted">Allowed formats: JPG, PNG, GIF</small>
                        </div>
                    </div>

                    <!-- Image Preview -->
                    <div class="row">
                        <div class="col-md-5">
                            <div id="imagePreviewContainer" style="display:none; margin-top:10px;">
                                <label class="control-label">Preview:</label><br />
                                <img id="imagePreview" src="#" alt="Image Preview"
                                     style="max-width:100%; height:auto; border:1px solid #ccc; border-radius:8px; padding:5px;" />
                                <input type="hidden" name="ImageUrl" id="ImageUrl" value="@Model.FullImageURL" />
                            </div>
                        </div>
                    </div>


                    <!-- Alt Tag -->
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Alt Tag *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="AltTag" name="AltTag" type="text" value="@Model.AltTag" >
                        </div>
                    </div>

                    <!-- Title -->
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Title *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Title" name="Title" type="text" value="@Model.Title" >
                        </div>
                    </div>

                    <!-- Redirect URL -->
                    <div class="row">
                        <div class="col-md-8 form-group label-floating">
                            <label class="control-label">Redirect URL *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="255" id="RedirectUrl" name="RedirectUrl" type="url" placeholder="https://example.com" value="@Model.RedirectUrl">
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="row">
                        <div class="col-md-8 form-group label-floating">
                            <label class="control-label">Description</label>
                            <textarea autocomplete="off" class="form-control text-box single-line" maxlength="200" id="Description" name="Description" rows="3">@Model.Description</textarea>
                        </div>
                    </div>

                    <!-- Display Order -->
                    <div class="row">
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">Display Order *</label>
                            <input type="number"  autocomplete="off" class="form-control text-box single-line" id="DisplayOrder" name="DisplayOrder" min="0" value="@Model.DisplayOrder">
                        </div>
                    </div>

                    <!-- Active Checkbox -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group checkbox">
                                <label>
                                    <input type="checkbox" id="IsActive" name="IsActive" @(Model.IsActive ? "checked" : "")/>
                                    Active
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                                &nbsp;
                                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </form>
</div>

<!-- Preview Script -->
<script>


    $(document).ready(function () {

        // Image preview on edit
        const previewContainer = document.getElementById('imagePreviewContainer');
        const preview = document.getElementById('imagePreview');
        const hiddenImageInput = document.getElementById('ImageUrl');

        if (hiddenImageInput.value) {
            preview.src = hiddenImageInput.value; // Load existing image
            previewContainer.style.display = 'block';
        }

        const fromDateInput = document.getElementById('FromDate');
        const toDateInput = document.getElementById('ToDate');

        const today = new Date();
        const maxToDateLimit = new Date();
        maxToDateLimit.setFullYear(today.getFullYear() + 2);

        function parseDate(str) {
            if (!str) return null;
            // If format is dd/MM/yyyy
            if (str.includes('/')) {
                const [dd, mm, yyyy] = str.split('/').map(Number);
                return new Date(yyyy, mm - 1, dd);
            }
            // If format is yyyy-MM-dd (from date input)
            if (str.includes('-')) {
                const [yyyy, mm, dd] = str.split('-').map(Number);
                return new Date(yyyy, mm - 1, dd);
            }
            return null;
        }

        function formatDate(date) {
            const dd = String(date.getDate()).padStart(2, '0');
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const yyyy = date.getFullYear();
            return `${dd}/${mm}/${yyyy}`;
        }

        function formatDateForInput(date) {
            const dd = String(date.getDate()).padStart(2, '0');
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const yyyy = date.getFullYear();
            return `${yyyy}-${mm}-${dd}`;
        }

        // --- Load existing model values or defaults ---
        let initialFromDate = parseDate(fromDateInput.value) || today;
        fromDateInput.value = formatDate(initialFromDate);

        let initialToDate = parseDate(toDateInput.value) || initialFromDate;
        toDateInput.value = formatDate(initialToDate);

        // --- Focus/blur logic for native datepicker ---
        [fromDateInput, toDateInput].forEach(input => {
            input.addEventListener('focus', function () {
                this.type = 'date';

                // Set min/max limits dynamically
                if (this.id === 'FromDate') {
                    this.min = formatDateForInput(today);
                }

                if (this.id === 'ToDate') {
                    const minToDate = parseDate(fromDateInput.value);
                    this.min = formatDateForInput(minToDate);
                    this.max = formatDateForInput(maxToDateLimit);
                }

                // Convert existing value to yyyy-MM-dd
                if (this.value) {
                    const d = parseDate(this.value);
                    this.value = formatDateForInput(d);
                }
            });

            input.addEventListener('blur', function () {
                if (this.type === 'date' && this.value) {
                    const d = parseDate(this.value);
                    this.type = 'text';
                    this.value = formatDate(d);
                } else {
                    this.type = 'text';
                }
            });
        });

        // --- FromDate validation ---
        fromDateInput.addEventListener('blur', function () {
            const fromDate = parseDate(fromDateInput.value);
            if (fromDate < today) {
                alert('From Date cannot be earlier than today.');
                fromDateInput.value = formatDate(today);
            }

            const toDate = parseDate(toDateInput.value);
            if (toDate < fromDate) {
                toDateInput.value = formatDate(fromDate);
            }
        });

        // --- ToDate validation ---
        toDateInput.addEventListener('blur', function () {
            const fromDate = parseDate(fromDateInput.value);
            const toDate = parseDate(toDateInput.value);

            if (toDate < fromDate) {
                alert('To Date cannot be earlier than From Date.');
                toDateInput.value = formatDate(fromDate);
            } else if (toDate > maxToDateLimit) {
                alert('To Date cannot be more than 2 years from today.');
                toDateInput.value = formatDate(maxToDateLimit);
            }
        });
    });

    document.getElementById('ImageUrl2').addEventListener('change', function (event) {
        const file = event.target.files[0];
        const previewContainer = document.getElementById('imagePreviewContainer');
        const preview = document.getElementById('imagePreview');
        const hiddenImageInput = document.getElementById('ImageUrl');
        if (hiddenImageInput.value) {
            preview.src = hiddenImageInput.value; // or use full URL if needed
            previewContainer.style.display = 'block';
        }
        if (file && file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = function (e) {
                // Get the file type dynamically
                const base64Prefix = `data:${file.type};base64,`;
                const base64Data = e.target.result.split(',')[1]; // remove existing prefix
                const imageBase64 = base64Prefix + base64Data;
                preview.src = imageBase64;

                $('#ImageUrl').val(imageBase64);
                // Base64 URL with original file type
                console.log(preview.src);
                previewContainer.style.display = 'block';
            };
            reader.readAsDataURL(file);
        } else {
            preview.src = '#';
            //previewContainer.style.display = 'none';
        }
    });


    let altTagManuallyEdited = false;
    let titleManuallyEdited = false;

    // Detect manual edits on AltTag and Title
    $('#AltTag').on('input', function () {
        altTagManuallyEdited = true;
    });

    $('#Title').on('input', function () {
        titleManuallyEdited = true;
    });

    // Update AltTag and Title when typing in Name field
    $('#Name').on('keyup', function () {
        const nameValue = $(this).val().trim();

        // Update AltTag only if not manually edited
        if (!altTagManuallyEdited) {
            $('#AltTag').val(nameValue);
        }

        // Update Title only if not manually edited
        if (!titleManuallyEdited) {
            $('#Title').val(nameValue);
        }
    });
</script>


