
@model Scienter.HotelERP.Common.Domain.MaintenanceSetting

@{
    ViewBag.Title = "Maintenance Settings";
}

<div class="col-md-12">

    <form id="maintenancesetting">
        @Html.AntiForgeryToken()
        <div class="">
            <div class="row">
                <div class="col-md-3">
                    <div class="row">
                        <div class="col-md-10">

                            <div class="form-group label-floating">
                                <label class="control-label">Created Status </label>
                                @{Html.RenderAction("StatusCombo", "Status", new { area="administration", name = "CreatedStatusId", requiered = true, value = Model?.CreatedStatusId });}
                            </div>

                            <div class="form-group label-floating">
                                <label class="control-label">Completed Status </label>
                                @{Html.RenderAction("StatusCombo", "Status", new { area = "administration", name = "CompletedStatusId", requiered = true, value = Model?.CompletedStatusId });}
                            </div>

                            <div class="form-group label-floating">
                                <label class="control-label">Started Status</label>
                                @{Html.RenderAction("StatusCombo", "Status", new { area = "administration", name = "StartedStatusId", requiered = true, value = Model?.StartedStatusId });}
                            </div>

                            <div class="form-group">
                                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                                &nbsp;
                                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
