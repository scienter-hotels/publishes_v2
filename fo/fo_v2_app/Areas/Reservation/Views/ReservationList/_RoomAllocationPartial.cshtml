                                                                                    <img src="@btnImage" alt="" style="border: 1px solid #dddddd;padding: 3px;cursor:pointer;" />
                                                                                </a>

                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
