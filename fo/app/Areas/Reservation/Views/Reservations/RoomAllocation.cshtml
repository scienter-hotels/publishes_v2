@model Scienter.HotelERP.Common.Domain.ReservationHeader

@{
    ViewBag.Title = "Room Allocation";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <input type="hidden" value="@Model.Id" id="hidden-reservation-header-id"/>
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <a class="btn btn-sm  btn-theme-color-2 showGrid" href="~/reservation/reservations/list">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">

            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/isotope.pkgd.min.js"></script>
<script>
    $(function () {
        FillRooms();
    })

    //function FillRooms() {
    //    $.ajax({
    //        url: '/reservation/reservations/RoomListForAllocation?reservationHeaderId=' + $('#hidden-reservation-header-id').val(),
    //        dataType: 'html',
    //        method: 'get',
    //        success: function (response) {

    //            $('#contentLoadingArea').html('').fadeOut();
    //            $('#contentLoadingArea').html(response).fadeIn();
    //        }
    //    });
    //}

    $('body').on('click', '.floor-name-check', function () {
        if ($('.floor-name-check:checked').length == 0) {
            $('.floor-name-check-all').prop('checked', true);
        } else {
            $('.floor-name-check-all').prop('checked', false);
        }

        //-------filteration--------//
        var inclusives = [];
        $('.floor-name-check').each(function (i, elem) {
            
            if (elem.checked) {
                inclusives.push(elem.value);
            }
        });
        var filterValue = inclusives.length ? inclusives.join(', ') : '*';
        $('.rooms-container').isotope({ filter: filterValue })
        //------------------------//
    });
</script>
