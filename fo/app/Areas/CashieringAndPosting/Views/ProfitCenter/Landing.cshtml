    function SaveBillProfitCenter() {
        debugger;
        var IsComplementary = 0
        var AgentId = 0;
        if ($('#IsComplementary').prop("checked")) {
            IsComplementary = 1;
        } else {
            IsComplementary = 0;
        }
        var billpaymentArrayCheckIfNull = false;
        if (billpaymentArray.length == 0) {
            billpaymentArrayCheckIfNull = true;
        }

        if ($('#postingTypeTitle').val() == "guest") {
            AgentId = CompanyId;
        } else {
            AgentId = $('#CompanyId').val();
        }

        billDetail = {
            RoomId: $('#RoomId').val(),
            Name: $('#Name').val(),
            Address: $('#Address').val(),
            ProfitcenterItemCategoryId: LaundryDetailArrray[0].ProfitcenterItemCategoryId,  //Capturing laundry item category id from the first item type
            ProfitcenterDetailsJson: JSON.stringify(LaundryDetailArrray),
            PaymentDetailsJson: JSON.stringify(billpaymentArray),
            TaxDetailsJson: JSON.stringify(TaxGroupDetailArray),
            InhousePaymentAmount: parseFloat($('#taxCalculationTable1 tr:last td:eq(1)').text().trim().replace(/,/g, '')).toFixed(2),//report
            BillToRoomCheck: billpaymentArrayCheckIfNull,
             CompanyId: AgentId
        }
        console.log(billDetail);

        $.ajax({
            url: '/CashieringAndPosting/Profit_CenterWise_Posting/save',
            dataType: 'Json',
            data: { profit_CenterWisePosting: billDetail, IsComplementary: IsComplementary },
            method: 'POST',
            success: function (response) {
                debugger;
                //if (response.startsWith("ERR-")) {
                //    ShowErrorMessage(response.replace("ERR-", ""));
                //}
                if (typeof response === 'string' && response.startsWith("ERR-")) {
                    ShowErrorMessage(response.replace("ERR-", ""));
                }
                else {
                    $('#DocumentNoInGrid').html(response.DocumentNo)
                    $('#DocNo').html(response.DocumentNo)

                    $('#CusNameInGrid').html(response.Name)
                    $('#CusAddrInGrid').html(response.Address)
                    ShowSuccessMessage('Record has been saved successfully.');

                    $('.rowDelbtn').addClass('hidden');
                    $('#btnbillpayment').removeClass('disabled');
                    $('#btnbillpayment').addClass('btnReload');
                    $('#btnbillpayment').attr('data-href', '');
                    $('#btnbillpayment').text('New bill');
                    $('#ProfitCenterId').prop('disabled', false);
                }
            },
            complete: function () {
                var docType = "PRC";
                var docno = $('#DocumentNoInGrid').text();
                var propertyId = $('#PropertyId').val();
                var userId = $('#UserId').val();
                
                if ($('#PrintingMethod').val() == 'F') {
                    var fiscalPrinterUrl = '/Base/FiscalPrinter_DirectPrint?docType=' + docType + '&docno=' + docno + '&propertyId=' + propertyId + '&userId=' + userId;
                    FiscalPrinterRequest(fiscalPrinterUrl);
                }
            }
        });
    }

    //----Tax Cal----
    function CalculateTax() {
        debugger;
        var rate = 0;
        var discount = Number($('#Discount').val().replace(',', ''));
        if ($('#IsComplementary').is(":checked") == true) {
            rate = 0;
        } else {
            rate = (parseFloat($("#RateId").val().trim().replace(/,/g, '')) * parseInt($('#Quantity').val()))
        }

        taxDetails = {
            TaxGroupId: $('#ItemId option:selected').attr('taxgroup-data'),
            Amount: rate
        }
        
        TaxGroupDetailArray.push(taxDetails);

        if (discount>0) {
            taxDetails = {
                TaxGroupId: $('#ItemId option:selected').attr('taxgroup-data'),
                Amount: '-' + discount * parseInt($('#Quantity').val())
            }

            TaxGroupDetailArray.push(taxDetails);
        }

        console.log(TaxGroupDetailArray);

        $.ajax({
            url: '/CashieringAndPosting/TaxCalculation/GetTaxes_ProfitCenter',
            dataType: 'html',
            data: { TaxGroupAmontJson: JSON.stringify(TaxGroupDetailArray), ResId: 0, FolioNo: 0, Operation: "WALKIN" },
            method: 'POST',
            success: function (response) {

                $('#TaxCalcutationTable').html(response);
            },

        });

    }


