@model Scienter.HotelERP.Common.Domain.Asset

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="assets">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-5">
                    <div class="form-group label-floating">
                        <label class="control-label">ReferenceNo *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="ReferenceNo" name="ReferenceNo" type="text" value="@Model.ReferenceNo" required readonly="readonly">
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Asset Type *</label>
                        @{Html.RenderAction("AssestsTypeCombo", "AssetsTypes", new { name = "AssetTypeId", requiered = true, value = Model?.AssetTypeId });}
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Location *</label>
                        @{Html.RenderAction("LocationsCombo", "Locations", new { name = "LocationId", requiered = true, value = Model?.LocationId });}
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            IsActive
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
                <div class="col-md-1"></div>
                <div class="col-md-5">
                    <div class="form-group label-floating">
                        <label class="control-label">Remarks </label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Remarks" name="Remarks" type="text" value="@Model.Remarks" required>
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">ProductSerialNo </label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="ProductSerialNo" name="ProductSerialNo" type="text" value="@Model.ProductSerialNo" required>
                    </div>
                </div>

                <div class="col-md-1"></div>              
            </div>
        </div>
    </form>


</div>




