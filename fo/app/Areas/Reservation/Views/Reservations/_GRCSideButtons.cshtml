    $('body').off('click', '#btnReinstateFromInhouse').on('click', '#btnReinstateFromInhouse', function () {
       
        var ResheaderId = $('input[class="data-reservation-no"]:checked').val();
        $.ajax({
            url: '/Reservation/Reservations/ReinstateInHouseReservations?reservationHeaderId=' + ResheaderId,
            dataType: 'json',
            method: 'POST',
            success: function (response) {
               
                if (response == "success") {
                    ShowSuccessMessage('Reservation reinstate successfully.');
                    FillGrid();
                } else {
                    ShowWarningMessage(response);
                }
               
            },
            error: function (error) {
                ShowErrorMessage('There is an error.');
            }
        });
    });

    $('body').off('click', '#btnQuickCheckIn').on('click', '#btnQuickCheckIn', function () {

        var headerIdArray = [];

        headerIdArray.push({ Id: reservationHeaderId });
        $.ajax({
            // url: '/Reservation/QuickCheckIns/QuickCheckIn/qCheckIns?=' + { qCheckIn: headerIdArray },
            url: '/Reservation/QuickCheckIns/QuickCheckIn',
            data: { qCheckIns: headerIdArray, CheckInRemark: null },
            dataType: 'json',
            method: 'POST',
            success: function (response) {
            },
        });
    });

    $('body').off('click', '#btnCheckOutReinstate').on('click', '#btnCheckOutReinstate', function () {
        
