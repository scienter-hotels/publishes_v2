    <div class="row" style="padding-right: 0px;padding-left: 0px;">
        <div class="col-md-12" style="padding-right: 0px;padding-left: 0px;">
            <div class="wrapper">
                <div class="container">
                </div>
                <div id="dock-container">
                    <ul id="PropertyDiv">
                        @*<li >*@
                        @*<a href="#">
                            <img src="~/Images/properties/icon1.png" />
                        </a>*@
                        @*</li>*@
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

