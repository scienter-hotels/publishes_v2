    .form-group {
        margin: 0px;
    }

    .rooms-field-set {
        padding-top: 0px !important;
        height: 450px;
        overflow-y: scroll
    }

    .room-well {
        height: 30px;
        padding: 2px 15px 2px 10px !important;
        text-align: center;
        margin-bottom: 0px !important;
        background-color: #00ACC1;
        color: white;
    }

    .outoforder-room-well {
        background-color: #546E7A !important;
    }

    .selected-room-well {
        background-color: #E53935 !important;
    }
</style>
<form id="outOfOrderTXN">
    @Html.AntiForgeryToken()

    <div class="form">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <input type="hidden" value="@Model.Id" name="Id" id="Id" />

        <div class="col-md-12">
            <div class="row">
                <div class="col-md-8">
                    <div class="the-fieldset rooms-field-set">
                        <div>
                            <style>
                                .searchBox .form-group {
                                    margin: 0px !important;
                                }
                            </style>
                            <div class="row searchBox">
                                <div class="col-md-10">
                                    <input type="text" id="roomSearchBy" placeholder="Search by room code or name" class="form-control" />
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn-primary btn btn-block searchByBtn" style="width: 100%;float: right;">Search<div class="ripple-container"></div></button>
                                </div>
                            </div>
                            <div class="row out-of-order-rooms">
                                @*<div class="col-md-1">
                <div class="well" style="height:50px; padding:2px 15px 2px 15px !important; text-align:center">
                    <h6>100</h6>
                    <input type="checkbox" class="checkbox"style="margin:0px 0px 0px 0px !important"/>
                </div>
            </div>*@
                            </div>
                        </div>
                    </div>

                </div>
                <div class="col-md-4">
                    <div class="the-fieldset" style="height:450px; overflow-y:scroll">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group label-floating">
                                    Start date
                                    <div id="fromDateContainer" class='input-group date'>
                                        @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", value = Model?.FromDate })
                                        <span class="input-group-addon">
                                            <span class="glyphicon glyphicon-calendar"></span>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(model => model.FromDate, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group label-floating">
                                   Release date
                                    <div id="toDateContainer" class='input-group date'>
                                        @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", value = Model?.ToDate })
                                        <span class="input-group-addon">
                                            <span class="glyphicon glyphicon-calendar"></span>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(model => model.ToDate, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group label-floating">
                                    @Html.LabelFor(model => model.OutOfOrderReasonId, htmlAttributes: new { @class = "control-label" })
                                    @{Html.RenderAction("OutOfOrderReasonsCombo", "OutOfOrderReasons", new { area = "Administration", name = "OutOfOrderReasonId", value = Model?.OutOfOrderReasonId, required = true }); }
                                    @Html.ValidationMessageFor(model => model.OutOfOrderReasonId, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group label-floating">
                                    @Html.LabelFor(model => model.ReleaseAsId, htmlAttributes: new { @class = "control-label" })
                                    @{Html.RenderAction("RoomStatusCombo", "RoomStatus", new { area = "HouseKeeping", categoryId = 2, isApplicableforOutOfOrderEntry = 0, name = "ReleaseAsId", value = Model?.ReleaseAsId, requiered = true }); }
                                    @Html.ValidationMessageFor(model => model.ReleaseAsId, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group label-floating">
                                    @Html.LabelFor(model => model.Remarks, htmlAttributes: new { @class = "control-label" })
                                    <input type="text" name="Remarks" id="Remarks" class="form-control" value="@Model.Remarks" />
                                    @*@{Html.RenderAction("RoomStatusCombo", "RoomStatus", new { area = "HouseKeeping", categoryId = 2, isApplicableforOutOfOrderEntry = 0, name = "ReleaseAsId", value = Model?.ReleaseAsId, requiered = true }); }*@
                                    @*@Html.ValidationMessageFor(model => model.ReleaseAsId, "", new { @class = "text-danger" })*@
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <input type="submit" value="Create" class="btn btn-primary" id="btnsave" />
                                </div>
                            </div>
                        </div>

                        @*<hr />*@
                        <div class="row gridfortable">
                            <div class="col-md-12">
                                <div class="row grid">
                                    <div class="col-md-12 table-responsive" style="padding-left:15px; padding-right:15px;">
                                        <table class="table table-striped " id="outofordergrid">
                                            <thead>
                                                <tr>
                                                    <th>From</th>
                                                    <th>To</th>
                                                    <th>OOO Reason</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody class="room-wise-outoforder-grid"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
<script>
    $(function () {

        //2023-08-16--------------------------------------------------------------------------

        $('#NationalityId').addClass('select2');
        $('#SalutationId').addClass('select2');
        $('#CountryId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------

        FillRooms();

        $('#FromDate, #ToDate').daterangepicker({
            locale: {
                format: 'DD/MM/YYYY'
            },
            "showISOWeekNumbers": true,
            "singleDatePicker": true,
            "minDate": new Date(),
            "changeYear": true,
            "changeMonth": true,
            "opens": "right",
            "applyClass": "btn-primary",
            "dateLimit": {
                "days": false
            }
        });
    });
</script>
