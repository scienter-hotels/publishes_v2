    // form load --------------------------------
    $(document).ready(function () {
        //FillGrid();
        $('.showForm').click();
    });

    // show form --------------------------------
    $('body').on('click', '.showForm', function (e) {
        $.ajax({
            url: '/housekeeping/outofordertxn/form',
            dataType: 'html',
            method: 'POST',
            success: function (response) {      
                $('#contentLoadingArea #content').html('').fadeOut();
                $('#contentLoadingArea #content').html(response).fadeIn();
            }

        });
    });

    // show grid --------------------------------

    $('body').on('click', '.showGrid', function (e) {
        FillGrid();
    });
    // save --------------------------------------
    $('body').on('submit', '#outOfOrderTXN', function (e) {
       
        e.preventDefault();
        var selected_room_well = [];   
        var isOutOfService = 0;

        if (window.location.href.indexOf("OutOfService") !== -1) {
            // "OutOfService" exists in the URL
            isOutOfService = 1;
        }

        $('.selected-room-well').each(function (index, item) {
            if ($($(item).find('#room-id'))) {               
                SelectedRoomWell = {  
                    RoomId: $($(item).find('#room-id')).val(),
                    IsOutOfService: isOutOfService
                };
                selected_room_well.push(SelectedRoomWell);  
            }
        });   
            var OutofOrderTransaction = {
                __RequestVerificationToken: $('__RequestVerificationToken').val(),
                Id: $('#Id').val(),
                RoomIds: JSON.stringify(selected_room_well),
                FromDate: $('#FromDate').val(),
                ToDate: $('#ToDate').val(),
                OutOfOrderReasonId: $('#OutOfOrderReasonId').val(),
                OutOfOrderStatusId: 2044,
                ReleaseAsId: $('#ReleaseAsId').val(),
                Remarks: $('#Remarks').val(),

            };
            //
           // console.log(OutofOrderTransaction);
          
            $.ajax({
                url: '/housekeeping/outofordertxn/save',
                dataType: 'html',
                data: OutofOrderTransaction,
                method: 'POST',
                success: function (response) {
                   
                    if (response.includes("ERR-")) {
                        ShowWarningMessage(response.replace("ERR-",""));
                    } else {
                        ShowSuccessMessage('Record has been saved successfully.');
                        $('.showForm').click();
                    }
                   // FillGrid()
                },
                error: function (xhr, status, error) {
                   
                    ShowErrorMessage('Sorry, There is an error in saving this record.');
                }
            });          

    }); 

    // fill grid -----------------------------------
    function FillGrid() {
        var gridId = "#existingOutOfOrderTxnGrid"; // change this - relevent grid id
        var paginations = {
            PageIndex: $(gridId).attr('data-page-index'),
            PageSize: $(gridId).attr('data-page-size'),
            FilterType: $(gridId).attr('data-filter-type'),
            SearchKeyword: $(gridId).attr('data-search-keyword')
        }
        $.ajax({
            url: '/housekeeping/outofordertxn/selectforgrid',
            dataType: 'html',
            data: paginations,
            method: 'POST',
            success: function (response) {
                if ($('.grid-container').length > 0) {
                    $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                    $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                } else {
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }           

            }

        });
    }

    function FillRooms() {
        //e.preventDefault();
        $.ajax({
            url: '/HouseKeeping/OutOfOrderTXN/RoomList',
            dataType: 'json',
            method: 'GET',
            success: function (data) {
               
                $.each(data, function (index, data) {
                    var ooc = '';
                    if (data.OutOfOrder == 1) {
                        ooc = 'outoforder-room-well';
                    }
                    $('.out-of-order-rooms').append('<div class="col-md-2  room-block" data-room-text="' + data.Name+'" style="padding:2px"><div class="well room-well ' + ooc +'"><h6>' + data.Name + '<input type="hidden" value="' + data.Id +'" id="room-id" /></h6></div></div>');
                })
            }
        });
    }


    $('body').off('keyup', '#roomSearchBy').on('keyup', '#roomSearchBy', function () {
        FilterRooms();
    });

    $('body').off('click', '.searchByBtn').on('click', '.searchByBtn', function () {
        FilterRooms();
    });

    function FilterRooms() {
        debugger;
        $('.room-block').hide();
        $('.room-block').each(function (index, item) {
            if ($(item).attr('data-room-text').toLowerCase().includes($('#roomSearchBy').val().toLowerCase())) {
                $(item).fadeIn();
            }
        });
    }

