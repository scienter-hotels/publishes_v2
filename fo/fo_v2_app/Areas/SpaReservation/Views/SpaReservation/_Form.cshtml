@model Scienter.HotelERP.Common.Domain.ViewModels.SpaReservationViewModel
<style>
    .form-group-date {
        margin: 0px;
    }

    #contentLoadingArea {
        padding-left: 20px;
    }

    .padding-left-form {
        padding-left: 7px !important;
    }

    .rescheckbox {
        font-size: 10px;
        line-height: 12px;
        border-color: #a0613d;
        /*color: #000000;*/
        font-weight: 400;
    }

</style>

<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-timepicker/1.3.5/jquery.timepicker.min.css" />
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-timepicker/1.3.5/jquery.timepicker.min.js"></script>

<div class="col-md-12">
    <div class="" id="spaReservationDataLoadingArea">
        <form action="/" method="post" id="spaReservationForm">
            <input type="hidden" name="name" id="resId" value="@ViewBag.SpaResId" class="resId"/>
            <input type="hidden" name="name" id="spaRoomId" value="@ViewBag.SpaRoomId" class="roomId"/>
            <input type="hidden" name="name" id="reservationHeaderId" value="" />
            <input type="hidden" name="name" id="guestProfileId" value="" />
            <input type="hidden" name="name" id="packageHeaderId" value="" />
            <fieldset class="the-fieldset wizard" style="margin:20px 0;">
                <legend class="the-legend">Availability</legend>
                <div class="row">

                    <div class="col-md-3 padding-left-form">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Date *</label>
                            <input autocomplete="off" class="form-control text-box single-line datePicker" id="date" name="Date" required>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">From *</label>
                            <select id="from">
                                <option>Select</option>
                                @foreach (var timeSlot in Model.TimeSlots)
                                {
                                    <option value="@timeSlot.Id">@timeSlot.From</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">To *</label>
                            <select id="to">
                                <option>Select</option>
                                @foreach (var timeSlot in Model.TimeSlots)
                                {
                                    <option value="@timeSlot.Id">@timeSlot.From</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <div class="form-group">
                                <input type="button" id="btnCheckAvailability" value="Check Availability" class="btn btn-primary" />
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

            <fieldset class="the-fieldset wizard" style="margin:20px 0;" id="contentLoadingSpaReservationDetails" hidden>
                <legend class="the-legend">Reservation Details</legend>
                <div class="row">
                    <div class="col-md-4 padding-left-form">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Venue *</label>
                            <select id="venueId">
                                <option>Select</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-2 padding-left-form">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Therapist Gender *</label>
                            <select id="genderId">
                                <option>Select</option>
                                @foreach (var gender in Model.Genders)
                                {
                                    <option value="@gender.Id">@gender.Name</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-2" hidden id="contentLoadingSpaTherapist">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Therapist *</label>
                            <select id="employeeId">
                                <option>Select</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-2" hidden id="contentLoadingSpaRoomNo">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Room No *</label>
                            <select id="roomId">
                                <option>Select</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-2" hidden id="contentLoadingSpaPackage">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Package Name *</label>
                            <select id="packageId"></select>
                        </div>
                    </div>

                </div>
                
                <div class="row">
                    <div class="col-md-12  padding-left-form">
                        <div class="form-group form-group-margin-override label-floating contentLoadingReservationdetails" style="padding:0 20px">
                            <table class="table hidden table-striped" id="reservationdetails" style="box-shadow:0px 0px 10px #dedede;">
                                <thead style="border-bottom: 1px solid #eee; background-color:#f0f8ff;">
                                    <tr>
                                        <th style="font-weight: bold;">

                                        </th>
                                        @*<th style="font-weight: bold;">
                                            Res No
                                        </th>*@
                                        <th style="font-weight: bold;">
                                            G/Res No
                                        </th>
                                        <th style="font-weight: bold;">
                                            Guest Name
                                        </th>
                                        <th style="font-weight: bold;">
                                            Arrival
                                        </th>
                                        <th style="font-weight: bold;">
                                            Departure
                                        </th>
                                        <th style="font-weight: bold;">

                                        </th>
                                    </tr>
                                </thead>
                            </table>

                        </div>
                    </div>
                </div>
            </fieldset>
            
            <fieldset class="the-fieldset wizard" style="margin:20px 0;" id="contentLoadingSpaItemDetails" hidden>
                <legend class="the-legend">Item Details</legend>
                <div class="row">
                    <div class="col-md-7 padding-left-form">
                        <div class="form-group form-group-margin-override markets-container label-floating" required style="padding:0 20px">
                            <label class="required control-label">Item *</label>
                            <select id="itemId">
                                @foreach (var item in Model.SpaItems)
                                {
                                    var spaItemName = item.Name + " (Price - "+ item.SellingPrice+")";
                                <option value="@item.Id" data-item-name="@item.Name" data-item-sellingprice="@item.SellingPrice">@spaItemName</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override markets-container label-floating" required style="padding:0 20px">
                            <label class="required control-label">Qty *</label>
                            <input class="form-control text-box single-line number Quantity" min="1" max="100000000000" id="quantity" name="Quantity" step="1" type="number" required="">
                        </div>
                    </div>
                    @*<div class="row">*@
                        <div class="col-md-2">
                            <div class="form-group" style="padding:0 20px">
                                <input type="button" id="btnAdd" value="Add" class="btn btn-primary" style="width:100%;" />
                            </div>
                        </div>
                    @*</div>*@
                </div>
                <div class="" style="padding: 10px 0px;" id="contentLoadingSpaReservationItemGrid">
                    <div></div>
                    <div id="content">
                        <table class="col-md-12 table table-striped" id="itemtableSpaReservation" style="width:97.7%;margin-left:11px;">
                            <thead style="border-bottom: 1px solid #eee; background-color:#f0f8ff;height:30px !important; font-weight:800">
                                <tr style="width:100%;">
                                    <th class="col-md-4" style="padding-left:25px; font-weight:bold !important;">ITEM</th>
                                    <th class="col-md-3" style="padding-left:25px; font-weight:bold !important; text-align:right">Qty</th>
                                    <th class="col-md-3" style="padding-left:25px; font-weight:bold !important; text-align:right">Price</th>
                                    <th class="col-md-2" style="text-align:right;font-weight:bold !important; "></th>
                                </tr>
                            </thead>
                            <tbody id="itemtableBody"></tbody>
                        </table>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group" style="padding:0 20px;">
                                <input type="button" id="btnSave" value="Save" class="btn btn-primary" style="float:right !important;width:13%;" />
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>
        </form>

    </div>
</div>

<script>

    $(document).ready(function () {

        $('#quantity').val(1);

        $('.datePicker').val($('#hotelDate').val());
        $('#contentLoadingSpaReservationItemGrid').addClass('hidden');      
        

        $('#venueId').addClass('select2');
        $('#itemId').addClass('select2');
        $('#employeeId').addClass('select2');
        $('#from').addClass('select2');
        $('#to').addClass('select2');
        $('#genderId').addClass('select2');
        $('#roomId').addClass('select2');
        $('#packageId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        $('.datePicker').daterangepicker({
            "showDropdowns": true,
            singleDatePicker: true,
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "minDate": $('#hotelCurrentDate').val(),
            "startDate": $('#hotelCurrentDate').val(),
            "endDate": moment().add(1, 'days'),
            "opens": "right",
            "applyClass": "btn-primary",
            locale: {
                format: 'DD/MM/YYYY'
            }
        }, function (start, end, label) {
            $('input[name="From"]').val(start.format('DD/MM/YYYY'));
            $('input[name="To"]').val(end.format('DD/MM/YYYY'));
        });
        
    });
    
</script>