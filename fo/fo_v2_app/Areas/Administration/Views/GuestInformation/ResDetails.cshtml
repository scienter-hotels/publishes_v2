                }
                $('#checkedouttable tr:not(:first)').empty();
                $.each(data, function (index, item) {


                    $('<tr>' +
                        '<td>' + item.ReservationNo + '</td>' +
                        '<td>' + item.FirstName + '</td>' +
                        '<td>' + item.LastName + '</td>' +
                        '<td>' + item.Arrival + '</td>' +
                        '<td>' + item.Departure + '</td>' +
                        //'<td>' + item.Status + '</td>' +
                        '<td>' + item.BookingRemark + '</td>' +
                        '</tr>').appendTo($('#checkedouttable'));
                });
            },
            error: function (xhr, status, error) {
                console.log(error);
            }
        });
    }

    function FillFutureReservationTable() {
        var reservationno = $('#reservationno').val();
        $.ajax({
            url: '/GuestInformation/SelectFutureReservations',
            dataType: 'json',
            method: 'POST',
            data: { reservationno: reservationno },
            success: function (data) {
                if (data.length == 0) {
                    $('<tr><td colspan="4">No Record Found</td></tr>').appendTo($('#futuretable'));
                }
                $('#futuretable tr:not(:first)').empty();
                $.each(data, function (index, item) {


                    $('<tr>' +
                        '<td>' + item.ReservationNo + '</td>' +
                        '<td>' + item.FirstName + '</td>' +
                        '<td>' + item.LastName + '</td>' +
                        '<td>' + item.Arrival + '</td>' +
                        '<td>' + item.Departure + '</td>' +
                        //'<td>' + item.Status + '</td>' +
                        '<td>' + item.BookingRemark + '</td>' +
                        '</tr>').appendTo($('#futuretable'));
                });
            },
            error: function (xhr, status, error) {
                console.log(error);
            }
        });
    }

    function FillCancelReservationTable() {
        var reservationno = $('#reservationno').val();
        $.ajax({
            url: '/GuestInformation/SelectCancelReservations',
            dataType: 'json',
            method: 'POST',
            data: { reservationno: reservationno },
            success: function (data) {
                if (data.length == 0) {
                    $('<tr><td colspan="4">No Record Found</td></tr>').appendTo($('#canceltable'));
                }
                $('#canceltable tr:not(:first)').empty();
                $.each(data, function (index, item) {


                    $('<tr>' +
                        '<td>' + item.ReservationNo + '</td>' +
                        '<td>' + item.FirstName + '</td>' +
                        '<td>' + item.LastName + '</td>' +
                        '<td>' + item.Arrival + '</td>' +
                        '<td>' + item.Departure + '</td>' +
                        //'<td>' + item.Status + '</td>' +
                        '<td>' + item.BookingRemark + '</td>' +
                        '</tr>').appendTo($('#canceltable'));
                });
            },
            error: function (xhr, status, error) {
                console.log(error);
            }
        });
    }
</script>

