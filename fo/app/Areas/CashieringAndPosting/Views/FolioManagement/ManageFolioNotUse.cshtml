                        url: '/CashieringAndPosting/FolioManagement/ExchangeFolio',
                        dataType: 'json',
                        data: { ThisFolio: thisFolio, NextFolio: nextFolio, ResId: reservationHeaderId, DetailId: thisFolioDetailId },
                        method: 'GET',
