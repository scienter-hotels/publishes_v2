
@{
    ViewBag.Title = "User Password Reset";
}

<style>
    .reset-temporary-password {
        font-size : 12px;
        color: red
    }
    .card .card-header {
        border-radius: 0px;
    }
    .card {
        border-radius: 0px;
    }
    .btn, .navbar .navbar-nav > li > a.btn {
        border-radius:0px
    }
    .form-group {
        padding-bottom: 7px;
        margin: 5px 0 0 0;
    }

    #contentLoadingArea{
        overflow:no-display;
    }
</style>
<div class="card">
    <div class="card-header" data-background-color="purple">
        <div class="row">
            <div class="col-md-8">
                <h4 class="title">
                    @ViewBag.Title
                    <hr class="visible-print" />
                </h4>
            </div>
        </div>
    </div>
    <div class="card-content">
        <div class="row">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <input type="hidden" class="user-id" value="0" />
                            <label class="label"> User </label>
                            <select name="User" id="User" class="form-control active-users-password-reset active-users-password-reset select2" required>
                                <option value=""> -- Select -- </option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="label"> Reset Reasons </label>
                            <select name="reset-reasons" id="reset-reasons" class="form-control active-reset-reasons select2" required>
                                <option value=""> -- Select -- </option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row">
                    
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="label"> Remark </label>
                            <textarea class="reset-remark form-control remark" maxlength="500">  </textarea>
                        </div>
                    </div>

                    


                </div>
                <div class="row">
                    <div class="col-md-2 form-group checkbox label-floating" style="margin: 22px 0 0 -8px; margin-left: 0px;">
                        <label>
                            <input type="checkbox" class="isLock" checked name="IsLock" value="True" />Is Lock
                        </label>
                    </div>

                  
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <input type="submit" value="Save" class="btn btn-primary reset-password-save" />
                            &nbsp;
                            <input type="reset" value="Clear" class="btn btn-default reset-password-clear" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group label-floating temp-password hidden">
                            <label class="label"> Temporary Password </label>
                            <input type="text" readonly class="reset-temporary-password form-control" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/UI/Scienter.User.js"></script>
<script src="~/Scripts/UI/Scienter.Common.Combo.js"></script>