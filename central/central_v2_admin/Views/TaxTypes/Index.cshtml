
@{
    ViewBag.Title = "Tax Types";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm" title="Add New">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>
                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid" title="Show Grid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div class="row">
                    <div class="col-md-12" id="searchandbtndiv">
                        <div>
                            <input type="text" id="searchby" onkeyup="SearchGrid()" placeholder="Search by any Column" title="Search by any Column">
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12" id="gridArea">
                        <div>
                            <div class="master-file-grid" style="overflow-y:scroll; max-height:450px;">
                                <div class="table-responsive">
                                    <div id="loadingProjects" class="well">
                                        <center>
                                            <img src="~/Images/loading.gif" style="width:50px; margin-top:20px; margin-bottom:0px;" />
                                        </center>
                                    </div>
                                    <table class="table table-striped" id="grid" style="display:none;">
                                        <tr>
                                            <th></th>
                                            <th class="">Name</th>
                                            <th>Display Name</th>
                                            <th>Default Percentage</th>
                                            <th>Active</th>
                                            <th class="col-md-2"></th>
                                        </tr>
                                        <tr class="no-record">
                                            <td>No Records Found.</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <div class="col-md-12 master-file-form hidden">
                                <form id="form" class="form" enctype="multipart/form-data">

                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="form-group label-floating">
                                                <label class="control-label">Name *</label>
                                                <input type="hidden" id="ChargeTypeID" />
                                                <input type="text" class=" form-control" maxlength="30" id="Name" autocomplete="off" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="form-group label-floating">
                                                <label class="control-label">Display Name *</label>
                                                <input type="text" class=" form-control" id="DisplayName" value="" maxlength="30" required autocomplete="off" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="form-group label-floating">
                                                <label class="control-label">Default Percentage *</label>
                                                <input type="number" class="form-control" id="Percentage" min="0" value="" step="0.0001" required autocomplete="off" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="checkbox">
                                                <label><input type="checkbox" id="is-active" name="is-active" value="">Active</label>
                                            </div>
                                        </div>
                                    </div>



                                    <div class="row">
                                        <button type="submit" class="btn btn-success btn-width-100px" id="btnSubmit">
                                            Save
                                        </button>
                                        <button type="button" class="btn btn-default btn-width-100px btn-shadow clearbtn" onclick="ClearForm()">
                                            Clear
                                        </button>
                                    </div>
                                </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
<input type="hidden" value="" id="hdnAction" />
<script src="~/scripts/UI/Scienter.Taxtype.js"></script>
