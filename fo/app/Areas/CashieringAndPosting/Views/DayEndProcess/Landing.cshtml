                                                        <h5 style="margin-bottom:4px; font-size: 14px;">Un Settled Orders</h5>
                                                        <div class="table-responsive" style="max-height:280px; overflow-y:scroll;">

                                                            <table class="table table-striped">
                                                                <tr>
                                                                    <th>Doc #</th>
                                                                    <th>Date</th>
                                                                    <th>Res #</th>
                                                                </tr>
                                                                @foreach (var item in postings)
                                                                {
                                                                <tr>
                                                                    <td>@item.DocumentNo</td>
                                                                    <td>@item.ChargeDate</td>
                                                                    <td>@item.ReservationNo</td>
                                                                </tr>
                                                                }

                                                                @*@if (postings == 0)
                                                                {
                                                                    <tr>
                                                                        <td colspan="3">No records found.</td>
                                                                    </tr>
                                                                }*@
                                                            </table>
                                                        </div>
                                                    </div>
                                                    @*<div class="col-md-4">
            <h5 style="margin-bottom:4px; font-size: 14px;">Not Sign Off Orders</h5>
            <div class="table-responsive" style="max-height:280px; overflow-y:scroll;">

                <table class="table table-striped">
                    <tr>
                        <th>Shift No</th>
                        <th>Date</th>
