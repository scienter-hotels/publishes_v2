                    }
                </table>
            </div>
        </div>*@

                                                    <div class="col-md-4">
                                                        <h5 style="margin-bottom:4px; font-size: 14px;">Not Uploaded Orders</h5>
                                                        <div class="table-responsive" style="max-height:280px; overflow-y:scroll;">
                                                            <table class="table table-striped">
                                                                <tr>
                                                                    <th>Order No</th>
                                                                    <th>Date</th>
                                                                    <th>Description</th>
                                                                </tr>
                                                                @foreach (var item in Model.POSValidates.NotUploadedList)
                                                                {
                                                                    <tr>
                                                                        <td>@item.OrderNo</td>
                                                                        <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                                                                        <td>@item.Description</td>
                                                                    </tr>
                                                                }

                                                                @if (Model.POSValidates.NotUploadedList.Count == 0)
                                                                {
                                                                    <tr>
                                                                        <td colspan="3">No records found.</td>
                                                                    </tr>
                                                                }
                                                            </table>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <h5 style="margin-bottom:4px; font-size: 14px;">Un Settled Orders</h5>
                                                        <div class="table-responsive" style="max-height:280px; overflow-y:scroll;">
                                                            <table class="table table-striped">
                                                                <tr>
                                                                    <th>Order No</th>
                                                                    <th>Date</th>
                                                                    <th>Description</th>
                                                                </tr>
                                                                @foreach (var item in Model.POSValidates.UnSettledOrdersList)
                                                                {
                                                                    <tr>
                                                                        <td>@item.OrderNo</td>
                                                                        <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                                                                        <td>@item.Description</td>
                                                                    </tr>
                                                                }

                                                                @if (Model.POSValidates.UnSettledOrdersList.Count == 0)
                                                                {
                                                                    <tr>
                                                                        <td colspan="3">No records found.</td>
                                                                    </tr>
                                                                }
                                                            </table>
                                                        </div>
                                                    </div>

                                                </div>

                                                <button type="button" class="btn-primary btn btn-block save-room-change next action-button"
                                                        name="next" value="Next Step" style="width: 10em;float: right;">
                                                    Next Step
                                                    <div class="ripple-container"></div>
                                                </button>
                                                <button type="button" next class="btn-danger btn btn-block previous action-button-previous" name="previous" style="width: 10em;float: right;">
                                                    Previous
                                                </button>
                                            </div>

                                        </div>
                                    </fieldset>
                                    <fieldset>
                                        <div class="form-card">

                                            <div class="stepLoading">
                                                <center>
                                                    <h3>00%</h3>
                                                    <p>
                                                        Checking Pseudo Rooms ...
                                                    </p>
                                                    <img src="~/Images/work-process-gif.gif" />
                                                    <br />
                                                </center>
                                            </div>

                                            <div class="stepContent">

                                                @if (Model.DayEndPseudoRoomCheck.Count > 0)
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-striped">
                                                            <tr>
                                                                <th>Res. No</th>
                                                                <th>Room Code</th>
                                                                <th>Guest Name</th>
                                                                <th>Arrival</th>
                                                                <th>Depature</th>
                                                                <th>Status</th>
                                                                <th>Type</th>
                                                            </tr>

                                                            @foreach (var item in Model.DayEndPseudoRoomCheck)
                                                            {
                                                                <tr>
                                                                    <td>@item.ReservationNo</td>
                                                                    <td>@item.RoomCode</td>
                                                                    <td>@item.GuestName</td>
                                                                    <td>@item.Arrival.ToString("dd/MM/yyyy")</td>
                                                                    <td>@item.Departure.ToString("dd/MM/yyyy")</td>
                                                                    <td>@item.ReservationStatus</td>
                                                                    <td>@item.Type</td>
                                                                </tr>
                                                            }
                                                        </table>
