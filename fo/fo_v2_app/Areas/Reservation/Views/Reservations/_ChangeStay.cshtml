    $(document).ready(function () {
        LoadCompanies();
        LoadStayChangeReason();
        var reservationHeaderId = $('#resHeadId').val();
        var Type = $('#ReservationType').val();
        LoadReservationNumbers(reservationHeaderId, Type);
