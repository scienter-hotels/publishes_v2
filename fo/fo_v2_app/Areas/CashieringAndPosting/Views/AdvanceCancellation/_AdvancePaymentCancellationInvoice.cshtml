    function LoadPaymentypes()
    {

        $.ajax({
            url: '/CashieringAndPosting/AdvanceCancellation/PaymentMethods',
            dataType: 'json',
            method: 'GET',
            success: function (data) {

                //$('#PaymentTypes option').not(':first-child').remove();
                $.each(data, function (index, item) {
                    $('#PaymentTypes').append('<option value="' + item.Id + '">' + item.Name + '</option>');
                })
            },
            error: function (error) {

            }
        });
    }

