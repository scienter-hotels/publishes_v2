    $(".readCharacterCount").on("keyup", function () {
        var text = $(this).val();
        var maxLength = parseInt($(this).attr("maxlength"));
        var remainingChars = maxLength - text.length;
        $(this).closest('.readCharacterCountContainer').find($(".notesCounter")).text(text.length);

        if (remainingChars <= 0) {
            $(this).val(text.substr(0, maxLength));
            $(this).closest('.readCharacterCountContainer').find($(".notesCounter")).addClass("text-danger");
        } else {
            $(this).closest('.readCharacterCountContainer').find($(".notesCounter")).removeClass("text-danger");
        }
        //if (text === "/" || text === "*" || text === "-" || text === "+" || text === "@@" || text === "^") {
        //    $(this).val("");
        //}

    });

