            success: function (htmlContent) {

                $('#ExistinginvoiceGridloadingArea').html('');
                $('#ExistinginvoiceGridloadingArea').html(htmlContent);
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in getting records.');
            }


        });

    }

