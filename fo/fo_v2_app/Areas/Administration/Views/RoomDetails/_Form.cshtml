@using Scienter.HotelERP.Common.Domain;
@model Scienter.HotelERP.Common.Domain.ViewModels.RoomDetailView

@{
    ViewBag.Title = "Create / Edit";
}

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>

<div class="col-md-12">

    <form id="roomDetails">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-3">
                    <div class="form-group label-floating">
                        <label class="control-label">Room Code *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="RoomCode" name="RoomCode" type="text" value="@Model.RoomCode" required>
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Room Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Room Type *</label>
                        @{Html.RenderAction("RoomTypeCombo", "RoomTypes", new { name = "RoomTypeId", requiered = true, value = Model?.RoomTypeId });}
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Room Category *</label>
                        @{Html.RenderAction("RoomCategoryCombo", "RoomCategories", new { name = "RoomCategoryId", requiered = true, value = Model?.RoomCategoryId });}
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Bed Type *</label>
                        @{Html.RenderAction("BedTypeCombo", "BedTypes", new { name = "BedTypeId", requiered = true, value = Model?.BedTypeId });}
                    </div>
                </div>
                <div class="col-md-1">

                </div>
                <div class="col-md-3">
                    <div class="form-group label-floating">
                        <label class="control-label">Cleaning Credit *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="CleaningCredit" name="CleaningCredit" type="text" value="@Model.CleaningCredit" required>
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Room Index*</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="RoomIndex" name="RoomIndex" type="number" value="@Model.RoomIndex" required>
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Area *</label>
                        @{Html.RenderAction("RoomAreaCombo", "RoomAreas", new { name = "RoomAreaId", requiered = true, value = Model?.RoomAreaId });}
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Floor *</label>
                        @{Html.RenderAction("FloorCombo", "Floors", new { name = "RoomFloorId", requiered = true, value = Model?.RoomFloorId });}
                    </div>
                    <div class="form-group label-floating">
                        <label class="control-label">Extension *</label>
                        @{Html.RenderAction("ExtensionsCombo", "Extensions", new { name = "ExtentionId", requiered = true, value = Model?.ExtentionId });}
                    </div>

                </div>
                <div class="col-md-1">

                </div>
                <div class="col-md-3">
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsSmokingAllow)
                            SmokingAllowed
                        </label>
                        @Html.ValidationMessageFor(model => model.IsSmokingAllow, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsDriverRoom)
                            Driver Room
                        </label>
                        @Html.ValidationMessageFor(model => model.IsDriverRoom, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.ConciderForOccupancy)
                            Consider For Occupancy
                        </label>
                        @Html.ValidationMessageFor(model => model.ConciderForOccupancy, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            IsActive
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                    </div>
                    <div class="row">
                        <div class="col-sm-12 col-md-12" style="padding: 4px 0px 5px 0px;">
                            <fieldset class="the-fieldset" style="padding: 0px 0px 20px 20px; margin-right: 1.5em;">
                                <legend class="the-legend" style="padding: 0 5px;">Room Features</legend>

                                <div class="row">
                                    <div class="col-md-12">

                                        <div class="row">
                                            @{string isChecked = "";}
                                            @foreach (RoomFeatures roomFeatures in (List<RoomFeatures>)ViewBag.RoomFeatures)
                                            {
                                                isChecked = "";
                                                if (Model.RoomFeatures.Count > 0)
                                                {
                                                    if (Model.RoomFeatures.Exists(x => x.Id == roomFeatures.Id))
                                                    {
                                                        isChecked = "checked";
                                                    }
                                                }
                              
                                                <div class="col-md-6" style="margin-left: -20px;">
                                                    <div class="form-group checkbox RoomFeatures" style="margin-right: 0px;margin-left: 11px;">
                                                        <label>
                                                            <input type="checkbox" @isChecked class="data-roomFeatures" data-id="@roomFeatures.Id" id="roomFeatures-@roomFeatures.Id">
                                                            @roomFeatures.Name
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                &nbsp;
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
            </div>

        </div>
    </form>


</div>

<script>
    $(document).ready(function () {

        //2023-08-16--------------------------------------------------------------------------
        $('#RoomTypeId').addClass('select2');
        $('#RoomCategoryId').addClass('select2');
        $('#BedTypeId').addClass('select2');
        $('#RoomAreaId').addClass('select2');
        $('#RoomFloorId').addClass('select2');
        $('#ExtentionId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });
</script>
