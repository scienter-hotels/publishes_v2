    });

    $('#btnCheckIn').on('click', function (e) {
       
        e.preventDefault();
        var qCheckInsList = [];
        var ckInRemark = "Success";

        $('.data-reservation-no').each(function (index, item) {
            if ($(this).is(':checked')) {
                qCheckInsList.push({ Id: $(this).val() });
            }
        });

        if ($('.data-reservation-no:checked').attr('room-Id') > 0) {

            $.ajax({
                url: '/reservation/QuickCheckIns/QuickCheckIn',
                dataType: 'JSON',
                data: { qCheckIns: qCheckInsList, CheckInRemark: ckInRemark },
                method: 'POST',
                success: function (response) {
                    ShowSuccessMessage('Guest cheked in successfully..');
                    FillGrid();
                },
                error: function (xhr, status, error) {
                    ShowErrorMessage('Sorry, There is an error in check in this reservation.');
                }
            });
        } else {
            ShowErrorMessage('Sorry, Allocate Room Before CheckIn reservation.');
            qCheckInsList = [];
        }

    });
    function checkCheckoutDate() {
       
        var ResheaderId = $('input[class="data-reservation-no"]:checked').val();
        var IsAllowCheckOut = $('input[class="data-reservation-no"]:checked').attr('isAllowCheckOut');
        var IsCheckOutToday = $('input[class="data-reservation-no"]:checked').attr('data-isCheckoutToday');
        if (IsCheckOutToday=='False') {
            if (confirm('Departure date is not hotel current date.'))
            {
                $('#btnCheckOut').attr('data-href', '/Reservation/Reservations/CheckOutReservation?reservationHeaderId=' + ResheaderId + '&isAllowCheckOut=' + IsAllowCheckOut + '');
                $('#btnCheckOut').attr('data-title', 'Check Out reservation - ' + resNo + '');

            }
        } else {
            $('#btnCheckOut').attr('data-href', '/Reservation/Reservations/CheckOutReservation?reservationHeaderId=' + ResheaderId + '&isAllowCheckOut=' + IsAllowCheckOut + '');
            $('#btnCheckOut').attr('data-title', 'Check Out reservation - ' + resNo + '');

        }
    }
    function CheckCancelRequest() {
       
        var ResheaderId = $('input[class="data-reservation-no"]:checked').val();
        var IsAllowedToCancel = $('input[class="data-reservation-no"]:checked').attr('data-isAllowedToCancel');
        var resNo = $('input[class="data-reservation-no"]:checked').parents().eq(3).find('.res-no').html().trim();
        var cancelReservationUrl = '/Reservation/CancelReservation/CancelReservationByHeaderId?ReservationHeaderId=' + ResheaderId;
        if (IsAllowedToCancel == 'False') {
            $('.cancelReservation').attr('data-title', "NA");
           ShowErrorMessage('The arrival date is passed');
        } else {
            $('.cancelReservation').attr('data-href', cancelReservationUrl);
            $('.cancelReservation').attr('data-title', "Cancel Reservation : " + resNo);

        }

    }
</script>

