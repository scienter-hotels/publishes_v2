    function LoadInhouseRoomNumberListToGroupSettlement() {
        clearPreviousRecords();

        $.ajax({
            url: '/CashieringAndPosting/FolioManagement/ReservationList',
            dataType: 'json',
            method: 'GET',
            success: function (data) {
                //Anuradha 2024-07-01
                //Added by Ishara  on 2024-10-09
                AppendGroupReservationCombo();

                PopulateGroupReservationCombo(data);

                $.each(data, function (index, room) {
                    var reservationNo = room.GResNo && room.GResNo.trim() !== '' ? room.GResNo : room.ResNo;
                    var AllowCreditPosting = 1;  @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting  sp -ReservationNOs_T_Select modified room.AllowCreditPosting value Commented and harcoded the value for aravinda ayya request*@
                    $(
                        '<div class="inhouse-room-list room-number-name col-md-12" data-reservation-no="' + reservationNo +'" style="cursor:pointer !important; margin-bottom:10px;box-shadow: 0px 2px 5px #0000004a; ">' +
                        '<div class="row">' +
                        '<div class="col-md-9">' +
                        '<div class="row">' +
                        '<div class="col-md-12" style="margin-right:10px;color:#094f70;">' + room.RoomName + '</div>' +
                        '</div>' +
                        '<div class="row">' +
                        '<div class="col-md-12" style="margin-right:10px; font-size:10px;color:#094f70;">' + room.Name + '</div>' +
                        '</div>' +
                        '</div>' +
                        '<div class="col-md-3 checkbox">' +
                        '<label >' +
                          @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting  sp -ReservationNOs_T_Select modified room.AllowCreditPosting value Commented and harcoded the value for aravinda ayya request*@
                        '<input type="checkbox" class="inhouse-rooms"  data-inhouse-AllowCreditPosting="' + AllowCreditPosting + '"    data-inhouse-roomName="' + room.RoomName + '" data-inhouse-roomId="' + room.RoomNo + '">' +
                        '</label>' +
                        '</div>' +
                        '</div>' +
                        '</div>'
                    ).appendTo('#InhouseRoomNumberListToGroupSettlement');
                })
            },
            complete: function () {
                $('#GroupSettlement').attr('disabled', true);
                $('#GroupMerge').attr('disabled', true);
            },
            error: function (error) {
                $('#GroupSettlement').attr('disabled', true);
                $('#GroupMerge').attr('disabled', true);
            }
        });
    }


    function AppendGroupReservationCombo() {
        var comboBoxHtml = `
        <div class="col-md-12" style="margin-bottom: 10px;">
            <select id="groupReservationCombo" class="form-control">
                <option value="">All Reservations</option>
            </select>
        </div>`;
        $('#InhouseGroupReservationNoToGroupSettlement').prepend(comboBoxHtml);
    }


    function PopulateGroupReservationCombo(data) {
        var comboBox = $('#groupReservationCombo');
        var distinctReservationNos = new Set();

        $.each(data, function (index, room) {
            if (room.GResNo && room.GResNo.trim() !== '') {
                $('.selectAllRoom').prop('disabled', false).removeClass('disabled');
                var reservationNo = room.GResNo;
                distinctReservationNos.add(reservationNo);
                //var reservationNo = room.GResNo && room.GResNo.trim() !== '' ? room.GResNo : room.ResNo;
                //distinctReservationNos.add(reservationNo);
            }
        });

        comboBox.empty();
        comboBox.append('<option value="">All Reservations</option>');

        distinctReservationNos.forEach(function (reservationNo) {
            comboBox.append(`<option value="${reservationNo}">${reservationNo}</option>`);
        });
    }


    function FilterRoomsByReservation(selectedReservationNo) {
        $('#InhouseRoomNumberListToGroupSettlement .inhouse-room-list').each(function () {
            var roomReservationNo = $(this).data('reservation-no');
            var isSelectAllChecked = $('.selectAllRoom').is(':checked');



            if (selectedReservationNo.length === 0 && !isSelectAllChecked) {
                //$('.selectAllRoom').prop('checked', false).prop('disabled', true).addClass('disabled');
                $('.selectAllRoom').prop('checked', false);
            } else {

                $('.selectAllRoom').prop('disabled', false).removeClass('disabled');
            }

            if (selectedReservationNo === "") {
                $(this).show();

            } else {
                if (roomReservationNo === selectedReservationNo) {
                    $(this).show();
                    $('.selectAllRoom').prop('checked', false);

                } else {
                    $(this).hide();
                }
            }

            checkIfAllVisibleRoomsSelected();
        });
    }


    function checkComboAndSelectAll(selectedReservationNo) {
        var selectedReservationNo = $('#groupReservationCombo').val();
        var isSelectAllChecked = $('.selectAllRoom').is(':checked');

        var anyNotChecked = $('.inhouse-rooms:not(:checked)').length > 0;

        if (selectedReservationNo.length === 0 && !isSelectAllChecked) {
            //clearPreviousRecords();
            checkedRoomId = null;
        }



        //if (!anyNotChecked && selectedReservationNo.length === 0) {
        //    clearPreviousRecords();
        //    checkedRoomId = null;
        //}

        //if (selectedReservationNo.length === 0 && !isSelectAllChecked) {

        //    $('.selectAllRoom').prop('disabled',false).removeClass('disabled');
        //}
    }



    $('body').off('change', '.inhouse-rooms').on('change', '.inhouse-rooms', function () {
        var selectedRoomIdList = [];
        var roomId = $(this).attr('data-inhouse-roomId');
        var roomName = $(this).attr('data-inhouse-roomName');

        @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
        var allowCreditPosting = $(this).attr('data-inhouse-AllowCreditPosting');

        var allowCreditPostingValue = 0;

        if (allowCreditPosting === true || allowCreditPosting === 'true' || allowCreditPosting === 1) {
            allowCreditPostingValue = 1;
        }

        if ($(this).prop('checked')) {
            $(this).attr('disabled', true);
            var selectedRoom = {
                RoomId: roomId
            };
            selectedRoomIdList.push(selectedRoom);

            checkedRoomNumberArray.push(parseInt(roomId, 10));
        }



        if (selectedRoomIdList.length > 0) {
            var roomIds = JSON.stringify(selectedRoomIdList);
            LoadRoomsWithFolioTotal(roomIds, roomName, allowCreditPostingValue); @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
        }

        var IsFinalSettlement = 0
        GetActualFolioTotal(IsFinalSettlement);

    });



    var previouslySelectedGroups = [];

    function SetSelectedRoomsForMergeProcess() {


        clearPreviousRecords();

        var selectedRoomIdList = [];
  
        var selectedGroupReservationNo = null;




        $('.inhouse-rooms:checked').each(function () {
            var roomId = $(this).attr('data-inhouse-roomId');
            var roomName = $(this).attr('data-inhouse-roomName');
            var groupReservationNo = $(this).attr('data-group-reservation-no');

            @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
            var allowCreditPosting = $(this).attr('data-inhouse-AllowCreditPosting');

            var allowCreditPostingValue = 0;

            if (allowCreditPosting === true || allowCreditPosting === 'true' || allowCreditPosting === 1) {
                allowCreditPostingValue = 1;
            }

            if (!selectedGroupReservationNo) {

                selectedGroupReservationNo = groupReservationNo;

            }

            var alreadySelected = selectedRoomIdList.some(function (room) {
                return room.RoomId === roomId;
            });

            if (!alreadySelected) {
                var selectedRoom = {
                    RoomId: roomId
                };
                selectedRoomIdList.push(selectedRoom);

                var roomIds = JSON.stringify([selectedRoom]);
                //console.log('Processing Room:', roomName);
                @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
                LoadRoomsWithFolioTotal(roomIds, roomName, allowCreditPosting);
            }
        });

        var IsFinalSettlement = 0;
        GetActualFolioTotal(IsFinalSettlement);
    }



    function clearPreviousRecords() {
        $('#SelectedInhouseRooms').empty();
    }


    @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
    function LoadRoomsWithFolioTotal(roomIds, roomName, allowCreditPosting) {

        $.ajax({
            url: '/CashieringAndPosting/FolioManagement/SelectRoomWiseFolioTotal?roomIds=' + roomIds + '&roomName=' + roomName,
            dataType: 'json',
            method: 'GET',
            beforeSend: function () {
                ShowLoader();
            },
            success: function (data) {
                var checkedRoomIdStr = JSON.parse(roomIds);
                //console.log('checkedRoomIdStr',checkedRoomIdStr)

                checkedRoomId = checkedRoomIdStr[0].RoomId;
                //setTimeout(function () {
                @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
                DrawTags(data, roomName, checkedRoomId, allowCreditPosting);
                //}, 3000);

            },
            complete: function (error) {
                HideLoader();
                roomArray = []
                $('.selected-room-list').each(function (index, item) {
                    var roomId = $(item).find('.btn-remove-room').data('room-id');
                    roomArray.push(roomId);
                });
            },
            error: function (error) {

            }
        });
    }
    @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger allowCreditPosting *@
    function DrawTags(data, roomName, checkedRoomId, allowCreditPosting) {

        $.each(data, function (index, roomtag) {
            $(
                '<div class="col-md-4 selected-room-list">' +
                '<table style="margin:10px;" >' +
                '<div class="ribbon hidden" style="position:absolute;"><span style="width:80px !important; top:15px !important; right:-15px !important; background-color:#e67e22 !important" >Base</span></div>' +
                '<tr class="td-background-color">' +
                '<td class="col-md-2" style="font-size:11px;padding-left:10px;padding-top:10px;">Room</td>' +
                '<td class="col-md-1" style="padding-top:10px;padding-left:5px;">|</td>' +
                  @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger *@
                '<td class="col-md-4 inhouse-room-no text-right" style="font-weight:bold;padding-top:10px;padding-right: 0px;"  data-room-allowCreditPosting="' + allowCreditPosting + '"  data-room-name="' + roomName + '">' + roomName + '</td>' +

                //'<td class="col-md-4 inhouse-room-no text-right" style="font-weight:bold;padding-top:10px;padding-right: 0px;"  data-room-allowCreditPosting="' + allowCreditPosting + '"  data-room-name="' + roomName + '">' + roomName + '</td>' +
                '<td rowspan="2" style="padding: 10px 0px 7px 30px;">' +
                '<div class="checkbox">' +
                '<label >' +
                '<input type="checkbox" class="select-main-room">' +
                '</label>' +
                '</div>' +
                '</td>' +
                '</tr>' +
                '<tr class="folio-total td-background-color" data-folio-total="' + roomtag.FolioTotal + '">' +
                '<td  style="font-size:11px;padding-left:10px;">Amount</td>' +
                '<td  style="padding-left:5px;">|</td>' +
                '<td class="formatNumber room-folio-total  text-right" style="">' + roomtag.FolioTotalToDisplay + '</td>' +
                '</tr>' +
                '<tr class="td-background-color" style="border-top:1px solid #fff;">' +
                '<td colspan="4" style="font-size:11px;padding-top:3px;padding-left:10px;padding-right:13px;padding-bottom:5px;text-align:right;"><button class="btn btn-danger btn-sm btn-remove-room" data-room-id="' + checkedRoomId + '">Remove <span class="glyphicon glyphicon-trash"></span></button></td>' +
                '</tr>' +
                '</table >' +
                '</div >').appendTo('#SelectedInhouseRooms');

        })
    }

    var roomIds = "";

    function GetActualFolioTotal(IsFinalSettlement) {
        var currentSettlementAmount = 0
        var screenSettlementAmount = $("#GroupSettlementAmount").val();
        var roomList = [];
        $('.inhouse-rooms').each(function (index, item) {
            if ($(item).prop('checked')) {
                var roomObj = {
                    RoomId: $(item).attr('data-inhouse-roomId')
                };
                roomList.push(roomObj);
            }
        });

        if (roomList.length >= 0) {
            roomIds = JSON.stringify(roomList);

            $.ajax({
                url: '/CashieringAndPosting/FolioManagement/RoomWiseFolioTotal?roomIds=' + roomIds,
                dataType: 'json',
                method: 'GET',
                success: function (data) {
                    if (IsFinalSettlement == 1) {
                        currentSettlementAmount = Number(parseFloat(data.FolioTotalToDisplay).toFixed(2)).toLocaleString('en', { minimumFractionDigits: 2 });

                        //console.log(currentSettlementAmount);
                        //console.log(screenSettlementAmount);

                        if (currentSettlementAmount != screenSettlementAmount) {
                            ShowWarningMessage('Folio total and settlement total mismatch.');
                            return;
                        } else {
                            LoadSettlementScreen();
                        }
                    } else {
                        $('#GroupSettlementAmount').val(data.FolioTotalToDisplay);
                        $("#GroupSettlementAmount").attr('data-actual-settlement-amount', data.FolioTotal);
                    }
                },
                error: function (error) {

                },
                complete: function () {
                    HideLoader();
                },
            });

        }
    }

    function selectMergeSettle() {
        ShowLoader();
        if ($('.selected-room-list').length >= 2) {

            if ($('.select-main-room:checked').length > 0) {

                @* modified By ishara on 2024 - 10 - 08 old*@
                //var userConfirmed = confirm('Are you sure you want to merge these?');

                @* modified By ishara on 2024 - 10 - 08 New *@
                if (IsFinalSettlementAfterMerge) {
                    var userConfirmed = confirm('Are you sure you want to settle these folios?');
                } else {
                    var userConfirmed = confirm('Are you sure you want to merge these?');
                }

                if (userConfirmed) {

                    @* modified By ishara on 2024 - 10 - 08 old *@
                    //var IsFinalSettlement = 1;
                    //GetActualFolioTotal(IsFinalSettlement);

                    mergeResultJsonArray = [];
                    $('.selected-room-list').each(function (index, item) {
                        var roomId = $(item).find('.btn-remove-room').attr('data-room-id');
                        var roomAmount = $(item).find('.folio-total').attr('data-folio-total');
                        var isBaseRoom = $(item).find('.select-main-room').prop('checked');

                        var element = {
                            RoomId: roomId,
                            Amount: roomAmount,
                            IsBaseRoom: isBaseRoom,
                        }
                        mergeResultJsonArray.push(element);
                    });


                    @* modified By ishara on 2024 - 10 - 08 NEW *@
                    setTimeout(function () {

                        if (isMergeOnly) {
                            GroupMergeOnly();
                        }
                        else {

                            var IsFinalSettlement = 1;

                            GetActualFolioTotal(IsFinalSettlement);
                        }

                    }, 3000);

                } else {
                    //console.log('Merge operation was cancelled.');
                    HideLoader();
                }
            } else {
                alert('Please select a Base room to merge..');
                HideLoader();
            }
        } else {
            alert('Select atleast two or more rooms');
            HideLoader();
        }

    }



    $('body').off('click', '#GroupSettlement').on('click', '#GroupSettlement', function () {
        selectMergeSettle();
        isMergeOnly = false;
        IsFinalSettlementAfterMerge = false;
        $('#GroupSettlement').addClass('disabled');
    });

    $('body').off('click', '#GroupMerge').on('click', '#GroupMerge', function () {
        selectMergeSettle();
        isMergeOnly = true;
        IsFinalSettlementAfterMerge = false;
    });

    $('body').off('click', '#GroupSettlementAfterMerge').on('click', '#GroupSettlementAfterMerge', function () {

        isMergeOnly = false;
        IsFinalSettlementAfterMerge = true;
        selectMergeSettle();

    });

    $('body').off('click', '#addNewGroup').on('click', '#addNewGroup', function () {

        isMergeOnly = false;
        IsFinalSettlementAfterMerge = false;
        clearPreviousRecords();

        $('.selectAllRoom').removeClass('disabled').prop('disabled', false);
        $('.inhouse-rooms').prop('checked', false).removeClass('disabled').prop('disabled', false);



    });

