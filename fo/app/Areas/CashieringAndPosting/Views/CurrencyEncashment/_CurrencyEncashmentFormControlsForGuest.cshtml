@model Scienter.HotelERP.Common.Domain.ViewModels.CurrencyEncashmentViewModel

<div class="col-md-12">
    <div class="row" style="margin-right: -30px;">
        <div class="walkin">
            <input class="transport-header-id" type="hidden" id="transport-header-id" />
        </div>
        <div class="col-md-12">

            <div class="row">
                <div class="col-md-12">
                    <div class="room-combo form-group label-floating">
                        <label class="control-label" for="Rate">Room Code *</label>
                        @{Html.RenderAction("GetInHouseRooms", "RoomDetails", new { area = "Administration", name = "RoomId", requiered = true, value = Model?.RoomId });}
                        @Html.ValidationMessageFor(model => model.RoomId, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="guestname-combo form-group label-floating">
                        <label class="control-label" for="Rate">Guest Name *</label>                      
                        @{Html.RenderAction("GuestProfileCombo", "GuestProfiles", new { area = "Administration", name = "GuestId", requiered = true, value = Model?.GuestId });}
                        @Html.ValidationMessageFor(model => model.GuestId, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="form-group label-floating">
                <label class="control-label" for="Rate">Country *</label>
                @{Html.RenderAction("CountriesCombo", "Countries", new { area = "Administration", name = "CountryId", requiered = true, value = Model?.CountryId });}
                @Html.ValidationMessageFor(model => model.CountryId, "", new { @class = "text-danger" })
            </div>
            <div class="row">
                <div class="form-group label-floating col-md-6">
                    <label class="control-label" for="Rate">Currency *</label>
                    @{Html.RenderAction("SelectedCurrenciesCombo", "Currencies", new { area = "Administration", name = "CurrencyId", requiered = true, value = Model?.CurrencyId });}
                    @Html.ValidationMessageFor(model => model.CurrencyId, "", new { @class = "text-danger" })
                </div>
                <div class="form-group label-floating col-md-6">
                    <label class="control-label" for="Rate">Rate Type *</label>
                    <select name="RateType" id="RateType" class="form-control rate-type" required>
                        <option value="Select Rate Type"></option>
                        <option value="SR">Selling Rate</option>
                        <option value="BR">Buying Rate </option>
                    </select>
                </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="control-label" for="Rate">Rate *</label>
                            @Html.EditorFor(model => model.Rate, new { htmlAttributes = new { @class = "form-control font-size-16px", @readonly = "readonly" } })
                            @Html.ValidationMessageFor(model => model.Rate, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="control-label" for="Amount">Amount *</label>
                            @Html.EditorFor(model => model.Amount, new { htmlAttributes = new { @class = "form-control font-size-16px", min = 0 } })
                            @Html.ValidationMessageFor(model => model.Amount, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12" id="convertionType">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group label-floating">
                                    <input type="radio" id="convertionType1" name="contact" value="C" checked>
                                    <label for="convertionType1">Currency</label>
                                </div>
                            </div>


                            <div class="col-md-8">
                                <div class="form-group label-floating">
                                    <label class="control-label" for="ReferenceNo">Reference No/Currency No *</label>
                                    <input type="text" name="ReferenceNo" id="ReferenceNo" required class="form-control font-size-16px" />
                                    @Html.ValidationMessageFor(model => model.ReferenceNo, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        @*<div class="row">
                    <div class="col-md-4">
                        <input type="radio" id="convertionType2" name="contact" value="T">
                        <label for="convertionType2">TT</label>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <input type="radio" id="convertionType3" name="contact" value="O">
                        <label for="convertionType3">Other</label>
                    </div>
                </div>*@

                    </div>
                </div>

                <div class="form-group label-floating">
                    <label class="control-label" for="Remarks">Remarks *</label>
                    <textarea id="Remarks" Name="Remarks" class="form-control" required></textarea>
                    @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "text-danger" })
                </div>
            </div>
    </div>
    @*<div class="row">
            <div class="col-md-2"></div>
            <div class="form-group col-md-10">
                <input type="button" id="btnAdd" value="Add" class="btn btn-primary" disabled />
                &nbsp;
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
            </div>
        </div>*@

    <br /> <br />
    <div class="row">

        <div class="col-md-6">

            <button type="button" id="btnAdd" value="Add" class="btn btn-primary" disabled style="width:100%">Add</button>
        </div>

        <div class="col-md-6">

            <button type="reset" id="btnClear" value="Clear" class="btn btn-default" style="width:100%">Clear</button>
        </div>


    </div>
</div>



<script>

    $(function () {
        $('.required-date').daterangepicker({
            "showDropdowns": true,
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "singleDatePicker": true,
            "opens": "right",
            "applyClass": "btn-primary",
            "minDate": $('#hotelDate').val(),
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        //$('.required-date').daterangepicker({
        //    linkedCalendars: true,
        //    "showWeekNumbers": true,
        //    "alwaysShowCalendars": true,
        //    singleDatePicker: true,
        //    "minDate": $('#hotelDate').val(),
        //    locale: {
        //        format: 'DD/MM/YYYY'

        //    }
        //}

    });

    $('#Reservations').change(function () {
        changeOnReservationHeaderChange($(this))
        $('#InHouseRooms').change();
    });

    function changeOnReservationHeaderChange(option) {
        if ($(option).find(':selected').data('room-no') == -1) {
            $('#InHouseRooms').val(0);
        } else {
            $('#InHouseRooms').val($(option).find(':selected').data('room-no'));
        }
    }

    $('#InHouseRooms').change(function () {

        if ($('.guest #Reservations').val().length == 0 ) {
            $('.guest #Reservations').val($('#InHouseRooms :selected').data('reservation-header-id'));
        }
        InHouseRoomChange(0);
    })

    function InHouseRoomChange(guestId) {
        $.ajax({
            method: 'get',
            datatype: 'html',
            url: '/administration/guestprofiles/GuestSelectByReservation?reservationId=' + $('#InHouseRooms :selected').data('reservation-header-id'),
            success: function (htmlContent) {
                $('.guest .inhouse-reservation-guest-select').html('');
                $('.guest .inhouse-reservation-guest-select').append('<label class="control-label">Guest</label>');
                $('.guest .inhouse-reservation-guest-select').append(htmlContent);

                if (guestId != 0) {
                    $('.guest .guest-combo').val(guestId);
                }
            }
        })
    }

    function ReservationChange(resId) {
        $.ajax({
            method: 'get',
            datatype: 'html',
            url: '/administration/guestprofiles/GuestSelectByReservation?reservationId=' + resId,
            success: function (htmlContent) {
                $('.guest .inhouse-reservation-guest-select').html('');
                $('.guest .inhouse-reservation-guest-select').append('<label class="control-label">Guest</label>');
                $('.guest .inhouse-reservation-guest-select').append(htmlContent);
            }
        })
    }
</script>
