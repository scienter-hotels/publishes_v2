}
<style>
    label.CusAddrInGrid {
        /* width: 23em;
        word-wrap: break-word;*/
    }

    .checkbox label, .radio label, label {
        font-size: 12px !important;
    }

    .form-group {
    margin:25px 0 0 0;
    }
</style>

<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("IsDirectPrint")" name="" id="IsDirectPrint" />
