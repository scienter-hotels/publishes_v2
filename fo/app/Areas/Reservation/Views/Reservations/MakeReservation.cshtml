    $('body').on('click', '.delete-room', function (e) {
        e.preventDefault();
        var rowNumber = [];
        rowNumber.push(parseInt($(this).closest('tr').find('.room-number').val()));

        var roomcat = $(this).closest('tr').find('.room-category').val();
        var roomType = $(this).closest('tr').find('.room-type').val();

        var td = $('.roomDetail').find('td[data-cat-id="' + roomcat + '"][data-type-id="' + roomType + '"]');
        var roomCountVal = $(td).find('.room-count').val();
        $(td).find('.room-count').val(roomCountVal - 1);

        DeleteRooms(rowNumber);
        RoomCountGridSetRoomNumber();
        DrawRoomCountGrid();
        HideGrid();
    });

    function HideGrid() {
        if ($('.room-wise-counts tbody tr').length == 0) {
            $('.room-count-fieldset').fadeIn();
            $('.room-count-fieldset').addClass('hidden').fadeOut();
        }
    }

    function ShowRoomCountGrid() {
        if ($('.room-count-fieldset').hasClass('hidden')) {
            $('.room-count-fieldset').removeClass('hidden').fadeOut();
            $('.room-count-fieldset').fadeIn();
        }
    }

    function DeleteRooms(rowNumber) {
        var i = RoomCountJson.length;

        while (i--) {
            if (rowNumber.indexOf(RoomCountJson[i].RoomNo) != -1) {
                RoomCountJson.splice(i, 1);
            }
        }
    }


    

