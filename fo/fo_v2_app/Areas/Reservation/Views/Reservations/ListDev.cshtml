    const ShowResult = () => {
        $.ajax({
            url: '/Reservation/Reservations/SelectReservationListFilter',
            dataType: 'Json',
            success: function (response) {
                if (response.toString().startsWith('ERR-')) {
                    ShowErrorMessage("Sorry, There is an error in saving this record.");
                } else {

                    if (response.FilterMethod == 1) {
                        GridFilterByText('Confirmed');
                    }
                    else if (response.FilterMethod < 0) {
                        GridFilterByText('Tentative');
                    }
                    else if (response.FilterMethod > 1) {
                        GridFilterByText('');
                    }
                    else {
                        GridFilterByText('Cancelled');
                    }
                }
            },
            error: function (xhr, status, error) {
                ShowWarningMessage('Sorry, There is an error in saving this record.');
            }
        });
    };

