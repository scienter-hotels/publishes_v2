        color: #fff;
    }

    .font-style {
        font-size: 16px;
        font-weight: 500;
        text-align: center;
        padding: 0.6em 0em 0em 0em;
    }

    a .check-square-icon {
        font-size: 3em;
        color: #e17b21;
    }

    .well {
        border: 1px solid #ccc;
        border-radius: 3px !important;
        min-height: 17px;
        padding: 0px 0px 0px 0px;
        margin-bottom: 5px;
        border-radius: 0px !important;
        -webkit-box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.05);
