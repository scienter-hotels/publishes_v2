@model Scienter.HotelERP.Common.Domain.ViewModels.ReservationTraces

<style>
    .form-group {
        padding-bottom: 10px;
        margin: 10px 0 0 0;
    }
    .the-fieldset {
        padding: 0 20px 20px 20px;
    }
</style>

<ul class="nav nav-tabs">
    <li id="tab3"><a data-toggle="tab" href="#tab1">Add Trace</a></li>
    <li class="active" id="tab4"><a data-toggle="tab" href="#tab2">Traces Grid</a></li>
</ul>

<div id="tab2" class="tab-pane  grid-tab active">
    @{Html.RenderAction("TracesGrid", "ReservationTraces");}
</div>

<div class="col-md-12" style="padding-top:10px;">
    <form id="ReservationTracesForm">
        <input type="hidden" id="hiddenreservationheaderId" value="@Model.ReservationHeaderId" />
        <input type="hidden" id="hiddenreservationtraceId" value="@Model.Id" />
        <input type="hidden" id="hiddenArrivalDate" value="@ViewBag.arrivalDate" />
        <input type="hidden" id="hiddenDepartureDate" value="@ViewBag.departureDate" />
        <input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />
        <input type="hidden" id="hidden-ItemId" value="@Model.ItemId" />

        <div class="row">
            <div class="col-md-2" style="padding-left:1px;">
                <fieldset class="the-fieldset" style="height:380px;">
                    <legend class="the-legend">
                        <div class="checkbox">
                            <label style="color:black"> <input type="checkbox" id="cb-selectAllRes" /> Res No </label>
                        </div>
                    </legend>
                    <div class="col-md-12" style="padding:0px;overflow-y:auto;  height:303px;" id="reservationNumbersLoadingArea">

                    </div>
                </fieldset>
            </div>
            <div class="col-md-2" style="padding-left:1px;">
                <fieldset class="the-fieldset" style="height:380px;">
                    <legend class="the-legend">
                        <div class="checkbox">
                            <label style="color:black"> <input type="checkbox" id="cb-selectAllDates" /> Dates </label>
                        </div>
                    </legend>

                    <div>
                        @Html.Partial("_ReservationDates")

                    </div>
                </fieldset>
            </div>
            <div class="col-md-4" style="padding-left:2px;">
                <fieldset class="the-fieldset" style="height:380px;">
                    <legend class="the-legend">
                        <div class="checkbox">
                            <label style="color:black"> <input type="checkbox" id="cb-selectAllDepartments" />Departments </label>
                        </div>
                    </legend>

                    <div id="departments-in-reservationTraces" class="departments-in-reservationTraces" style="overflow-y:scroll; height:315px ">

                    </div>

                </fieldset>
            </div>
            <div class="col-md-4" style="padding-left:1px;padding-right:2px;">
                <fieldset class="the-fieldset" style="height:380px;">
                    <legend class="the-legend">
                        <div class="checkbox">
                            <label style="color:black"> Traces</label>
                        </div>
                    </legend>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group label-floating">
                                @*  <label class="control-label">Item </label>
        <select id="ItemId" name="ItemId" class="form-control">
             <option value="ALL">ALL</option>
         </select>*@
                                @Html.LabelFor(model => model, "Item", htmlAttributes: new { @class = "control-label" })
                                @{Html.RenderAction("TracesCombo", "Traces", new { area = "Administration", name = "ItemId", requiered = true, value = Model?.ItemId });}
                                @Html.ValidationMessageFor(model => model.ItemId, "", new { @class = "text-danger" })
                            </div>
                            <div class="form-group label-floating">
                                @Html.LabelFor(model => model.Quantity, htmlAttributes: new { @class = "control-label" })
                                @Html.EditorFor(model => model.Quantity, new { htmlAttributes = new { @class = "form-control font-size-16px", min = 1, requiered = true } })
                                @Html.ValidationMessageFor(model => model.Quantity, "", new { @class = "text-danger" })
                            </div>
                            <div class="form-group label-floating">
                                @Html.LabelFor(model => model.Remark, htmlAttributes: new { @class = "control-label" })
                                <textarea id="Remark" class="form-control" required></textarea>
                                @Html.ValidationMessageFor(model => model.Remark, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-md-6" style="padding-left:15px;">
                            <input type="submit" id="btnAdd" value="Save" class="btn btn-primary btn-width-100" />

                        </div>
                        <div class="form-group col-md-6" style="padding-left:2px;">
                            <input type="reset" id="btnClear" value="Clear" class="btn btn-default btn-width-100" />
                        </div>
                    </div>

                </fieldset>
            </div>
        </div>
    </form>
</div>

@*<script src="~/Scripts/ui/reservation-list/side-buttons/traces.js"></script>*@


