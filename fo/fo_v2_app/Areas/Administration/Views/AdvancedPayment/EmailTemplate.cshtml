                                                <div style="display:inline-block; max-width:50%; min-width:240px; vertical-align:top; width:100%;">

                                                    <table align="left" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:300px;">
                                                        <tr>
                                                            <td align="left" valign="top" style="font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                                <p style="font-weight: 800;">Reserved By</p>
                                                                <p>
                                                                    @Model.SelectedGuest.FullName<br />
                                                                    Email : @Model.SelectedGuest.Email<br />
                                                                    Contact No : @Model.SelectedGuest.ContactNo<br />
                                                                    Country : @Model.SelectedStay.CountryName
                                                                </p>

                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                                <!--[if (gte mso 9)|(IE)]>
                                                </td>
                                                <td align="left" valign="top" width="300">
                                                <![endif]-->
                                                <div style="display:inline-block; max-width:50%; min-width:240px; vertical-align:top; width:100%;">
                                                    <table align="left" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:300px;">
                                                        <tr>
                                                            <td align="left" valign="top" style="font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                                <p style="font-weight: 800;">Reservation Details</p>
                                                                <p>
                                                                    Arrival :  @Convert.ToDateTime(Model.SelectedStay.CheckIn).ToShortDateString() <br>
                                                                    Departure : @Convert.ToDateTime(Model.SelectedStay.CheckOut).ToShortDateString()<br>
                                                                    No of Night(s) : @Model.SelectedStay.NoOfNights<br />
                                                                    Paxs : @Model.SelectedStay.Adults Adult(s) / @Model.SelectedStay.Kids Kid(s)
                                                                </p>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                                <!--[if (gte mso 9)|(IE)]>
                                                </td>
                                                </tr>
                                                </table>
                                                <![endif]-->
                                            </td>
                                        </tr>
                                    </table>
                                    <!--[if (gte mso 9)|(IE)]>
                                    </td>
                                    </tr>
                                    </table>
                                    <![endif]-->
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style=" padding: 35px; background-color: #1b9ba3;" bgcolor="#1b9ba3">
                                    <!--[if (gte mso 9)|(IE)]>
                                    <table align="center" border="0" cellspacing="0" cellpadding="0" width="600">
                                    <tr>
                                    <td align="center" valign="top" width="600">
                                    <![endif]-->
                                    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px;">
                                        <tr>
                                            <td width="25%" align="center" style="color: #ffffff; font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                Payment Status
                                                <h2 style="font-size: 20px; font-weight: 800; line-height: 30px; color: #ffffff; margin: 0;">
                                                    PAID <span style="font-size:14px;">via @Model.SelectedPayment.PaymentMethod</span>
                                                    <br />
                                                    <span style="font-size:14px;">@Model.SelectedPayment.CardNo</span>
                                                </h2>
                                            </td>
                                            <td width="30%" align="center" style="color: #ffffff; font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                Transaction No
                                                <h2 style="font-size: 20px; font-weight: 800; line-height: 30px; color: #ffffff; margin: 0;">
                                                    @Model.SelectedPayment.TransactionNo
                                                </h2>
                                            </td>
                                            <td width="45%" align="center" style="color: #ffffff; font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                Transaction D/T (UTC)
                                                <h2 style="font-size: 20px; font-weight: 800; line-height: 30px; color: #ffffff; margin: 0;">
                                                    @Model.SelectedPayment.PaymentGatewayRedirectBackToWebsiteAt
                                                </h2>
                                            </td>
                                        </tr>
                                    </table>
                                    <!--[if (gte mso 9)|(IE)]>
                                    </td>
                                    </tr>
                                    </table>
                                    <![endif]-->
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style="padding: 35px; background-color: #ffffff;" bgcolor="#ffffff">
                                    <!--[if (gte mso 9)|(IE)]>
                                    <table align="center" border="0" cellspacing="0" cellpadding="0" width="600">
                                    <tr>
                                    <td align="center" valign="top" width="600">
                                    <![endif]-->
                                    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px;">
                                        <tr>
                                            <td align="center">
                                                <img src="@Model.SelectedProperty.BookingEngineLogo" width="60" height="60" style="display: block; border: 0px;" />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td align="center" style="font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px; padding: 5px 0 10px 0;">
                                                <p style="font-size: 14px; font-weight: 800; line-height: 18px; color: #333333;">
                                                    @Model.SelectedProperty.Name<br>
                                                    <span style="font-weight:normal;"> @Model.SelectedProperty.Address<br /> Email : @Model.SelectedProperty.Emails<br />Telephone: @Model.SelectedProperty.ContactNos</span>
                                                </p>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td align="left" style="font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 400; line-height: 24px;">
                                                <p style="font-size: 14px; font-weight: 400; line-height: 20px; color: #777777;">
                                                    If you didn't create this reservation, please contact us immediately via @Model.SelectedProperty.Emails</a>.
                                                </p>
                                            </td>
                                        </tr>
                                    </table>
                                    <!--[if (gte mso 9)|(IE)]>
                                    </td>
                                    </tr>
                                    </table>
                                    <![endif]-->
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style=" padding: 35px; background-color: #ccc;" bgcolor="#ccc">
                                    <!--[if (gte mso 9)|(IE)]>
                                    <table align="center" border="0" cellspacing="0" cellpadding="0" width="600">
                                    <tr>
                                    <td align="center" valign="top" width="600">
                                    <![endif]-->
                                    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px;">
                                        <tr>
                                            <td width="100%" align="center" style="color: #000; font-family: Open Sans, Helvetica, Arial, sans-serif; font-size: 12px; font-weight: 400; line-height: 24px;">
                                                <b>Check-in time 13.00hrs and Check-out time 11.00hrs.</b> <br />

                                                <span style="margin-bottom:10px !important; display:block !important;">Additional compulsory supplementary charges – For non Sri Lankans/ Expatriates ( USD clients) – Please settle direct at the hotel on arrival.</span>

                                                <span style="margin-bottom:10px !important; display:block !important;">24th December - Xmas eve – additional compulsory supplement of USD 68 nett per Adult & 50% discount for Kids between 5 – 11.99years.</span>

                                                <span style="margin-bottom:10px !important; display:block !important;">31st December – New Year’s eve - additional compulsory supplement of USD 78 nett per Adult & 50% discount for Kids between 5 – 11.99years.</span>

                                                <span style="margin-bottom:10px !important; display:block !important;"></span>

                                                <span style="margin-bottom:10px !important; display:block !important;">Additional compulsory supplementary charges – for Sri Lankans and Expatriates ( Sri Lankans Clients) – Please settle direct at the hotel on arrival.</span>

                                                <span style="margin-bottom:10px !important; display:block !important;">24th December - Xmas eve – additional compulsory supplement of Rs. 5,000 per Adult & 50% discount for Kids between 5 – 11.99years.</span>

                                                <span style="margin-bottom:10px !important; display:block !important;">31st December – New Year’s eve – additional compulsory supplement of Rs. 6,000 per Adult & 50% discount for Kids between 5 – 11.99years.</span>

                                                Please email us on info@sigiriyajungles.com for any further assistance or information in relation to your reservation, the hotel, its facilities or related services and experiences.

                                            </td>

                                        </tr>
                                    </table>
                                    <!--[if (gte mso 9)|(IE)]>
                                    </td>
                                    </tr>
                                    </table>
                                    <![endif]-->
                                </td>
                            </tr>
                        </table>
                        <!--[if (gte mso 9)|(IE)]>
                        </td>
                        </tr>
                        </table>
                        <![endif]-->
                    </td>
                </tr>
            </table>

        </body>
</html>




