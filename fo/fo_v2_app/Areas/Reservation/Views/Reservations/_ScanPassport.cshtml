                    //ShowErrorMessage('Sorry there is an error in scanning the passport.');
                    ShowWarningMessage('Scanner busy. Please try again after 10 seconds.');
                } else {
                    ShowPassportDetails(data);
                }
            },
            error: function (data) {
                ShowErrorMessage('Sorry there is an error in scanning the passport.');
            }
        });
    }

