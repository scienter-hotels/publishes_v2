<configuration>
  <appSettings>
    <add key="IsRelatedToOutlet" value="{{IsRelatedToOutlet}}" />
    <add key="IsCentralLoginEnabled" value="{{IsCentralLoginEnabled}}" />
    <add key="ExternalApiBaseUrl" value="{{ExternalApiBaseUrl}}" /> 
    <add key="FiscalPrinterURL" value="{{FiscalPrinterURL}}" />  
    <add key="CentralAccessApi" value="{{CentralAccessApi}}"/>
    <!-- <add key="LoginPortalUrl" value="http://119.13.103.4:8090/" /> -->
    <add key="LoginPortalUrl" value="{{LoginPortalUrl}}" />
    <add key="ThemeColor" value="blue" />
    <add key="DateFormat" value="dd/MM/yyyy" />
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="CrystalImageCleaner-AutoStart" value="true" />
    <add key="CrystalImageCleaner-Sleep" value="60000" />
    <add key="CrystalImageCleaner-Age" value="120000" />

    <add key="ReportWidth" value="1200" />
    <add key="ReportHeight" value="500" />
    <add key="OutletDBName" value="Standardinventory1" />
    <add key="BaseUrl" value="{{BaseUrl}}" />
    <add key="ConnectionTimeout" value="300" />
   
    <add key="ErrorLogFolder" value="C:\RestaurantBackendErrorLog" />
    <add key="ErrorLogFile" value="\ErrorLog.txt" />

	
    <add key="ReportSourceConStr" value="{{ReportSourceConStr}}" />
    <add key="ReportServer" value="{{ReportServer}}" />
    <add key="SSRSReportsFolder" value="{{SSRSReportsFolder}}" />
    <add key="ReportServerUserName" value="{{ReportServerUserName}}" />   
   
  </appSettings>
  
  <connectionStrings>
	<add name="eFinancials_AccountingConnectionString" connectionString="{{eFinancials_AccountingConnectionString}}" />
    <add name="RestaurantHotelResConnectionString" connectionString="{{RestaurantHotelResConnectionString}}" />
  </connectionStrings>
  
  <system.web>
    <compilation targetFramework="4.5">
      <assemblies />
      <buildProviders>
        <add extension=".rdlc" type="Microsoft.Reporting.RdlBuildProvider, Microsoft.ReportViewer.WebForms, Version=14.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" />
      </buildProviders>
    </compilation>
    <httpRuntime targetFramework="4.5" maxQueryStringLength="4000" enable="true" useFullyQualifiedRedirectUrl="true" executionTimeout="1800" />
    <sessionState timeout="20" />
    <httpModules>
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web" />
    </httpModules>
    <httpHandlers>
      <add verb="*" path="Reserved.ReportViewerWebControl.axd" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=10.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
    </httpHandlers>
  </system.web>
