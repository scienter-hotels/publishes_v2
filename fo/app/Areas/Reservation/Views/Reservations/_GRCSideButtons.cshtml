            $(this).find('input.data-reservation-no').prop('checked', true);
        }-


        $('#existingReservationGrid tr').not(this).find('input.data-reservation-no').prop('checked', false);
        $('#existingReservationGrid tr').not(this).closest('tr').removeClass('selectdRecord');
        $(this).addClass('selectdRecord');

