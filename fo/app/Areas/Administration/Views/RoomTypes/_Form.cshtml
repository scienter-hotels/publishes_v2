
@model Scienter.HotelERP.Common.Domain.RoomTypes

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">
    <form id="roomtypes">
        @Html.AntiForgeryToken()
        <div class="">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-5">
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Code *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="3" id="Prefix" name="Prefix" type="text" value="@Model.Prefix" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-8 form-group label-floating">
                            <label class="control-label">Name *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 ">
                            <div class="form-group label-floating">
                                <label class="control-label">Description *</label>
                                <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Description" name="Description" type="text" value="@Model.Description" required>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Max Head Count *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="10" id="MaxHeadCount" name="MaxHeadCount" type="number" value="@Model.MaxHeadCount" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">Max Adult Count *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="10" id="MaxAdultCount" name="MaxAdultCount" type="number" value="@Model.MaxAdultCount" required>
                        </div>

                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">Max Child Count *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="10" id="MaxChildCount" name="MaxChildCount" type="number" value="@Model.MaxChildCount" required>
                        </div>
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">Max Infants Count *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="10" id="MaxInfantsCount" name="MaxInfantsCount" type="number" value="@Model.MaxInfantsCount" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Display Order *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="10" id="DisplayOrder" name="DisplayOrder" type="number" value="@Model.DisplayOrder" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.IsApplicableForIBE) Apply for booking engine
                            </label>
                            @Html.ValidationMessageFor(model => model.IsApplicableForIBE, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.IsActive) Active
                            </label>
                            @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                        </div>
                        @if (Scienter.HotelERP.Common.Domain.SessionObjects.FOSettings.IsDormitory)
                        {
                            <div class="form-group checkbox">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsDormitory) IsDormitory
                                </label>
                                @Html.ValidationMessageFor(model => model.IsDormitory, "", new { @class = "text-danger" })
                            </div>
                        }

                    </div>
                    <div class="row">
                        <div class="form-group">
                            <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                            &nbsp;
                            <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                        </div>
                    </div>
                    </div>
                    <div class="col-md-2"></div>
                    <div class="col-md-5" style="display:none">
                        @{Html.RenderAction("ListVertical", "Properties", new { selectedPoperties = Model.Properties }); }
                    </div>
                </div>
        </div>
    </form>


</div>


