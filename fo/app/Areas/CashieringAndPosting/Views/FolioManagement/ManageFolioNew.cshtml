@using Scienter.HotelERP.Common.Domain

@{
    //Layout = "~/Areas/CashieringAndPosting/Views/Shared/_Layout.cshtml";
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewBag.Title = "Manage Folios";
}

<style>
    td {
        vertical-align: top !important;
    }

    .sideBtns .row {
        margin: 0px;
    }

    .sideBtns .col-md-6, .sideBtns .col-md-12 {
        padding: 3px;
        vertical-align: middle;
    }

    .tileBtn span {
        display: block;
        margin-bottom: 5px;
        padding-top: 5px;
    }

    .the-fieldset {
        margin-bottom: 0px;
    }

    .room-number {
        background-color: #bdc3c7 !important;
        color: #000;
    }

    .room-number-selected {
        background-color: #094F70 !important;
        color: #fff;
    }

    .form-group {
        margin-top: 5px !important;
    }

    .btn-custom-color {
        background-color: #e67e22;
        font-size: 10px;
        width: 100%;
        padding: 5px;
    }

        .btn-custom-color:hover {
            background-color: #7d4412;
        }

    .table-label {
        font-weight: bold !important;
    }

    .img-style {
        width: 15px !important;
    }

    .sticky-header {
        position: sticky;
        top: 0;
        background-color: #e5e5e5;
        z-index: 100;
    }

    #tbl-all-transactions td, #tbl-all-transactions th {
        padding: 2px 5px;
    }

    #tbl-all-transferred-transactions td, #tbl-all-transferred-transactions th {
        padding: 2px 5px;
    }

    .btn-expand {
        font-size: 10px !important;
        padding: 3px 6px !important;
    }

    .btn-folio-numbers::-webkit-scrollbar {
        width: 5px !important;
        padding-left: 3px;
    }

    .btn-folio-numbers::-webkit-scrollbar-track {
        background: #f1f1f1 !important;
    }

    .btn-folio-numbers::-webkit-scrollbar-thumb {
        background: #c1c1c1 !important;
    }

        .btn-folio-numbers::-webkit-scrollbar-thumb:hover {
            background: #8E8E8E !important;
        }

    .sideBtns-div::-webkit-scrollbar {
        width: 5px !important;
    }

    .sideBtns-div::-webkit-scrollbar-track {
        background: #f1f1f1 !important;
    }

    .sideBtns-div::-webkit-scrollbar-thumb {
        background: #c1c1c1 !important;
    }

        .sideBtns-div::-webkit-scrollbar-thumb:hover {
            background: #8E8E8E !important;
        }

    #inHouseRoomList::-webkit-scrollbar {
        width: 5px !important;
    }

    #inHouseRoomList::-webkit-scrollbar-track {
        background: #f1f1f1 !important;
    }

    #inHouseRoomList::-webkit-scrollbar-thumb {
        background: #c1c1c1 !important;
    }

        #inHouseRoomList::-webkit-scrollbar-thumb:hover {
            background: #8E8E8E !important;
        }


    .ribbon {
        height: 60px !important;
    }

    .tileBtn {
        min-height: 60px;
        text-transform: capitalize !important;
        display: block;
        width: 100% !important;
        padding: 0px;
        margin: 0px;
        padding-top: 5px;
        word-wrap: break-word !important;
        line-height: 13px;
        box-shadow: #bdc3c7 1px 1px 2px;
    }

    .sideBtns .tileBtn:hover {
        background-color: #fff !important;
        color: #222 !important;
        border: 1px solid #222;
    }

    .folio-number-select {
        display: grid;
        place-items: center;
        font-size: 20px;
        padding: 10px !important;
        background-color: #094f70;
        border-top-left-radius: 4px;
        border-bottom-left-radius: 4px;
        color: #fff !important;
    }

    .folio-text {
        font-size: 10px;
        margin-bottom: -5px;
    }

    .ribbon-span {
        width: 63px !important;
        top: 8px !important;
        right: -15px !important;
        background-color: #094f70 !important;
    }

    .folio-btn-styles {
        cursor: pointer;
        margin-bottom: 5px !important;
        padding-left: 0px !important;
        width: 100%;
        color: #2b2b2b;
        padding: 0px;
        min-height: 60px;
        display: block;
        place-items: center;
        border-radius: 4px !important;
        border-top-left-radius: 5px !important;
        border-bottom-left-radius: 5px !important;
    }

    .folio-btn-company {
        text-align: left;
        padding: 0px 5px 0px 5px !important;
        height: 60px;
        display: block;
        align-content: center;
    }

    .folio-btn-invoice-icon {
        display: grid;
        place-items: center;
        height: 60px;
        z-index: 10;
    }

        .folio-btn-invoice-icon i {
            font-size: 20px;
            color: #000 !important;
        }

            .folio-btn-invoice-icon i:hover {
                color: #f00 !important;
            }

    .invoice-number-to-report {
        font-weight: 100;
        font-size: 10px;
    }

    .disabled-div {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

