                    <div class="col-md-2">
                        <div class="form-group  label-floating">
                            @*<label class="control-label">Room Type*</label>
                        @{Html.RenderAction("RoomTypeCombo", "RoomTypes", new { area = "Administration", name = "RoomType" });}*@
