<script>
    $(document).ready(function () {

        setTimeout(() => {


        let barChartHeight = $('#feedbackBarChart').height();
        let pieChartHeight = $('#feedbackBarChart').height();

        var higherCardHeight = Math.max(barChartHeight, pieChartHeight);

        $('#feedbackBarChart').height(higherCardHeight);
        $('#feedbackPieChart').height(higherCardHeight);

            setTimeout(() => {
            $('#pieChart').css('margin', '50px 0');
        },800);

        },1000);

        $.ajax({
            url: '/GuestPortal/Feedback/SelectDoughnutChart',
            method: 'POST',
            success: function (response) {
                var colour = [];
                var labels = [];
                var data = [];

                $(response).each(function (index, item) {
                    //console.log(item.lstComplaint);

                    //if (item.ResultJson === null) {
                        //    $(".doughnutChart").replaceWith("<p>No data available</p>");
                        //    return;
                        //}

                    var month = item.MonthName;
                    var year = item.Year;
                    var name = month + ' ' + year;

                    var className = "data-doughnutChart-" + index;
                    $(item.lstFeedback).each(function (index1, item1) {
                        var color = item1.Color;
                        colour.push(color);

                        var label = item1.Label;
                        labels.push(label);

                        var count = item1.Percentage;
                        data.push(count);
                    });

                    $('<div class="col-md-3">' +
                        '<canvas class="' + className + '" ></canvas>' +
                        '</div>').appendTo('.doughnutChart');

                    DoughnutChart(colour, labels, data, className, name);
                    colour = [];
                    labels = [];
                    data = [];
                });
            }
        });
    });

    function DoughnutChart(colour, labels, data, className, name) {
        //console.log(data);
        var charts = document.getElementsByClassName(className);
        var colour = ['Red', 'Blue', 'Yellow', 'Green', 'Purple', 'Orange'];

        for (var i = 0; i < charts.length; i++) {
            var ctx = charts[i].getContext('2d');
            var myDoughnutChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Month Wise Complaints',
                        data: data,
                        //backgroundColor: colour,
                        borderWidth: 1
                    }]
                },
                options: {
                    cutout: '60%',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'right'
                            //align:'start'
                        },
                        title: {
                            display: true,
                            position: 'top',
                            text: name
                        }
                    }
                }
            });

        }
    }

</script>

