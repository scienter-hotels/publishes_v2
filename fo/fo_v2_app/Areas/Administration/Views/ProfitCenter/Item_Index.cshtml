@*@model  IEnumerable<Scienter.HotelERP.Common.Domain.ProfitCenter>*@
@{
    ViewBag.Title = "Profit Center Items";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>

                    </div>
                </div>
            </div>

            <div class="card-content" id="contentLoadingArea">
                <div id="content">


                </div>
                @Html.Partial("_Loading")
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
    // form load --------------------------------
    $(document).ready(function () {
        //debugger;
        FillGrid();
    });


    // show form --------------------------------
    $('body').on('click', '.showForm', function (e) {
        ShowForm();
    });
    function ShowForm() {
        //debugger;
        $.ajax({
            url: '/administration/ProfitCenter/Item_Form',
            dataType: 'html',
            method: 'POST',
            success: function (response) {

                $('#contentLoadingArea #content').html('').fadeOut();
                $('#contentLoadingArea #content').html(response).fadeIn();
            }

        });
    }
    // show grid --------------------------------

    $('body').on('click', '.showGrid', function (e) {
        //debugger;
        FillGrid();
    });


    // save --------------------------------------
    $('body').on('submit', '#ProfitCenteritems', function (e) {
        //debugger;
        e.preventDefault();
        //var ItemCategoryWiseTypeWisePrcingsArray = [];

        //$('.ItemCategory').each(function (indexCategory, itemCategory) {
        //    var ItemCategoryId = $(itemCategory).attr('categoryId');

        //    $($(itemCategory).find('.ChargeType')).each(function (indexChargeType, itemChargeType) {
        //        var chargeTypeId = $(itemChargeType).attr('ChargeTypeId');
        //        var chargeTypeValue = $($(itemChargeType).find('.laundryChargeTypeValue')).val();
        //        var CostPrice = $($(itemChargeType).find('.CostPrice')).val();
        //        var SellingPrice = $($(itemChargeType).find('.SellingPrice')).val();
        //        ItemCategoryWiseTypeWisePrcingsArray.push({ CategoryId: ItemCategoryId, ChargeTypeId: chargeTypeId, Price: chargeTypeValue, CostPrice: CostPrice, SellingPrice: SellingPrice });
        //    });
        //});
        //console.log(ItemCategoryWiseTypeWisePrcingsArray);

        var Type = {
            __RequestVerificationToken: $('__RequestVerificationToken').val(),
            Id: $('#Id').val(),
            Name: $('#Name').val(),
            ProfitCenterId: $('#ProfitCenterId').val(),
            IsActive: $('#IsActive').prop("checked"),
            SellingPrice: $('.SellingPrice').val(),
            InventoryItemId: $('#inventoryItemId').val(),
            //profitCenterItemCategoryWiseTypeWisePrcing: ItemCategoryWiseTypeWisePrcingsArray

        };
        console.log(Type);
        $.ajax({
            url: '/administration/ProfitCenter/Save_Item',
            dataType: 'html',
            data: Type,
            method: 'POST',
            success: function (response) {
                $('#contentLoadingArea').html('').fadeOut();
                $('#contentLoadingArea').html(response).fadeIn();
                ShowSuccessMessage('Record has been saved successfully.');
                location.reload();
            }

        });
    });



    //fill grid -----------------------------------
    function FillGrid() {
        //debugger;
        var gridId = "#existingProfitCenterItemGrid"; // change this - relevent grid id
        var paginations = {
            PageIndex: $(gridId).attr('data-page-index'),
            PageSize: $(gridId).attr('data-page-size'),
            FilterType: $(gridId).attr('data-filter-type'),
            SearchKeyword: $(gridId).attr('data-search-keyword')
        }
        //debugger;
        $.ajax({
            url: '/administration/ProfitCenter/Item_SelectForGrid',
            dataType: 'html',
            data: paginations,
            method: 'POST',
            success: function (response) {
                if ($('.grid-container').length > 0) {
                    $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                    $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                } else {
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }
            }
        });
    }

</script>
