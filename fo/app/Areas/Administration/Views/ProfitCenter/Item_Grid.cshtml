@model  IEnumerable<Scienter.HotelERP.Common.Domain.ProfitCenterItem>
@{
    ViewBag.Title = "Exising Profit Center Items";
}
<div class="table-responsive">
    <table class="table table-striped" id="existingProfitCenterItemGrid">
        <thead>
            <tr>
                <th class="text-primary">
                    Name
                </th>
                <th class="text-primary">
                    Selling Price
                </th>
                <th class="text-primary">
                    Profit Center
                </th>
                <th class="col-md-1 text-primary">
                    IsActive
                </th>
                <th class="col-md-1 hidden-print">

                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SellingPrice)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ProfitCenterName)
                </td>
                <td class="col-md-1">
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsActive)
                            <span class="hidden">
                                @if (item.IsActive)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>
                </td>
                <td class="hidden-print text-right">
                    @*<input type="number" name="name" value="@item.Id" data-id="@item.Id" />*@
                    <a class="btn btn-theme-color-2 btn-sm" id="btn-Edit" data-id="@item.Id" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/administration/ProfitCenter/Edit_Item/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/ProfitCenter/Delete_Item/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

<script>
    $(document).ready(function () {
        $('#existingProfitCenterItemGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    'pdf',
                    'print'
                ],
                scrollY: '58vh',
            });
    });
   
</script>
