<script>
    $(document).ready(function () {
        $('.data-hide').hide();

        var resArrival;
        var resDeparture;
        var duration;
        var timeArrival;
        var timeDeparture;

        $('.reservationDetailsLoop').each(function (index, item) {
            resArrival = moment($($(item).find('.res-arrival')).val()).format("DD/MM/YYYY");
            $(item).find($('.resArrival .datePicker')).val(resArrival);

            resDeparture = moment($($(item).find('.res-departure')).val()).format("DD/MM/YYYY");
            $(item).find($('.resDeparture .datePicker')).val(resDeparture);

            duration = moment($(item).find('.res-departure').val()).diff(moment($(item).find('.res-arrival').val()), 'days');
            $(item).find($('.NoOfNights')).val(duration);

            timeArrival = $(item).find('.timeArrival').val();
            $(item).find($('.resArrivalTime .time-range')).val(timeArrival);

            timeDeparture = $(item).find('.timeDeparture').val();
            $(item).find($('.resDepartureTime .time-range')).val(timeDeparture);
        });
    });

    $('body').on('change', '.resArrival .datePicker', function () {
        var resArrival = moment($(this).val(), 'DD/MM/YYYY');
        var resDeparture = moment($(this).closest('.reservationDetailsLoop').find('.resDeparture .datePicker').val(), 'DD/MM/YYYY');
        var duration = resDeparture.diff(resArrival, 'days');

        if (duration < 0) {
            ShowWarningMessage('Invalid Date!');
            $(this).closest('.reservationDetailsLoop').find('.NoOfNights').val(0).focus();
        }
        else {
            $(this).closest('.reservationDetailsLoop').find('.NoOfNights').val(duration);
        }
    });

    $('body').on('change', '.resDeparture .datePicker', function () {
        var resDeparture = moment($(this).val(), 'DD/MM/YYYY');
        var resArrival = moment($(this).closest('.reservationDetailsLoop').find('.resArrival .datePicker').val(), 'DD/MM/YYYY');
        var duration = resDeparture.diff(resArrival, 'days')

        if (duration < 0) {
            ShowWarningMessage('Invalid Date!');
            $(this).closest('.reservationDetailsLoop').find('.NoOfNights').val(0).focus();
        }
        else {
            $(this).closest('.reservationDetailsLoop').find('.NoOfNights').val(duration);
        }
    });

    $('.Editbtn').on('click', function () {
        var $this = $(this);
        $this.toggleClass('Editbtn');
        if ($this.hasClass('Editbtn')) {
            $('.data-hide').toggle();
            $('.data-show').toggle();
            $this.text('Edit');
        } else {
            $this.text('Done');
            $('.data-hide').toggle();
            $('.data-show').toggle();
        }
    });

    //$('body').on('click', '.btnaddGuest', function () {
    //   
    //    var target = $(this).closest('.reservationDetailsLoop').find('.panelGuest');
    //    target.collapse('toggle') 
    //});

</script>