@model Scienter.HotelERP.Common.Domain.ViewModels.HotelConfirmationView

<style>
    .disabled {
        cursor: not-allowed;
    }
    .dataTables_filter {
        width: 29% !important;
        float: left !important;
    }

    .dt-buttons {
        width: 70% !important;
    }

    .superscript {
        font-size: 0.8em;
    }

    .form-group {
        margin-top: 5px;
    }

    .table .radio, .table .checkbox {
        margin-right: 10px;
    }

    #guestGroupGrid {
        font-size: 12px !important;
    }

        #guestGroupGrid input, select {
            font-size: 12px !important;
        }
</style>



<div class="row">
    <div class="col-md-2">
        @*-----------Hidden fields for reservation update-----------------*@
        <input type="hidden" id="GuestName" value="@ViewBag.GuestName" />
        <input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
        <input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
        <input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />
        <input type="hidden" id="ReservationType" value="@ViewBag.ReservationType" />
        <input type="hidden" id="resHeadId" value="@ViewBag.ResheaderId" />
        <input type="hidden" class="ReseNo" value="@Model.ReservationNo" />
        <input type="hidden" class="segmentId-hidden" value="@Model.SegmentId" />
        <input type="hidden" class="rateCodeId-hidden" value="@Model.RateCodeHeaderId" />
        <input type="hidden" class="marketId-hidden" value="@Model.MarketId" />
        <input type="hidden" class="reservation-country" value="@Model.CountryID" />
        <input type="hidden" class="reservation-status" value="@Model.StatusId" />
        <input type="hidden" class="reservation-bookingSource" value="@Model.BookingSourceId" />
        <input type="hidden" class="reservation-company" value="@Model.AgentId" />
        <input type="hidden" class="reservation-rateCode" value="@Model.RateCodeHeaderId" />
        <input type="hidden" class="reservation-segment" value="@Model.SegmentId" />
        <input type="hidden" class="reservation-market" value="@Model.MarketId" />
        <input type="hidden" id="ExistingVisitPurposeId" value="@Model.VisitPurposeId" />
        @*--------Hidden fields for reservation update end----------*@

        @*----------Hidden fields for stay change------------------*@
        <input type="hidden" id="roomCategoryId" value="@ViewBag.RoomCategoryId" />
        <input type="hidden" id="ViewRateCodeHeaderId" value="@ViewBag.RateCodeHeaderId" />
        <input type="hidden" id="ViewMealPlanId" value="@ViewBag.MealPlanId" />
        <input type="hidden" id="ViewRoomTypeId" value="@ViewBag.RoomTypeId" />
        <input type="hidden" id="IsChangeRoom" value="@ViewBag.IsChangeRoom" />
        <input type="hidden" id="CurrentDate" value="@ViewBag.CurrentDate" />
        <input type="hidden" id="ViewCompanyId" value="@ViewBag.CompanyId" />
        <input type="hidden" id="ViewCountryId" value="@ViewBag.CountryId" />
        <input type="hidden" id="isDormitory" name="isDormitory" value="@ViewBag.IsDormitory" required />
        @*----------Hidden fields for stay change end--------------*@
        @*-----------Hidden fields for guest update------------------*@
        <input type="hidden" id="groupReservationNo" value="@ViewBag.GroupReservationNo" />
        @*-----------------------------------------------------------*@
        <fieldset class="the-fieldset" style="padding:3px; height:1013px;overflow-y:scroll">
            <legend class="the-legend">Reservation No</legend>
            @*<div class="input-group searchdiv">
                <input type="text" class="form-control text-box single-line" placeholder="Res No" style="text-align:center" onkeyup="searchReservation()" id="txtSearch" />
            </div>*@
            <div class="col-md-12" id="reservationNumbersLoadingArea">

            </div>
        </fieldset>
    </div>
    <div class="col-md-10">
        <form id="reservationUpdate">
            <div class="row">
                <div class="col-md-12">
                    <div class="row">
                        <div class="col-md-7">
                            @if (@ViewBag.fromRes == true)
                            {
                                <input type="hidden" id="UpdatePopup" class="UpdatePopup" value="U" />
                            }

                            <fieldset class="the-fieldset">
                                <legend class="the-legend">Reservation Details</legend>

                                <div class="row" style="margin-top:-15px;">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label required">Country</label>
                                            @{Html.RenderAction("CountriesCombo", "Countries", new { area = "Administration", name = "CountryID", requiered = true, value = Model?.CountryID });}
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Status</label> <select name="StatusId" id="StatusId" class="form-control" required>
                                                <option value="0">N/A</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Booking Sources</label>
                                            @{Html.RenderAction("BookingSourceCombo", "BookingSources", new
                                                {
                                                    area = "Administration",
                                                    name = "BookingSourceId",
                                                    requiered = true,
                                                    value = Model?.BookingSourceId
                                                });}
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Company</label>
                                            <select required id="CompanyId" name="CompanyId" class="form-control" disabled>
                                                <option value="">-- Select Company --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override rate-code-container label-floating">
                                            <label class="required control-label">Rate Code</label>
                                            <select required id="RateCodeHeaderId" name="RateCodeHeaderId" class="form-control" disabled>
                                                <option value="">-- Select Rate Code --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override markets-container label-floating">
                                            <label class="required control-label">Market</label>
                                            <select required id="MarketId" name="MarketId" class="form-control">
                                                <option value="">-- Select Market --</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override segments-container label-floating">
                                            <label class="required control-label">Segment</label>
                                            <select required id="SegmentId" name="SegmentId" class="form-control">
                                                <option value="">-- Select Segment --</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Sales Person</label>
                                            @{Html.RenderAction("StaffDetailsFrontOfficeOnlyCombo", "StaffDetails", new
                                                {
                                                    area = "Administration",
                                                    name = "SalesPersonId",
                                                    requiered = false,
                                                    value = Model?.SalesPersonId
                                                });}
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Sales Person Contact</label>
                                            <input type="text" name="SalesPersonContact" id="SalesPersonContact" class="form-control" value="@Model.SalesPersonContactNo" />
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Voucher No</label>
                                            <input type="text" name="VoucherNo" id="VoucherNo" class="form-control" value="@Model.VoucherNo" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Tour No</label>
                                            <input type="text" name="TourNo" id="TourNo" class="form-control" value="@Model.TourNo" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Visit Purpose</label> <select name="VisitPurposeId" id="VisitPurposeId" class="form-control" required>
                                                <option value="0">N/A</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Guest payment mode</label>
                                            @{Html.RenderAction("GuestPaymentModesCombo", "GuestPaymentModes", new { area = "Administration", name = "GuestPaymentModes", requiered = true, value = Model?.GuestPaymentMode });}
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="required control-label">Package</label>
                                            @{Html.RenderAction("PackageHeaderCombo", "PackageHeaders", new { area = "Administration", name = "PackageHeaderId", requiered = true, value = Model?.PackageHeaderId });}
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Remark</label>
                                            <input type="text" name="Remark" id="RemarkId" maxlength="500" class="form-control" value="@Model.BookingRemark" />
                                        </div>
                                    </div>
                                </div>
                            </fieldset>
                        </div>


                        <div class="col-md-5">

                            <fieldset class="the-fieldset padding-margin-bottom-override">
                                <legend class="the-legend">Accommodation Details</legend>
                                <div class="row" style="margin-top:-15px;">
                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Arrival</label>
                                            <input type="text" name="ArrivalDate" id="ArrivalDate" class="form-control  ArrivalDate" value="@Convert.ToDateTime(Model.Arrival).ToShortDateString()" />
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Departure</label>
                                            <input type="text" name="DepartureDate" id="DepartureDate" class="form-control  DepartureDate" value="@Convert.ToDateTime(Model.Departure).ToShortDateString()" />
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">No Of Nights</label>
                                            <input type="text" name="NoOfNights" id="NoOfNights" class="form-control" value="@Model.NoOfNights" readonly />
                                        </div>
                                    </div>

                                </div>

                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">No Of Adults</label>
                                            <input type="number" name="NoOfAdults" id="NoOfAdults" class="form-control" value="@Model.NoOfAdults" />
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">No Of Kids</label>
                                            <input type="number" name="NoOfKids" id="NoOfKids" class="form-control" value="@Model.NoOfKids" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Arrive For</label>
                                            @{Html.RenderAction("MealCombo", "MealPlans", new
                                                {
                                                    area = "Administration",
                                                    name = "ArriveMeal",
                                                    requiered = false,
                                                    value = Model?.ArrivalForId
                                                });}
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Leave After</label>
                                            @{Html.RenderAction("MealCombo", "MealPlans", new
                                                {
                                                    area = "Administration",
                                                    name = "DeparturePlan",
                                                    requiered = false,
                                                    value = Model?.LeaveAfterId
                                                });}
                                        </div>
                                    </div>

                                </div>


                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating resArrivalTime" id="ExpectedArrivalTimeId">
                                            <label class="required control-label">Expected Arrival Time</label>
                                            <input type="hidden" class="timeArrival" value="@Model.ExpectedArrivalTime" />
                                            @{Html.RenderPartial("_TimeRange");}

                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-group form-group-margin-override label-floating resDepartureTime" id="ExpectedDepartureTimeId">
                                            <input type="hidden" class="timeDeparture" value="@Model.ExpectedDepartureTime" />
                                            <label class="required control-label">Expected Departure Time</label>
                                            @{Html.RenderPartial("_TimeRange");}

                                        </div>
                                    </div>

                                </div>
                            </fieldset>

                            <fieldset class="the-fieldset padding-margin-bottom-override" style="height:136px;">
                                <legend class="the-legend">Room Details</legend>
                                <div class="row" style="margin-top:-15px;">
                                    <div class="col-md-4">
                                        <div class="form-group label-floating">
                                            <label class="control-label">Category</label>
                                            @{Html.RenderAction("RoomCategoryCombo", "RoomCategories", new { area = "Administration", name = "RoomCategory", value = @Model.RoomCategoryId });}
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group  label-floating">
                                            <label class="control-label">Type</label>
                                            @{Html.RenderAction("RoomTypeCombo", "RoomTypes", new { area = "Administration", name = "RoomType", value = @Model.RoomTypeId });}
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-group form-group-margin-override label-floating">
                                            <label class="control-label">Meal Plan</label>
                                            @{Html.RenderAction("MealPlanCombo", "MealPlans", new
                                                {
                                                    area = "Administration",
                                                    name = "MealPlanId",
                                                    requiered = true,
                                                    value = Model?.MealPlanId
                                                });}
                                        </div>
                                    </div>
                                </div>

                            </fieldset>

                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-2 col-md-offset-9">
                            <button type="submit" class="btn btn-primary pull-right" id="">
                                Update Reservation  <span class="glyphicon "></span>
                            </button>
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-primary pull-right" id="" data-dismiss="modal">
                                <span class="glyphicon glyphicon-floppy-remove"></span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
        <fieldset class="the-fieldset">
            <legend class="the-legend">Stay Change</legend>
            <div style="min-height:500px;">
                <div class="hiddenSection">
                    <br />
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group  label-floating change-departure-container" style="margin-top:5px;">
                                <label class="control-label">Reason*</label>
                                <div id="StayChangeReasonComboContainer">
                                    <select name="StayChangeReasonId" id="StayChangeReasonId" class="form-control" required>
                                        <option> </option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group label-floating" style="margin-top:5px;">
                                <label class="control-label">Remark*</label>
                                <textarea maxlength="1000" rows="1" id="StayChange-Remark" name="StayChange-Remark" class="form-control"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group form-group-margin-override label-floating">
                                <label class="control-label">Arrival*</label>
                                @if (ViewBag.ReservationType == "reservation")
                                {
                                    <input type="text" name="From" id="StayChange-ArrivalDate" class="form-control dateSelect inhouse-start-date-picker ArrivalDate disabled" value="@Convert.ToDateTime(ViewBag.arrivalDate).ToShortDateString()" />

                                }
                                else
                                {
                                    <input type="text" name="From" id="StayChange-ArrivalDate" class="form-control dateSelect ArrivalDate disabled" value="@Convert.ToDateTime(ViewBag.arrivalDate).ToShortDateString()" />

                                }
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group form-group-margin-override label-floating">
                                <label class="control-label">Departure*</label>
                                <input type="text" name="To" id="StayChange-DepartureDate" class="form-control dateSelect end-date-picker DepartureDate" value="@Convert.ToDateTime(ViewBag.departureDate).ToShortDateString()" />
                            </div>
                        </div>

                        <div class="col-md-4" style="margin-top:20px;">
                            <input type="button" id="btnSelectDate" value="Check Availability" class="btn btn-primary" />
                        </div>
                    </div>

                    <div class="row">

                        <div class="col-md-2">
                            <div class="form-group form-group-margin-override label-floating">
                                <label class="required control-label">Meal Plan*</label><select name="StayChange-MealPlanId" id="StayChange-MealPlanId" class="form-control" required><option></option></select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group  label-floating">
                                <label class="required control-label">Room Type*</label><select name="StayChange-RoomType" id="StayChange-RoomType" class="form-control" required><option></option></select>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group  label-floating">
                                <label class="control-label">Company*</label>
                                <select required id="StayChange-CompanyId" name="StayChange-CompanyId" class="form-control">
                                    <option value="">-- Select Company --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="form-group  label-floating rate-code-container">
                                <label class="control-label">Rate Code*</label>
                                @{Html.RenderAction("RateCodeHeadersCombo", "RateCodeHeaders", new { area = "Administration", name = "StayChange-RateCodeHeaderId", IBEEnable = ViewBag.IsLocalRate, value = ViewBag.RateCodeHeaderId });}
                            </div>
                        </div>
                    </div>

                </div>

                <div class="availabilityArea">
                    <div class="row grid">
                        <div class="col-md-12 table-responsive">
                            <table class="table table-striped" id="grid" style="display:none; overflow-y:scroll;">
                                <tr>
                                    <th class="">Category</th>
                                    <th class="">Availability</th>
                                    <th class="col-md-1" style="text-align:center"><span data-toggle="tooltip" title="Active / Inactive">Set</span></th>
                                </tr>
                                <tr class="no-record">
                                    <td colspan="4">No Rooms Available for Date Period.</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <input type="button" style="float:right;margin-right:14px; display:none;" id="btnChange" value="Change" class="btn btn-primary" />
                        </div>
                    </div>
                </div>

            </div>
        </fieldset>

    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <fieldset class="the-fieldset">
            <legend class="the-legend">Guest Update</legend>

            <div class="manage-group">
                <div class="table-responsive">
                    <form id="guestGroup">
                        <table class="table table-striped table-hover" id="guestGroupGrid" cellspacing="5">

                            <tr>
                                <th width="50px"></th>
                                <th class="text-primary " input type="text" width="100px">
                                    Res.No
                                </th>
                                <th class="text-primary " input type="text" width="80px">
                                    Room
                                </th>
                                <th class="text-primary " width="80px">
                                    Salutation
                                </th>
                                <th class="text-primary " width="100px">
                                    First Name
                                </th>
                                <th class="text-primary " width="100px">
                                    Last Name
                                </th>
                                <th class="text-primary " width="150px">
                                    Email
                                </th>
                                <th class="text-primary " width="100px">
                                    ContactNo
                                </th>
                                <th class="text-primary " width="120px">
                                    DOB
                                </th>
                                <th class="text-primary " width="120px">
                                    Country
                                </th>
                                <th class="text-primary " width="120px">
                                    Nationality
                                </th>
                            </tr>

                        </table>
                        <div class="form-group ">
                            <input type="submit" id="btnUpdate" disabled="disabled" value="Update" class="btn btn-primary " />
                        </div>
                    </form>
                </div>
            </div>
        </fieldset>

    </div>
</div>

<script src="~/Scripts/ui/common/scienter.frontoffice.layout2.js"></script>
<script src="~/Scripts/ui/common/Scienter.Common.ComboBoxes.js"></script>
<script src="~/Scripts/ui/common/scienter.common.datatimepicker.js"></script>
<script src="~/Scripts/ui/ReservationEdit.js"></script>

@if (Model.Area == "I")
{
    <script>
        $(document).ready(function () {
            setInterval(function () {

                $('#StatusId').prop('disabled', true);
                $('#CompanyId').prop('disabled', true);
                $('#MarketId').prop('disabled', true);
                //$('#SegmentId').prop('disabled', true);
                $('#StatusId').prop('disabled', true);
                $('#NoOfAdults').prop('disabled', true);
                $('#NoOfKids').prop('disabled', true);
                $('#Timerange').prop('disabled', true);
                $('#PackageHeaderId').prop('disabled', true);
                $('#ArriveMeal').prop('disabled', true);
            }, 200);
            LoadReservationStatus();
        });

    </script>
}

<script>
    var countryId = 0;
    $(document).ready(function () {

        LoadCompanies();
        LoadRateCodes();
        LoadMarkets();
        LoadSegments();
        loadVisitPuposeCombo();
        LoadReservationStatus();
        $('#RoomCategory').attr("disabled", true);
        $('#RoomType').attr("disabled", true);

        timeArrival = $('.timeArrival').val();
        $('.resArrivalTime .time-range').val(timeArrival);

        timeDeparture = $('.timeDeparture').val();
        $('.resDepartureTime .time-range').val(timeDeparture);

        $('#ArrivalDate').prop("disabled", true);
        $('#DepartureDate').prop("disabled", true);
        $('#MealPlanId').prop("disabled", true);
    });

    function searchReservation() {

        var input, filter, count, tt, b, i, li;

        input = document.getElementById("txtSearch");
        filter = input.value.toUpperCase();
        ul = document.getElementById("myUL");
        li = ul.getElementsByTagName("li");

        for (i = 0; i < li.length; i++) {
            b = li[i].getElementsByTagName("label")[0];
            if (b.innerHTML.toUpperCase().indexOf(filter) > -1) {
                li[i].style.display = "";
            } else {
                li[i].style.display = "none";

            }
        }
    }
</script>


