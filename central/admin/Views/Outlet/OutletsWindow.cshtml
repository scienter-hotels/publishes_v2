<form id="outletForm">
    <div class="col-md-4"></div>
    <div class="col-md-4">
        <div class="card" style="margin-top:90px; height:250px;">
            <div class="card-header card-header-icon" style="padding-bottom:5px;" data-background-color="purple">
                <div class="row">
                    <div class="col-md-12" style="padding-top:11px; text-align:right;">
                        <span href="http://www.scienter.lk" target="_blank">
                            <img src="~/Images/destinity-horizon-logo.png" width="300px" />
                        </span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-1"> </div>
                <div class="col-md-10">

                    <div class="form-group label-floating">
                        <label class="control-label">Outlet</label>
                        <select id="outletCombo" name="outlet" class="form-control @*font-size-16px*@" required>
                          
                        </select>
                    </div>
                    <div class="form-group text-center">
                        <input type="submit" id="btnSave" value="Select" class="btn btn-primary" />
                    </div>
                </div>
                <div class="col-md-1"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4"> </div>
</form>
<script>
    $(document).ready(function () {

        FillOutletCombo();
    });
    //--------------------------------------------------------------------------------------------------------
    function FillOutletCombo() {
        $.ajax({
            url: '/Outlet/selectuserwiseOutlets',
            dataType: 'json',
            success: function (data) {
                $('#outletCombo').find('option').not(':first-child').remove();
                $.each(data, function (index, outlet) {
                    $('<option  value="' + outlet.Code + '">' + outlet.Description + '</option>').appendTo($('#outletCombo'));
                });
            },
        });
    }
    //--------------------------------------------------------------------------------------------------------
    $('body').on('submit', '#outletForm', function (e) {
        e.preventDefault();
        var outletCode = $('#outletCombo').val();
        $.ajax({
            url: '/outlet/SetUserWiseOutlets?outletCode=' + outletCode,
            dataType: 'json',
            success: function (data) {
                if (data.startsWith('ERR-')) {
                    ShowErrorMessage(data.replace("ERR-", ""));
                } else {
                    window.location.href = '/dashboard/landing/'
                }
            }
        });

    });

</script>