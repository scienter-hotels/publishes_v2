                                    '<th style="width:75%; padding-left:10px;">ITEM</th>' +
                                     '<th style="width:25%; text-align:right">AMOUNT</th>' +
                                 '</tr>  ';

        var tableTr = '<tr><td style="width:75%; padding-left:10px; padding-top:10px!important;">' + invoiceData.billType + '-' + invoiceData.folioText + '</td><td style="width:25%; text-align:right; padding-top:10px!important;">' + invoiceData.amount+ '</td><tr>'
        var tableEnd = '</thead>' +
                '</table>';
        tableAll = table + tableTr + tableEnd;

        $(tableAll).appendTo($('#ReportBody1'));

        $('<tr>').appendTo($('#chargeCalculation'));

        var a1 = '<div id="sliding-div" style="background-color:none">', a2 = '', a3 = '</div>';

        a2 = '<table class="table-posting report-width100perc" style="width:100%">' +
                             ' <tr>' +
                                  '<th></th>' +
                                 ' <th></th>' +
                                  '<td class="" style="width:70%;background-color:#fff!important;">' +
            '<div class="row" style="padding-left:20px;"><b>Room#:</b></div>' +
            '<div class="row room-Id-each-table" style="padding-top:10px; padding-bottom:10px; padding-left:20px; font-size:30px" id="roomCode">' + invoiceData.roomIds + '</div>' +
                                  '</td>' +
            '<td class="" style="width:30%;background-color:#fff!important;">' +
            '<div class="row"><b>Res No:&nbsp</b>' + invoiceData.reservationNo + '</div>' +
            '<div class="row RptinvoiceNo"><b>Receipt#:&nbsp </b>	' + invoiceData.invoiceNo + '</div>' +
            '<div class="row">  <b>Date:&nbsp</b>' + invoiceData.chargeDate + '</div>' +
                                         // '<div class="row">  <b>User:&nbsp</b>'+@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Username+'</div>' +
                                 ' </td>' +
                             '</tr>' +
            '</table>'+
            '<input type="hidden" name="ExtraPostingId" id="ExtraPostingId" value="'+id+'" />'; 

        var x = a1 + a2 + a3;
        $(x).appendTo('#easyPaginate2')
        $('#sliding-div').easyPaginate({
            paginateElement: 'table',
            elementsPerPage: 1,
            effect: 'slide'
        });

    });

    function LoadTaxDetails(id) {
        
        $.ajax({
            url: '/CashieringAndPosting/Posting/LoadPendingExtraPostingTaxDetail',
            dataType: 'html',
            data: { id: id},
            method: 'POST',
            success: function (response) {
                $('#TaxLoadingArea').html(response)
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error.');
            }
        });

    }

