@model Scienter.HotelERP.Common.Domain.CompanyWiseContacts

@{
    ViewBag.Title = "Create / Edit";
}
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>

<div class="col-md-12">

    <form id="companywisecontacts">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />
            <input type="hidden" value="@Model.RepresentativeList" name="RepresentativeList" id="RepresentativeList" class="RepresentativeList" />
            <input type="hidden" value="@Model.CompanyId" name="Id" id="companyId" />

            <div class="row">
                <div class="col-md-7">

                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Company</label>
                            @{Html.RenderAction("CompaniesCombo", "Companies", new { name = "CompanyId", value = Model?.CompanyId });}
                        </div>
                    </div>

                    <div class="col-md-1"></div>

                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Name</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="representativename" name="RepresentativeName" type="text" value="@Model.RepresentativeName">
                        </div>
                    </div>
                    <div class="col-md-1"></div>
                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Email</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="representativeemail" name="Email" type="text" value="@Model.RepresentativeName">
                        </div>
                    </div>
                    <div class="col-md-1"></div>
                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Contact No</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="contactno" name="ContactNo" type="text" value="@Model.RepresentativeName">
                        </div>
                    </div>
                    <div class="col-md-1"></div>
                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Designation</label>
                            @{Html.RenderAction("DesignationCombo", "Designations", new { name = "DesignationId", value = Model?.DesignationId });}
                        </div>
                    </div>
                    <div class="col-md-1"></div>
                    <div class="col-md-5">
                        <div class="form-group label-floating">
                            <label class="control-label">Address</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="representativeaddress" name="Address" type="text" value="@Model.RepresentativeName">
                        </div>
                    </div>

                </div>
                <div class="col-md-5">
                    <div class="col-md-12">
                        <div class="col-md-12 table-responsive">
                            <div id="order-listing_wrapper" class="dataTables_wrapper container-fluid dt-bootstrap4 no-footer">
                                <div class="row" style="overflow-y:auto; ">
                                    <div class="col-sm-12">
                                        <table class="table table-striped representativeList" id="companywiserepresentative">
                                            <tr class="data-company-row">
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>ContactNo</th>
                                                <th></th>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-5">
                    <input type="button" id="add-company-wise-representatives" value="Add" class="btn btn-primary" />
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('#CompanyId').addClass('select2');
        $('#DesignationId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

    //-------------------------------------------------------------------------------------------

        if ($('.RepresentativeList').val().length != 0) {
            var Representatives = $('.RepresentativeList').val();
            if (Representatives != null) {
                DrawCompanyWiseRepresentativesGrid($.parseJSON(Representatives));
            }
        }
    });

    function DrawCompanyWiseRepresentativesGrid(repArr) {

        $('#companywiserepresentative tr').not(':first').remove();

        $.each(repArr, function (index, eachItem) {
            $('#companywiserepresentative').append(
                ' <tr class="data-company-row">' +
                '<td>' + eachItem.RepresentativeName + '</td>' +
                '<td>' + eachItem.RepresentativeEmail + '</td>' +
                '<td>' + eachItem.RepresentativeContactNo + '</td>' +
                ' <td style="text-align:right;">' +
                '<a class="btn btn-icons btn-inverse-secondary company-editbtn-id" CompanyId="' + eachItem.Id + '" representativename="' + eachItem.RepresentativeName + '" representativeemail="' + eachItem.RepresentativeEmail + '" contactno="' + eachItem.RepresentativeContactNo + '" DesignationId="' + eachItem.DesignationId + '" representativeaddress="' + eachItem.RepresentativeAddress + '" ><span class="glyphicon glyphicon-pencil"></span></a >' +
                '</td >' +
                '</tr>'
            );
        })
    }

