@{
    ViewBag.Title = "_HouseKeepingStatusAndGuestHistory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #eeeeee !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
        background-color: #eeeeee;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    </style>
<div class="row">
    <div class="col-md-3">
        <div class="form-group label-floating">
            <label class="control-label">From Date</label>
            <div id="dobContainerInGuestProfiles" class="input-group date">
                <input autocomplete="off" class="form-control text-box single-line datePickerNoRestriction" maxlength="100" name="FromDateFilter" id="FromDateFilter" type="text">
                <span class="input-group-addon">
                    <span class="glyphicon glyphicon-calendar"></span>
                </span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-group label-floating">
            <label class="control-label">To Date</label>
            <div id="dobContainerInGuestProfiles" class="input-group date">
                <input autocomplete="off" class="form-control text-box single-line datePickerNoRestriction" maxlength="100" name="ToDateFilter" id="ToDateFilter" type="text">
                <span class="input-group-addon">
                    <span class="glyphicon glyphicon-calendar"></span>
                </span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-group form-group-margin-override label-floating">
            <label class="required control-label">Room</label>
            @{Html.RenderAction("RoomDetailCombo", "RoomDetails", new { area = "Administration", name = "RoomId", requiered = true });}
            @*<select name="RoomId" id="RoomId" class="form-control">
                    <option value="N/A" class="do-not-delete">N/A</option>
                </select>*@
        </div>
    </div>
    <div class="col-md-2" style="padding-top:23px;">
        <input type="submit" id="btnFilterHistoryDetail" value="SEARCH" class="btn btn-primary do-not-disable" style="width:100%" />
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <fieldset class="the-fieldset">
            <legend class="the-legend"><font size="2"></font> Guest History </legend>
            <div id="GuestHistoryList" style="height:420px; overflow-x:hidden; overflow-y:scroll;">
                <table class="table table-striped table-hover" id="guestHistoryGrid" cellspacing="5">
                    <tr>
                        <th class="text-primary " input type="text">
                            Res.#
                        </th>
                        <th class="text-primary " input type="text">
                            Arrival
                        </th>
                        <th class="text-primary " input type="text">
                            Departure
                        </th>
                        <th class="text-primary " input type="text">
                            Reservation Date
                        </th>
                        <th class="text-primary " input type="text">
                            Guest Name
                        </th>
                        <th class="text-primary " input type="text">
                            Guest Type
                        </th>
                    </tr>
                </table>
            </div>
        </fieldset>
    </div>
    <div class="col-md-6">
        <fieldset class="the-fieldset">
            <legend class="the-legend"><font size="2"></font> House Keeping </legend>
            <div id="HouseKeepingList" style="height:420px; overflow-x:hidden; overflow-y:scroll;">
                <table class="table table-striped table-hover" id="houseKeepingGrid" cellspacing="5">
                    <tr>
                        <th class="text-primary " input type="text">
                            RoomCode
                        </th>
                        <th class="text-primary " input type="text">
                            Date
                        </th>
                        <th class="text-primary " input type="text">
                            Room Status
                        </th>
                        <th class="text-primary " input type="text">
                            Status Category
                        </th>
                    </tr>
                </table>
            </div>
        </fieldset>
    </div>
</div>

<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------

        $('#RoomId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------


        //$('.datePicker').daterangepicker({
        //    "showDropdowns": true,
        //    "showWeekNumbers": true,
        //    "showISOWeekNumbers": true,
        //    "singleDatePicker": true,
        //   // "maxDate": $('#hotelDate').val(),
        //    //'Custom Range': 'custom',
        //    //"yearRange": '1980:2018',
        //    "changeYear": true,
        //    "changeMonth": true,
        //    "opens": "right",
        //    "applyClass": "btn-primary",
        //    "dateLimit": {
        //        "days": false
        //    },
        //    locale: {
        //        format: 'YYYY-MM-DD'
        //    }
        //});

        $('.datePickerNoRestriction').daterangepicker({
            "showDropdowns": true,
            "singleDatePicker": true,
            //"maxDate": $('#hotelDate').val(),
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "opens": "right",
            "applyClass": "btn-primary",
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#loadingPot').show();
        $('#FromDateFilter').val('');
        $('#ToDateFilter').val('');

    });

    $('body').off('click', '#btnFilterHistoryDetail').on('click', '#btnFilterHistoryDetail', function () {

        var fromDate = ChangeDateFormat( $('#FromDateFilter').val());
        var toDate = ChangeDateFormat($('#ToDateFilter').val());
        var roomId = $('#RoomId').val();

        $.ajax({
            method: 'get',
            url: '/HouseKeeping/UpdateHouseKeepingStatus/SelectHouseKeepingStatusAndGuestHistory?roomId=' + roomId + '&fromDate=' + fromDate + '&toDate=' + toDate,
            datatype: 'json',
            beforeSend: function () {
                $('#houseKeepingGrid tr').not(':first-child').remove();
                $('#guestHistoryGrid tr').not(':first-child').remove();
            },
            success: function (data) {

                if (data !== undefined) {
                    try {
                        var houseKeepingobj = $.parseJSON(data.HouseKeeping);
                        $.each(houseKeepingobj, function (index, item) {
                            $('<tr class="data-single-filteration">' +
                                '<td>' +
                                item.RoomCode +
                                '</td>' +
                                '<td>' +
                                item.TxnDate +
                                '</td>' +
                                '<td>' +
                                item.RoomStatus +
                                '</td>' +
                                '<td>' +
                                item.RoomStatusCategory +
                                '</td>' +
                                '</tr>'
                            ).appendTo("#houseKeepingGrid");
                        });

                        var guestHistoryobj = $.parseJSON(data.GuestHistory);
                        $.each(guestHistoryobj, function (index1, item1) {
                            $('<tr class="data-single-filteration">' +
                                '<td>' +
                                item1.ReservationNo +
                                '</td>' +
                                '<td>' +
                                item1.Arrival +
                                '</td>' +
                                '<td>' +
                                item1.Departure +
                                '</td>' +
                                '<td>' +
                                item1.ReservationDate +
                                '</td>' +
                                '<td>' +
                                item1.Name +
                                '</td>' +
                                '<td>' +
                                item1.GuestProfileType +
                                '</td>' +
                                '</tr>'
                            ).appendTo("#guestHistoryGrid");
                        });
                    }
                    catch (errror) {
                        console.error("Not a JSON response")
                    }
                }
            },
        });

    });

</script>
