@using  Scienter.HotelERP.Common.Domain
@model   List<ReservationSideButtons> 

<style>

    .panel-default {
        border: none;
    }

    .panel-body-padding {
        padding-top: 0px !important;
    }

    #reservationGrid {
        margin-top: -20px;
    }

    .searchDate .form-group {
        margin: 0px;
        padding-bottom: 0px;
    }
    /*.highlight {
        background-color: red;
    }*/
    .listLoadingArea td {
        padding: 0px 4px !important;
    }

    .listLoadingArea .glyphicon-bell, .listLoadingArea .fa-taxi {
        padding-left: 5px !important;
    }

    .highlight {
        background-color: darkseagreen !important;
    }

    .listLoadingArea {
        min-height: 430px;
    }

    #pageNoLine {
        text-align: right;
    }

    .table thead > tr > td, .table tbody > tr > td, .table tfoot > tr > td {
        font-size: 11px;
    }

    .current-page-no {
        margin-right: 20px;
        font-weight: bold;
    }

    .listLoadingArea th {
        padding: 4px 4px !important;
    }

    .data-page-no-btn {
        border: 1px solid #b0b0b0 !important;
        margin-left: 3px !important;
    }

        .data-page-no-btn:hover {
            background-color: #b45b23 !important;
        }

    .listLoadingArea tr:nth-child(even) {
        background-color: #e9e9e9;
    }

    .searchPara {
        width: 100%;
        border: 1px solid #ccc;
    }

    .scroll-content ::-webkit-scrollbar {
        width: 8px;
    }

    .scroll-content ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .scroll-content ::-webkit-scrollbar-thumb {
        background: #888;
    }

    .reservation-filter-area .checkbox label, .radio label, label {
        font-size: 10px;
        line-height: 12px;
        color: #000000;
        font-weight: 400;
    }

    .reservation-filter-area .form-group {
        padding-bottom: 10px;
        margin: 10px 0 0 0;
    }

        .reservation-filter-area .form-group .form-control {
            margin-top: -46px;
            font-size: 12px;
        }

        .reservation-filter-area .form-group input {
            padding-top: 23px;
        }

    .input-group .input-group-addon {
        vertical-align: top;
        padding-top: 0;
    }
</style>
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-11">
                        <h4 class="title">
                            @ViewBag.Title (@ViewBag.CurrentHistory.ToUpper())
                            <hr class="visible-print" />
                        </h4>
                    </div>

                    @*<div class="col-md-1"></div>*@

                    <div class="col-md-1 text-right hidden-print">   
                        
                        <a class="btn btn-sm btn-theme-color-2" href="~/reservation/reservations/makereservation">
                            <span class="glyphicon glyphicon-plus"></span>
                        </a>
                        <a class="btn btn-sm  btn-theme-color-2" href="~/reservation/reservations/list">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea" style="padding-left:15px; padding-right:15px;">

                <div class="row hidden-on-checkout reservation-filter-area">
                    <div class="col-md-12">
                        <div style="padding:10px; padding-bottom:3px; padding-top:6px; margin-bottom:10px; margin-top:-10px; background-color:#f2f2f2; border:1px solid #c3c3c3; border-radius:2px;">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="row">
                                        <div class="col-md-5">
                                            <label>Res. Status</label>   
                                            <select id="reservationStatus-list" style="margin-top:-29px; font-size:12px; line-height: 36px;" name="" class="form-control">
                                                <option value="-1" selected>All-Without-Cancel</option>
                                                <option value="0">All</option>
                                            </select>
                                        </div>
                                        <div class="col-md-7">
                                            <label>Search</label>
                                            <input class="txtSearch form-control" style="margin-top:-29px; font-size:12px;" type="text" id="searchby" placeholder="" title="Search by any Column">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="row">                                   
                                        <div class="col-md-2">
                                            <label>Sort By</label>
                                            <select id="SortColumn-list" style="margin-top:-29px; font-size:12px; line-height: 36px;" name="" class="form-control"></select>
                                        </div>
                                        <div class="col-md-2">
                                            <label></label>
                                            <select id="SortType-list" style="margin-top:-29px; font-size:12px; line-height: 36px;" name="" class="form-control">
                                                <option value="ASC">A-Z</option>
                                                <option value="DESC">Z-A</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <div class="row" id="filerReservationCalender">                                               
                                                <div class="col-md-5 searchDate">
                                                    <label>From</label>
                                                    <div id="" class="input-group ">
                                                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" name="DateFilterFromReservation" id="DateFilterFromReservation" type="text">
                                                        <span class="input-group-addon">
                                                            <span class="glyphicon glyphicon-calendar"></span>
                                                        </span>
                                                    </div>
                                                </div>

                                         
                                                <div class="col-md-5 searchDate">
                                                    <label>To</label>
                                                    <div id="" class="input-group ">
                                                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" name="DateFilterToReservation" id="DateFilterToReservation" type="text">
                                                        <span class="input-group-addon">
                                                            <span class="glyphicon glyphicon-calendar"></span>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" style="width:100%; background-color:#b45b23" class="applyBtn btn btn-default btn-sm">Search</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                
                               
                            </div>
                        </div>
                    </div>
                </div>




                <div class="row">
                    <div class="col-md-12" id="reservationGrid">

                        <center id="loading-pot" style="margin:0px auto;width:100px;">
                            <img src="~/Images/loading_pot.gif" style="width:100px; margin: 0 auto; margin-top:100px;" />
                        </center>

                        <div class="listLoadingArea" id="content" style="padding-top:15px;">
                            @if (ViewBag.type == "checkout")
                            {
                                <script>
                                    $('.hidden-on-checkout').hide();
                                </script>
                                <div class="">
                                    <div class="row">
                                        <div class="col-md-12 " id="main-grid-content">
                                            <div class="table-responsive">
                                                <table class="table font-size-12px" id="existingReservationGrid">
                                                    <tr>
                                                        <th class="text-primary"></th>
                                                        <th class="text-primary"> </th>
                                                        <th class="text-primary">Arrival</th>
                                                        <th class="text-primary"> Departure </th>
                                                        <th class="text-primary"> Group# </th>
                                                        <th class="text-primary col-md-1">Res#</th>
                                                        <th class="text-primary">Guest</th>
                                                        <th class="text-primary">Company </th>
                                                        <th class="text-primary">Vouch# </th>
                                                        <th class="text-primary col-md-1">Category </th>
                                                        <th class="text-primary">Room Type</th>
                                                        <th class="text-primary" width="60px">A.#</th>
                                                        <th class="text-primary">K.#</th>
                                                        <th class="text-primary col-md-1">Room#</th>
                                                        @*<th class="text-primary col-md-1">Credit Enable</th>*@
                                                        <th class="text-primary col-md-1">Status</th>
                                                        <th class="text-primary hidden">Res. Status </th>
                                                        <th></th>
                                                        <th></th>
                                                        <th class="text-primary"></th>
                                                        <th class="hidden"></th>
                                                        <th class="hidden"></th>
                                                    </tr>
                                                    @*second row*@
                                                    <tr>
                                                        <th class="text-primary"></th>
                                                        <th class="text-primary"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchArrival" size="5"> </th>

                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchDeparture" size="5"> </th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchGroupNo" size="5"> </th>
                                                        <th class="text-primary col-md-1"><input type="text" class="searchPara" id="searchResNo" size="5"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchGuest" size="5"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchCompany" size="5"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchVouchNo" size="5"></th>
                                                        <th class="text-primary col-md-1"><input type="text" class="searchPara" id="searchCategory" size="5"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchRoomType" size="5"></th>
                                                        <th class="text-primary" width="60px"><input type="text" class="searchPara" id="searchANo" size="5"></th>
                                                        <th class="text-primary"><input type="text" class="searchPara" id="searchKNo" size="5"></th>
                                                        <th class="text-primary col-md-1"><input type="text" class="searchPara" id="searchRoomNo" size="5"></th>
                                                        @*<th class="text-primary col-md-1"><input type="text" class="searchPara" id="searchIsCreditEnable" size="5"></th>*@
                                                        <th class="text-primary col-md-1"><input type="text" class="searchPara" id="searchStatus" size="5"></th>
                                                        <th class="text-primary hidden">Res. Status</th>
                                                        <th colspan="4"><button type="button" style="width:100%; background-color:#b45b23" class="searchBtn btn btn-default btn-sm">Search</button></th>

                                                    </tr>

                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div id="pageNoLine">
                            
                        </div>
                    </div>
                    <div class="scroll-content">
                        <div class="col-md-2" id="reservationOptions" style="overflow-y:auto; overflow-x:hidden; display: none; position: fixed;z-index: 53;background-color: #ffffff; right: 30px;top: 58px;padding: 30px;padding-top: 15px;padding-right: 17px;padding-bottom: -7px;padding-bottom: 5px;box-shadow: 0px 1px 10px 0px #838383;width:235px; ">
                            @Html.Partial("_SideButtons", Model)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@{
    DateTime hotelDate = Scienter.HotelERP.Common.Domain.SessionObjects.FOSettings.CurrentDate;
}
<input type="hidden" id="From" name="From" value="@hotelDate.ToString("yyyy-MM-dd")" />
<input type="hidden" id="To" name="To" value="@hotelDate.AddDays(30).ToString("yyyy-MM-dd")" />

<input type="hidden" id="defaultToDate" value="@hotelDate.AddDays(60).ToString("dd/MM/yyyy")" />
<input type="hidden" id="defaultFromDate" value="@hotelDate.AddDays(0).ToString("dd/MM/yyyy")" />

<input type="hidden" id="defaultToDateCheckout" value="@hotelDate.AddDays(-60).ToString("dd/MM/yyyy")" />
<input type="hidden" id="defaultFromDateCheckout" value="@hotelDate.AddDays(0).ToString("dd/MM/yyyy")" />

<input type="hidden" id="arrivalDate" />
<input type="hidden" id="departureDate" />

<input type="hidden" value="@HttpContext.Current.Session["ResNo"].ToString()" id="resNo" />

<input type="hidden" id="type" value="@ViewBag.type" />
<input type="hidden" id="CurrentHistory" value="@ViewBag.CurrentHistory" />
<input type="hidden" id="reservation-uuid" value="@ViewBag.Uuid" />

<input type="hidden" id="hdn-index" value="1" />
<input type="hidden" id="hdn-noOfPages" value="0" />
@*<script src="~/Scripts/ui/common/scienter.grid2.js"></script>*@
<script src="~/Scripts/ui/common/Scienter.Common.TimeFormat.js"></script>
<script>
    // form load --------------------------------
    var resNo = $('#resNo').val();
    var ReservationHeaders = "";
    var InhouseReservationHeaders = "";
    var CheckedOutReservationHeaders = "";
    var gridId = "#existingReservationGrid";
    var reservationStatus = 3;
    var searchValue = "";
    var windowHeight = $(window).height();

    var contentHeight = $('#content').height();

    var SortType = "";
    var SortColumn = "";

    $(document).ready(function () {
        LoadReservationstatus();
        LoadSortingColumnList();

        if (windowHeight > 661) {
            $('#reservationOptions').css('right', '40px')
            $('#reservationOptions').height(windowHeight - 156);
            $('.card').css('min-height',(windowHeight - 116));

        }
        else {
            $('#reservationOptions').height(windowHeight - 120);
            $('.card').css('min-height', (windowHeight - 80));
        }


        searchValue = GetParameterValuesForReservationList('search');
        $('#searchby').val(searchValue);

        if ($('#type').val() == "inhouse") {
         //   $('#filerReservationCalender').hide();
            $('.searchDate').hide();
            $('.searchDateLabel').hide();
        }

        $('#DateFilterFromReservation').daterangepicker({
            "showDropdowns": true,
            singleDatePicker: true,
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "opens": "right",
            "applyClass": "btn-primary",
            locale: {
                format: 'DD/MM/YYYY'
            }
        }, function (start, end, label) {
            $('input[name="From"]').val(start.format('DD/MM/YYYY'));
        });

        $('#DateFilterToReservation').daterangepicker({
            "showDropdowns": true,
            singleDatePicker: true,
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "opens": "right",
            "applyClass": "btn-primary",
            locale: {
                format: 'DD/MM/YYYY'
            }
        }, function (start, end, label) {
            $('input[name="To"]').val(end.format('DD/MM/YYYY'));
        });

        //ScorelToTop60px();
        if ($('#type').val() == "reservation") {

            $('#DateFilterFromReservation').val($('#defaultFromDate').val());
            $('#DateFilterToReservation').val($('#defaultToDate').val());

            $('#DateFilterFromReservation').daterangepicker({
               // "minDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true, locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateFilterToReservation').daterangepicker({
               // "minDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

        }

        if ($('#CurrentHistory').val() == "history") {
            $('#DateFilterFromReservation').val($('#defaultFromDate').val());
            $('#DateFilterToReservation').val($('#defaultToDate').val());

            $('#DateFilterFromReservation').daterangepicker({
              //  "minDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true, locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateFilterToReservation').daterangepicker({
              //  "minDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });
        }

        if ($('#type').val() == "checkout") {

            $('#DateFilterToReservation').val($('#defaultFromDateCheckout').val());
            $('#DateFilterFromReservation').val($('#defaultToDateCheckout').val());

            $('#DateFilterFromReservation').daterangepicker({
                // "maxDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true, locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateFilterToReservation').daterangepicker({
                "maxDate": $('#hotelCurrentDate').val(),
                singleDatePicker: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });
        }
        var fromDt = $('#DateFilterFromReservation').val();
        var toDt = $('#DateFilterToReservation').val();
        $('#From').val(ChangeDateFormat(fromDt));
        $('#To').val(ChangeDateFormat(toDt));

        //var paginations = {
        //    //PageIndex: 1,
        //    PageSize: 10,
        //    PageIndex: $(gridId).closest('.grid-container').attr('data-page-index'),
        //   // PageSize: $(gridId).closest('.grid-container').attr('data-page-size'),
        //    FilterType: $(gridId).closest('.grid-container').attr('data-filter-type'),
        //    SearchKeyword: $(gridId).closest('.grid-container').attr('data-search-keyword'),
        //    CurrentHistory: $('#CurrentHistory').val(),
        //    tempValue: $('#reservation-uuid').val(),
        //    FromDate: $('#From').val(),
        //    ToDate: $('#To').val()
        //}
        //FillGrid(paginations);
        var paginations = Paginations(1);
        $('.searchPara').val('');

          FillGrid(paginations);



    });

    function LoadReservationstatus() {
        var URL = "/Administration/ReservationStatus/ReservationStatusJson";
        $.ajax({
            url: URL,
            dataType: 'json',
            method: 'POST',
            beforeSend: function () {
                 //$('#reservationStatus-list option').remove();
            },
            success: function (data) {
                $(data).each(function (index, item) {
                    //var selected = "";
                    //if (item.Id == 3) {
                    //    selected = "selected";
                    //}
                    //$('<option value="' + item.Id + '" ' +selected+' >' + item.Name + '</optoin>').appendTo($('#reservationStatus-list'));
                    
                    $('<option value="' + item.Id + '">' + item.Name + '</optoin>').appendTo($('#reservationStatus-list'));
                });
            },
           
        });
    }

    function LoadSortingColumnList() {
        var URL = "/Reservation/Reservations/ReservationSortingColumnListSelect";
        $.ajax({
            url: URL,
            dataType: 'json',
            method: 'POST',
            beforeSend: function () {
            },
            success: function (data) {
                $(data).each(function (index, item) {
                    $('<option value="' + item.Value + '">' + item.Label + '</optoin>').appendTo($('#SortColumn-list'));
                });
            },

        });
    }

    //window.addEventListener('scroll', (event) => {
    //    console.log('Scrolling...');
    //});

    var lastStrokeDate = new Date();
    var isOkayToCallSearch = false;
    $('body').on('keyup', '.txtSearch', function (e) {
        lastStrokeDate = new Date();
        isOkayToCallSearch = true;

        setInterval(function () {
            var diff = new Date(new Date() - lastStrokeDate);
            if (diff > 2000) {

                if (isOkayToCallSearch) {
                    $('.txtSearch').attr('disabled',true);
                    var fromDt = $('#DateFilterFromReservation').val();
                    var toDt = $('#DateFilterToReservation').val();
                    $('#From').val(ChangeDateFormat(fromDt));
                    $('#To').val(ChangeDateFormat(toDt));

                    var paginations = Paginations(1);
                    FillGrid(paginations);

                    isOkayToCallSearch = false;

                }
            }
        }, 1000);


    });

    $('.txtSearch').keypress(function (e) {
        var key = e.which;
        if (key == 13)  // 13 is the key code for enter key
        {
            $('.txtSearch').attr('disabled', true);
            var fromDt = $('#DateFilterFromReservation').val();
            var toDt = $('#DateFilterToReservation').val();
            $('#From').val(ChangeDateFormat(fromDt));
            $('#To').val(ChangeDateFormat(toDt));

            var paginations = Paginations(1);
            FillGrid(paginations);
        }
    });

    $('body').on('change', '#reservationStatus-list', function (e) {
        var fromDt = $('#DateFilterFromReservation').val();
        var toDt = $('#DateFilterToReservation').val();
        $('#From').val(ChangeDateFormat(fromDt));
        $('#To').val(ChangeDateFormat(toDt));

        var paginations = Paginations(1);
        FillGrid(paginations);
    });

    $('body').on('click', '.applyBtn', function (e) {
      
        var fromDt = $('#DateFilterFromReservation').val();
        var toDt = $('#DateFilterToReservation').val();
        $('#From').val(ChangeDateFormat(fromDt));
        $('#To').val(ChangeDateFormat(toDt));

        var paginations = Paginations(1);
        FillGrid(paginations);
    });

    //$('body').on('click', '.apply-btn-search', function (e) {
    //    alert('aa');
    //    var fromDt = $('#DateFilterFromReservation').val();
    //    var toDt = $('#DateFilterToReservation').val();
    //    $('#From').val(ChangeDateFormat(fromDt));
    //    $('#To').val(ChangeDateFormat(toDt));

    //    var paginations = Paginations(1);
    //    FillGrid(paginations);
    //});

    function Paginations(pageIndex) {
        var searchBy = "";

        if ($('#searchby').val().length > 0) {
            searchBy = $('#searchby').val();
          //  window.location.href = "/reservation/reservations/list/";
            var originalUrl = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&');
            var reservationType = $('#reservationLevel').val();
            var redirectionUrl = '/reservation/reservations/list/' + reservationType + '?search=' + searchBy;

            if (searchBy != searchValue) {
                window.location.href = redirectionUrl;
            }
            
            //alert(redirectionUrl);
            //alert(redirectionUrl);
        }

        //if ($('#reservationStatus-list').val()>0) {
        //    reservationStatus = $('#reservationStatus-list').val();
        //}
        reservationStatus = $('#reservationStatus-list').val();
        SortType = $('#SortType-list').val();
        SortColumn = $('#SortColumn-list').val();

        if (windowHeight > 661) {
            var paginations = {
                PageIndex: pageIndex,
                PageSize: 17,
                FilterType: $(gridId).closest('.grid-container').attr('data-filter-type'),
                SearchKeyword: searchBy,
                CurrentHistory: $('#CurrentHistory').val(),
                tempValue: $('#reservation-uuid').val(),
                FromDate: $('#From').val(),
                ToDate: $('#To').val(),
                ReservationStatus: reservationStatus,
                SortType: SortType,
                SortColumn: SortColumn
            }
        }
        else {
            var paginations = {
                PageIndex: pageIndex,
                PageSize: 10,
                FilterType: $(gridId).closest('.grid-container').attr('data-filter-type'),
                SearchKeyword: searchBy,
                CurrentHistory: $('#CurrentHistory').val(),
                tempValue: $('#reservation-uuid').val(),
                FromDate: $('#From').val(),
                ToDate: $('#To').val(),
                ReservationStatus: reservationStatus,
                SortType: SortType,
                SortColumn: SortColumn
            }
        }

        sessionStorage.setItem("reservationListIndex", pageIndex);
        

        return paginations;
    }

    $('body').on('click', '.showForm', function (e) {
        window.location.href = '/reservation/reservations/makereservation';
    });

