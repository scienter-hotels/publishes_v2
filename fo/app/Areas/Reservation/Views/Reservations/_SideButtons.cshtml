    function CheckCancelRequest() {

        var groupResNo = $('input[class="data-reservation-no"]:checked').closest('tr').find('.group-res-no').html() == null ? $('input[class="data-reservation-no"]:checked').closest('tr').find('.group-res-no').html() : $('input[class="data-reservation-no"]:checked').closest('tr').find('.group-res-no').html().trim();
        var ResheaderId = $('input[class="data-reservation-no"]:checked').val();
        var HasAdvancePayment = $('input[class="data-reservation-no"]:checked').attr('data-HasAdvancePaymentRecord');
        var IsAllowedToCancel = $('input[class="data-reservation-no"]:checked').attr('data-isAllowedToCancel');
        var resNo = $('input[class="data-reservation-no"]:checked').closest('tr').find('.res-no').html().trim();
        var ResUuid = $('input[class="data-reservation-no"]:checked').attr('res-Uuid');
        var cancelReservationUrl = '/Reservation/CancelReservation/CancelReservationByHeaderId?ReservationHeaderId=' + ResheaderId + '&Uuid=' + ResUuid;
        var cancelGroupReservationUrl = '/Reservation/CancelReservation/CancelReservationByGroupResNo?groupReservationNo=' + groupResNo + '&Uuid=' + ResUuid;
        var popUpTitle = "";
        popUpTitle = "Cancel Reservation : " + resNo;

        if (groupResNo != "" && groupResNo != null) {
            if (HasAdvancePayment == "true") {
                //cancelReservationUrl = '/Reservation/reservations/AdvancePaymentRefundPopup';
                //CallDetailModelSimple(popUpTitle, cancelReservationUrl, 600);
                ShowWarningMessage('This reservation has an advance payment please refund the advance payment and cancel the reservation.');
            }
            else if (IsAllowedToCancel == 'False') {
                $('.cancelReservation').attr('data-title', "NA");
                ShowWarningMessage('The arrival date is passed');
            } else {
                CallDetailModelSimple(popUpTitle, cancelGroupReservationUrl, 600);
            }
        }
        else {
            if (HasAdvancePayment == "true") {
                //cancelReservationUrl = '/Reservation/reservations/AdvancePaymentRefundPopup';
                //CallDetailModelSimple(popUpTitle, cancelReservationUrl, 600);
                ShowWarningMessage('This reservation has an advance payment please refund the advance payment and cancel the reservation.');
            }
            else if (IsAllowedToCancel == 'False') {
                $('.cancelReservation').attr('data-title', "NA");
                ShowWarningMessage('The arrival date is passed');
            } else {
                CallDetailModelSimple(popUpTitle, cancelReservationUrl, 600);
            }
        }

    }

    // email-reservation-confirmation
    $('body').on('click', '.email-reservation-confirmation', function (e) {
        var reservationUuid = $('input[class="data-reservation-no"]:checked').attr('res-Uuid');
        $.ajax({
            url: '/Reservation/Reservations/SendEmailConfirmation?uuid=' + reservationUuid,
            dataType: 'json',
            method: 'get',
            success: function (response) {
                if (response == "OK") {
                    ShowSuccessMessage("Conformation email sent.");
                } else {
                    ShowErrorMessage(response);
                }
            },
        });
    });

