        $('body').off('click', '.btn-apply-allotment').on('click', '.btn-apply-allotment', function (e) {
            
            e.preventDefault();
            var ReservationHeaderId = $('#ReservationHeaderIdForAllotment').val();
            var AllotmentHeaderId = $(this).attr('AllotmentHeaderId');
            var RoomCategoryId = $(this).attr('RoomCategoryId');
           
            var selectedReservationList = [];
            var isRecordSelected = false;

            $('.data-single-filteration').each(function (index, item) {
                if ($($(item).find('.list-checkBox')).prop('checked')) {
                    isRecordSelected = true;
                    return false;
                }
            });

            if (isRecordSelected == false) {
                ShowWarningMessage('Please select at least reservation.');
            }
            else {
                $('.data-single-filteration').each(function (index, item) {
                    var res = {};
                    if ($($(item).find('.list-checkBox')).prop('checked')) {
                       
                        res = {
                            Id: $($(item).find('.list-checkBox')).val(),
                            ReservationHeaderId: ReservationHeaderId,
                            AllotmentHeaderId: AllotmentHeaderId,
                            RoomCategoryId: RoomCategoryId,
                        }
                        selectedReservationList.push(res);
                    }
                });

                $.ajax({
                    url: '/Reservation/Reservations/AttachAllotment',
                    dataType: 'JSON',
                    data: { selectedReservationListForAllotment: selectedReservationList },
                    method: 'POST',
                    success: function (response) {
                        
                        $('#grid-record-detail-model').modal('hide');
                        ShowSuccessMessage('Allotment Applied');
                        setTimeout(function () {

                            //Update Uuid
                            window.location.href = "/reservation/reservations/list/" + $('#hidden-Uuid').val();
                            console.log("Uuid");

                        }, 2500);
                    }   
                });
            }
        });

        function LoadReservationList() {
            var ReservationHeaderId = $('#ReservationHeaderIdForAllotment').val();
            var roomCategoryId = $('#roomCategoryIdForAllotment').val();
            
            console.log(ReservationHeaderId);
            $.ajax({
                url: '/Reservation/Reservations/SelectReservationListForAttachAllotment?ReservationHeaderId=' + ReservationHeaderId + '&roomCategoryId=' + roomCategoryId,
                dataType: 'json',
                method: 'get',
                success: function (data) {
                    $.each(data, function (index, item) {
                        console.log(data);
                        var AllotmentHeaderId = $('#AllotmentHeader').val();
                        var RoomCategoryId = $('#RoomCategory').val();
                        var ReservationRoomCategoryId = $('#ReservationRoomCategoryId').val();
                        var btn = '<button class="btn btn-sm btn-danger btn-remove-allotment" RoomCategoryId="' + RoomCategoryId + '" AllotmentHeaderId="' + AllotmentHeaderId + '">REMOVE</button>'
                        var isDisabled = "";
                      
                        if (item.IsAlreadyAttachedAllotment == false) {
                                btn = ''
                                
                            }
                            else {
                                if (ReservationRoomCategoryId == RoomCategoryId) {
                                    btn = '<button class="btn btn-sm btn-danger btn-remove-allotment" data-reservation-heaader-id="' + item.Id + '" RoomCategoryId="' + RoomCategoryId + '" AllotmentHeaderId="' + AllotmentHeaderId + '">REMOVE </button>';
                                    isDisabled = 'disabled';
                                }
                            }
                       
                        $('<tr class="data-single-filteration">' +
                            '<td style="margin-right:0.2em">' +
                            '    <div class="form-list checkbox">' +
                            '        <label>' +
                            '            <input class="list-checkBox" ' + isDisabled+' type="checkbox" value="' + item.Id + '" />' +
                            '        </label>' +
                            '    </div>' +
                            '</td>' +
                            '<td>' +
                            item.ReservationNo +
                            '</td>' +
                            '<td>' +
                            item.GroupReservationNo +
                            '</td>' +
                            '<td>' +
                            item.Company +
                            '</td>' +
                            '<td>' +
                            item.Market +
                            '</td>' +
                            '<td>'
                            +
                            btn
                            +
                            '</td>' +
                            '</tr>'
                        ).appendTo("#reservationGridForAllotment");
                    });
                }
            });
        }

        $('body').off('click', '#isAll').on('click', '#isAll', function () {
            if ($('#isAll').is(':checked')) {
                $('.list-checkBox').not(':disabled').prop('checked', true);

            } else {
                $('.list-checkBox').prop('checked', false);
            }
        });
    </script>
