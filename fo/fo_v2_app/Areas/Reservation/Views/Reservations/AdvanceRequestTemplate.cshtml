@model Scienter.HotelERP.Common.Domain.AdvanceRequestOnline
@{
    Layout = null;
}

<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,400;8..144,500;8..144,600;8..144,700&display=swap"
          rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
          integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N"
          crossorigin="anonymous" />
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js"
            integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-Fy6S3B9q64WdZWQUiU+q4/2Lc9npb8tCaSX9FK7E8HnRr0Jz8D6OP9dO5Vg3Q9ct"
            crossorigin="anonymous"></script>

    <title>Jetwing Hotels</title>
</head>

<body style="
      width: 600px;
      height: 100%;
      margin: 0;
      padding: 0;
      margin: auto;
      background-color: #fdfdfd;
    ">
    <section>
        <div class="row">
            <div class="col-12 text-center mt-5 mb-5"
                 style="
            font-family: 'Roboto Flex', sans-serif;
            font-weight: 600;
            font-size: 18px;
            color: #2f2f2f;
          ">
                Requesting for the Advanced Payment
            </div>
        </div>
        <div class="row mb-5">
            <div class="col-12">

                <img src="~/Images/assets/images/email-image.png"
                     alt="envelop-image"
                     style="
                display: block;
                margin-left: auto;
                margin-right: auto;
                width: 108px;
                " />
            </div>
        </div>
        <div class="row p-4" style="background-color: #fdfdfd">
            <div class="col-12">
                <div class="row">
                    <div class="col-12 mb-4"
                         style="font-family: 'Roboto Flex', sans-serif; font-weight: 600">
                        Advanced Payment Request for Reservation No @Model.ReservationNo
                    </div>
                    <div class="col-12 mb-4"
                         style="
                font-family: 'Roboto Flex', sans-serif;
                font-weight: 400;
                font-size: 16px;
                color: #2f2f2f;
              ">
                        Dear @Model.GuestName,
                    </div>
                    <div class="col-12 mb-4"
                         style="
                text-align: justify;
                font-family: 'Roboto Flex', sans-serif;
                font-weight: 400;
                font-size: 16px;
                color: #2f2f2f;
                line-height: 28px;
              ">
                        @Model.Body
                    </div>
                    <div class="col-12 mb-5">
                        <div class="mr-2"
                             style="
                  display: flex;
                  float: left;
                  font-family: 'Roboto Flex', sans-serif;
                  font-weight: 600;
                  font-size: 16px;
                  color: #2f2f2f;
                ">
                            Amount:
                        </div>
                        <div>@Model.Amount @Model.CurrencyCode</div>
                    </div>
                    <div class="col-12">
                        <button class="btn" data-Uuid="@Model.Uuid" style="background: #249188;border-radius: 5px;color: #ffffff;width: 155px;">
                            Make Payment
                            <img src="~/Images/assets/icons/arrow-right.png" style="width: 14px" />
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer"
             style="
        background-image: url('../../../../Images/assets/images/jetwing-footer.jpg');
        background-size: 100%;
        background-repeat: no-repeat;
        margin-left: -15px;
        display: inline-block;
        width: 630px;
        height: 200px;
        display: block;
    ">
            <div class="d-flex">
                <div class="col-3 pt-3" style="border-right: 1px solid #8d8d35; height: 90px; margin-top: 20px; ">
                    <img src="~/Images/assets/logos/hotel-logo.png" style="width: 120px; padding-left: 20px" />
                </div>

                <div class="col-9 pt-3">
                    <div class="row">
                        <div class="col-12"
                             style="
                  font-family: 'Roboto Flex', sans-serif;
                  font-weight: 600;
                  font-size: 13px;
                  color: #757d8c;
                ">
                            Jetwing House I, 46/26, Nawam Mawatha, Colombo 02, Sri Lanka
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="col-6 pr-0"
                                 style="
                    font-family: 'Roboto Flex', sans-serif;
                    font-weight: 600;
                    font-size: 13px;
                    color: #757d8c;
                  ">
                                Tel: (+94) 11 234 5700
                            </div>
                            <div class="col-6 pl-0"
                                 style="
                    font-family: 'Roboto Flex', sans-serif;
                    font-weight: 600;
                    font-size: 13px;
                    color: #757d8c;
                  ">
                                Email:jetwing@jetwinghotels.com
                            </div>
                        </div>
                        <br />
                        <br />
                        <div class="d-flex">
                            <div class="col-2">

                                <img src="~/Images/assets/icons/instagram.png" style="width: 17px" />
                            </div>
                            <div class="col-2">

                                <img src="~/Images/assets/icons/facebook.png" style="width: 17px" />
                            </div>
                            <div class="col-2">

                                <img src="~/Images/assets/icons/youtube.png" style="width: 17px" />
                            </div>
                            <div class="col-2">

                                <img src="~/Images/assets/icons/twitter.png" style="width: 17px" />
                            </div>
                            <div class="col-4">

                                <img src="~/Images/assets/icons/linkedin.png" style="width: 17px" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>
</html>

