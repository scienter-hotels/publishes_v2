@{
    ViewBag.Title = "Quick Check Out";
}

<style>
    .divCorner {
        border-radius: 25px;
        border: 2px solid #CBC8C8;
        margin: 20px;
    }

    .card .card-content {
        padding: 25px 20px;
    }

    .form-control-margin-top {
        margin-top: 0px;
    }
</style>

@*<input type="hidden" id="GuestName" value="@ViewBag.guestName" />*@
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>

                </div>
            </div>

            <div id="checkOut">
                <div class="card-content" id="contentLoadingArea">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="grid-area">

                            </div>
                        </div>
                        <div class="col-md-12 margin-top-20px">
                            <div class="row">

                                <div class="col-md-9">
                                    <div class="form-group label-floating form-control-margin-top">
                                        <label class="control-label">Check Out Remark</label>
                                        <input type="Text" class="form-control" id="CheckOutRemark" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <input type="button" id="btnCheckOut" value="CHECK OUT" class="btn btn-primary call-popup-model" data-width="500px" />
                                    &nbsp;
                                    <input type="reset" id="btnClear" value="CLEAR" class="btn btn-default" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>







