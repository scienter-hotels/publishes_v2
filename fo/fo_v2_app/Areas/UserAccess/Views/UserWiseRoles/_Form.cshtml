@model Scienter.HotelERP.Common.Domain.UserWiseRole

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="userWiseRoles">
        @Html.AntiForgeryToken()
 
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <input type="hidden" value="@Model.Id" name="Id" id="Id" />
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group label-floating">
                        <label class="control-label">User *</label>
                        @{Html.RenderAction("UsersCombo", "Users", new { name = "UserId", requiered = true, value = Model?.UserId });}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="control-label" style="font-size:14px;">Role (s) *</label>
                        <div id="userWiseRolesContainer">
                            @{Html.RenderAction("LoadUserWiseRoles", "UserWiseRoles", new { userId = 0 });}
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                &nbsp;
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
            </div>
    </form>
</div>


@* Select Index change in combo box*@

<script>
    $(document).ready(function () {
        var userId = 0;
        userId = GetParameterValues("userId");
        if (userId != 0) {        
            LoadUserWiseRoles(userId)
        } else {
        }

    });


    function LoadUserWiseRoles(userId) {
    
        $.ajax({
            url: '/useraccess/userwiseroles/LoadUserWiseRoles?userId=' + userId,
            dataType: 'html',
            success: function (data) {
                $('#UserId').val(userId);
                $('#userWiseRolesContainer').html(data);
              
            },

        });
    }


    $('#UserId').change(function () {
      if ($(this).val() > 0) {

        $.ajax({
            url: '/useraccess/userwiseroles/LoadUserWiseRoles?userId=' + $(this).val(),
            dataType: 'html',
            success: function (data) {
                $('#userWiseRolesContainer').html(data);
                
            },

        });
      } else {
          $('input:checkbox').removeAttr('checked');
      }
    });
</script>

