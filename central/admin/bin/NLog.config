<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off" internalLogFile="c:\temp\nlog-internal.log">

  <!-- optional, add some variables
  https://github.com/nlog/NLog/wiki/Configuration-file#variables
  -->
  <variable name="myvar" value="myvalue"/>

  <!--
  See https://github.com/nlog/nlog/wiki/Configuration-file
  for information on customizing logging rules and outputs.
   -->
  <targets>
    <target name="logfile1" xsi:type="File" fileName="RestaurantlogFile.txt" />
    <target name="logfile2" xsi:type="File" fileName="RestaurantReportErrorlogFile.txt" />
  </targets>

  <rules>
    <logger name="Logger" minlevel="Trace" writeTo="logfile1" />
    <logger name="ReportLogger" minlevel="Trace" writeTo="logfile2" />
  </rules>
</nlog>
