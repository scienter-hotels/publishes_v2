
@{
    ViewBag.Title = "User Lock/ Unlock";
}

@{
    int type = ViewBag.Type;
    string reasonTypeName = "";
    string reasonCode = "";
    string title = "";

    switch (type)
    {
        case 1:
            reasonTypeName = "Lock Reason";
            title = "Temporary Lock User";
            reasonCode = "TL";
            break;
        case 2:
            reasonTypeName = "Permanently Lock Reason";
            title = "Permanently Lock User";
            reasonCode = "PL";
            break;
        case 3:
            reasonTypeName = "Unlock User Reason";
            title = "Unlock Locked User";
            reasonCode = "UL";
            break;
        default:
            break;
    }
}
<style>
    .card .card-header {
        border-radius: 0px;
    }

    .card {
        border-radius: 0px;
    }

    .btn, .navbar .navbar-nav > li > a.btn {
        border-radius: 0px
    }
    .form-group {
        padding-bottom: 7px;
        margin: 5px 0 0 0;
    }
</style>
<div class="card">
    <div class="card-header" data-background-color="purple">
        <div class="row">
            <div class="col-md-8">
                <h4 class="title">
                    @title
                    <hr class="visible-print" />
                </h4>
            </div>
        </div>
    </div>
    <div class="card-content" id="contentLoadingArea">
        <div class="row">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <input type="hidden" class="user-id" value="0" />
                            <input type="hidden" class="reason-code" value="@reasonCode" />
                            <label class="label"> User </label>
                            <select name="User" id="User" class="form-control active-users-lockUnlock active-users select2" required>
                                <option value=""> -- Select -- </option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="label"> @reasonTypeName </label>
                            <select name="reset-reasons" id="reset-reasons" class="form-control lockunlock-reason-types select2" required>
                                <option value=""> -- Select -- </option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="label"> Remark </label>
                            <textarea class="lockUnlock-remark form-control" maxlength="500">  </textarea>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <input type="submit" value="Save" class="btn btn-primary user-lockUnlock-save" />
                            &nbsp;
                            <input type="reset" value="Clear" class="btn btn-default user-lockUnlock-clear" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/UI/Scienter.User.js"></script>