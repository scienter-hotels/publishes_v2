@{
    ViewBag.Title = "Meal Plans";
}


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                        <hr class="visible-print" />
                    </h4>
                </div>
                <div class="col-md-4 text-right hidden-print">
                    <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                        <span class="glyphicon glyphicon-plus"></span>
                    </button>

                    <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                        <span class="glyphicon glyphicon-th-list"></span>
                    </button>

                </div>
            </div>
        </div>
        <div class="card-content" id="contentLoadingArea">
            <div id="content">

            </div>
            @Html.Partial("_Loading")
        </div>
    </div>
</div>
</div>

<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
         // form load --------------------------------
        $(document).ready(function () {
            FillGrid();
        });

        // show form --------------------------------
        $('body').on('click', '.showForm', function (e) {
            $.ajax({
                url: '/administration/mealplans/form',
                dataType: 'html',
                method: 'POST',
                success: function (response) {
                   
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }
                
            });
        });

        // show grid --------------------------------

        $('body').on('click', '.showGrid', function (e) {
            FillGrid();
        });


        // save --------------------------------------
        $('body').on('submit', '#mealPlans', function (e) {
            e.preventDefault();

            var mealswithrates = [];

            $('.meal-rate').each(function () {
                var mealId = $(this).attr('data-mealId');
                var amount = parseFloat($(this).val()) || 0; 

                // Add the mealId and amount to the array as an object
                mealswithrates.push({
                    Id: mealId,
                    Amount: amount
                });
            });

            var mealplan = {
                __RequestVerificationToken: $('__RequestVerificationToken').val(),
                Id: $('#Id').val(),
                Name: $('#Name').val(),
                Prefix: $('#Prefix').val(),
                FoodAllocation: $('#FoodAllocation').val(),
                BevAllocation: $('#BevAllocation').val(),
                DisplayOrder: $('#DisplayOrder').val(),
                IsApplicableForIBE: $('#IsApplicableForIBE').prop("checked"),
                IsActive: $('#IsActive').prop("checked"),
                Properties: selectedProperties,
                IsDormitory: $('#IsDormitory').prop("checked"),
                Meals: mealswithrates
            };
            //if (selectedProperties.length > 0) {
                $.ajax({
                    url: '/administration/mealplans/save',
                    dataType: 'html',
                    data: mealplan,
                    method: 'POST',
                    success: function (response) {
                        ShowSuccessMessage('Record has been saved successfully.');
                        FillGrid();
                    }
                   
                });
            //}
            //else {
            //    ShowErrorMessage('Please select at least one property to continue.');
            //}
        });


        // fill grid -----------------------------------
        function FillGrid() {
            var gridId = "#existingMealPlanGrid"; // change this - relevent grid id
            var paginations = {
                PageIndex: $(gridId).attr('data-page-index'),
                PageSize: $(gridId).attr('data-page-size'),
                FilterType: $(gridId).attr('data-filter-type'),
                SearchKeyword: $(gridId).attr('data-search-keyword')
            }
            $.ajax({
                url: '/administration/mealplans/selectforgrid',
                dataType: 'html',
                data: paginations,
                method: 'POST',
                success: function (response) {
                    if ($('.grid-container').length > 0) {
                        $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                        $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                    } else {
                        $('#contentLoadingArea #content').html('').fadeOut();
                        $('#contentLoadingArea #content').html(response).fadeIn();
                    }

             
                }
               
            });
    }

</script>

