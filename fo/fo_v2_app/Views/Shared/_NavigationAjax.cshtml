<style>
    .cd-primary-nav a:hover {
        text-decoration: none !important;
    }

    .cd-primary-nav a:hover, a:focus {
        color: #fff;
        text-decoration: none;
    }
    /*2023-08-23-Anuradha---------------------------------------------------------------------------------------- checking*/
    .cd-secondary-nav::-webkit-scrollbar {
        width: 5px !important;
    }

    .cd-secondary-nav::-webkit-scrollbar-track {
        background: #f1f1f1 !important;
    }

    .cd-secondary-nav::-webkit-scrollbar-thumb {
        background: #c1c1c1 !important;
    }

        .cd-secondary-nav::-webkit-scrollbar-thumb:hover {
            background: #8E8E8E !important;
        }

    .navigation-area-image {
        width: 46px;
    }

    .cd-primary-nav .cd-secondary-nav > li {
        overflow-y: hidden;
    }

        .cd-primary-nav .cd-secondary-nav > li > a {
            font-size: 1.4rem;
        }

    .cd-primary-nav .cd-secondary-nav a {
        font-size: 1.2rem;
    }

    #secondUl {
        line-height: 1;
    }

        #secondUl li {
            margin-bottom: -6px;
        }

    /*-----------------------------------------------------------------------------------------------------------*/
</style>

