<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Central Access </title>
    <link href="~/Content/Site.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/mega-menu/css/reset.css" rel="stylesheet" />
    <link href="~/Content/mega-menu/css/style.css" rel="stylesheet" />
    <link href="~/Content/Theme.css" rel="stylesheet" />
    <script src="~/Scripts/modernizr-2.6.2.js"></script>
    <link href="~/Content/material-dashboard.css" rel="stylesheet" />
    <link href="~/Content/scienter.theme.blue.css" rel="stylesheet" />
    <link href="~/Content/Styles.css" rel="stylesheet" />


    <meta http-equiv="cache-control" content="max-age=0" />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <meta http-equiv="expires" content="Tue, 01 Jan 1980 1:00:00 GMT" />
    <meta http-equiv="pragma" content="no-cache" />



    <style>
        .card .card-header {
            padding-bottom: 10px !important;
        }
    </style>
</head>
<body>


    <div class="navbar navbar-default navbar-fixed-top">
        <div class="container content">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <div class="row">
                    <div class="col-md-1">
                        <a id="back" href="#" class="icon-color"><img src="~/Images/back-button.png" class="img-responsive" style="width:32px;" /></a>
                    </div>
                    <div class="col-md-4">

                        <img src="~/Images/destinity-horizon-logo-full.png" class="img-responsive" style="width:200px; margin-top:-3px;" />
                        <span style="font-size:11px; text-align:center;">CENTRAL ACCESS MODULE</span>

                    </div>
                    <div class="col-md-3"></div>
                    <div class="col-md-4">
                        <div class="row">
                            <div class="col-md-6">
                                <img src="~/Images/password.png" width="25" />
                                <a id="passwordReset" href="#" class="text-color">
                                    <span>Password Reset</span>
                                </a>
                            </div>
                            <div class="col-md-6">
                                <img src="~/Images/exit.png" width="25" />
                                <a href="/login/centrallogoutuserstatusupdate" class="text-color1">
                                    <span>Logout</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="body-content">
        @*<div class="container body-content">*@
        @RenderBody()
        <hr />
        @*<footer>
                <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
            </footer>*@
    </div>


    <script src="~/Scripts/jquery-3.2.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Content/mega-menu/js/main.js"></script>

    <script src="~/Scripts/material.min.js"></script>
    <script src="~/Scripts/chartist.min.js"></script>
    <script src="~/Scripts/arrive.min.js"></script>
    <script src="~/Scripts/perfect-scrollbar.jquery.min.js"></script>
    <script src="~/Scripts/bootstrap-notify.js"></script>
    <script src="~/Scripts/material-dashboard.js"></script>
    <script src="~/Scripts/scienter.lablefloating.override.js"></script>

    <script>
        $(document).ready(function () {
            $('#back').click(function () {
                parent.history.back();
                return false;
            });
            $('#passwordReset').click(function () {
                window.location = '/Login/ResetPassword';
            });
            $('#logOut').click(function () {
                $.ajax({
                    url: "/login/CentralLogoutUserStatusUpdate",
                    type: "POST",
                    dataType: "json",
                    success: function (data) {
                        window.location = '/Login/Index';
                    }
                });
              
            });
        });

    </script>

</body>
</html>