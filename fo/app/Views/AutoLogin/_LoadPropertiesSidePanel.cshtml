@using Scienter.HotelERP.Common.Domain
@model List<Scienter.HotelERP.Common.Domain.Property>
<br />
@{ 
    string loggedPrefix = SessionObjects.LoggedUser.LoggedProperty.Prefix;
    string isActive = "";
}
@foreach (var item in Model)
{
    isActive = "";
    if (item.Prefix == loggedPrefix)
    {
        isActive = "checked";
    }

<div class="well temp-well @isActive propertySidePanelInnerContainer">


    @if (!string.IsNullOrEmpty(item.Logo))
    {

        <div class="row">
            <div class="col-sm-4">
                <img src="@item.Logo" style="width:60px; height:60px;" />
            </div><div class="col-sm-8">
                <h4 style="font-size:1.1em;">@item.Name</h4>
                <form class="changePropertyBtn" method="post">
                    <input type="hidden" name="Prefix" id="Prefix" value="@item.Prefix" />
                    <button type="submit" class="btn btn-primary btn-sm close-right btn-style">CHANGE PROPERTY</button>
                </form>
            </div>
        </div>
    }
    else
    { 
        <div class="row">
            <div class="col-sm-10">
                <h4 style="font-size:1.1em;">@item.Name</h4>                
            </div>
            <div class="col-sm-2">
                <form class="changePropertyBtn" method="post">
                    <input type="hidden" name="Prefix" id="Prefix" value="@item.Prefix" />
                    <button type="submit" class="btn btn-primary btn-sm close-right btn-style"><span class="glyphicon glyphicon-arrow-right"></span></button>
                </form>
            </div>
        </div>
            }
        </div>

    }

<br />
<br />