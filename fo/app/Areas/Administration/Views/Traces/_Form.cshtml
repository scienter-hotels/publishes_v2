
@model Scienter.HotelERP.Common.Domain.Trace
<script src="~/Scripts/ui/common/scienter.common.datatimepicker.js"></script>
@{
    ViewBag.Title = "Create / Edit";
}
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>
<div class="col-md-12">

    <form id="traces">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>
                    <div class="row">
                        <div class="col-md-5">
                            <div class="form-group label-floating">
                                <label class="control-label">Currency Type *</label>
                                @{Html.RenderAction("CurrenciesConvertionCombo", "Currencies", new { area = "Administration", name = "CurrencyId", ChargeTypeCode = "PT", required = true, value = Model?.CurrencyId }); }
                            </div>
                        </div>
                        <div class="col-md-2">

                        </div>
                        <div class="col-md-5">
                            <div class="form-group form-group-margin-override postingType-container label-floating">
                                <label class="required control-label">Posting Type</label>
                                <select name="PostingTypeId" id="PostingTypeId" class="select2 form-control" required>
                                    <option>-- Select Currency --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    @*<div class="form-group label-floating">
                            @Html.LabelFor(model => model.DefaultTime, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.DefaultTime, new { htmlAttributes = new { @class = "form-control font-size-16px" } })
                            @Html.ValidationMessageFor(model => model.DefaultTime, "", new { @class = "text-danger" })
                        </div>*@
                    @*<div class="form-group">
                            @Html.LabelFor(model => model.DefaultTime, htmlAttributes: new { @class = "control-label" })
                            <div id="DefaultTime" class='input-group date'>
                                @Html.TextBoxFor(model => model.DefaultTime, new { @class = "form-control" })
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-calendar">
                                    </span>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.DefaultTime, "", new { @class = "text-danger" })
                        </div>*@

                    @*<div class="form-group label-floating">
                            <label> Default Time</label>
                            <input type="text" id="DefaultTime" class="form-control datePicker" value=@Model.DefaultTime />
                        </div>*@

                    <div class="row">
                        <div class="form-group label-floating col-md-8">
                            <label class="control-label"> Default Date*</label>
                            <div id="dobContainerInSeasons" class='input-group date'>
                                <input autocomplete="off" class="form-control datePicker text-box single-line" maxlength="100" id="DefaultTime" name="DefaultTime" type="text" value="@Model.DefaultTime" required>
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-calendar"></span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Default Qty *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="20" id="DefaultQty" name="DefaultQty" type="text" value="@Model.DefaultQty" required>
                    </div>

                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            @*<input type="checkbox" checked name="IsActive" value="True" />*@ Is Active
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('#CurrencyId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });

    $('body').on('change', '#CurrencyId', function () {
        var currencyId = $('#CurrencyId').val();
        $.ajax({
            url: '/CashieringAndPosting/PostingBillType/PostingBillTypeCombo?name=PostingTypeId&currencyId=' + currencyId + '&requiered=true',
            dataType: 'html',
            method: 'get',
            success: function (response) {
                $('.postingType-container').html('');
                $('<label class="required control-label">Charge Type</label>').appendTo($('.postingType-container'));
                $(response).appendTo($('.postingType-container'));
            }
        });
    });
</script>