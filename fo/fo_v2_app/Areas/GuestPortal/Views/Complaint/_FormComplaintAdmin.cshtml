
@model Scienter.HotelERP.Common.Domain.GuestPortal_RequestType
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<div class="col-md-12">
    <form id="guestPortalComplaint">
        @Html.AntiForgeryToken()
        <div>
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @*@Html.HiddenFor(model => model.Id)*@
            <input type="hidden" value="@Model.Id" name="Id" id="Id" />
            <div class="row">
                <div class="col-md-12">

                    <div class="row">
                        <div class="col-md-5 form-group label-floating">
                            <label class="control-label">Name *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="50" id="Name" name="Name" type="text" value="@Model.Name" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-8 form-group label-floating">
                            <label class="control-label">Description </label>
                            <textarea autocomplete="off" class="form-control text-box single-line" maxlength="200" id="Description" name="Description" type="text" rows="3">@Model.Description</textarea>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 form-group label-floating">
                            <label class="control-label">Display Order *</label>
                            <input autocomplete="off" class="form-control text-box single-line" @*min="0"*@ id="DisplayOrder" name="DisplayOrder" type="number" value="@Model.DisplayOrder">
                        </div>

                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group checkbox">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsActive)
                                    Active
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                                &nbsp;
                                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </form>

</div>

