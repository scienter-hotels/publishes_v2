    function EnableGroupMergeButton() {

        $('#btnPreview').addClass('hidden').hide();

        isGroupMergeOnly = $('#IsGroupMergeOnly').val();

        isGroupMergeOnly = parseInt(isGroupMergeOnly, 10);

        if (isGroupMergeOnly === 1) {
            $('#GroupMerge').css('text-decoration', 'none'); // Remove line-through
            $('#GroupSettlement').css('text-decoration', 'line-through !important');
            $('#GroupMerge').removeClass('hidden').show();
            $('#GroupSettlementDiv').addClass('hidden').hide();
            $('#GroupSettlementAfterMerge').addClass('hidden').hide();
            //$('#GroupSettlementAfterMerge').removeClass('hidden').show();
        } else {
            $('#GroupSettlementAfterMerge').addClass('hidden').hide();
            $('#GroupSettlement').removeClass('hidden').show();
            $('#GroupMerge').removeClass('hidden').show().css('text-decoration', 'line-through !important');
        }

