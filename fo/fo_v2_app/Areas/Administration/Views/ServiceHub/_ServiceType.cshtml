
@model Scienter.HotelERP.Common.Domain.ServiceType

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12 serviceTypeForm">

    <form id="serviceType">
        @Html.AntiForgeryToken()
        <div class="">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="hdnId" id="hdnId" />
            <input type="hidden" name="hdnServiceCatId" id="hdnServiceCatId" value="@Model.ServiceCategoryId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-md-8 form-group label-floating">
                            <label class="control-label">Service Category</label>
                            <select name="serviceCat" id="serviceCat" @*value="@Model.ServiceCategory"*@ class="form-control "></select>
                            
                        </div>
                        </div>
                        <div class="row">
                            <div class="col-md-8 form-group label-floating">
                                <label class="control-label">Name *</label>
                                <input autocomplete="off" class="form-control text-box single-line" maxlength="50" id="Name" name="Name" type="text" value="@Model.Name" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group checkbox">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsActive)
                                    Active
                                </label>
                                @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group">
                                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                                &nbsp;
                                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                            </div>
                        </div>
                    </div>
                </div>

        </div>
    </form>
</div>
<script>
    $(document).ready(function () {
        LoadServiceCategoriesCombo();
    });
</script>

