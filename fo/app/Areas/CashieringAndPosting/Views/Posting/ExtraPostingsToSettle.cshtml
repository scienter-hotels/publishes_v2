@{
    ViewBag.Title = "Pending Postings";
}

<div class="row">
    <div class="col-md-12">
        <div class="card" id="rebateCard">
            <div class="card-header hidden-print" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title hidden-print">
                            @ViewBag.Title
                        </h4>
                    </div>

                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div class="row">
                    <div class="col-md-6 hidden-print">
                        <table class="table" id="pendingPostingTable" style="margin-top: 11px;">
                            <tr>
                                <th>Date</th>
                                <th>Doc #</th>
                                <th>Res #</th>
                                <th>Room #</th>
                                <th style="text-align:right;">Amount</th>
                                <th></th>
                            </tr>
                            <tbody class="all-pending-postings">
                                <tr>
                                    <td class="" colspan="5">No any pending postings to settle.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-6" id="Postinginvoice">
                        @Html.Partial("_Invoice")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery.easyPaginate.js"></script>

<script>
    $(document).ready(function () {
        LoadPendingExtraPostingsToSettle();
        $('#ReportFooter').addClass('hidden');
    });

    function LoadPendingExtraPostingsToSettle() {
        $.ajax({
            async: false,
            url: '/CashieringAndPosting/Posting/LoadPendingExtraPostingsToSettle',
            dataType: 'json',
            method: 'POST',
            beforeSend: function () {
                $('.all-pending-postings tr').remove();
            },
            success: function (data) {
                $('.all-pending-postings tr').remove();
                $(data).each(function (index, item) {
                    $('.all-pending-postings').append('<tr class="data-rows">' +
                        '<td class="">' + item.ChargeDate + '</td>'+
                        '<td class="">' + item.DocumentNo + '</td>'+
                        '<td class="">' + item.ReservationNo + '</td>'+
                        '<td class="">' + item.RoomNo + '</td>'+
                        '<td class="formatNumber data-amount">' + item.Amount.toFixed(2) + '</td>' +
                        '<td>' +
                        '<button type="button" class="btn btn-primary btn-sm rowAdd" data-ExtraPostingId="' + item.Id+'" data-chargeDate="' + item.ChargeDate + '" data-invoiceNo="' + item.DocumentNo + '" data-reservationNo="' + item.ReservationNo + '" data-remark="' + item.Remarks + '" data-TaxGroupId="' + item.TaxGroupId + '" data-RoomNo="' + item.RoomNo + '" data-FolioText="' + item.FolioText + '" data-TaxDetail="aaa' + JSON.stringify(item.TaxDetails) + '" data-OriginalAmount="' + item.OrginalAmount + '">ADD</button>' +
                        '</td>'+
                        '</tr>');
                });
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error.');
            }
        });
    }


    $('body').off('click').on('click', '.rowAdd', function (e) {
        RoomIds = [];
        invoiceData = {};
        $('#ReportBody1').html("");
        $('#easyPaginate2').html("");
        var tableAll = "";
        var id = $(this).attr('data-ExtraPostingId')

        $('#ReportFooter').removeClass('hidden');
        $('#ReportFooter').removeAttr('style');

        invoiceData = {

            roomIds: $(this).attr('data-RoomNo'),
            billType: $(this).attr('data-FolioText'),
            TaxGroupId: $(this).attr('data-TaxGroupId'),
            PostingCatgNo: 1,
            folioText: $(this).attr('data-FolioText'),
            amount: Number(parseFloat($(this).attr('data-OriginalAmount')).toFixed(2)).toLocaleString('en', { minimumFractionDigits: 2 }),
            remarks: $(this).attr('data-remark'),
            reservationNo: $(this).attr('data-reservationNo'),
