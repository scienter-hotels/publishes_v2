    @* modified By ishara on 2024 - 10 - 08 NEW*@
    function SaveBill() {

        var rooms = JSON.stringify(mergeResultJsonArray);
        var payments = JSON.stringify(billpaymentArray);
        var isMergeOnlySend = isMergeOnly;
        var IsFinalSettlementAfterMergeSend = IsFinalSettlementAfterMerge

        if (IsFinalSettlementAfterMerge) {

            $.ajax({
                url: '/CashieringAndPosting/FolioManagement/GroupSettlementAfterMergeSave?rooms=' + rooms + '&payments=' + payments + '&IsMerged=' + IsFinalSettlementAfterMergeSend,
                dataType: 'json',
                method: 'GET',
                success: function (response) {
                    if (response.startsWith('Err-')) {
                        ShowWarningMessage(response.replace("Err-", ""));
                    } else {
                        ShowSuccessMessage('Record has been saved successfully.');

                        @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger *@
                        GroupMergeAllowCreditPosting = 0;
                        IsGroupSettlement = 0;
                    }
                },
                error: function (error) {
                    ShowErrorMessage('An error occurred while attempting to save the record.');
                }, complete: function () {
                    setTimeout(function () {
                        window.location.reload();
                    }, 3000);
                }
            });

        } else {

            $.ajax({
                url: '/CashieringAndPosting/FolioManagement/GroupSettlementSave?rooms=' + rooms + '&payments=' + payments + '&isMergeOnly=' + isMergeOnlySend,
                dataType: 'json',
                method: 'GET',

                success: function (response) {
                    if (response.startsWith('Err-')) {
                        ShowWarningMessage(response.replace("Err-", ""));
                    } else {
                        ShowSuccessMessage('Record has been saved successfully.');
                        //setTimeout(function () {
                        //    LoadAllTransactions(4, 10348)
                        //}, 3000);

                        @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger *@
                        GroupMergeAllowCreditPosting = 0;
                        IsGroupSettlement = 0;
                    }
                },
                error: function (error) {
                    ShowErrorMessage('An error occurred while attempting to save the record.');
                    @* Added By ishara on 2024 - 12 - 06 -- Modification for anable City Ledger *@
                    GroupMergeAllowCreditPosting = 0;
                    IsGroupSettlement = 0;

                }, complete: function () {
                    //setTimeout(function () {
                    //    window.location.reload();
                    //}, 3000);
                }
            });
        }

    };
    @* Added By ishara on 2024 - 10 - 08 NEW *@
    function GroupMergeOnly() {
        var rooms = JSON.stringify(mergeResultJsonArray);
        var isMergeOnlySend = isMergeOnly;

        if (rooms.length >= 0) {
            $.ajax({
                url: '/CashieringAndPosting/FolioManagement/GroupMerge?rooms=' + rooms + '&isMergeOnly=' + isMergeOnlySend,
                dataType: 'json',
                method: 'GET',

                success: function (response) {
                    if (response.startsWith && response.startsWith('Err-')) {
                        ShowWarningMessage(response.replace("Err-", ""));
                    } else {
                        resHeaderId = response.ReservationID;
                        folioNo = response.FolioNo;
                        $('#btnPreview').removeClass('hidden').show();
                        $('#GroupMerge').addClass('disabled');
                        $('#GroupSettlementAfterMerge').removeClass('hidden');
                        $('#GroupSettlementAfterMerge').removeClass('disabled').show();
                        $('#btnPreview').css('box-shadow', 'none');
                        $('.selectAllRoom').addClass('disabled').prop('disabled', true);
                        $('.inhouse-rooms').addClass('disabled').prop('disabled', true);
                        $('#addNewGroup').removeClass('hidden').removeClass('disabled').show();



                        ShowSuccessMessage('Folio Merged successfully.');

                        // Set the href dynamically
                        $('#btnPreview').attr('href', '/Reporting/Report/ViewReport?ReportName=FolioInvoiceDetail&ReservationHeaderId='
                            + encodeURIComponent(resHeaderId)
                            + '&FolioNo=' + encodeURIComponent(folioNo)
                            + '&IsPreview=0&IsLKROnlyInvoice=0');

                    }
                },
                error: function (error) {
                    ShowErrorMessage('An error occurred while attempting to merge the record.');
                    //setTimeout(function () {
                    //    window.location.reload();
                    //}, 3000);
                }, complete: function () {
                    HideLoader();

                }
            });
        }

    }

    $('#searchRoomNumber').on('input', function () {
        let searchKeyWord = $(this).val().toLowerCase();
        let isAnyRoomVisible = false;
        $('#InhouseRoomNumberListToGroupSettlement .room-number-name').each(function () {
            if ($(this).text().toLowerCase().includes(searchKeyWord)) {
                $(this).show();
                isAnyRoomVisible = true;
            } else {
                $(this).hide();
            }
            if (!isAnyRoomVisible) {
                $('#noRecordsMessage').show();
            } else {
                $('#noRecordsMessage').hide();
            }
        });
    });

