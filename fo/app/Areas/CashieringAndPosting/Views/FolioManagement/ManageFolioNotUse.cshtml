        <script src="~/Scripts/ui/common/scienter.grid2.js"></script>
        <script>
            // form load --------------------------------
            $(document).ready(function () {
                //global var
                var reservationHeaderId;
                var selectedFolioNumber;
                var taxGroupIdArray = []
                var chargersAmountArray = []
                var SelectedFolioNumber
                var roomNo
                var ResID


                //ScorelToTop60px();
                $('newFolioBtn').on('click', function (e) {

                });

                // drag
                $('#table-draggable2').on('click', function (e) {

                });


            });
                //allow only one checkbox to click
                $(document).on('click', '.folio-detail-id', function (e) {
                    //    $('input[type=checkbox]').on('click', function (e) {
                    $('.folio-detail-id').prop('checked', false)
                    $(this).prop('checked', true)

                });

                //Load Reservations [1]
                $.ajax({
                    url: '/CashieringAndPosting/FolioManagement/ReservationList',
                    dataType: 'json',
                    method: 'GET',
                    success: function (data) {
                        $.each(data, function (index, eachRoomDetail) {

                            $('<option key="' + eachRoomDetail.ReservationHeaderId + '" value="' + eachRoomDetail.RoomNo + '"> Room NO: ' + eachRoomDetail.Code + '  - ResNo: ' + eachRoomDetail.ResNo + ' - ' + eachRoomDetail.Name + '</option>').appendTo($('#cmbAllRooms'));
                            $('#inHouseRoomList').append('<input  style=" padding-left:15px; padding-right:15px; width:60px; background-color:#F7A53E""  type="button" key="' + eachRoomDetail.ReservationHeaderId + '" class="btn btn-primary room-list-btn" value="' + eachRoomDetail.Code + '" name="Folio" id="' + eachRoomDetail.RoomNo + '" data-toggle="tooltip" title=" Res No: ' + eachRoomDetail.ResNo + ' - Guest: ' + eachRoomDetail.Name + ' " >')

                        })
                    },
                    error: function (error) {

                    }
                });

                //load data to fields when Room Select [2]
                //  $("#cmbAllRooms").change(function () {
                $(document).on('click', '.room-list-btn', function (e) {
                    
                    // clear fields
                    $('#txtGuest').val(' ')
                    $('#txtFolio').val(' ')
                    $('#txtName').val(' ')
                    $('.all-transaction').html('')
                    $('.tbl-folioWiseTable').html('')
                    $('.btn-folio-numbers').html('')
                    $('#btnBillPreview').removeAttr('data-href')
                    $('#btnBillSettlement').removeAttr('data-href')


                    roomNo = $(this).attr('id') //$("#cmbAllRooms").find('option:selected').val();
                    ResID = $(this).attr('key')//$("#cmbAllRooms").find('option:selected').attr('key')
                    $('.reservation-header-id').val(ResID);
                    $('.reservation-room-id').val(roomNo);

                    
                    $.ajax({
                        url: '/CashieringAndPosting/FolioManagement/FolioDetails',
                        dataType: 'json',
                        data: { RoomNo: roomNo, ResID: ResID },
                        method: 'POST',
                        success: function (data) {

                            $('#txtGuest').val(data.Name)
                            $('#txtFolio').val(1)
                            $('#txtName').val(data.Name)

                            $('#txtGuest').prop('readOnly', true)
                            $('#txtFolio').prop('readOnly', true)
                            $('#txtName').prop('readOnly', true)

                            reservationHeaderId = data.ReservationHeaderId;
                            SelectedFolioNumber = 0

                            //load data to table
                            LoadAllTransactions(roomNo, reservationHeaderId)
                            GetAllFoliosNumbers(roomNo, reservationHeaderId)

                            //Alert Function
                            ReservationAlert(reservationHeaderId, 'FOL')
                        }
                    });

                })

                //Create New folio [3]
                $('#newFolioBtn').on('click', function (e) {


                    //Check if there are any charge under FOLIO 1
                    //Atleast one chareg should be under FOLIO 1
                    var folioOneCount = 0
                    $('.td-folio-nos').each(function (index, item) {
                        if ($('.td-folio-nos').eq(index).text() == 1) {
                            folioOneCount++;
                        }

                    });

                    // get selected folio detail id
                    var chargersArray;
                    $('.folio-detail-id').each(function (index, item) {
                        if ($(this).prop('checked')) {
                            // chargersArray.push({

                            chargersArray = $(this).val()
                            // });
                        }
                    });



                    if (chargersArray != null) {
                        if (folioOneCount > 1) {

                            // post selected folio detail id to update to new folio number
                            $.ajax({
                                url: '/CashieringAndPosting/FolioManagement/ChangeFolioNumber',
                                dataType: 'json',
                                data: { FolioDetailId: chargersArray, ReservationHeaderId: reservationHeaderId },
                                success: function (data) {
                                    $('.all-transaction').html('')
                                    $('.tbl-folioWiseTable').html('')
                                    $('.btn-folio-numbers').html('')
                                    LoadAllTransactions(roomNo, reservationHeaderId);
                                    GetAllFoliosNumbers(roomNo, reservationHeaderId)
                                }
                            })


                        } else {
                            ShowErrorMessage('Atleast One CHarge should be places under FOLIO 1')
                        }
                    } else {
                        ShowErrorMessage('Select a Folio')
                    }



                });


                //LoadFolioTransactionsWiseFolioNO [4] // folio Btn click
                $(document).on('click', '.folio-btn', function () {
                    $('.tbl-folioWiseTable').html('')
                    $('#btnBillSettlement').attr('disabled', false)
                    $('#folio-no').val((this).id)

                    $.ajax({
                        url: '/CashieringAndPosting/FolioManagement/FilterTransactionsByFolioNo',
                        dataType: 'json',
                        data: { FolioNo: (this).id, ReservationHeaderId: reservationHeaderId },
                        success: function (data) {
                          
                            $.each(data, function (index, folio) {
                                
                                $('.tbl-folioWiseTable').append('<tr>' +
                                          '<td>' + folio.ChargeDate + '</td>' +
                                          '<td>' + folio.FolioText.substring(0, 35) + '</td>' +
                                          '<td class="charge-amount formatNumber">' + folio.ChargeAmount.toFixed(2) + '</td>' +
                                          '<td style="text-align:right">' + folio.FolioNo + '</td>' +
                                          '<td class="taxGroup-Id hidden" >' + folio.TaxGroupId + '</td>' + //style="display:none;"
                                          '<td><input type="checkbox" value="' + folio.FolioDetailID + '"  class="folio-detail-id hidden" ></td>' +
                                      '</tr>')
                              

                                SelectedFolioNumber = folio.FolioNo;

                                if (folio.FolioDetailID < 0) {
                                    
                                    $('#btnBillSettlement').attr('disabled', true)
                                }

                            })
                           


                        }
                    });


                })

                // FOLIO EXCHANGE
                var nextFolio;
                $(document).on('click', '.folio-btn', function () {
                    nextFolio = $(this).attr('id')
                })
                $('#ExchangeFolioBtn').on('click', function (e) {

                    // check if checkbox is clicked
                    var thisFolio;
                    var thisFolioDetailId
                    $('.folio-detail-id').each(function (index, item) {
                        if ($(this).is(':checked', true)) {
                            // checkbxArray.push({

                            thisFolio = $('.folio-detail-id').eq(index).closest('tr').find('td.td-folio-nos').text()
                            thisFolioDetailId = $(this).val()
                            
                            // });
                        }
                    });



                    if (thisFolio != null && nextFolio != null) {

                        ExchangeFolio(thisFolio, nextFolio, thisFolioDetailId)
                        
                    } else {
                        ShowWarningMessage("Select Folio Number From Table and select Folio Button to Exchange Folio")

                    }

                });

                //methods
                //function LoadAllTransactions(roomNo, reservationHeaderId) {
                //    
                //    $.ajax({
                //        url: '/CashieringAndPosting/FolioManagement/FolioChargers',
                //        dataType: 'json',
                //        data: { RoomNo: roomNo, ReservationHeaderId: reservationHeaderId },
                //        success: function (data) {
                //            $('.all-transaction').html('')
                //            $.each(data, function (index, folio) {
                                
                //                $('.all-transaction').append('<tr>' +
                //                      '<td class="data-date">' + folio.ChargeDate + '</td>' +
                //                      '<td class="data-desc">' + folio.FolioText.substring(0, 30) + '</td>' +
                //                      '<td class="formatNumber data-amount">' + folio.ChargeAmount.toFixed(2) + '</td>' +
                //                      '<td class="td-folio-nos" style="text-align:right">' + folio.FolioNo + '</td>' +
                //                      '<td><div class="checkbox"><label>' +
                //                      '<input type="checkbox" value="' + folio.FolioDetailID + '"  class="form-group checkbox folio-detail-id" >' +
                //                      '</label></div></td>' +
                //                  '</tr>')

                //                $('.tbl-folioWiseTable').append('<tr>' +
                //                          '<td>' + folio.ChargeDate + '</td>' +
                //                          '<td>' + folio.FolioText.substring(0, 35) + '</td>' +
                //                          '<td class="charge-amount formatNumber">' + folio.ChargeAmount.toFixed(2) + '</td>' +
                //                          '<td style="text-align:right">' + folio.FolioNo + '</td>' +
                //                          '<td class="taxGroup-Id hidden"  >' + folio.TaxGroupId + '</td>' +//style="display:none;"
                //                      '<td class="hidden"><input type="checkbox" value="' + folio.FolioDetailID + '"  class="form-group checkbox folio-detail-id" ></td>' +
                //                  '</tr>')


                //            })

                //            $.each($('.folio-detail-id'), function (index, folioCharge) {
                                
                //                if ($(this).val() < 0) {
                //                    $(this).prop('disabled', true)
                //                }

                //            })

                //        }
                //    });

                //}
                function GetAllFoliosNumbers(roomNo, reservationHeaderId) {

                    $.ajax({
                        url: '/CashieringAndPosting/FolioManagement/GetAllFolios',
                        dataType: 'json',
                        data: { RoomNo: roomNo, ReservationHeaderId: reservationHeaderId },
                        success: function (data) {
                            
                            $.each(data, function (index, itemfolioNo) {

                                $('.btn-folio-numbers').append('<tr class="abc">' +
                                '<td style="text-align:center">' +
                                '<input type="button" class="btn btn-primary folio-btn" value="FOLIO ' + (itemfolioNo) + '" name="Folio" id="' + (itemfolioNo) + '">' +
                                ' </td></tr>'
                                )
                            })

                        }
                    });

                }
                function ExchangeFolio(thisFolio, nextFolio, thisFolioDetailId) {
