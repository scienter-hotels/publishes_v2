@using Scienter.DestinityHorizon.Common.Domain
@*@model IEnumerable<Scienter.DestinityHorizon.Common.Domain.Outlet>*@
@{
    ViewBag.Title = "Waiters";
    //string LoggedOutletCode = SessionObjects.LoggedUser.LoggedOutlet.Code.ToString();
}

<style>
    .form-group-marging {
        margin-top: 0px;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                @* <input type="hidden" value="@LoggedOutletCode" id="hdnLoggedOutlet" />*@
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm" title="Add New">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>
                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid" title="Show Grid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div class="row">
                    <div class="col-md-12 master-file-grid">
                        @*Grid comes here*@
                        <div class="row grid">
                            <div class="col-md-12 table-responsive">
                                <input type="text" id="searchby" onkeyup="SearchGrid()" placeholder="Search by any Column" title="Search by any Column">
                                <div id="loadingProjects" class="well">
                                    <center>
                                        <img src="~/Images/loading.gif" style="width:50px; margin-top:20px; margin-bottom:0px;" />
                                    </center>
                                </div>
                                <input type="hidden" id="UpdateFlg" />
                                <table class="table table-striped" id="grid" style="display:none;">
                                    <tr>
                                        <th class="col-md-1">Code</th>
                                        <th>Waiter Name</th>
                                        <th class="col-md-1">Active</th>
                                        <th class="col-md-1">ViewAllOrders</th>
                                        <th class="col-md-1">Cashier</th>
                                        <th class="col-md-2"></th>
                                    </tr>
                                    <tr class="no-record">
                                        <td colspan="4">No Records Found.</td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                    </div>
                    <div class="col-md-12 master-file-form ">
                        @*Form Comes here*@
                        <div class="col-md-12">
                            <form id="form" class="form" enctype="multipart/form-data" hidden>
                                @*<div class="row">*@
                                @*<div class="col-md-6">*@
                                <div class="row">
                                    <div class="col-md-2">
                                        <div class="form-group label-floating">
                                            <label class="control-label">Code *</label>
                                            <input type="text" class="code form-control" id="code" value="" autocomplete="off" required maxlength="8" />
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group label-floating">
                                            <label class="control-label">Card No *</label>
                                            <input type="text" class="cardNo form-control" id="cardNo" value="" autocomplete="off" maxlength="50" required />
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group label-floating">
                                            <label class="control-label">Name *</label>
                                            <input type="text" class="name form-control" id="Name" value="" autocomplete="off" required maxlength="20" />
                                        </div>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="form-group form-group-marging checkbox">
                                            <label><input type="checkbox" id="active" name="Active" />Active</label>
                                        </div>
                                    </div>
                                </div>
                               
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="form-group  checkbox">
                                            <label>  <input type="checkbox" id="ViewAllOrders" name="IsViewAllOrders" />ViewAllOrders</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-9">
                                        <div class="form-group checkbox">
                                            <label><input type="checkbox" id="cashier" name="IsCashier" />Cashier</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <button type="submit" class="btn btn-success btn-width-100px" id="btnSubmit">
                                            Save
                                        </button>
                                        <button type="reset" class="btn btn-default btn-width-100px btn-shadow" id="btnClear" onclick="ClearFormWaiter()">
                                            Clear
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/scripts/UI/Scienter.waiter.js"></script>

