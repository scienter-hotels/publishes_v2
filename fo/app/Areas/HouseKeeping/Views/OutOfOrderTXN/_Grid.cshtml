@model IEnumerable<Scienter.HotelERP.Common.Domain.OutOfOrderTXN>

@{
    ViewBag.Title = "Out Of Order Update";
}
<div class="table-responsive grid-container">
    <table class="table table-striped"
           id="existingOutOfOrderTxnGrid">


        <tr>

            <th>
                Room
            </th>
            <th>
               From Date
            </th>
            <th>
               To Date
            </th>
            <th>
                Out Of Order Reason
            </th>
            <th>Remark</th>
            <th>
            
        </th>
            <th>
                @*@Html.DisplayNameFor(model => model.ReleaseAsId)*@
            </th>

        </tr>

        @foreach (var item in Model)
        {
            <tr class="outoforder">

                <td>
                   @item.RoomName
                </td>
                <td>
                   @item.FromDate
                </td>
                <td>
                   @item.ToDate
                </td>
                <td>
                    @item.OutofOrderReason
                </td>
                <td>
                   @item.Remarks
                </td>
                <td>
                    @*@Html.DisplayFor(modelItem => item.ReleaseAsId)*@
                </td>
                <td>
                <td class="hidden-print text-right">
                    @*<a class="btn btn-theme-color-2 btn-sm call-popup-model" id="btnPrint" data-title="Out Of Order Reasons - @item.Name" data-href="/administration/outoforderreasons/print/@item.Id">
            <span class="glyphicon glyphicon-print"></span>
        </a>*@

                    <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/housekeeping/outofordertxn/edit/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/housekeeping/outofordertxn/delete/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>

                  
                </td>

            </tr>
        }

    </table>
</div>
    <script>
    $(document).ready(function () {
        $('#existingOutOfOrderTxnGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                            'copy',
                            'excel',
                            'csv',
                            'pdf',
                            'print'
                ],
                scrollY: '58vh',
            } );
    });
    </script>
