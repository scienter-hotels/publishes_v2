@model Scienter.HotelERP.Common.Domain.ViewModels.HotelConfirmationView
<style>
    .single-page-edit .disabled {
        cursor: not-allowed;
    }

    .single-page-edit .dataTables_filter {
        width: 29% !important;
        float: left !important;
    }

    .single-page-edit .dt-buttons {
        width: 70% !important;
    }

    .single-page-edit .superscript {
        font-size: 0.8em;
    }

    .single-page-edit .form-group {
        margin-top: 5px;
    }

    .single-page-edit .table .radio, .single-page-edit .table .checkbox {
        margin-right: 10px;
    }

    .single-page-edit #guestGroupGrid {
        font-size: 12px !important;
    }

        .single-page-edit #guestGroupGrid input, select {
            font-size: 12px !important;
        }

    .single-page-edit .control-label,
    .single-page-edit .label-data {
        font-size: 11px !important;
    }

    .single-page-edit .area-two,
    .single-page-edit .area-one,
    .single-page-edit .area-three {
        border: 1px solid #ccc;
        border-radius: 3px;
        padding: 10px;
    }

    .single-page-edit .area-one {
        margin-right: 15px
    }

    .single-page-edit .the-legend {
        font-size: 10px
    }
    .select2{
        width: 165px;
        margin-top: 10px;
        font-size: 11px;
        margin-top:5px;
    }

    #tableLoadingArea .form-group{
        padding-bottom:0px !important;
    }



    .single-page-edit .form-group.label-static label.control-label,
    .single-page-edit .form-group.label-floating.is-focused label.control-label,
    .single-page-edit .form-group.label-floating:not(.is-empty) label.control-label {
        top: -22px;
        /* left: 0; */
        font-size: 10px !important;
        line-height: 1.07143;
    }



    .the-fieldset {
        border-radius: 3px !important;
    }

    /*2023-08-15---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label{
        z-index:1 !important;
    }

    .select2-container{
        width:100% !important;
    }

    .guest-select-all-checkBox:checked {
        background-color: red; /* Checked background color */
    }

        /* Styling for the check mark */
        .guest-select-all-checkBox:checked::after {
            content: '\2713'; /* Unicode check mark character */
            color: yellow; /* Check mark color */
            font-size: 14px; /* Adjust the font size as needed */
            margin: -5px 0 0 -5px; /* Adjust the margin to position the check mark */
        }
    /*-------------------------------------------------------------------------------*/


    label .checkbox .checkbox-material .check {
        position: relative;
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 1px solid #b6ff00;
        overflow: hidden;
        z-index: 1;
        border-radius: 0px;
    }

    .guest-select-all-checkBox {
    border:6px solid #0ff000;
    }

</style>
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>
@*-----------Hidden fields for reservation update-----------------*@
<input type="hidden" id="GuestName" value="@ViewBag.GuestName" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />
<input type="hidden" id="ReservationType" value="@ViewBag.ReservationType" />
<input type="hidden" id="resHeadId" value="@ViewBag.ResheaderId" />
<input type="hidden" class="ReseNo" value="@Model.ReservationNo" />
<input type="hidden" class="segmentId-hidden" value="@Model.SegmentId" />
<input type="hidden" class="rateCodeId-hidden" value="@Model.RateCodeHeaderId" />
<input type="hidden" class="marketId-hidden" value="@Model.MarketId" />
<input type="hidden" class="reservation-country" value="@Model.CountryID" />
<input type="hidden" class="reservation-status" value="@Model.StatusId" />
<input type="hidden" class="reservation-bookingSource" value="@Model.BookingSourceId" />
<input type="hidden" class="reservation-company" value="@Model.AgentId" />
<input type="hidden" class="reservation-rateCode" value="@Model.RateCodeHeaderId" />
<input type="hidden" class="reservation-segment" value="@Model.SegmentId" />
<input type="hidden" class="reservation-market" value="@Model.MarketId" />
