
<style>
    .bg-success {
        background-color: #4caf50;
    }

    .progress-bar-striped {
        background-image: linear-gradient(45deg, rgba(255, 255, 255, 0.15) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.15) 50%, rgba(255, 255, 255, 0.15) 75%, transparent 75%, transparent);
        background-size: 1rem 1rem;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <h4>Processing</h4>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <div class="progress">
            <div class="progress-bar progress-bar-striped bg-success progress-bar-striped" role="progressbar" style="width: 0%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">0%</div>


            <div class="stepLoading">
                <center>
                    <h3>Please wait</h3>
                    <p>
                        Checking Pseudo Rooms ...
                    </p>
                    <img src="~/Images/work-process-gif.gif" />
                    <br />
                </center>
            </div>

        </div>
    </div>
</div>


<script>
    var width = 0;

    $(function () {
        setInterval(function () { changeProgress(); }, 100);

        $.ajax({
            url: '/CashieringAndPosting/DayEndProcess/ProcessDayEnd',
            dataType: 'json',
            method: 'get',
            success: function (data) {
            },
        });
    })

    function changeProgress() {

        $('.loading-screen-without-gif').attr('hidden', false);

        if (width <= 99) {
            width = width + 1;
            $('.progress-bar').css('width')
            $('.progress-bar').attr('style', 'width: ' + width + '%');
            $('.progress-bar').html(width + '%');
        } 

        if (width == 100) {
            setTimeout(function () {
                window.location.href = '/cashieringandposting/dayendprocess';
            }, 3000)
            
        }
    }
</script>