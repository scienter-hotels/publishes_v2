<script>

    var guestInfo = '';
    var guestInfo2 = '';
    var schedulePosting = [];
    var invoice = '';
    var postingDatesarray = [];
    var AmountwithoutTax = 0;

    // form load ------------------------------
    $(document).ready(function () {
        //ScorelToTop60px();
        if ($('#schedulePostingVia').val() == "fromRes") {
            guestInfo2 = { ReservationNo: '', groupresNo: '', GuestName: '', RoomCode: '', RoomId: '', GuestProfileId: '', ArrivalDate: '', Departure: '' }

            guestInfo2 = {
                ReservationNo: $('#resNo_SP').val(),
                groupresNo: $('#gresNo_SP').val(),
                GuestName: $('#guestName_SP').val(),
                RoomCode: $('#roomNo_SP').val(),
                RoomId: parseInt($('#roomId_SP').val()),
                GuestProfileId: parseInt($('#guestProf_SP').val()),
                ArrivalDate: $('#arrival_SP').val(),
                Departure: $('#departure_SP').val()
            }

            $('#resNo').html(guestInfo2.ReservationNo);
            $('#roomNo').html(guestInfo2.RoomCode);
            $('#guest').html(guestInfo2.GuestName);
            $('#arrival').html(guestInfo2.ArrivalDate);
            $('#depature').html(guestInfo2.Departure);

            GetDates(guestInfo2.ArrivalDate, guestInfo2.Departure);
            FillHistoryGrid(guestInfo2.ReservationNo, guestInfo2.GuestProfileId, guestInfo2.RoomId);


        }
        else {
            //ScorelToTop60px();
            FillDropDownReservation();
            // FillDropDownInhouse();
        }
    });


    $('body').on('change', '#BillTypeId', function () {
        $('#Amount').prop('disabled', false);
        var price = $(this).find("option:selected").attr('data-price');
        var ifFixed = $(this).find("option:selected").attr('data-isfixed');
        $('#amountField').addClass('is-focused');
        $("#Amount").val(Number(parseFloat(price).toFixed(2)).toLocaleString('en', { minimumFractionDigits: 2 }));
        if (ifFixed == "True") {
            $('#Amount').prop('disabled', true);
        }
    });

    $('body').on('change', '#CurrencyId', function () {
        var selectedCurrencyId = $("#CurrencyId option:selected").val();
        $.ajax({
            url: '/CashieringAndPosting/PostingBillType/PostingBillTypeCombo',
            dataType: 'html',
            data: {
                name: "BillTypeId",
                required: true,
                currencyId: selectedCurrencyId
            },
            method: 'POST',
            success: function (data) {
                $('#PostingBillTypeComboContainer').html("");
                $('#PostingBillTypeComboContainer').html(data);
            },
        });
    });

    var currRate, currencyTypeId, CurrencyAmount, ConvertedAmount;

    $('body').off('submit').on('submit', '#Schedule-Posting', function (e) {
        e.preventDefault();
        CallPasswordModel(function (e) {
            if ($('.Res-dates-checkBoxGroup:checked').length > 0) {
                if ($('#Quantity').val() >= 1) {
                    $('#btnSave').removeClass('disabled');
                    postingDatesarray = [];

                    quantity = $('#Quantity').val();
                    currRate = $("#CurrencyId option:selected").attr('data-rate');//convertion rate
                    currencyTypeId = $("#CurrencyId option:selected").val()//currency id
                    CurrencyAmount = parseFloat($('#Amount').val().trim().replace(/,/g, '')).toFixed(2);
                    ConvertedAmount = Number(parseFloat((CurrencyAmount * quantity) * currRate).toFixed(2)).toLocaleString('en', { minimumFractionDigits: 2 });

                    var foliotext = $("#BillTypeId option:selected").text() + '[' + CurrencyAmount.toString() +' '+ $("#CurrencyId option:selected").text() + '*' + quantity.toString() + ']';


                    $.ajax({
                        async: false,
                        url: '/CashieringAndPosting/TaxCalculation/GetOriginalBillValue',
                        dataType: 'json',
                        data: { Amount: parseFloat(ConvertedAmount.replace(/,/g, '')).toFixed(2), TaxGroupId: $("#BillTypeId option:selected").attr('tax-groupid') },
                        method: 'POST',
                        success: function (response) {
                            AmountwithoutTax = response.Amount;

                            if ($('#schedulePostingVia').val() == "fromRes") {

                                schedulePostingdata = {
                                    BillTypeId: $("#BillTypeId option:selected").val(),
                                    TaxGroupId: $("#BillTypeId option:selected").attr('tax-groupid'),
                                    PostingCategoryId: $("#BillTypeId option:selected").attr('posting-catg'),
                                   //FolioText: $("#FolioText").val() == "" ? $("#BillTypeId option:selected").text() : $("#FolioText").val(),
                                    FolioText:foliotext,
                                    //Amount: parseFloat($("#Amount").val().trim().replace(/,/g, '')).toFixed(2),
                                    Amount: parseFloat(AmountwithoutTax.toString().trim().replace(/,/g, '')),
                                    Remarks: $("#Remarks").val(),
                                    ChargeCodeId: parseInt($("#BillTypeId option:selected").attr('charge-code')),
                                    ScheduleDates: getDates(),
                                    ReservationNo: guestInfo2.ReservationNo,
                                    groupresNo: guestInfo2.groupresNo,
                                    GuestName: guestInfo2.GuestName,
                                    RoomCode: guestInfo2.RoomCode,
                                    RoomId: guestInfo2.RoomId,
                                    GuestProfileId: guestInfo2.GuestProfileId,
                                    ArrivalDate: guestInfo2.ArrivalDate,
                                    DepartureDate: guestInfo2.Departure,
                                    DRCR: 'D',
                                    AmountFC: parseFloat($("#Amount").val().trim().replace(/,/g, '')).toFixed(2),
                                    ConvertionRate: parseFloat(currRate),
                                    CurrencyId: currencyTypeId
                                }
                            }
                            else {

                                schedulePostingdata = {
                                    BillTypeId: $("#BillTypeId option:selected").val(),
                                    TaxGroupId: $("#BillTypeId option:selected").attr('tax-groupid'),
                                    PostingCategoryId: $("#BillTypeId option:selected").attr('posting-catg'),
                                    FolioText: $("#FolioText").val() == "" ? $("#BillTypeId option:selected").text() : $("#FolioText").val(),
                                    Amount: parseFloat(AmountwithoutTax.toString().trim().replace(/,/g, '')).toFixed(2),
                                    Remarks: $("#Remarks").val(),
                                    ChargeCodeId: parseInt($("#BillTypeId option:selected").attr('charge-code')),
                                    ScheduleDates: getDates(),
                                    ReservationNo: guestInfo.ReservationNo,
                                    groupresNo: guestInfo.groupresNo,
                                    GuestName: guestInfo.GuestName,
                                    RoomCode: guestInfo.RoomCode,
                                    RoomId: guestInfo.RoomId,
                                    GuestProfileId: guestInfo.GuestProfileId,
                                    ArrivalDate: guestInfo.ArrivalDate,
                                    DepartureDate: guestInfo.Departure,
                                    DRCR: 'D',
                                    AmountFC: parseFloat($("#Amount").val().trim().replace(/,/g, '')).toFixed(2),
                                    ConvertionRate: parseFloat(currRate),
                                    CurrencyId: currencyTypeId
                                }
                            }

                            $.ajax({
                                url: '/CashieringAndPosting/SchedulePosting/SaveSchedulePosting',
                                datatype: 'html',
                                data: schedulePostingdata,
                                method: 'POST',
                                success: function (response) {
                                    var Type = $('#resType').val();
                                    ShowSuccessMessage('Record has been saved successfully.');
                                    //$('#btnSave').addClass('d');
                                    $('#BillTypeId').prop('selectedIndex', 0);
                                    $('#FolioText').val('');
                                    $("#Amount").val('');
                                    $("#Remarks").val('');
                                    $('#Quantity').val(1);

                                    $('#ExistinginvoiceGridloadingArea').html(response);

                                    $('#Schedule-Posting div').addClass('is-empty');
                                    $('#amountField').removeClass('is-focused');

                                    setTimeout(function () {
                                        if (Type == "reservation") {
                                            // closeFullContent();
                                            //LoadReservationGrid();
                                        } else {
                                            //location.reload()
                                            LoadInhouseReservationGrid();
                                        }

                                    }, 2500);


                                },
                                error: function (xhr, status, error) {
                                    ShowErrorMessage('Sorry, There is an error in saving this record.');

                                }
                            });
                        },
                        error: function (xhr, status, error) {
                            ShowErrorMessage('Sorry, There is an error.');
                        }
                    });
                } else {
                    ShowErrorMessage("Please enter the correct quantity");
                    $('#btnSave').addClass('disabled');
                }
            } else {
                ShowErrorMessage("Please select a date to add posting");
                $('#btnSave').addClass('disabled');
            }
        });
    });

    $('body').on('click', '#scheduleHistoryTable .rowDelbtn', function () {
        var currentRow = $(this);
        CallPasswordModel(function (e) {
            DeleteRow(currentRow);
        });
    });

    function DeleteRow(currentRow) {
        var id = $(currentRow, '.rowDelbtn').attr('schedule-Id');
        var chargedate = $(currentRow, '.rowDelbtn').attr('charge-date');
        var ReservationNo = $(currentRow, '.rowDelbtn').attr('res-no');
        var GuestProfileId = $(currentRow, '.rowDelbtn').attr('guest-id');
        var RoomId = $(currentRow, '.rowDelbtn').attr('data-RoomId');

        $.ajax({
            method: 'GET',
            url: '/CashieringAndPosting/SchedulePosting/DeleteHistory?reservationNo=' + ReservationNo + '&guestProfileId=' + GuestProfileId + '&roomId=' + RoomId + '&Id=' + id,
            datatype: 'html',
            success: function (htmlContent) {

                $('#ExistinginvoiceGridloadingArea').html('');
                $('#ExistinginvoiceGridloadingArea').html(htmlContent);

                $('.Res-dates-checkBoxGroup:checked').each(function (index, elm) {
                    //uncheck checked checkboxes

                    if ($(elm).attr('org-date') == chargedate) {

                        $(elm).prop('checked', false);
                    }

                });
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in getting records.');
            }
            ///$(this).closest('tr').remove();

        });
    }

    function getDates() {

        $('.Res-dates-checkBoxGroup:checked').each(function (index, elm) {
            postingDatesarray.push(
                {
                    Sceduledate: $(this).attr('org-date')
                });

        });
        return postingDatesarray;
    }

    //$('#btnClear').click(function () { location.reload(); });

    function hidebuttons() {

        $('.showForm').hide();
        $('.dropdown-toggle').hide();
    }

    //enable schedule button when checkbox selected btnSave

    $('body').on('click', '.Res-dates-checkBoxGroup', function () {
        
        if ($('.Res-dates-checkBoxGroup:checked').length > 0) {
            $('.btn-Save').removeClass('disabled');
            $('#btnSave').removeClass('disabled');
        }
        else {
            $('#btnSave').addClass('disabled');
            $('.btn-Save').addClass('disabled');
        }
    });


