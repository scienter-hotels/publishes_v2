@model Scienter.HotelERP.Common.Domain.PostingRhythm

@{
    ViewBag.Title = "Create / Edit";
}
<style>
    .form-group {
        margin: 20px 0 0 0;
    }
</style>
<div class="col-md-12">

    <form id="guestProfiles">
        @Html.AntiForgeryToken()
        <div class="">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">

                <div class="col-md-3">
                    <div class="row">
                        <div class="col-md-10">
                            <div class="form-group label-floating">
                                <label class="control-label">Name *</label>
                                <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                            </div>
                            <div class="form-group checkbox checkboxgrp">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsDaily)
                                    Is Daily
                                </label> 
                            </div>
                            <div class="form-group checkbox checkboxgrp">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsArrivalOnly)
                                    Is Arrival Only
                                </label>
                            </div>
                            <div class="form-group checkbox checkboxgrp">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsDepartureOnly)
                                    Is Departure Only
                                </label>
                            </div>
                            <div class="form-group checkbox checkboxgrp">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsEveryOtherDay)
                                    Is EveryOther Day
                                </label>
                            </div>
                            <div class="form-group checkbox">
                                <label>
                                    @Html.CheckBoxFor(model => model.IsActive)
                                    Active
                                </label>                             

                            </div>
                            <div class="form-group">
                                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                                &nbsp;
                                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                            </div>
                        </div>
                    </div>
                </div> 

            </div>
        </div>
    </form>
</div>
