@model Scienter.HotelERP.FrontOffice.WebUIMvc.Areas.CashieringAndPosting.Models.ProfitCenterWisePostingViewModel
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    </style>
<form id="ProfitCenterWisePostingForm" class="hidden-print">
    <input type="hidden" value="@Model.Id" name="Id" id="Id" />
    <input type="hidden" value="@ViewBag.postingType" name="postingTypeTitle" id="postingTypeTitle" />
    <div class="row" style="margin-top: -27px;">
        <div class="col-md-12">
            @if (ViewBag.postingType == "walkin") //GANGULI 22-10-12
            {
                <div class="form-group label-floating">
                    <div id="PostingCompanyComboContainer">
                        @Html.LabelFor(model => model.LaundryItemId, "Company", htmlAttributes: new { @class = "control-label" })
                        @{Html.RenderAction("CompaniesCombo", "Companies", new { area = "Administration", name = "CompanyId", required = true, value = Model.CompanyId }); }
                    </div>
                    @*@Html.ValidationMessageFor(model => model.CompanyId, "", new { @class = "text-danger" })*@
                </div>
                <div class="form-group label-floating">
                    @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control font-size-14px", required = true, autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                </div>
                <div class="form-group label-floating">
                    @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label" })
                    @Html.EditorFor(model => model.Address, new { htmlAttributes = new { @class = "form-control font-size-14px", required = true, autocomplete = "off" } })
                    @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger" })
                </div>
                @*<div class="form-group label-floating">
                        <label class="control-label">Company</label>
                        <div id="PostingCompanyComboContainer">
                            @{Html.RenderAction("CompaniesCombo", "Companies", new { area = "Administration", name = "CompanyId", required = true, value = Model.CompanyId }); }
                        </div>
                    </div>*@
            }

            @if (ViewBag.postingType == "guest")
            {
                <div class="form-group label-floating">
                    @Html.LabelFor(model => model.RoomId, "Room Code", htmlAttributes: new { @class = "control-label" })
                    @{Html.RenderAction("GetInHouseRooms", "RoomDetails", new { area = "Administration", name = "RoomId", requiered = true, value = Model.RoomId });}
                    @Html.ValidationMessageFor(model => model.RoomId, "", new { @class = "text-danger" })
                </div>
            }

            @*<div class="form-group label-floating">
                    @Html.LabelFor(model => model.LaundryItemId, "Item", htmlAttributes: new { @class = "control-label" })
                    @{Html.RenderAction("LaundryItemCombo", "LaundryItems", new { area = "Administration", name = "LaundryItemId", requiered = true, value = Model.LaundryItemId });}
                    @Html.ValidationMessageFor(model => model.LaundryItemId, "", new { @class = "text-danger" })
                </div>*@
            <div class="row">
                <div class="col-md-6" style="padding-left:15px;">
                    <div class="form-group label-floating">
                        @*change by Ganguli*@

                        @*@Html.LabelFor(model => model.LaundryItemId, "Item Category", htmlAttributes: new { @class = "control-label" })
                            @{Html.RenderAction("LaundryItemCategoryCombo", "LaundryItemCategories", new { area = "Administration", name = "LaundryItemCategoryId", requiered = true, value = Model.LaundryItemId });}
                            @Html.ValidationMessageFor(model => model.LaundryItemId, "", new { @class = "text-danger" })*@

                        <label class="control-label">Item Category</label>
                        <select name="LaundryItemCategoryId" id="LaundryItemCategoryId" class="select2 form-control LaundryItemCategoryId" required></select>

                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group label-floating">
                        @Html.LabelFor(model => model.LaundryChargeTypeId, "Charge Type", htmlAttributes: new { @class = "control-label" })
                        @{Html.RenderAction("LaundryChargeTypeCombo", "LaundryChargeTypes", new { area = "Administration", name = "LaundryChargeTypeId", requiered = true, value = Model.LaundryChargeTypeId });}
                        @Html.ValidationMessageFor(model => model.LaundryChargeTypeId, "", new { @class = "text-danger" })


                    </div>
                </div>

            </div>

            <div class="row" style="margin-top:-7px;">
                <div class="col-md-6" style="padding-left:15px;">
                    <div class="form-group label-floating">
                        @*@Html.LabelFor(model => model.LaundryItemId, "Item", htmlAttributes: new { @class = "control-label" })
                            @{Html.RenderAction("LaundryItemCombo", "LaundryItems", new { area = "Administration", name = "LaundryItemId", requiered = true, value = Model.LaundryItemId });}
                            @Html.ValidationMessageFor(model => model.LaundryItemId, "", new { @class = "text-danger" })*@

                        <label class="control-label">Item</label>@*change by Ganguli*@
                        <select name="LaundryItemId" id="LaundryItemId" class="select2 form-control LaundryItemId" required></select>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group label-floating">
                        <label class="control-label">Price Type</label>
                        <select name="PriceType" id="PriceType" class="select2 form-control price-type" required></select>
                    </div>
                </div>
            </div>

            <div class="row" style="margin-top:-7px;">
                <div class="col-md-12">
                    <div class="col-md-6" style="padding-left:10px;">
                        <div class="form-group label-floating">
                            <label class="control-label">Rate</label>
                            <input class="form-control text-box single-line number" id="Rate" name="Rate" type="text" value="@Model.Rate" required disabled>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.Quantity, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.Quantity, new { htmlAttributes = new { @class = "form-control font-size-16px text-right", min = 1 } })
                            @Html.ValidationMessageFor(model => model.Quantity, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:-20px;">
                    <div class="col-md-12">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.Remarks, htmlAttributes: new { @class = "control-label" })
                            <textarea id="Remarks" class="form-control" autocomplete="off"></textarea>
                            @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div style="position:absolute; width:86%; bottom:14px; margin-left:-2px;" id="btnDiv2">
        <div class="row" style="margin-left:-12px;">
            <div class="col-md-12" style="margin-bottom:-20px;">
                <div class="form-group checkbox IsComplementarychkbox">
                    <label style="color:#000000">
                        @Html.CheckBoxFor(model => model.IsComplementary)
                        Complementary
                    </label>
                    @Html.ValidationMessageFor(model => model.IsComplementary, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <input type="submit" id="btnAdd" value="Add" class="btn btn-primary" style="width:100%;" />
            </div>
            <div class="col-md-6">
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" style="width:100%;" />
            </div>
        </div>
    </div>
    <input type="hidden" name="FIT" value="" id="FITId" />
</form>

<style>
    #ProfitCenterWisePostingForm .form-group {
        margin: 15px 0 0 0;
    }
    .itemsstyle {
        margin-top: -9px !important;
    }
</style>
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.min.js"></script>
<script>

    $(document).ready(function () {
        $('.card form-group').css('margin-bottom', '10px')

        //2023-08-16--------------------------------------------------------------------------

        $('#LaundryChargeTypeId').addClass('select2');
        $('#RoomId').addClass('select2');
        $('#CompanyId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------

    });

    function LoadItemPriceTypeCombo() {
        $.ajax({
            url: '/Administration/LaundryItems/SelectLaundryItemPriceTypesForCombo',
            dataType: 'json',
            success: function (modules) {
                if ($('.price-type').length > 0) {
                    $('.price-type option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('.price-type'));
                    });
                }
            }
        });
    }


    $('#CompanyId').change(function () {//----*
        debugger;
        let CompanyId = $('#CompanyId').val();
        var Name = $('option:selected', this).attr('data-Name');
        var Address = $('option:selected', this).attr('data-Address');
        var FITProfile = $('option:selected', this).attr('data-FIT');

        $('#Name').val(Name);
        $('#Address').val(Address);
        $('#FITId').val(FITProfile);
        //console.log(Name);
        //console.log(Address);
        //console.log(FITProfile);

        if (FITProfile == 'False') {
            $("#Name").attr("disabled", "disabled");
            $("#Address").attr("disabled", "disabled");
        } else {
            $("#Name").removeAttr("disabled");
            $("#Address").removeAttr("disabled");
        }
    });
</script>