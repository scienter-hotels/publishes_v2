@model Scienter.HotelERP.Common.Domain.ActivityTypeMaintenanceType

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="activityWiseMaintenance">
        @Html.AntiForgeryToken()

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @*<input type="hidden" value="@Model.I                                                                                                                                                                                                                                                                                                                        d" name="Id" id="Id" />*@

        <div class="row">
            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label">Activity *</label>
                    @{Html.RenderAction("ActivityCombo", "Activities", new { name = "ActivityId", requiered = true, value = Model?.ActivityId });}
                </div>
            </div>

        </div>

        <div class="row">
            <div class="col-md-6">
                <fieldset class="the-fieldset">
                    <legend class="the-legend"> Maintenance Type</legend>
                        <div id="companyWiseMarketsContainer">
                            @{Html.RenderAction("LoadActivityWiseMaintenance", "ActivityWiseMaintenanceTypes", new { activityId = 0});}
                        </div>
                </fieldset>
            </div>
        </div>

        <div class="form-group checkbox">
            <label>
                @Html.CheckBoxFor(model => model.IsActive)
                @*<input type="checkbox" checked name="IsActive" value="True" />*@ IsActive
            </label>
            @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
            &nbsp;
            <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
        </div>

    </form>


</div>


@* Select Index change in combo box*@

<script>
    $('#ActivityId').change(function () {
        if ($(this).val() > 0) {

            $.ajax({
                url: '/Maintenance/ActivityWiseMaintenanceTypes/LoadActivityWiseMaintenance?activityId=' + $(this).val(),
                dataType: 'html',
                success: function (data) {
                    $('#companyWiseMarketsContainer').html(data);

                },

            });
        } else {
            $('input:checkbox').removeAttr('checked');
        }
    });
</script>
