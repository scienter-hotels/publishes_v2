        //}

        // $("id").val() = "reservation";

        var actionURL = "/reservation/reservations/CheckOutReservationList";
        //debugger;
        // var id = "reservation";

        if ($('#type').val() == "inhouse") {
            actionURL = "/reservation/reservations/InHouseReservationList"
            // actionURL = "reservation/reservations/reservationlist"
        }
        else if ($('#type').val() == "checkout") {
            actionURL = '/Reservation/Reservations/SearchCheckOut';
            var obj = {};

            obj.Arrival = $('#searchArrival').val();
            obj.Departure = $('#searchDeparture').val();
            obj.GroupNo = $('#searchGroupNo').val();
            obj.ResNo = $('#searchResNo').val();
            obj.Guest = $('#searchGuest').val();
            obj.Company = $('#searchCompany').val();
            obj.VouchNo = $('#searchVouchNo').val();
            obj.Category = $('#searchCategory').val();
            obj.RoomType = $('#searchRoomType').val();
            obj.ANo = $('#searchANo').val();
            obj.KNo = $('#searchKNo').val();
            obj.RoomNo = $('#searchRoomNo').val();
          //  obj.IsCreditEnabled = $('#searchIsCreditEnabled').val();
            obj.Status = $('#searchStatus').val();
            paginations = {};
            paginations = { checkoutList: obj };
        }
        else {
            actionURL = "/reservation/reservations/reservationlist";

            //  $('#dobContainerInGuestProfiles').show();
        }

        $.ajax({
            url: actionURL,
            dataType: 'json',
            data: paginations,
            method: 'POST',
            beforeSend: function () {
                $('#loading-pot').show();
                $('#reservationStatus-list').attr('disabled', true);
                $('.applyBtn').hide();
                $('#existingReservationGrid').hide();
                $('.txtSearch').attr('disabled', true);
                $('#DateFilterFromReservation').attr('disabled', true);
                $('#DateFilterToReservation').attr('disabled', true);
            },
            success: function (data) {
                if (data.length>0) {
                    $('#TotalNoOfRecords').text(data[0].TotalNoOfRows);
                }
                var resNo = $('#resNo').val();
                if ($('#type').val() == "inhouse") {
                    LoadInhouseReservationList(data);
                }
                else if ($('#type').val() == "checkout") {
                    LoadCheckedOutReservationList(data);
                }
                else {
                    LoadReservationList(data);
                }
            },
            complete: function () {
                $('#loading-pot').hide();
                $('#existingReservationGrid').show();
                $('#reservationStatus-list').attr('disabled', false);
                $('.txtSearch').attr('disabled', false);
                $('.applyBtn').show();
                $('.txtSearch').focus();
                $('#DateFilterFromReservation').attr('disabled', false);
                $('#DateFilterToReservation').attr('disabled', false);
            },
            error: function (error) {

            }
        });
    }

