<style>
    .disabled {
        cursor: not-allowed;
    }

    .dataTables_filter {
        width: 29% !important;
        float: left !important;
    }

    .dt-buttons {
        width: 70% !important;
    }

    .superscript {
        font-size: 0.8em;
    }

    .form-group {
        margin-top: 5px;
    }

    .table .radio, .table .checkbox {
        margin-right: 10px;
    }

    #guestGroupGrid {
        font-size: 12px !important;
    }

