
@{
    ViewBag.Title = "Booking Settings";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        @*<button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>*@

                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div id="content">

                </div>
                @Html.Partial("_Loading")
            </div>

        </div>
    </div>
</div>

<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
    // form load --------------------------------
    $(document).ready(function () {
        ShowForm();
    });

    // show form -----------------------------------
    $('body').on('click', '.showForm', function (e) {
        ShowForm();
    });

    function ShowForm()
    {
        $.ajax({
            url: '/administration/bookingsettings/form',
            dataType: 'html',
            method: 'POST',
            success: function (response) {
                $('#contentLoadingArea #content').html('').fadeOut();
                $('#contentLoadingArea #content').html(response).fadeIn();
            }
        });
    }


    // save --------------------------------------
    $('body').on('submit', '#bookingsettings', function (e) {

        e.preventDefault();

        var bookingSettings = {
            __RequestVerificationToken: $('__RequestVerificationToken').val(),
            LocalCountryId: $('#LocalCountryId').val(),
            IBEBookingStatusId: $('#IBEBookingStatusId').val(),
            WebApiBookingStatusId: $('#WebApiBookingStatusId').val(),
            IBEEmailCommiunicationTypeId: $('#IBEEmailCommiunicationTypeId').val(),
            IBETelephoneCommiunicationTypeId: $('#IBETelephoneCommiunicationTypeId').val(),
            WebAgentId: $('#WebAgentId').val(),
            WebApiAgentId: $('#WebApiAgentId').val(),
            AccomadationChargeCodeId: $('#AccomadationChargeCodeId').val(),
            AccomadationTaxGroupId: $('#AccomadationTaxGroupId').val(),
            BookingCancelStatusId: $('#BookingCancelStatusId').val(),
            BookingConfirmStatusId: $('#BookingConfirmStatusId').val(),
            ChargeCodeRoomCharges: $('#ChargeCodeRoomCharges').val(),
            ChargeCodeAdvancedPayments: $('#ChargeCodeAdvancedPayments').val()

        };


        $.ajax({
            url: '/administration/bookingsettings/save',
            dataType: 'html',
            data: bookingSettings,
            method: 'POST',
            success: function (response) {
                ShowSuccessMessage('Record has been saved successfully.');
                $('#contentLoadingArea #content').html('').fadeOut();
                $('#contentLoadingArea #content').html(response).fadeIn();
            }
        });
    });
</script>

