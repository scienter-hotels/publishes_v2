    <style>

        :root {
            --date_color: #ced6e0;
            --available_room: #dfe6e9;
            --table_1: #d0d0d0;
            --table_2: #F1F6F9;
            --rate_color: #D2E9E9;
        }

        html {
            overflow-y: scroll;
            height: auto;
            position: absolute;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        #wrap {
            width: 100%;
            margin: 0 auto;
        }

        #external-events {
            float: left;
            width: 150px;
            padding: 0 10px;
            border: 1px solid #ccc;
            background: #eee;
            text-align: left;
        }

            #external-events h4 {
                font-size: 16px;
                margin-top: 0;
                padding-top: 1em;
            }

            #external-events .fc-event {
                margin: 10px 0;
                cursor: pointer;
            }

            #external-events p {
                margin: 1.5em 0;
                font-size: 11px;
                color: #666;
            }

                #external-events p input {
                    margin: 0;
                    vertical-align: middle;
                }

        #calendar {
            float: right;
            width: 100%;
            height: auto;
            font-family: 'GT Eesti Pro Text', sans-serif;
        }

        .fc-left {
            color: #094F70;
            font-size: 7px;
            padding-right: 10px;
        }

            .fc-left h2 {
                font-family: 'GT Eesti Pro Text', sans-serif !important;
                font-weight: 800 !important;
                display:none;
            }

        .fc-content div .fc-timeline-event {
            margin-top: 10px !important;
            line-height: 20px;
            border-radius: 3px;
        }

        .fc-timeline-event .fc-event {
            top: 10px !important;
        }

        .fc-resource-area {
            width: 160px !important;
        }

        .fc-button {
            border-radius: 0px !important;
            background-color: white !important;
            color: #094F70 !important;
        }

        .fc-title {
            font-size: 10px;
            font-weight: 400 !important;
        }


        .fc-widget-header .fc-time-area {
            z-index: -100 !important;
        }

        /*right slide menu*/
        .right_menu {
            display: none;
            position: fixed;
            top: 0;
            right: 0;
            width: 341.5px !important;
            padding: 10px;
            margin-top: 3px;
            padding-bottom: 3px;
            height: auto;
            padding-top: 10px !important;
            margin-right: 11px;
            font-family: 'GT Eesti Pro Text', sans-serif;
        }

        .main_details {
            margin-top: 20px;
            margin-bottom: 20px;
        }

            .main_details div {
                padding: 5px;
                line-height: 15px;
            }

        .label_div {
            color: black;
            font-size: 12px;
        }

        .span {
            display: inline-block;
        }

        span img {
            width: 30px;
        }

        .side-panel-icons {
            width: 13px;
            margin-right: 30px;
        }

        .db_div {
            color: black;
            font-size: 15px;
        }

        .value-box {
            margin-top: -10px;
            margin-bottom: -10px;
            text-align: center;
            margin-right: 0px !important;
        }

            .value-box span {
                font-size: 14px;
            }

            .value-box .value span {
                font-size: 16px !important;
            }

            .value-box img {
                width: 20px;
            }

        .room_num {
            color: #094F70;
            font-size: 20px !important;
        }

        lable {
            font-size: 12px;
            display: block;
            margin-bottom: 10px;
            font-weight: normal !important;
        }

        hr {
            margin: 3px 0px !important;
        }

        .ch_room_num .form_group {
            margin-top: -10px !important;
            margin-bottom: -40px !important;
            font-size: 12px !important;
        }

        .form_group {
            padding-bottom: 0px;
            margin: 20px 0px -20px 0 !important;
        }

        fc-scroller {
            overflow: hidden !important;
            height: 570px !important;
        }

        #change-title {
            margin-left: -15px;
            font-weight: 500 !important;
            font-family: 'GT Eesti Pro Text', sans-serif !important;
            padding: 15px 0;
            font-size: 18px;
        }

        .close_button {
            background-color: white !important;
            color: #094F70 !important;
            font-size: 28px !important;
        }

        .right_menu_row {
            background-color: #dfe6e9;
            padding: 5px;
            padding-bottom: 16px;
        }

        #cross-close:hover {
            background-color: white !important;
            color: black !important;
        }

        #ledgen_menu {
            width: 273.2px !important;
            padding: 0px;
            padding-top: 7px !important;
            margin-top: 3px;
            overflow-y: scroll;
            margin-right: -6px;
        }

        .ledgendata {
            border-collapse: separate;
            text-align: left;
            border-spacing: 8px;
            margin-top: -9px;
        }

        .circleSpan {
            width: 20px !important;
            height: 20px !important;
            border-radius: 50px;
            border: solid 2px black;
        }

        .ledIcon {
            width: 20px;
            margin-right: 15px;
        }

        .tooltip-inner {
            background-color: #094F70 !important;
            color: white;
            font-weight: 500;
            width: auto;
        }

        .cursor-pointer {
            cursor: pointer !important;
        }

        .fc-view table {
            height: 300px;
        }

        #container {
            height: 200vh;
            display: flex;
            justify-content: center;
            align-items: center;
            position: absolute;
            margin: auto -20px;
            top: 300px;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 9999999;
            background-color: rgba(0, 0, 0,.6);
        }

        #h3 {
            color: white;
        }

        #ring {
            width: 190px;
            height: 190px;
            border: 1px solid transparent;
            border-radius: 50%;
            position: absolute;
        }

            #ring:nth-child(1) {
                border-bottom: 8px solid #e67e22;
                animation: rotate1 2s linear infinite;
            }

        #h3 {
            color: white;
        }

        /*Animation parts (keyframe parts) on scheduler.min.css*/

    </style>

</head>

