
<input type="hidden" id="hidden-isAllowCheckOut" value="@ViewBag.isAllowCheckOut" />
<input type="hidden" id="hidden-reservationHeaderId" value="@ViewBag.reservationHeaderId" />
<form>
    <div class="form-group label-floating col-md-12">
        <label class="control-label">
            Remark
        </label>
        <textarea id="remark" name="remark" cols="50" class="form-control" required></textarea>
    </div>
    <div class="form-group col-md-12">
        <input type="submit" id="btnSave" value="Check-Out" class="btn btn-primary" />
        &nbsp;
        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
    </div>
</form>

<script>
    $(document).ready(function () {
        if ($('#hidden-isAllowCheckOut').val() == 0) {
            ShowErrorMessage('This room is not ready to check Out. Please updated the Folio Header Details.');
            $('.success-popup-ok, .error-popup-ok').closest('.modal').on('hide.bs.modal', function (e) {
                location.reload();
            })
        }
    });

    $('#btnSave').on('click', function (e) {
        debugger;
        e.preventDefault();
        var qCheckOutsList = [];
        var ckOutRemark = "";
        qCheckOutsList.push({
            Id: $('#hidden-reservationHeaderId').val(),
            ReservationNo: ""
        });

        ckOutRemark = $('#CheckOutRemark').val()

        $.ajax({
            url: '/reservation/QuickCheckOut/QuickCheckOut',
            dataType: 'JSON',
            data: { qCheckOut: qCheckOutsList, CheckOutRemark: ckOutRemark },
            method: 'POST',
            success: function (response) {
                ShowSuccessMessage('Guest checked out successfully.');
                $('.success-popup-ok, .error-popup-ok').closest('.modal').on('hide.bs.modal', function (e) {
                    location.reload();
                })
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in checkout.');
            }
        });
    });
</script>