
@{
    ViewBag.Title = "Schedule Posting";
}

<input type="hidden" value="@ViewBag.GResNo" name="" id="gresNo_SP" />
<input type="hidden" value="@ViewBag.ResNo" name="" id="resNo_SP" />
<input type="hidden" value="@ViewBag.GuestName" name="" id="guestName_SP" />
<input type="hidden" value="@ViewBag.RoomNo" name="" id="roomNo_SP" />
<input type="hidden" value="@ViewBag.RoomId" name="" id="roomId_SP" />
<input type="hidden" value="@ViewBag.Arrival" name="" id="arrival_SP" />
<input type="hidden" value="@ViewBag.Departure" name="" id="departure_SP" />
<input type="hidden" value="@ViewBag.GuestProfileId" name="" id="guestProf_SP" />
<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />

@if (@ViewBag.fromReservationScreen != null)
{
    <input type="hidden" value="fromRes" name="" id="schedulePostingVia" />
}
else
{
    <input type="hidden" value="Other" name="" id="schedulePostingVia" />
}
@if (@ViewBag.fromReservationScreen != null)
{
    <div class="row" style="max-height:1000px;">
        <div class="col-md-12">

            @if (@ViewBag.fromReservationScreen == null)
            {
                <div class="card-header hidden-print" data-background-color="purple">
                    <div class="row">
                        <div class="col-md-8">
                            <h4 class="title hidden-print">
                                @ViewBag.Title
                            </h4>
                        </div>

                    </div>
                </div>
            }

            <div class="card-content">
                <div class="row">
                    @if (@ViewBag.fromReservationScreen != null)
                    {
                        <div class="col-md-12">
                            <fieldset class="the-fieldset" style="padding:10px !important;">
                                <legend class="the-legend">Reservation Details</legend>

                                <div class="row">
                                    <div class="col-md-12">
                                        <table class="restable">
                                            <tr style="background-color: #fff !important;">
                                                <td style="width:45px !important;">Guest:&nbsp;</td>
                                                <td id="guest" class="col-md-6" style="padding-left:0px;"></td>

                                                <td style="width:10px;">Room#:&nbsp;</td>
                                                <td id="roomNo" class="col-md-2" style="padding-left:0px;"></td>

                                                <td style="width:10px;">Arrival:&nbsp;</td>
                                                <td id="arrival" class="col-md-2" style="padding-left:0px;"></td>

                                                <td style="width:10px;">Departure:&nbsp;</td>
                                                <td id="depature" class="col-md-2" style="padding-left:0px;"></td>
                                            </tr>
                                        </table>
                                    </div>

                                </div>
                            </fieldset>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-12 hidden-print">
                            <fieldset class="the-fieldset" style="min-height:180px;">
                                <legend class="the-legend">Select Reservations</legend>
                                <div id="contentLoadingArea">
                                    @Html.Partial("_ReservationDetails")
                                </div>
                            </fieldset>
                        </div>
                    }

                </div>
                <div class="row bill-Process">
                    <div class="col-md-2 hidden-print">
                        <fieldset class="the-fieldset" style="min-height:420px !important; max-height:421px !important;">
                            <legend class="the-legend">Booking Dates</legend>
                            <div class="col-md-12" id="reservationDatesLoadingArea"></div>
                        </fieldset>
                    </div>
                    <div class="col-md-3">
                        <fieldset class="the-fieldset" style="min-height:420px !important; max-height:421px !important;">
                            <legend class="the-legend">Schedule Bill</legend>
                            <div class="col-md-12">
                                @Html.Partial("_Form", new Scienter.HotelERP.Common.Domain.Posting())
                            </div>
                        </fieldset>
                    </div>
                    <div class="col-md-7">
                        <fieldset class="the-fieldset" style="min-height:420px !important; max-height:421px !important;">
                            <legend class="the-legend">Existing Invoice Details</legend>
                            <div class="col-md-12" id="ExistinginvoiceGridloadingArea"></div>
                        </fieldset>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row" style="max-height:1000px;">
        <div class="col-md-12">
            <div class="card">
                @if (@ViewBag.fromReservationScreen == null)
                {
                    <div class="card-header hidden-print" data-background-color="purple">
                        <div class="row">
                            <div class="col-md-8">
                                <h4 class="title hidden-print">
                                    @ViewBag.Title
                                </h4>
                            </div>

                        </div>
                    </div>
                }

                <div class="card-content">
                    <div class="row">
                        @if (@ViewBag.fromReservationScreen != null)
                        {
                            <div class="col-md-12">
                                <fieldset class="the-fieldset" style="padding:10px !important;">
                                    <legend class="the-legend">Reservation Details</legend>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <table class="restable">
                                                <tr style="background-color: #fff !important;">
                                                    <td style="width:45px !important;">Guest:&nbsp;</td>
                                                    <td id="guest"></td>
                                                </tr>
                                                <tr>
                                                    <td style="width:10px;">Room#:&nbsp;</td>
                                                    <td id="roomNo"></td>
                                                </tr>

                                            </table>
                                        </div>
                                        <div class="col-md-6">
                                            <table class="restable">
                                                <tr>
                                                    <td style="width:10px;">Arrival:&nbsp;</td>
                                                    <td id="arrival"></td>
                                                </tr>
                                                <tr>
                                                    <td style="width:10px;">Departure:&nbsp;</td>
                                                    <td id="depature"></td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-12 hidden-print">
                                <fieldset class="the-fieldset" style="height:150px;padding:13px 0px 1px 0px;">
                                    @*<legend class="the-legend">Select Reservations</legend>*@
                                    <div id="contentLoadingArea">
                                        @Html.Partial("_ReservationDetails")
                                    </div>
                                </fieldset>
                            </div>
                        }

                    </div>
                    <div class="row bill-Process">
                        <div class="col-md-2 hidden-print">
                            <fieldset class="the-fieldset" style="min-height:350px;">
                                <legend class="the-legend">Booking Dates</legend>
                                <div class="col-md-12" id="reservationDatesLoadingArea"></div>
                            </fieldset>
                        </div>
                        <div class="col-md-3">
                            <fieldset class="the-fieldset" style="min-height:350px;">
                                <legend class="the-legend">Schedule Bill</legend>
                                <div class="col-md-12">
                                    @Html.Partial("_Form", new Scienter.HotelERP.Common.Domain.Posting())
                                </div>
                            </fieldset>
                        </div>
                        <div class="col-md-7">
                            <fieldset class="the-fieldset" style="min-height:350px;">
                                <legend class="the-legend">Existing Invoice Details</legend>

                                <div class="col-md-12" id="ExistinginvoiceGridloadingArea"></div>

                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}



<style>
    .tab-content .form-group {
        margin: 5px 0 0 0;
    }
</style>
<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
