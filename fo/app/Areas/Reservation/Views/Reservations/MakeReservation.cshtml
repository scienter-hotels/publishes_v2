
@{
                /**/

                ViewBag.Title = "Make a Reservation";
}
<style>
    .formWizardNumbers {
        border-radius: 300px;
        padding: 8px;
        margin: 0 auto !important;
        color: white;
        width: 35px;
        text-align: center;
    }

    .formWizardText {
        margin-top: 15px;
        color: #0a1324;
        text-align: center;
        font-size: 13px;
        text-decoration: none;
        text-transform: uppercase;
        margin-left: 5px;
    }

    .step {
        background-color: #f2f2f2;
    }

    .selectedStep {
        background-color: #f2f2f2;
    }

    .stepSmallText {
        font-size: 9px;
        display: block;
    }

    #contentLoadingArea {
        padding-left: 20px !important;
        padding-right: 20px !important;
    }

    .reservation-detail-table {
        height: 130px;
        overflow-y: scroll;
    }
    /*.reservation-form-height {
        height: 500px !important;
    }*/
    .card-content-override {
        max-height: 600px !important;
    }

    .top-padding-0 {
        padding-top: 0px !important;
    }

    .disabled {
        cursor: not-allowed;
    }

    /*2024 - 03 - 27 - Anuradha-------------------------*/
    .isCheckboxDisableTd {
        border: none;
    }
    /*--------------------------------------------------*/
</style>


<div class="card">
    <div class="card-header" data-background-color="purple">
        <div class="row hidden-print">
            <div class="col-md-8">
                <h4 class="title">
                    @ViewBag.Title
                </h4>
            </div>
            <div class="col-md-4 text-right hidden-print">
                <a class="btn btn-sm  btn-theme-color-2 showGrid" href="~/reservation/reservations/makereservation">
                    <span class="glyphicon glyphicon-plus"></span>
                </a>
                <a class="btn btn-sm  btn-theme-color-2 showForm" href="~/reservation/reservations/list">
                    <span class="glyphicon glyphicon-th-list"></span>
                </a>
            </div>
        </div>
    </div>

    <div class="card-content card-content-override top-padding-0">
        <div class="row margin-top-20px reservation-form-height">
            <div class="col-md-12">
                <div class="row">



                    <input type="hidden" name="From" id="FromDateId" class="FromDate" />
                    <input type="hidden" name="reservationFor" id="reservationFor" />
                    <input type="hidden" id="ToDateId" name="To" class="ToDate" />
                    <input type="hidden" id="selectedcompanyid" name="companyid" class="selectedcompanyid" value="" />
                    <input type="hidden" name="noOfNights" class="noOfNights" />
                    <input type="hidden" name="reservation-details" class="hidden-stringify-json-reservation" />
                    <input type="hidden" name="guest-details" class="hidden-stringify-json-guest" />
                    <input type="hidden" name="guest-details" class="hidden-stringify-json-SelectedStay" />
                    <input type="hidden" name="guest-OtherDetails" class="hidden-stringify-json-SelectedStay" />
                    <input type="hidden" name="guest-rateCode" id="data-ratecode-details" data-rate-code data-room-category data-room-type data-meal-plan data-room-rate value="" />

                    <div class="col-md-2 hidden-print">
                        <div class="list-group" style="margin-top:20px;">
                            <div class="text-center list-group-item" id="step01">
                                <a href="javacript:preventDefault();">
                                    <div class="formWizardNumbers theme-bg-color-2"> 1 </div>

                                    <div class="formWizardText">
                                        Select Stay <span class="glyphicon"></span>
                                        <i class="stepSmallText" id="selectedStayRange"></i>
                                    </div>

                                </a>
                            </div>
                            <div class="text-center list-group-item" id="step02">
                                <a href="javacript:preventDefault();">
                                    <div class="formWizardNumbers theme-bg-color-2"> 2 </div>

                                    <div class="formWizardText">
                                        Guest Details <span class="glyphicon"></span>
                                        <i class="stepSmallText"></i>
                                    </div>
                                </a>
                            </div>
                            <div class="text-center list-group-item" id="step03">
                                <a href="javacript:preventDefault();">
                                    <div class="formWizardNumbers theme-bg-color-2"> 3 </div>

                                    <div class="formWizardText">
                                        Other Details <span class="glyphicon"></span>
                                        <i class="stepSmallText"></i>
                                    </div>
                                </a>
                            </div>
                            <div class="text-center list-group-item" id="step04">
                                <a href="javacript:preventDefault();">
                                    <div class="formWizardNumbers theme-bg-color-2"> 4 </div>

                                    <div class="formWizardText">
                                        Confirmation  <span class="glyphicon"></span>
                                        <i class="stepSmallText"></i>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-10">



                        <div class="" id="contentLoadingArea">


                        </div>


                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<input type="hidden" id="data-default-segment" value="@Scienter.HotelERP.Common.Domain.SessionObjects.FOSettings.DefaultSegment" />
<input type="hidden" id="data-res-status" value="" />
<input type="hidden" id="countryComboValue" value="" /> @*2024-03-27 - Anuradha*@

@*<script src="~/Scripts/ui/common/scienter.grid2.js"></script>*@

<script>
    var RoomCountJson = [];
    var appliedExtrasArray = []; ////
    var addedDiscountArray = [];
    // form load --------------------------------
    $(document).ready(function () {
        //$('#RateCodeHeaderId').val(rateCode)
        //ScorelToTop60px();
        $('.showForm').click();
        $('#step01').find($("span")).addClass("glyphicon-record");
        setTimeout(function () {
            SelectRoomAvailability();
            KeepAllowedStatusesForReservation();
            $('.room-wise-counts').find("tr:gt(0)").remove();
            ////var GuestStay = JSON.parse($('.hidden-stringify-json-SelectedStay').val());
            //var dateRange = $('#selectedStayRange').html().replace(" ", "");
            //var countryId = 1;
            //var companyId = $('#data-companyid').val();
            //var startDate = dateRange.split('-')[0];
            //var endDate = dateRange.split('-')[1];
            //var s = ChangeDateFormat(startDate);
            //var e = ChangeDateFormat(endDate);
            //var ratecode = $('#data-ratecode-details').attr('data-rate-code');
            //LoadRateCodeCombo(countryId, companyId, ratecode, s, e);
        }, 2000);
        var resFor = $('#ReseFor').val();
        $('#reservationFor').val(resFor);
        
    });

    // SELECT ROOM AVAILABILITY --------------------------------

    $('body').on('click', '#btnCheckRoomAvailability', function (e) {
        if ($('#ReseFor').val() == 0 || $('#ReseFor').val() == 2) { SelectRoomAvailability(); }
        RoomCountJson = [];
        DrawRoomCountGrid();
        $('#btnManageHeadCount').hide();
    });

    $('body').on('click', '.applyBtn', function (e) {
        if ($('#ReseFor').val() == 0 || $('#ReseFor').val() == 2) { SelectRoomAvailability(); }

    });

    $('body').on('click', '.btnViewRates', function (e) {
        if ($('#ReseFor').val() == 0 || $('#ReseFor').val() == 2) { SelectRoomAvailability(); }
    });

    function SelectRoomAvailability() {

        $('#step01').find($("span")).removeClass("glyphicon-ok");

        if ($('#FromDateId').val() == "undefined" || $('#ToDateId').val() == "undefined" || $('#FromDateId').val().length == 0 || $('#ToDateId').val().length == 0) {
            //  ShowErrorMessage("Please select the stay to continue.");
            $('#reservationDateRange').focus();
        }
        else {

            var CountryId = $('#CountryCombo').val();
            var From = $('#FromDateId').val();
            var To = $('#ToDateId').val();
        }

        var fromFormatted = ChangeDateFormat(From);
        var toFormatted = ChangeDateFormat(To);
        var reservationStatusId = $('#ReservatonStatusId').val();
        var reservationForId = $('#ReseFor').val();
        //alert(reservationStatusId);
        $.ajax({
            url: '/reservation/reservations/GetAvailability',
            dataType: 'html',
            method: 'POST',
            data: { CountryId: CountryId, fromDate: From, toDate: To, reservatonStatusId: reservationStatusId, reservationForId: reservationForId },
            success: function (response) {

                $('#roomAvailabilityContainer').html('').fadeOut();
                $('#roomAvailabilityContainer').html(response).fadeIn();
                setTimeout(function () {
                    $('.btnViewRates').attr('data-href', "/Administration/RoomRates/ViewRoomRates?from=" + fromFormatted + "&to=" + toFormatted + "&countryId=" + CountryId + "");
                    $('.btnViewRates').attr('data-title', "Room Rates from " + fromFormatted + " to " + toFormatted);
                    $('.btnViewRates').attr('data-width', "1000");

                }, 500);
            },
            error: function (error) {
            }
        });
    }

    $('body').on('change', '#ReservatonStatusId', function () {
        SelectRoomAvailability();
    });

    $('body').on('change', '#ReservationType', function () {
        if ($(this).val() == "D" || $(this).val() == "O") {
            $('.dateRangePickerTwoDays').daterangepicker({
                "showDropdowns": true,
                "showWeekNumbers": true,
                "showISOWeekNumbers": true,
                "minDate": $('#hotelCurrentDate').val(),
                "startDate": $('#hotelCurrentDate').val(),
                "endDate": moment().add(1, 'days'),
                "opens": "right",
                "applyClass": "btn-primary",
                "dateLimit": { "days": 0 },
                "dateLimitMin": { "days": 0 },

                locale: {
                    format: 'DD/MM/YYYY'
                }
            }, function (start, end, label) {
                $('input[name="From"]').val(start.format('DD/MM/YYYY'));
                $('input[name="To"]').val(start.format('DD/MM/YYYY'));
            });
        }
        else {
            $('.dateRangePickerTwoDays').daterangepicker({
                "showDropdowns": true,
                "showWeekNumbers": true,
                "showISOWeekNumbers": true,
                "minDate": $('#hotelCurrentDate').val(),
                "startDate": $('#hotelCurrentDate').val(),
                "endDate": moment().add(1, 'days'),
                "opens": "right",
                "applyClass": "btn-primary",
                //"dateLimit": { "days": 15 },
                "dateLimitMin": { "days": 1 },
                locale: {
                    format: 'DD/MM/YYYY'
                }
            }, function (start, end, label) {
                $('input[name="From"]').val(start.format('DD/MM/YYYY'));
                $('input[name="To"]').val(end.format('DD/MM/YYYY'));
            });
        }

    });

    // STEP 01 --------------------------------
    $('body').on('click', '.showForm', function (e) {
        LoadStep01();
    });

    // STEP 01 NEXT --------------------------------
    $('body').on('click', '#btnStep01Next', function (e) {

        $("#btnStep01Next").prop('disabled', true).addClass("disabled");
        e.preventDefault();
        var reservationForId = $('#ReseFor').val();
        $('#reservationFor').val(reservationForId);
        RoomCountJson = [];

        var allowReservation = $('.reservation-status').find(':selected').attr('data-isallowinmakereservation');
        if (allowReservation == "True") {
            $('#data-res-status').val($('.reservation-status').val());
            //var d = new Date();
            var fromDt = new Date($('#reservationDateRange').val().split('-')[0]);
            var toDt = new Date($('#reservationDateRange').val().split('-')[1]);
            var selectedRooms = 0;
            //var isEnoughRooms = true;
            var isRoomSelected = false;

            $(".roomDetail tr").each(function () {

                $(this).find('.room-count').each(function () {
                    selectedRooms = selectedRooms + parseInt($(this).val());

                });
                if (selectedRooms > 0) {
                    isRoomSelected = true;
                }
                if ($(this).find('.room-count').attr('data-max-availability') < selectedRooms && $(this).find('.room-count').attr('data-max-availability') >= 0) {
                    isEnoughRooms = false;
                }
                selectedRooms = 0;

            });

            //Update Room Count Json//
            $('.room-wise-counts tbody tr').each(function (index, eachRoom) {
                RoomCountJson.push({
                    RoomNo: parseInt($(eachRoom).find('.room-number').val()),
                    RoomCatId: $(eachRoom).find('.room-category').val(),
                    roomCatName: $(eachRoom).find('.room-category-name').val(),
                    RoomTypeId: $(eachRoom).find('.room-type').val(),
                    roomTypeName: $(eachRoom).find('.room-type-name').val(),
                    AdultCount: $(eachRoom).find('#NoOfAdults').val(),
                    ChildCount: $(eachRoom).find('#NoOfChildren').val(),
                    InfantCount: $(eachRoom).find('#NoOfInfants').val()
                })
            })

            console.log(RoomCountJson);
            //----------------------//

            //if ($('.reservation-status').val() == "1016") {
            //    isEnoughRooms = true;
            //}
            //else if (!isEnoughRooms) {
            //    ShowWarningMessage('Not enough rooms')
            //}
            if ($('#NoOfAdults').val() > 0) {
                //Check if to and from dates are not same before proceed
                if ($('#ReservationType').val() != "D" && fromDt.getTime() === toDt.getTime()) {
                    ShowWarningMessage('Stay Dates Can Not Be Same!');
                    $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
                }
                else if ($('#ReseFor').val() == 0 || $('#ReseFor').val() == 2) { // Not Cottage

                    if (!isRoomSelected) {
                        ShowWarningMessage('Please enter room count.');
                        $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
                    } else {
                        LoadStep02();
                        $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
                    }
                } else {
                    LoadStep02();
                    $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
                }
            } else {
                ShowWarningMessage('Please enter room count!');
                $("#btnStep01Next").prop("disabled", false).removeClass("disabled");
            }
        }

        //2024 - 03 - 27 - Anuradha-------------------------
        $('#countryComboValue').val($('#CountryCombo').val());
        //--------------------------------------------------
    });

    $('body').off('click', '#data-new-guest').on('click', '#data-new-guest', function (e) {
        $('#data-new-guest').prop('disabled', true).addClass("disabled");
        var guestId = GetSelectedGuest();
        if (guestId > -1) {
            if (confirm('This guest profile already exists.Are you sure want to create a new profile?')) {
                $('.guest-checkBox').each(function (index, element) {
                    if ($(element).prop('checked')) {
                        $(element).prop('checked', false);
                        $(element).removeClass('selectdRecord');
                        return false;
                    }
                });
                if (ValidateGuest()) {
                    CreateNewGuest();
                    $('#data-new-guest').prop('disabled', true).addClass("disabled");
                    ShowSuccessMessage('Guest successfully created');
                    LoadStep03();
                } else {
                    $('#data-new-guest').prop('disabled', false).removeClass("disabled");;
                }
            } else {
                $('#data-new-guest').prop('disabled', false).removeClass("disabled");;
            }
        } else {
            if (ValidateGuest()) {
                CreateNewGuest();
                $('#data-new-guest').prop('disabled', true).addClass("disabled");
                LoadStep03();
            } else {
                ShowWarningMessage('Please fill required information to proceed.');
                $('#data-new-guest').prop('disabled', false).removeClass("disabled");
            }
        }
    });

    function CreateNewGuest() {
        debugger;
        var guestId = GetSelectedGuest();
        SelectedGuest = {
            Id: guestId,
            FirstName: $('#FirstName').val(),
            LastName: $('#LastName').val(),
            Email: $('#Email').val(),
            ContactNo: $('#ContactNo').val(),
            NICPassport: $('#NICPassport').val(),
            SalutationId: $('#SalutationId').val(),
            CountryId: $('#CountryId').val(),
            NationalityId: $('#NationalityId').val(),
            VipLevelId: $('#VipLevelId').val()

        }
        //var selectedGuest = JSON.stringify(SelectedGuest);

        var occupancyCount = JSON.stringify(RoomCountJson);

        if (ValidateGuest()) {
            $.ajax({
                url: '/reservation/reservations/SaveGuest',
                dataType: 'html',
                data: { guestProfile: SelectedGuest, occupancyCount: occupancyCount },
                method: 'POST',
                beforeSend: function () {
                    $('#data-new-guest').prop('disabled', true).addClass("disabled");
                },
                success: function (data) {
                    $('.hidden-stringify-json-guest').val(data);
                },
                complete: function () {
                    $('#data-new-guest').prop('disabled', false).removeClass("disabled");
                },
                error: function (error) {
                }
            });

        } else {
            ShowWarningMessage('Please fill required information proceed.');

        }
    }

    function GetSelectedGuest() {
        var guestId = -1;
        $('.guest-checkBox').each(function (index, element) {
            if ($(element).prop('checked')) {
                guestId = $(element).val();
                return false;
            }
        });
        return guestId;
    }

    $('body').on('click', '#data-existing-guest', function (e) {

        $("#data-existing-guest").prop('disabled', true).addClass("disabled");
        if (ValidateGuest()) {
            var guestId = GetSelectedGuest();

            if (guestId > -1) {
                LoadStep03();
                $("#data-existing-guest").prop('disabled', true).addClass("disabled");
            } else {
                ShowWarningMessage('Please select a guest to proceed.');
                $("#data-existing-guest").prop("disabled", false).removeClass("disabled");
            }

        } else {
            ShowWarningMessage('Please fill required information to proceed.');
            $("#data-existing-guest").prop("disabled", false).removeClass("disabled");
        }
    });

    // STEP 03 NEXT -------------------------------------------------------------------------------
    $('body').on('submit', '#reservationDetail', function (e) {
        e.preventDefault(e);

        if ($('#CompanyId').val() == undefined || $('#CompanyId').val() == "") {
            ShowWarningMessage('Please select a company.');
        }
        else if ($('#RateCodeHeaderId').val() == undefined || $('#RateCodeHeaderId').val() == "") {
            ShowWarningMessage('Please select a rate code.');
        }
        else if ($('#PackageHeaderId').val() == undefined || $('#PackageHeaderId').val() == "") {
            ShowWarningMessage('Please select a package.');
        }
        else if ($('#MarketId').val() == undefined || $('#MarketId').val() == "") {
            ShowWarningMessage('Please select a market.');
        }
        else if ($('#BookingSourceId').val() == undefined || $('#BookingSourceId').val() == "") {
            ShowWarningMessage('Please select a booking source.');
        }
        else if ($('#GuestPaymentModes').val() == undefined || $('#GuestPaymentModes').val() == "") {
            ShowWarningMessage('Please select a guest payment modes.');
        }
        else if ($('#VisitPurposeId').val() == undefined || $('#VisitPurposeId').val() == "") {
            ShowWarningMessage('Please select a visit purpose.');
        }
        else if ($('#MealPlanId').val() == undefined || $('#MealPlanId').val() == "") {
            ShowWarningMessage('Please select a meal plan.');
        }
        else if ($("#MealPlanId option:selected").val() == '') {
            ShowWarningMessage("Please select the meal plan.");
        }
        else if ($('#ExpectedArrivalTimeId #Timerange').val() == undefined || $('#ExpectedArrivalTimeId #Timerange').val() == "") {
            ShowWarningMessage('Please select arrival time.');
        }
        else if ($('#ExpectedDepartureTimeId #Timerange').val() == undefined || $('#ExpectedDepartureTimeId #Timerange').val() == "") {
            ShowWarningMessage('Please select departure time.');
        }
        else {

            var selectedRooms = [];
            var ReservationDetails = JSON.parse($('.hidden-stringify-json-reservation').val());

            var selectedRoomsWithRates = [];
            var ReservationPostings = [];

            $.each(ReservationDetails, function (index, eachDetail) {

                var eachselectedRoom;
                var catId = eachDetail.roomCategoryId;
                var Promo = ''

                if (eachDetail.IsPromotion == 'True') {
                    Promo = 1
                } else {
                    Promo = 0
                }

                $.each(eachDetail.roomTypeArrineachTr, function (index, eachRoomDetail) {

                    eachselectedRoom = {
                        RoomCategoryId: catId,
                        RoomTypeId: eachRoomDetail.roomTypeId,
                        NoOfRooms: eachRoomDetail.count,
                        RateCodeHeaderId: $('#RateCodeHeaderId').val(),
                        MealPlanId: $('#MealPlanId').val(),
                        IsPromotion: Promo
                    }

                    selectedRooms.push(eachselectedRoom);

                });
            });
            //guestdetails object fill---------------------------------------------------------------------------------------------------
            var GuestDetails = JSON.parse($('.hidden-stringify-json-guest').val());

            SelectedGuest = {
                Id: GuestDetails.Id,
                FirstName: GuestDetails.FirstName,
                LastName: GuestDetails.LastName,
                Email: GuestDetails.Email,
                ContactNo: GuestDetails.ContactNo,
                NICPassport: GuestDetails.NICPassport,
                SalutationId: GuestDetails.SalutationId,
                CountryId: GuestDetails.CountryId,
                NationalityId: GuestDetails.NationalityId,

            }
            //SelectedStay object fill----------------------------------------------------------------------------------------------------
            var GuestStay = JSON.parse($('.hidden-stringify-json-SelectedStay').val());
            SelectedStay = {
                CheckIn: $('#FromDateId').val(),
                CheckOut: $('#ToDateId').val(),
                NoOfNights: $('.noOfNights').val(),
                Adults: GuestStay.Adults,
                Kids: GuestStay.Kids,
                Infants: GuestStay.Infants,
                CountryId: GuestStay.CountryId,
                IsFullCottage: GuestStay.IsFullCottage,
                ReservationType: GuestStay.ReservationType
            }

            console.log(SelectedStay);
            //SelectedOtherDetails object fill----------------------------------------------------------------------------------------------------
            var CompanyName = $('#CompanyId :selected').html();
            var ReservationStatus = $('#StatusId :selected').html();

            var IsBillPaymentFromLKR = "";

            if ($('input.isBillPaymentFromLKR').is(':checked')) {                  /* Bangaldesh modification*/
                IsBillPaymentFromLKR = "true"
            } else {
                IsBillPaymentFromLKR = "false"
            }

            var applicablePromotions = $('.hidden-stringify-json-ApplicablePromotions').val();

            var SelectedOtherDetails = {
                CompanyId: $('#CompanyId').val(),
                MarketId: $('#MarketId').val(),
                BookingSourceId: $('#BookingSourceId').val(),
                SegmentId: $('#SegmentId').val(),
                VisitPurposeId: $('#VisitPurposeId').val(),
                VoucherNo: $('#VoucherNo').val(),
                TourNo: $('#TourNo').val(),
                StatusId: $('#StatusId').val(),
                SalesPersonId: $('#SalesPersonId').val(),
                SalesContactNo: $('#SalesPersonContact').val(),
                ArriveForMealId: $('#ArriveMeal').val(),
                DepartuerAfterMealId: $('#DeparturePlan').val(),
                ExpectedArrivalTime: $('#ExpectedArrivalTimeId #Timerange').val(),
                ExpectedDepartureTime: $('#ExpectedDepartureTimeId #Timerange').val(),
                Remark: $('#RemarkId').val(),
                GuestPaymentMode: $('#GuestPaymentModes').val(),
                PackageHeaderId: $('#PackageHeaderId').val(),
                IsBillPaymentFromLKR: IsBillPaymentFromLKR,
                //ExpectedArrivalTimeString: $('#ExpectedArrivalTimeId #Timerange').val().split(' ')[1],
                //ExpectedDepartureTimeString: $('#ExpectedDepartureTimeId #Timerange').val().split(' ')[1],
                ApplicablePromotions: applicablePromotions
            }

            //Rooms with rate------------------------
            $('.roomCategoryWise-roomTypeWise-details tbody tr').each(function () {
                selectedRoomsWithRates.push({
                    RoomCategoryId: $(this).find('input').data('custome-rate-roomcategoryid'),
                    RoomTypeId: $(this).find('input').data('custome-rate-roomtypeid'),
                    CurrencyCode: $(this).find('input').data('custome-rate-currency'),
                    RoomRate: $(this).find('input').val()
                });
            });

            ////Postings
            //ReservationPostings.push({
            //    ExtraPostingId : 1,
            //    Quantity: 2,
            //    Remark: "One",
            //    ReferenceId01: 1,
            //    ReferenceString01:"One"
            //});

            //ReservationPostings.push({
            //    ExtraPostingId: 2,
            //    Quantity: 4,
            //    Remark: "Two",
            //    ReferenceId01: 2,
            //    ReferenceString01: "Two"
            //});

            var quickReservationData = {
                SelectedGuest: SelectedGuest,
                SelectedRooms: selectedRooms,
                SelectedStay: SelectedStay,
                SelectedOtherDetails: SelectedOtherDetails,
                ReservationRoomCountDetails: RoomCountJson,
                RemarkTypeWiseRemarks: remarkJSONArray,
                SelectedRoomsWithRates: selectedRoomsWithRates,
                ReservationPostings: appliedExtrasArray,
                ReservationDiscounts: addedDiscountArray
            };

            var IsApproveAsTentative = $('#ApproveAsTentative').val();
            var IsApproveVoucherNumberDuplication = $('#ApproveVoucherNumberDuplication').val();
            var IsCustomRate = $('#isChangeRoomRateCheckBox').is(':checked') ? 1 : 0;

            console.log(addedDiscountArray);

            $.ajax({
                url: '/reservation/reservations/SaveReservationNew',
                dataType: 'json',
                method: 'POST',
                data: { quickReservation: quickReservationData, IsApproveAsTentative: IsApproveAsTentative, IsApproveVoucherNumberDuplication: IsApproveVoucherNumberDuplication, IsCustomRate:IsCustomRate },
                beforeSend: function () {
                    $("#btnStep03Next").prop('disabled', true).addClass("disabled");
                },
                success: function (data) {
                    if (typeof data == 'string') {
                        if (data.startsWith("Err")) {
                            ShowWarningMessage(data.replace("Error -", ""));
                        } else if (data.startsWith("104")) {
                            var confirmationMsg = data.replace("104-", "")
                            if (confirm(confirmationMsg)) {

                                $('#ApproveAsTentative').val(1);

                                setTimeout(function () {
                                    $("#btnStep03Next").click();
                                }, 1000);

                            }
                        } else if (data.startsWith("105")) {
                            var confirmationMsg = data.replace("105-", "")
                            if (confirm(confirmationMsg)) {

                                $('#ApproveVoucherNumberDuplication').val(1);

