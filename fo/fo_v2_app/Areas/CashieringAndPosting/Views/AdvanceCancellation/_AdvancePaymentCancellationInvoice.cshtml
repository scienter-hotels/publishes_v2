    $('body').on('change', '#AdvancedPayAmount', function () {

        var originalAmount = parseFloat($('.hidden-originalAmount').val());
        var changedAmount = parseFloat($(this).val());

        if (changedAmount > originalAmount) {
            ShowWarningMessage('Refund amount cannot exceed original advance amount.');
            $(this).val(originalAmount.toFixed(2));
        } else {
            $(this).val(changedAmount.toFixed(2));
        }

    })

