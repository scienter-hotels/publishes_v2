@model Scienter.HotelERP.Common.Domain.Budget
@using Scienter.HotelERP.Common.Domain
@using Scienter.HotelERP.FrontOffice.Service


@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="budget">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />

            <div class="row">
                <div class="col-md-5">
                    <div class="form-group label-floating">
                        <label class="control-label">Segment Id *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="4" id="SegId" name="SegId" type="text" value="@Model.SegId" required>
                    </div>

                  
                    @{
                        List<Month> options = new BudgetService().SelectMonth();
                        List<Year>
                            optionyear = new BudgetService().Selectyear();
                    }
                
                        <div class="col-md-12 form-group form-group-marging">
                            <label>Month *</label>
                            <select id="Month" name="Month" required class="month-combo form-control" value="@Model.Month">
                                <option value="0">All</option>
                                @foreach (var item in options)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                        </div>
                 
                   
                        <div class="col-md-12 form-group form-group-marging">
                            <label>Year *</label>
                            <select id="Year" name="Year" required class="year-combo form-control" value="@Model.Year">
                                <option value="0">All</option>
                                @foreach (var item in optionyear)
                                {
                                    <option value="@item.Years">@item.Years</option>
                                }
                            </select>
                        </div>
                    
                    <div class="form-group label-floating">
                        <label class="control-label">Value *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="value" name="value" type="text" value="@Model.Value" required>
                    </div>
                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>

                <div class="col-md-1"></div>

            </div>
        </div>
    </form>


</div>





