@{
    ViewBag.Title = "Service Types";
}


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                    <div class="col-md-4 text-right hidden-print">
                        <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                            <span class="glyphicon glyphicon-plus"></span>
                        </button>

                        <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                            <span class="glyphicon glyphicon-th-list"></span>
                        </button>

                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div id="content">

                </div>
                @Html.Partial("_Loading")
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
         // form load --------------------------------
    $(document).ready(function () {
            FillGrid();
    });

    function LoadServiceCategoriesCombo() {
        debugger;
        $.ajax({
            url: '/administration/servicehub/SelectServiceCategoriesForCombo',
            dataType: 'json',
            success: function (data) {
                if ($('#serviceCat').length > 0) {
                    $('#serviceCat option').not(':first').remove();
                    $.each(data, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#serviceCat'));
                    });
                }
            },
            complete: function (data) {
                var selectedServiceCatId = $('#hdnServiceCatId').val();
                if (selectedServiceCatId>0) {
                    $('#serviceCat').val(selectedServiceCatId);
                    $('#serviceCat').trigger('change');
                }
            }
        });
    }

        // show form --------------------------------
    $('body').on('click', '.showForm', function (e) {
        
        debugger;
            $.ajax({
                url: '/administration/servicehub/ServiceType',
                dataType: 'html',
                method: 'POST',
                success: function (response) {
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }

            });
        });

        // show grid --------------------------------

        $('body').on('click', '.showGrid', function (e) {
            FillGrid();
        });

   

    // save --------------------------------------
    $('body').on('submit', '#serviceType', function (e) {
        e.preventDefault();

        var serviceCategoryId = $('#serviceCat option:selected').val();

        var type = {
            Id: $('#hdnId').val(),
            ServiceCategoryId: serviceCategoryId,
            Name: $('#Name').val(),
            IsActive: $('#IsActive').prop("checked")
        };
        $.ajax({
            url: '/administration/servicehub/ServiceTypeSave',
            dataType: 'html',
            data: type,
            method: 'POST',
            success: function (response) {
                ShowSuccessMessage('Record has been saved successfully.');
                FillGrid();
            }

        });
    });

        // fill grid -----------------------------------
        function FillGrid() {
            var gridId = "#existingServiceTypeGrid"; // change this - relevent grid id
            var paginations = {
                PageIndex: $(gridId).attr('data-page-index'),
                PageSize: $(gridId).attr('data-page-size'),
                FilterType: $(gridId).attr('data-filter-type'),
                SearchKeyword: $(gridId).attr('data-search-keyword')
            }
            $.ajax({
                url: '/administration/servicehub/ServiceTypeGrid',
                dataType: 'html',
                data: paginations,
                method: 'POST',
                success: function (response) {
                    if ($('.grid-container').length > 0) {
                        $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                        $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                    } else {
                        $('#contentLoadingArea #content').html('').fadeOut();
                        $('#contentLoadingArea #content').html(response).fadeIn();
                    }


                }

            });
    }

</script>


