


@model  List<Scienter.HotelERP.Common.Domain.GuestPortal_HotelPromotion>
@{
    ViewBag.Title = "Guest Portal Hotel Promotion";
}

<div class="table-responsive">
    <table class="table table-striped" id="guestPortalHotelPromotion">
        @*2022-10-20*@
        <thead>
            <tr>
                <th class="col-md-2 text-primary">
                    Name
                </th>
                <th class="col-md-5 text-primary">
                    Description
                </th>
                <th class="col-md-1 text-primary">
                    DisplayOrder
                </th>
                <th class="col-md-1 text-primary">
                    Active
                </th>
                <th class="col-md-1 text-primary">
                    From
                </th>
                <th class="col-md-1 text-primary">
                    To
                </th>
                <th class="col-md-1 text-primary">

                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr style="height: 36px !important;">
                <td>
                    @item.Name
                </td>
                <td>
                    @item.Description
                </td>
                <td>
                    @item.DisplayOrder
                </td>
                <td>
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsActive)
                            <span class="hidden">
                                @if (item.IsActive)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>

                </td>
                <td>
                    @item.FromDateFormatted
                </td>
                <td>
                    @item.ToDateFormatted
                </td>
                <td style="text-align:right !important;">
                    <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/GuestPortal/HotelPromotion/Edit/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/GuestPortal/HotelPromotion/Delete/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

<script>

    $(document).ready(function () {
        $('#guestPortalHotelPromotion').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    'pdf',
                    'print'
                ],
                scrollY: '58vh',
            });
        //LoadSelectComplaintActionType();
    });

</script>


