    function LoadProfitCenterCombo() {
        //debugger;
        $.ajax({
            url: '/CashieringAndPosting/ProfitCenter/Select_ProfitCenter_ForCombo',
            dataType: 'json',
            success: function (modules) {
                if ($('.Profit-Centers').length > 0) {
                    $('.Profit-Centers option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $('<option value="' + type.Id + '" ProfitCenter-Id="' + type.Id + '">' + type.Name + ' </option>').appendTo($('#ProfitCenterId'));
                        //console.log(index);
                    });
                }
            },
            complete: function () {
                //debugger;
                $('#ProfitCenterId').val($('#hdn-ProfitCenterId').val());
            }
        });
    }

    function LoadSpaInventoryItem() {
        $.ajax({
            url: '/Administration/ProfitCenter/SelectSpaInventoryItem',
            dataType: 'json',
            success: function (modules) {
                if ($('.Profit-Centers').length > 0) {
                    $('.Profit-Centers option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $('<option value="' + type.ItemCode + '" data-recipe-name="' + type.Description + '">' + type.Description + ' </option>').appendTo($('#inventoryItemId'));
                        //console.log(index);
                    });
                }
            },
            complete: function () {
                //debugger;
                $('#ProfitCenterId').val($('#hdn-ProfitCenterId').val());
                $('#inventoryItemId').val($('#hdn-InventoryItemId').val());
            }
        });
    }

    $('body').on('change', '#inventoryItemId', function (e) {

        var profitCenterId = $('#hdn-ProfitCenterId').val();
        if (profitCenterId > 0) {
           
        } else {
            var selectedOption = $('#inventoryItemId').find('option:selected');
            var itemName = selectedOption.data('recipe-name');
            $('#Name').val(itemName);
        } 
    });

</script>
