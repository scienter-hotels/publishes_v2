@model Scienter.HotelERP.Common.Domain.ProfitCenterItem

@{
    ViewBag.Title = "Create / Edit";
}

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>

<div class="col-md-12">

    <form id="ProfitCenteritems">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="ItemId" id="Id" />
            <input type="hidden" value="@Model.ProfitCenterId" id="hdn-ProfitCenterId" />

            <input type="hidden" value="@Model.CategoryId" id="hdn-CategoryId" />
            <input type="hidden" value="@Model.ChargetypeId" id="hdn-ChargetypeId" />
            <input type="hidden" value="@Model.InventoryItemId" id="hdn-InventoryItemId" />

            <div class="row">
                <div class="col-md-6" style="margin-left: 15px;">
                    <div class="form-group label-floating">
                        <label class="control-label">Profit Centers</label>
                        <select name="ProfitCenters" id="ProfitCenterId" class="select2 form-control Profit-Centers" required></select>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Inventory Item *</label>
                        <select name="InventoryItemId" id="inventoryItemId" class="select2 form-control InventoryItemId"></select>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Selling Rate *</label>
                        <input autocomplete="off" class="form-control text-box single-line SellingPrice" maxlength="100" id="Name" name="Name" type="text" value="@Model.SellingPrice" required>
                    </div>

                    <div class="form-group checkbox" style="margin-top: 1em;margin-bottom: -1em;">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            @*<input type="checkbox" checked name="IsActive" value="True" />*@ Is Active
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12" style="padding-left: 0px;margin-top: -25px;" id="CategoryWiseRatePaletContainer">
                    @*@{Html.RenderAction("CategoryWiseRatePalet", "ProfitCenter", new { Id = Model?.Id });}*@
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">

                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    // form load --------------------------------
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
        //debugger;
        LoadProfitCenterCombo();
        setTimeout(function () {
            let profitCenterId = $('#ProfitCenterId').val();
            //ProfitCenterChange(profitCenterId);
        }, 500);

        LoadSpaInventoryItem();
    });


    $('body').on('click', '#btnClear', function (e) {
        $('#Name').val('');
        $('.SellingPrice').val('0');
    });

    //$('#ProfitCenterId').change(function () {
    //    debugger;
