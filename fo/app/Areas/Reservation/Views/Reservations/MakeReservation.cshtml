            },
            success: function (response) {
                $('#step02').find($('.stepSmallText')).text(guestName);
                $('#step02').find($("span")).removeClass("glyphicon-record");
                $('#step02').find($("span")).addClass("glyphicon-ok");
                $('#step02').find($(".formWizardNumbers")).removeClass("theme-bg-color-2");
                $('#step02').find($(".formWizardNumbers")).addClass("theme-bg-color-3");

                $('#step03').find($("span")).addClass("glyphicon-record");
                $('#contentLoadingArea').html('').fadeOut();
                $('#contentLoadingArea').html(response).fadeIn();

                setTimeout(function () {
                    SetStayDates();
                    //FillTable();

                    $('#ExpectedArrivalTimeId #Timerange').val('2000-01-01 14:00:00');
                    $('#ExpectedDepartureTimeId #Timerange').val('2000-01-01 12:00:00');

                }, 1000);

            },
            complete: function () {
                $("#data-existing-guest").prop("disabled", false).removeClass("disabled");

            },
            error: function (error) {
            }
        });
    }

    $('body').on('click', '.rateValue', function () {
        var a = $(this);
        $('#data-ratecode-details').attr('data-rate-code', a.attr('data-rate-code'));
        $('#data-ratecode-details').attr('data-room-category', a.attr('data-room-category'));
        $('#data-ratecode-details').attr('data-room-type', a.attr('data-room-type'));
        $('#data-ratecode-details').attr('data-meal-plan', a.attr('data-meal-plan'));


        $('#data-ratecode-details').attr('data-room-rate', a.attr('data-room-rate'));
        var res = a.attr('data-rate-code') + ' | ' + a.attr('data-room-category') + ' | ' + a.attr('data-room-type') + ' | ' + a.attr('data-meal-plan') + ' | ' + a.attr('data-room-rate');
        $('#grid-record-detail-model').modal("hide");
        $('.roomDetail tr td').each(function () {
            currentTd = $(this);
            if (currentTd.attr('data-cat-id') == a.attr('data-room-category')) {

                if (currentTd.attr('data-type-id') == a.attr('data-room-type')) {

                    currentTd.find('.room-count').val('1');
                    $('.room-count').keyup();
                    return false;
                }
            }
        });
    });


    function KeepAllowedStatusesForReservation() {

        $('.reservation-status option').each(function () {
            currentOption = $(this);
            if (currentOption.attr('data-isAllowInMakeReservation') == "False") {

                currentOption.prop('hidden', true)
            }
        });
    }


    $('body').on('change', '#ReseFor', function () {
        if ($(this).val() == 1) {
            $('.roomDetail').hide();

            if ($('.room-count-fieldset').hasClass('hidden')) {
                $('.room-count-fieldset').removeClass('hidden').fadeOut();
                $('.room-count-fieldset').fadeIn();
            }

            $.ajax({
                url: '/reservation/reservations/FullCottageDetailSelect',
                dataType: 'json',
                method: 'GET',
                success: function (response) {
                    "use strict";
                    let RoomSet = JSON.parse(response.AvailableRoomTypesJson);

                    $('.room-wise-counts').find("tr:gt(0)").remove();

                    $.each(RoomSet, function (index, roomDetails) {
                        $(
                            '<tr>' +
                            '<td class="padding-6px room-number-name"><input type="hidden" class="room-number" value="' + roomDetails.RoomCode + '" /> #' + roomDetails.RoomCode + '</td>' +
                            '<td class="padding-6px"><input type="hidden" class="room-category-name" value="' + roomDetails.RoomCategoryName + '"/><input type="hidden" class="room-category" value="' + roomDetails.RoomCategoryId + '"/>' + roomDetails.RoomCategoryName + '</td >' +
                            '<td class="padding-6px"><input type="hidden" class="room-type-name" value="' + roomDetails.RoomTypeName + '"/> <input type="hidden" class="room-type-Count" value="' + roomDetails.Count + '"/> <input type="hidden" class="room-type" value="' + roomDetails.RoomTypeId + '"/>' + roomDetails.RoomTypeName + '</td>' +
                            '<td class="padding-6px"><input type="number" name="NoOfAdults" id="NoOfAdults" class="form-control form-control-padding-override" max="5" min="1" value="2" required /></td>' +
                            '<td class="padding-6px"><input type="number" name="NoOfChildren" id="NoOfChildren" class="form-control form-control-padding-override" max="5" min="1" value="0" required /> </td>' +
                            '<td class="padding-6px"><input type="number" name="NoOfInfants" id="NoOfInfants" class="form-control form-control-padding-override" max="5" min="1" value="0" required /> </td>' +
                            //'<td class="padding-6px"><a class= "btn btn-danger btn-sm delete-room"><span class="glyphicon glyphicon-trash"></span></a></td>' +
                            '</tr >'
                        ).appendTo('.room-wise-counts tbody');
                    })

                }
            });



        }
        else {
            $('.room-wise-counts').find("tr:gt(0)").remove();
            $('.roomDetail').show();
            HideGrid();


        }
        $('#reservationFor').val($(this).val());
        SelectRoomAvailability();
    });

</script>
