@model IEnumerable<Scienter.HotelERP.Common.Domain.ProfitCenterPattern>

@{
    ViewBag.Title = "Existing Profit Center Patterns";
}

<div class="table-responsive">
    <table class="table table-striped"
           id="existingProfitCenterPatternGrid">
        <thead>
            <tr>
                <th class="text-primary" style="display:none">
                    Id
                </th>
                <th class="text-primary">
                    Name
                </th>
                <th class="text-primary">
                    Numbe Of Days
                </th>
                <th class="text-primary">
                    Profit Center Name
                </th>
                <th class="col-md-1 text-primary">
                    IsActive
                </th>
                <th class="col-md-1 hidden-print"></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td style="display:none">
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.NumberOfDays)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ProfitCenterName)
                </td>
                <td class="col-md-1">
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsActive)
                            <span class="hidden">
                                @if (item.IsActive)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>
                </td>
                <td class="hidden-print text-right">
                    <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/administration/ProfitCenter/Edit_ProfitCenterPattern/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/ProfitCenter/Delete_ProfitCenterPattern/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>
<script>
    $(document).ready(function () {
        $('#existingProfitCenterPatternGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                    'copy',
                    'excel',
                    'csv',
                    'pdf',
                    'print'
                ],
                scrollY: '58vh',
            });
    });
</script>