@model Scienter.HotelERP.Common.Domain.Image
@{
    Layout = null;
}
@{
    ViewBag.Title = "LoadImages";
}

<div class="form-group label-floating col-md-6">
    @if (@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("FilesUploadTo") == "AzureBlobStorage")
    {
        <div style="margin-bottom:5px;">

            @{
                string imageUrl = "/Attachments/" + Model.Url;
                if (Model.Url.Contains("windows.net"))
                {
                    imageUrl = Model.Url;
                }
            }

            <img class="img img-thumbnail show-popup-image" src="@imageUrl" style="width: 80px; height: 80px;">
            <input type="file" name="Images" id="Images" accept="image/*" multiple style="display:none;">
        </div>
    }
    else
    {
        <img class="img img-thumbnail show-popup-image" src="/Attachments/@Model.Url" style="width: 80px; height: 80px;">
        <input type="file" name="Images" id="Images" accept="image/*" multiple style="display:none;">
    }
</div>

