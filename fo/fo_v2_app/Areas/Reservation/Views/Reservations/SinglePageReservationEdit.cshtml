<input type="hidden" class="meal-arrivalForId" value="@Model.ArrivalForId" />
<input type="hidden" class="meal-leaveAfterId" value="@Model.LeaveAfterId" />
@*--------Hidden fields for reservation update end----------*@

@*----------Hidden fields for stay change------------------*@
<input type="hidden" id="roomCategoryId" value="@ViewBag.RoomCategoryId" />
<input type="hidden" id="ViewRateCodeHeaderId" value="@ViewBag.RateCodeHeaderId" />
<input type="hidden" id="ViewMealPlanId" value="@ViewBag.MealPlanId" />
<input type="hidden" id="ViewRoomTypeId" value="@ViewBag.RoomTypeId" />
<input type="hidden" id="IsChangeRoom" value="@ViewBag.IsChangeRoom" />
<input type="hidden" id="CurrentDate" value="@ViewBag.CurrentDate" />
<input type="hidden" id="ViewCompanyId" value="@ViewBag.CompanyId" />
<input type="hidden" id="ViewCountryId" value="@ViewBag.CountryId" />
<input type="hidden" id="isDormitory" name="isDormitory" value="@ViewBag.IsDormitory" required />
@*----------Hidden fields for stay change end--------------*@
@*-----------Hidden fields for guest update------------------*@
<input type="hidden" id="groupReservationNo" value="@ViewBag.GroupReservationNo" />
@*-----------------------------------------------------------*@

@if (Convert.ToDateTime(Scienter.HotelERP.Common.Domain.SessionObjects.Dashboard.HotelDate).ToShortDateString() == Convert.ToDateTime(Model.Arrival).ToShortDateString())
