    function LoadCalenderByDateRange() {
        var roomDetails = '[]';
        var reservations = '[]';

        $.ajax({
            url: '/Reservation/ReservationChart/SelectRoomDetailsForReservationChart',
            dataType: 'json',
            method: 'POST',
            beforeSend: function () {
                $('#container').show();
            },
            success: function (rooms) {
                roomDetails = '[]'
                roomDetails = rooms

                $.ajax({
                    url: '/Reservation/ReservationChart/SelectReservationsForReservationChartByDateRange',
                    data: { From: $('#From').val(), To: $('#To').val() },
                    dataType: 'json',
                    method: 'POST',
                    success: function (res) {
                        reservations = '[]';
                        reservations = res;
                        DrawCalender(rooms, res);
                        //LoadRates();
                    },
                    error: function () {
                    },

                    complete: function () {
                        $('#calendar').fullCalendar('removeEvents');
                        $('#calendar').fullCalendar('addEventSource', reservations);
                        $('#container').hide();
                    }
                });

            }, complete: function () {
                // $('h2').text("");

            }
        });
    }

    function DrawCalender(roomDetails, reservations) {
        //debugger;
        //var w = window.innerWidth;
        //var h = window.innerHeight;
        //var ar = 0;

        //if (h >= 760) {
        //    ar = 2.1
        //} else {
        //    ar=2.75
        //}

        //console.log(ar)

        $('#calendar').fullCalendar({
            schedulerLicenseKey: 'GPL-My-Project-Is-Open-Source',
            //now: $('#FromDate').val(),
            now: $('#From').val(),
            editable: true, // enable draggable events
            droppable: true, // this allows things to be dropped onto the calendar
            aspectRatio: 2.75,
            scrollTime: '00:00', // undo default 6am scrollTime
            header: {
                left: 'title',
                center: '',
                right: ''
                //timelineDay, timelineThreeDays, timelineTenDays, timeline14Days, timeline21Days,timeline30Days
            },
            defaultView: 'timeline30Days',
            views: {
                //timelineThreeDays: {
                //    type: 'timeline',
                //    duration: { days: 3 },
                //},
                //timelineTenDays: {
                //    type: 'timeline',
                //    duration: { days: 10 }
                //},
                //timeline14Days: {
                //    type: 'timeline',
                //    duration: { days: 14 },
                //},
                //timeline21Days: {
                //    type: 'timeline',
                //    duration: { days: 21 }
                //},
                timeline30Days: {
                    type: 'timeline',
                    duration: { days: 28 }
                }
            },
            resourceLabelText: 'Rooms',
            resources: roomDetails,

            events: reservations,

            eventClick: function (event) {
                var roomId = parseInt(event.resourceId);
                reservationDetail = JSON.parse(event.description);
                reservation = reservationDetail[0];

                dateCalculation(event);
                SetRoomNumber(roomId);

                PopupRightMenu();
                SetTableHeight();
            },

            drop: function (date, jsEvent, ui, resourceId) {
                console.log('drop', date.format(), resourceId);
                // is the "remove after drop" checkbox checked?
                if ($('#drop-remove').is(':checked')) {
                    // if so, remove the element from the "Draggable Events" list
                    $(this).remove();
                }
            },

            eventReceive: function (event) { // called when a proper external event is dropped
                console.log('eventReceive', event);
            },

            eventResize: function (event, delta, revertFunc) {

                reservationDetail = JSON.parse(event.description);
                reservation = reservationDetail[0];
                var roomId = parseInt(event.resourceId);
                var arrival = event.start.format();
                var departure = event.end.format();

                if (reservation.BookingMethod != "OOO") {

                    dateCalculation(event);
                    SetRoomNumber(roomId);
                    SetTableHeight();
                    PopupRightMenu();
                    CheckRoomAvailability(roomId, arrival, departure, reservation.resheaderId);
                }
                else {
                    SetRoomNumber(roomId);
                    LoadCalenderByDateRange();
                    SetTableHeight();
                    CheckRoomAvailability(roomId, arrival, departure, reservation.resheaderId);
                    event.preventDefault();
                }

            },

            eventDrop: function (event, delta, revertFunc) {
                reservationDetail = JSON.parse(event.description);
                reservation = reservationDetail[0];
                var roomId = parseInt(event.resourceId);
                var arrival = event.start.format();

                if (reservation.BookingMethod != "OOO") {
                    var departure = event.end.format();
                    dateCalculation(event);
                    SetRoomNumber(roomId);

                    SetTableHeight();
                    PopupRightMenu();

                    CheckRoomAvailability(roomId, arrival, departure, reservation.resheaderId);
                }
                else {
                    SetRoomNumber(roomId);
                    LoadCalenderByDateRange();
                    SetTableHeight();
                    CheckRoomAvailability(roomId, arrival, '2023-02-10', reservation.resheaderId);
                    event.preventDefault();
                }
            }
        });
        getfcLeftDate();

        $('#external-events .fc-event').each(function () {

            console.log($(this).description);
            // store data so the calendar knows to render an event upon drop
            $(this).data('event', {
                title: $.trim($(this).text()), // use the element's text as the event title
                stick: true // maintain when user navigates (see docs on the renderEvent method)
            });

            // make the event draggable using jQuery UI
            $(this).draggable({
                zIndex: 999,
                revert: true,      // will cause the event to go back to its
                revertDuration: 0  //  original position after the drag
            });

        });

    }

