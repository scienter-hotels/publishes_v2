@model Scienter.HotelERP.Common.Domain.TaxType

@{
    ViewBag.Title = "Create / Edit";
}
<div class="col-md-12">

    <form id="taxtypes">

        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })


            @Html.HiddenFor(model => model.Id)
            <div class="row">
                <div class="col-md-5">

                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Rate *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Rate" name="Rate" type="text" value="@Model.Rate" required>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">ResnetVal *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="ResnetVal" name="ResnetVal" type="text" value="@Model.ResnetVal" required>
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            @*<input type="checkbox" checked name="IsActive" value="True" />*@ Is Active
                        </label>
                        @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })

                    </div>
                </div>
                <div class="col-md-1">
                </div>
                <div class="col-md-4" style="display:none">
                    @{Html.RenderAction("ListVertical", "Properties", new { selectedPoperties = Model.Properties }); }
                </div>
            </div>
            <div class="row">
                <div class="col-md-12" style="padding-left:0px">
                    <div class="form-group">
                        <div class="col-md-10">
                            <input type="submit" value="Save" class="btn btn-primary" />
                            &nbsp;
                            <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>


