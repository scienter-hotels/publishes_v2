                            '<td style="text-align:right;"><span>' + item.OtherRev + '</span></td>' +
                            '<td style="text-align:right;"><span>' + item.InvoiceTotal + '</span></td>' +
                            '<td><span style="margin-left:5px;">' + item.Segment + '</span></td>' +
                            '</tr>'
                        ).appendTo('#cancelResTable');
                    }
                })


                $(document).off('click', '.CurrentPlus').on('click', '.CurrentPlus', function () {
                    $(this).closest('tr.data-row').next('tr.data-row').find('.currentinvoiceDetailsTable').toggle();
                });

                $(document).off('click', '.FuturePlus').on('click', '.FuturePlus', function () {
                    $(this).closest('tr.data-row').next('tr.data-row').find('.futureinvoiceDetailsTable').toggle();
                });

                $(document).off('click', '.PastPlus').on('click', '.PastPlus', function () {
                    $(this).closest('tr.data-row').next('tr.data-row').find('.pastinvoiceDetailsTable').toggle();
                });

