<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/

    .disabled {
        cursor: not-allowed;
    }
</style>

<div>
    <div class="row SearchWindow" style="margin-top:12px;">
        <div class="row">
            <div class="col-md-4">
                @*2024 - 03 - 27 - Anuradha-------------------------*@
                <fieldset class="the-fieldset" style="height:415px;max-height:416px;min-height:415px;">
                @*<fieldset class="the-fieldset" style="height:415px;">*@
                @*--------------------------------------------------*@
                    <legend class="the-legend">Search  / Create Guest Profile</legend>
                    <div id="dataGuestProfileForm">
                        @{Html.RenderAction("GetGuestDetails", "ReservationList", new { id = 0 });}
                    </div>
                </fieldset>
            </div>
            <div class="col-md-8">
                @*2024 - 03 - 27 - Anuradha-------------------------*@
                <fieldset class="the-fieldset" style="max-height:416px;min-height:415px;">
                    @*<fieldset class="the-fieldset" style="max-height:405px">*@
                    @*--------------------------------------------------*@
                    <legend class="the-legend">Existing Guest Profiles</legend>
                    <div class="div-scroll" style="min-height:350px !important; height:350px !important;" id="roomAvailabilityContainer">
                        @{Html.RenderAction("ExistingGuestProfile", "ReservationList");}
                    </div>
                </fieldset>
            </div>
        </div>
    </div>
    <div class="row btnStep02Next">
        @*<div class="col-md-12 text-right" style="margin-top:25px;">
                <button type="button" class="btn theme-bg-color-2" id="btnStep02Next">
                    Next  <span class="glyphicon glyphicon-arrow-right"></span>
                </button>
            </div>*@
        <div class="col-md-8 text-right">
            <button type="button" class="btn theme-bg-color-2" id="data-existing-guest">
                Retrieve selected profile and proceed
            </button>
        </div>
        <div class="col-md-4 text-right">
            <button type="button" class="btn theme-bg-color-1 disabled" id="data-new-guest">
                Create new profile and proceed
            </button>
        </div>
    </div>
</div>

<script>

    //2023-08-16--------------------------------------------------------------------------

    $(document).ready(function () {
        
        LoadDropdowns();
       
    });
    function LoadDropdowns() {
        $('#NationalityId').addClass('select2');
        $('#SalutationId').addClass('select2');
        $('#CountryId').addClass('select2');
        $('#VipLevelId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 100);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });
    }

    $('body').off('click', '.check').on('click', '.check', function () {
        setTimeout(function () {
            LoadDropdowns();
        }, 1000);
    });

    //-------------------------------------------------------------------------------------------
    
    $('body').on('click', '#btnSearch', function (e) {
        SearchCustomer();
    });

    $('.SearchWindow').keypress(function (e) {
        if (e.which == 13) {
            SearchCustomer();
        }
    });

    function SearchCustomer() {

        Salutation = $('#TitleCombo').val(),
            FirstName = $('#FirstName').val(),
            LastName = $('#LastName').val(),
            NICPassport = $('#NICPassport').val(),
            Country = $('#CountryCombo2').val(),
            Nationality = $('#NationalityCombo').val(),
            Email = $('#Email').val(),
            ContactNo = $('#ContactNo').val(),
            $.ajax({
            url: '/reservation/ReservationList/SearchGuest',
                dataType: 'html',
                method: 'POST',
                beforeSend: function () {
                    $('#roomAvailabilityContainer').html('').fadeOut();
                },
                data: { Salutation: Salutation, FirstName: FirstName, LastName: LastName, NICPassport: NICPassport, Country: Country, Nationality: Nationality, Email: Email, ContactNo: ContactNo },
                success: function (response) {
                    $('#roomAvailabilityContainer').html(response).fadeIn();
            },
            complete: function () {
                $('#data-new-guest').removeClass('disabled');
            },
                error: function (error) {

                }
            });
    }


</script> 