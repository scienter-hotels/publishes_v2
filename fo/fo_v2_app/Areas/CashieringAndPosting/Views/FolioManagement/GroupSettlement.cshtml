    $('body').off('click', '.btn-remove-room').on('click', '.btn-remove-room', function () {
        ShowLoader();
        //$('.selectAllRoom').prop('checked', false).addClass('disabled').prop('disabled', true);

        $('.selectAllRoom').prop('checked', false);

        var removedRoom = $(this).data('room-id');

        $('.inhouse-room-list').each(function (index, item) {
            var roomId = $(item).find('.inhouse-rooms').data('inhouse-roomid');

            if (removedRoom === roomId) {
                $(item).find('.inhouse-rooms').prop('checked', false);
                $(item).find('.inhouse-rooms').prop('disabled', false);
            }
        });

        if (roomArray.includes(removedRoom)) {
            $(this).closest('.selected-room-list').remove();
        }

        checkIfAllVisibleRoomsSelected();

        var IsFinalSettlement = 0
        GetActualFolioTotal(IsFinalSettlement);

    });

    function checkIfAllVisibleRoomsSelected() {
        // Get all visible records
        var visibleRooms = $('.inhouse-room-list:visible');

        // Get all visible checkboxes that are checked
        var visibleCheckedRooms = visibleRooms.find('.inhouse-rooms:checked');

        // If the number of checked visible rooms matches the number of total visible rooms, check the "Select All" box
        if (visibleCheckedRooms.length === visibleRooms.length && visibleRooms.length > 0) {
            $('.selectAllRoom').prop('checked', true); // Check the "Select All" checkbox

        } else {
            $('.selectAllRoom').prop('checked', false); // Uncheck the "Select All" checkbox
        }
    }



