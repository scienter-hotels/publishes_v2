@model IEnumerable<Scienter.HotelERP.Common.Domain.Spa_Reservation>

<style>
    .border-margin {
        border: 1px solid white;
    }

    table.dataTable tbody th, table.dataTable tbody td {
        padding: 2px !important;
        text-align: left;
        line-height: 18px;
    }
</style>

<div class="row">
    <div class="col-md-12" id="main-grid-content">
        <div class="table-responsive">
            <table class="table table-sm" id="spaReservationGrid">
                <thead>
                    <tr>
                        <th class="text-primary" hidden>
                            
                        </th>
                        <th class="text-primary">
                            Spa Reservation No
                        </th>
                        <th class="text-primary">
                            Reservation No
                        </th>
                        <th class="text-primary">
                            Date
                        </th>
                        <th class="text-primary">
                            Name
                        </th>
                        <th class="text-primary">
                            Room
                        </th>
                        <th class="text-primary">
                            Status
                        </th>
                        <th class="text-primary">
                            Venue
                        </th>
                        <th class="text-primary">
                            Therapist
                        </th>
                        <th class="text-primary">

                        </th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr value="@item.Id">
                            <td hidden>
                                
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ReservationNo)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ResNo)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.DateFormatted)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.GuestName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.RoomName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Status)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Venue)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Therapist)
                            </td>
                            <td>
                                <div class="form-group checkbox">
                                    <label>
                                        <input class="spaRes-checkBox" type="checkbox" value="@item.Id" data-sparesno="@item.ReservationNo" data-spavenue="@item.Venue" data-spatherapist="@item.Therapist" data-statusid="@item.StatusId" />
                                    </label>
                                </div>
                                @*}*@
                            </td>
                        </tr>
                    }

            </table>
        </div>
    </div>
    <div id="side-buttons" class="hidden">

        <div class="row row-padding0px">
