@model Scienter.HotelERP.Common.Domain.Complain

@{
    ViewBag.Title = "Form";
}

<form id="updatecomplain">
    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    @Html.HiddenFor(model => model.Id)

    <div class="row">
        <div class="col-md-3">
            @{Html.RenderAction("LoadReservation", "GuestComplain", new { name = "ReservationHeaderId", required = true, complainCode = Model?.ComplainCode });}
            @Html.ValidationMessageFor(model => model.ReservationHeaderId, "", new { @class = "text-danger" })

        </div>
        <div class="col-md-9">
            <fieldset class="the-fieldset" style="height:580px;">
                <legend class="the-legend">Guest Complain</legend>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.ComplainCode, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.ComplainCode, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                            @Html.ValidationMessageFor(model => model.ComplainCode, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-6"></div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="control-label">Room</label>
                            <div id="roomcombo">
                                @{Html.RenderAction("SelectRoombyReservation", "RoomDetails", new { name = "RoomId", required = true, value = Model?.RoomId });}
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">

                        
                        <div class="form-group label-floating" id="guestcombo">
                            <label class="control-label">Guest</label>
                            @{Html.RenderAction("GuestSelectByReservation", "GuestProfiles", new { name = "GuestProfileId", required = true, value = Model?.GuestProfileId, @readonly = "readonly" });}
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.ComplainTypeId, htmlAttributes: new { @class = "control-label" })
                            @{Html.RenderAction("ComplainTypeCombo", "ComplainTypes", new { name = "ComplainTypeId", required = true, value = Model?.ComplainTypeId });}
                            @Html.ValidationMessageFor(model => model.ComplainTypeId, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.SensitivityLevelId, htmlAttributes: new { @class = "control-label" })
                            @{Html.RenderAction("SensitivityLevelCombo", "SensitivityLevel", new { name = "SensitivityLevelId", required = true, value = Model?.SensitivityLevelId });}
                            @Html.ValidationMessageFor(model => model.SensitivityLevelId, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            <label class="control-label">Status *</label>
                            @{Html.RenderAction("StatusCombo", "Status", new { name = "StatusId", required = true, value = Model?.StatusId });}
                            @Html.ValidationMessageFor(model => model.StatusId, "", new { @class = "text-danger" })

                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.DepartmentId, htmlAttributes: new { @class = "control-label" })
                            @{Html.RenderAction("DepartmentCombo", "Departments", new { name = "DepartmentId", required = true, value = Model?.DepartmentId });}
                            @Html.ValidationMessageFor(model => model.DepartmentId, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.Subject, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.Subject, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
                            @Html.ValidationMessageFor(model => model.Subject, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group label-floating">
                            @Html.LabelFor(model => model.ComplainLogs.FirstOrDefault().Remark, htmlAttributes: new { @class = "control-label" })
                            @Html.EditorFor(model => model.Description, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                
                    
                
            </fieldset>

            <div class="row">
                <div class="col-md-12" id="taskAssignees">
                   
                    <div id="membersContainer">

                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <div class="col-md-offset-2 col-md-10">
                            <input type="submit" value="Save" class="btn btn-default" />
                            <input type="reset" value="Clear" class="btn btn-default" />
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#roomcombo').addClass('disabled');
        $('#guestcombo').addClass('disabled');
        
        LoadRoom();
        LoadGuest();
    });

    $('body').on('change', '.reservationHeader', function () {
        
        LoadRoom();
        LoadGuest();
    });


    function LoadRoom() {
        $.ajax({
            url: '/RoomDetails/SelectRoombyReservation?reservationId=' + $('.reservationHeader:checked').val() + '&name=roomheadercombo',
            dataType: 'html',
            method: 'get',
            success: function (data) {
                $('#roomcombo').html('');
                $('#roomcombo').html(data);
            }
        });
    }
    function LoadGuest() {
        $.ajax({
            url: '/GuestProfiles/GuestSelectByReservation?reservationId=' + $('.reservationHeader:checked').val() + '&name=guest-combo',
            dataType: 'html',
            method: 'get',
            success: function (data) {
                $('#guestcombo').html('');
                $('#guestcombo').html(data);
            }
        });
    }


    $(document).ready(function () {

        LoadMember();
    });


    function LoadMember() {
        $.ajax({
            url: '/StaffDetails/VerticalList',
            dataType: 'html',
            method: 'POST',
            data: { Code: $('#ComplainCode').val() },
            success: function (response) {
                
                $('#membersContainer').html('').fadeOut();
                $('#membersContainer').html(response).fadeIn();
            },
            error: function (error) {
                
            }
        });
    }

</script>



