    $('body').on('click', '.room-well', function () {

        if ($(this).hasClass('selected-room-well')) {
            $(this).removeClass('selected-room-well');
        } else {
            $(this).addClass('selected-room-well');
        }

        if ($('.selected-room-well ').length > 1) {
            $('.room-wise-outoforder-grid').hide();
        } else if ($('.selected-room-well ').length == 1) {
            $('.room-wise-outoforder-grid').show();
            var roomId = $('.selected-room-well ').find('#room-id').val();

            $.ajax({
                url: '/housekeeping/outofordertxn/SelectOutOfOrderListRoomWise?roomId=' + roomId,
                dataType: 'json',
                method: 'get',
                success: function (data) {
                    $('.room-wise-outoforder-grid').html('');

                    $.each(data, function (index, item) {
                        $('.room-wise-outoforder-grid').append('<tr>' +
                            '<td>' + item.FromDateString + '</td>' +
                            '<td>' + item.ToDateString + '</td>' +
                            '<td>' + item.OutofOrderReason + '</td>' +
                            '<td style="text-align:right"><button type="button" data-rowID = "' + item.Id + '" class="btn btn-danger btn-sm outoforderdelete"> <span class="glyphicon glyphicon-minus"></span></button></td></tr>');
                    })
                }
            });
        } 
        
    })

    $('body').on('click', '.outoforderdelete', function () {
        if (confirm("Are you sure you want to release this room?")) {
            var val = $(this).attr('data-rowID');
            var val1 = $(this).data('rowID');
            $.ajax({
                url: '/housekeeping/outofordertxn/QuickDeleteRoomWise?id=' + $(this).attr('data-rowID'),
                dataType: 'json',
                method: 'get',
                success: function (data) {
                    $('.showForm').click();
                }
            });
        }
