    function FillCountryCombo() {
        $.ajax({
            url: '/reservation/reservations/CountryCombo',
            dataType: 'json',
            success: function (data) {
                $('#CountryCombo').find('option').not(':first-child').remove();
                $.each(data, function (index, country) {
                    if (country.Id == 217) {
                        $('<option value="' + country.Id + '" selected>' + country.Name + '</option>').appendTo($('#CountryCombo'));  // Bangaladesh Modification
                    } else {
                        $('<option value="' + country.Id + '">' + country.Name + '</option>').appendTo($('#CountryCombo'));
                    }
                });
            },
        });
    }

