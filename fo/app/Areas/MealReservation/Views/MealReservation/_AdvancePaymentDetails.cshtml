@model IEnumerable<Scienter.HotelERP.Common.Domain.MealReservationWiseAdvancePayments>
<style>

    .theme-bg-color-2 {
        background-color: #038958 !important;
        background: #094F70 !important;
    }

    .text-right {
        text-align: right;
        text-align: left !important;
    }
</style>
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("IsDirectPrint")" name="" id="IsDirectPrint" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />

<form id="advForm">
    <input type="hidden" name="docno" id="DocNo" value="DocNo" />
    <fieldset class="the-fieldset collapse" id="addNewPay">

        <input type="hidden" id="isBillToAgent" value="@ViewBag.isBillToAgent" />
        <input type="hidden" id="advMealReservationId" value="@ViewBag.MResId" />
        <input type="hidden" id="mealReservationId" value="@ViewBag.MResId" />

        <div class="row">
            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label">Amount *</label>
                    <input class="form-control text-box single-line" id="advAmount" name="Meal Reservation Name" type="number" value="" min="0" required>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label">Date *</label>
                    <input autocomplete="off" disabled class="form-control text-box single-line datePicker" id="advDate" name="Date" value="" required>
                </div>
            </div>
        </div>


        <div class="row">

            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label" id="advPaymenMode">PaymenMode </label>
                    @{Html.RenderAction("PaymentModesCombo", "PaymentModes", new { area = "Administration", name = "Payment_ModeId", });}
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label">Settlement Remark *</label>
                    <input class="form-control text-box single-line" id="settlementRemark" name="Settlement Remark" type="text" value="">
                </div>
            </div>
        </div>

        <div class="row">
            @*<div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label" id="advPaymenMode">PaymenMode </label>
                    @{Html.RenderAction("PaymentModesCombo", "PaymentModes", new { area = "Administration", name = "Payment_ModeId", });}
                </div>
            </div>*@
            <div class="col-md-6">
                <div class="form-group label-floating">
                    <label class="control-label">Remark</label>
                    <input class="form-control text-box single-line" id="advRemark" name="Meal Reservation Remark" type="text" value="">
                </div>
            </div>
        </div>
        <div class="row margin-top-10px">
            <div class="col-md-12">
                <div class="col-md-12 text-right" style="margin-top:25px;">
                    <button type="button" class="btn theme-bg-color-2 btnAdvSave disabled" id="btnAdvSave">
                        Save  <span class="glyphicon glyphicon"></span>
                    </button>

                    @if (Scienter.HotelERP.Common.Utility.Configs.GetAppSettingBoolValue("IsDirectPrint"))
                    {
                        <button type="button" disabled class="btn theme-bg-color-2 btnAdvPrint disabled" id="btnAdvPrint" title="Print">
                            Print  <span class="glyphicon glyphicon"></span>
                        </button>
                    }
                    else
                    {
                        <a id="btnAdvPrint" class="btn btn-primary hidden-print" target="">
                            <span class="glyphicon glyphicon-print"></span>
                        </a>
                    }

                </div>
            </div>
        </div>
    </fieldset>
    <div class="card-content reservation-form-height">
        <button type="button" id="AddToggle" data-toggle="collapse" data-target="#addNewPay" class="btn btn-sm theme-bg-color-2 pull-right">
            <span class="glyphicon glyphicon-plus"></span> Add New Advance
            <div class="ripple-container"></div>
        </button>
        <div class="col-md-12 table-responsive" style="overflow-y:scroll; height:200px">
            <table class="table table-striped" id="MealReservationGrid2">
                <tr>
                    <th class="text-primary">
                        Doc no
                    </th>
                    <th class="text-primary">
                        Txn Date Time
                    </th>
                    <th class="text-primary">
                        Amount
                    </th>
                    <th class="text-primary">
                        Payment Mode
                    </th>
                    <th class="text-primary">
                        Status
                    </th>

                    <th class="text-primary">
                        Cancel
                    </th>

                    @*<th class="text-primary" style="text-align:right">
                            Print
                        </th>*@
                </tr>
                @*@if (Model.Count() == 0)
                {
                    <tr>
                        <td>
                            No Records.
                        </td>
                    </tr>
                }*@
                @*else
                    {

                        foreach (var item in Model)
                        {
                            <tr value="@item.Id">
                                <td>
                                    @Html.DisplayFor(modelItem => item.DocNo)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Date)
                                </td>
                                <td>

                                    @Html.DisplayFor(modelItem => item.Amount)
                                </td>
                                <td>

                                    @Html.DisplayFor(modelItem => item.Payment_ModeName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Status)
                                </td>

                                @if (item.Status == "T")
                                {

                                }
                                else
                                {
                                    <td>
                                        <a class="btn btn-danger btn-sm btnEdit" id="btnAdvCancel" data-item-Id="@item.Id">
                                            <span class="glyphicon glyphicon-remove"></span>
                                        </a>
                                    </td>
                                }

                                @*<td>
                                        <a href="" class="pull-right btn btn-primary hidden-print" target="_blank" id="" data-docno="@item.DocNo" style="padding: 5px 10px;"><span class="glyphicon glyphicon-print"></span></a>
                                    </td>
                            </tr>
                        }
                    }*@
            </table>
        </div>
    </div>
</form>

<script>
    $(document).ready(function () {
        RemarkRequiredVerificationByPaymentType();
        //$('.btnAdvPrint').prop('disabled', true);
        LoadGridAdvancePayment();//GANGULI 25-08-2022
        $('.btnAdvSave').removeClass('disabled');

    });

    $('.datePicker').daterangepicker({
        "showDropdowns": true,
        singleDatePicker: true,
        "showWeekNumbers": true,
        "showISOWeekNumbers": true,
        //"minDate": $('#hotelCurrentDate').val(),
        "opens": "right",
        "applyClass": "btn-primary",
        locale: {
            format: 'DD/MM/YYYY'
        }
    }, function (start, end, label) {
        $('input[name="From"]').val(start.format('DD/MM/YYYY'));
        $('input[name="To"]').val(end.format('DD/MM/YYYY'));
    });
    //GANGULI 25-08-2022
    function LoadGridAdvancePayment() {
        var mealReservationId = $('#mealReservationId').val();
        $.ajax({
            url: '/MealReservation/MealReservation/AdvancePaymentDetailsSelect',
            method: 'POST',
            data: { mealReservationId: mealReservationId},
            success: function (response) {
                $('.data-row').remove();
                console.log(response);
                $(response).each(function (index, item) {
                    var button = '';
                    if (item.Status == 'A') {
                        button = '<button type="button" data-id="' + item.Id + '" id="btnAdvCancel" class="btn btn-sm btn-danger btnAdvCancel" title="Delete"><span class="glyphicon glyphicon-remove"></button>'
                    }

                    $('<tr class="data-row">' +
                        '<td>' + item.DocNo + '</td>' +
                        '<td>' + item.DateToDispaly + '</td>' +
                        '<td>' + item.Amount + '</td>' +
                        '<td>' + item.Payment_ModeName + '</td>' +
                        '<td>' + item.Status + '</td>' +
                        '<td>' +
                        button +
                        '</td>' +
                        '</tr >').appendTo('#MealReservationGrid2');
                });
            },
            error: function () {
                alert('There is an Error');
            }
        });
    }


    $('#Payment_ModeId').change(function () {
        debugger;
        RemarkRequiredVerificationByPaymentType();
    });

    function RemarkRequiredVerificationByPaymentType() {
        debugger;

        if ($('#Payment_ModeId option:selected').attr('required-remarks',true)) {

            $('#settlementRemark').prop('required', true);

        }
        else {
            $('#settlementRemark').prop('required', false);
        }
    }

    //#AddToggle
    $('body').off('click', '#AddToggle').on('click', '#AddToggle', function (e) {
        e.preventDefault();
        $('.btnAdvSave').removeClass('disabled');
        $('#advAmount').val('');
        $('#advRemark').val('');
        $('#Payment_ModeId').val(0);
        $('#settlementRemark').val('');

    });

</script>
