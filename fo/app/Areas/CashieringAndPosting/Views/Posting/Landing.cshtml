                            var docno = $('#ReportHeader #walkin-billheader td .RptinvoiceNo').text().replace('Receipt#:', '').trim();
                            var docType = "GEP";
                            CreateFiscalPrinterRequestUrl(invoiceNo, docno, docType);
                        }
                    }
                });
            }
            //-----------------------------------------End walkin posting-------------------


            //---------------------------------------------rebate posting---------------------
            else if (postingtype == "rebate") {

                var rebateposting = {
                    BillTypeId: $("#BillTypeId option:selected").val(),
                    TaxGroupId: $("#BillTypeId option:selected").attr('tax-groupid'),
