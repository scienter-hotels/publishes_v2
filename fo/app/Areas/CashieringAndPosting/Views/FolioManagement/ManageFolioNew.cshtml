    function GetAllSettledFoliosNumbers(roomNo, reservationHeaderId) {
        $.ajax({
            url: '/CashieringAndPosting/FolioManagement/GetAllSettledFolios',
            dataType: 'json',
            data: { RoomNo: roomNo, ReservationHeaderId: reservationHeaderId },
            success: function (data) {
                $('.btn-folio-numbers').html('')
                $.each(data, function (index, item) {
                    console.log(item);
                    $('.btn-folio-numbers').append('<div value="' + item.FolioNo + '"  id="' + item.FolioNo + '" class="well-height well col-md-11  folio-btn"  style="cursor:pointer; margin-bottom:5px !important; padding-left:5px !important; width:100% !important; padding-right:5px !important; background-color: #645d51  !important; color:#ffffff; padding:8px; min-height:60px;">'
                        + '<div class="ribbon hidden" style="position:absolute;"><span style="width:80px !important; top:12px !important; right:-19px !important; background-color:#850272 !important" >selected</span></div>'
                        + '<div class="col-md-3 res-this-folio-no" style="color:#f1c40f; font-size:30px; padding:4px 20px 0px 5px !important;"><b>' + item.FolioNo + '</b></div>'
                        + '<input type="hidden" class="hidden-folio-header-Id" value="' + item.FolioHeaderID + '">'
                        + '<div class="col-md-6" style="text-align:left; padding:0px 5px 0px 5px !important;">' + item.FolioCompanyName + '</div>'
                        //+ '<div class="col-md-6" style="text-align:left; padding:0px 5px 0px 5px !important;">' + item.InvoiceNo + '</div>'
                        //+ '<div class="col-md-6" style="text-align:left; padding:0px 5px 0px 5px !important; font-size: 12px;">' + item.RefDocNo + '</div>'
                        + '</div>'
                        + '<div class="row" style="margin-left:1px;margin-right:1px;"><div class="col-md-12" style="text-align: right;padding: 0px 5px 0px 5px !important;color: #fff;font-style: italic;font-size: 14px;background-color:#645d51 !important;margin:58px 0 0 0;height:25px;"><a href="/Reporting/Report/ViewReport?ReportName=FolioInvoice&ReservationHeaderId=' + reservationHeaderId + '&FolioNo=' + item.FolioNo + '&IsPreview=0' + '&IsLKROnlyInvoice=0" style="margin: -8px 7px 12px 0;"  class="pull-right reportViewBtn" target="_blank">' + item.InvoiceNo + '</a></div></div>'
                    );
                });
            }
        });
    }

    //Send documents
    $('body').off('click', '#btnSendInvoicePreview').on('click', '#btnSendInvoicePreview', function (e) {
        // read values from the clicked button's data-* attributes
        var invoiceNo = "";
        var resNo = $('.hdn-reservation-No').val();
        
        var documentParams = {
            reservationHeaderId: reservationHeaderId, // prefer button's value; fallback to global
            guestProfileId: $('#GuestProfileId').val(),
            Uuid: "",
            reservationLevel: "Folio",
            reservationNo: resNo,
            InvoiceNo: invoiceNo,
            FolioNo: folioNo
        };

        if (folioNo > 0) {
            var url = '/DocumentDelivery/DocumentDelivery?documentParams=' + encodeURIComponent(JSON.stringify(documentParams));
            var title = 'Send Document ' + (typeof resNo !== 'undefined' ? resNo : '');

            CallDetailModelSimple(title, url, 800);
        } else {
            ShowWarningMessage('Select folio to proceed.');
        }

        
    });


</script>