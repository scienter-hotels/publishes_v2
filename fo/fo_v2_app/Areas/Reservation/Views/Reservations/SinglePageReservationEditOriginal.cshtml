<script>
    var countryId = 0;
    $(document).ready(function () {

        LoadCompanies();
        LoadRateCodes();
        LoadMarkets();
        LoadSegments();
        loadVisitPuposeCombo();
        LoadReservationStatus();
        $('#RoomCategory').attr("disabled", true);
        $('#RoomType').attr("disabled", true);

        timeArrival = $('.timeArrival').val();
        $('.resArrivalTime .time-range').val(timeArrival);

        timeDeparture = $('.timeDeparture').val();
        $('.resDepartureTime .time-range').val(timeDeparture);

        $('#ArrivalDate').prop("disabled", true);
        $('#DepartureDate').prop("disabled", true);
        $('#MealPlanId').prop("disabled", true);
    });

    function searchReservation() {

        var input, filter, count, tt, b, i, li;

        input = document.getElementById("txtSearch");
        filter = input.value.toUpperCase();
        ul = document.getElementById("myUL");
        li = ul.getElementsByTagName("li");

        for (i = 0; i < li.length; i++) {
            b = li[i].getElementsByTagName("label")[0];
            if (b.innerHTML.toUpperCase().indexOf(filter) > -1) {
                li[i].style.display = "";
            } else {
                li[i].style.display = "none";

            }
        }
    }
</script>
