@model IEnumerable<Scienter.HotelERP.Common.Domain.ViewModels.RoomDetailView>
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    .dates-div {
        height: 290px !important;
    }

    .form-group-margin-override {
        margin-top: 5px !important;
    }

    .col12-padding {
        padding-left: 1px !important;
    }

    .well-customize {
        padding: 5px !important;
        margin-bottom: 10px !important;
        border: 1px solid #a7a4a4;
        border-radius: 0px;
    }

    .colpaddingLeft {
        padding-left: 5px !important;
    }

    .colpaddingRight {
        padding-right: 5px !important;
    }

    .dates-div {
        height: 250px !important;
    }

    .top-padding-for-date {
        padding-top: 10px !important;
    }

    .col-md-2-5 {
        padding-right: 5px;
        padding-left: 0px;
        margin-bottom: -5px;
    }
</style>
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id" name="" id="PropertyId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.Id" name="" id="UserId" />
<input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintURL")" id="DirectPrintURL" />
<input type="hidden" value="@ViewBag.ReservationNo" id="ReservationNumber" />
<input type="hidden" id="GuestName" value="@ViewBag.guestName" />
<input type="hidden" id="roomNo" value="@ViewBag.AssingedRoom" />
<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />

<style>
    .searchBox .form-group {
        margin: 0px !important;
    }
</style>
<div class="row searchBox">
    <div class="col-md-10">
        <input type="text" id="roomSearchBy" placeholder="Search by room code, name or housekeeping status" class="form-control" />
    </div>
    <div class="col-md-2">
        <button type="button" class="btn-primary btn btn-block searchByBtn" style="width: 100%;float: right;">Search<div class="ripple-container"></div></button>
    </div>
</div>


<div class="manage-group">

    <div class="row" style="margin-right: -17px;margin-left: 0px;">
        @*<div class="col-md-12 col12-padding form-group label-floating form-group-margin-override">
                <input type="hidden" value="@Model.Id" class="reservation-header-id" />
                <label class="control-label">Rooms</label>
                @{ Html.RenderAction("AvailaleRoomsForReservatioinCombo", "RoomChange", new { reservationHeaderId = Model.Id, name = "RoomDetails", required = true });}
            </div>*@

        <div class="col-md-12 rooms-div div-scroll">
            <div class="row">
                @foreach (var item in Model)
                {

                    List<string> list = item.Name.Split('-').ToList();

                    string dis = "";
                    if (ViewBag.ReservationRoom == item.Id)
                    {
                        dis = "disabled";
                    }


                    <div class="col-md-2 col-md-2-5 each-date room-block" data-room-text="@list[0] @list[1] @list[2]">
                        <div class="well well-customize" style="padding-top: 0px !important;padding-bottom: 0px !important;border-color: @item.Code">
                            <div class="row well-margin-1">
                                <div class="col-md-9 pad-l-r-0 max-height-well" style="background-color:@item.Code;opacity:1;">

                                    <span class="room-code color-white" style="font-size:14px !important; padding-left:5px; padding-top:5px;">
                                        @list[0]<br /><span class="room-name color-white" style="font-size:12px !important; padding:0px; font-weight:normal !important">@list[1] (@list[2])</span>
                                    </span>
                                </div>
                                <div class="col-md-3  pad-l-r-0 max-height-well" style="background-color:@item.Code; opacity:0.8">
                                    <div class="checkbox well-middle">
                                        <label>
                                            <input type="checkbox" @dis class="room-check-box" value="@item.Id" />
                                            <input type="hidden" />
                                        </label>
                                    </div>
                                </div>



                                @*<div class="col-sm-3 col-md-4 pad-l-r-0 max-height-well" style="background-color:@item.Code;opacity:1;">
                                        <span class="room-code color-white">@list[0]</span>
                                        <hr />
                                        <span class="room-name color-white">@list[1]</span>
                                    </div>
                                    <div class="col-sm-6 col-md-5 pad-l-r-0 max-height-well well-border-l-r" style="background-color:@item.Code; opacity:0.8">
                                        <span class="room-status color-white">@list[2]</span>
                                    </div>
                                    <div class="col-sm-3 col-md-3 pad-l-r-0 max-height-well" style="background-color:@item.Code; opacity:0.8">
                                        <div class="checkbox well-middle">
                                            <label>
                                                <input type="checkbox" @dis class="room-check-box" value="@item.Id" />
                                                <input type="hidden" />
                                            </label>
                                        </div>
                                    </div>*@
                            </div>
                        </div>
                    </div>

                }
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 form-group label-floating ">
                <label class="control-label">Rooms Change Reason</label>
                @{ Html.RenderAction("RoomChangeReasonSelect", "RoomChange", new { name = "RoomDetails", required = true });}
            </div>

            <div class="col-md-5  form-group label-floating">
                <label class="control-label">Remark</label>
                <input type="text" class="Remark form-control" value="" />
            </div>
            <div class="col-md-3">
                <div class="row" style="margin-top: 1.6em;">
                    <div class="col-md-5">
                        <button type="button" class="btn-danger btn btn-block clear-all" style="width: 10em;float: left;">Clear</button>
                    </div>

                    <div class="col-md-7">
                        <button type="button" class="btn-primary btn btn-block save-room-change" style="width: 10em;float: left;">Save</button>
                    </div>
                </div>
            </div>
        </div>
        @*<div class="row pad0-masr0">
                <div class="col-md-6 col-md-offset-6">
                    <div class="row pad0-mar0">
                        <div class="col-md-8 col-md-offset-4">
                            <button type="button" class="btn-danger btn btn-block clear-all" style="width: 10em;float: right;">Clear</button>
                            <button type="button" class="btn-primary btn btn-block save-room-change" style="width: 10em;float: right;">Save</button>
                        </div>
                    </div>
                </div>
            </div>*@

    </div>
</div>
<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
    $(document).ready(function () {
        //ScorelToTop60px();
        //2023-08-16--------------------------------------------------------------------------

            $('#RoomChangeId').addClass('select2');

            $('.select2').select2();

            setTimeout(function () {
                $('.select2.select2-container').addClass('form-control');
                $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
                $('.select2-selection__arrow').css('display', 'none');
                $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
            }, 900);

            $('body').off('click', '.select2').on('click', '.select2', function () {
                setTimeout(function () {
                    $('.select2-results ul li').removeClass('select2-results__option--selected');
                }, 200);
            });
        //-------------------------------------------------------------------------------------------

    });


    $('body').off('keyup', '#roomSearchBy').on('keyup', '#roomSearchBy', function () {
        FilterRooms();
    });

    $('body').off('click', '.searchByBtn').on('click', '.searchByBtn', function () {
        FilterRooms();
    });

    function FilterRooms() {
        debugger;
        $('.room-block').hide();
        $('.room-block').each(function (index, item) {
            if ($(item).attr('data-room-text').toLowerCase().includes($('#roomSearchBy').val().toLowerCase())) {
                $(item).fadeIn();
            }
        });
    }


    $('body').on('click', '.data-reservation-no', function () {
        $.ajax({
            method: 'get',
            url: '/Reservation/RoomChange/InhouseReservationHeaderWiseDateAndRoomDetails?reservationHeaderId=' + $(this).val() + '&arrivalDate=' + $(this).closest('tr').find('.arrival-date-hidden').val() + '&departureDate=' + $(this).closest('tr').find('.departure-date-hidden').val(),
            datatype: 'html',
            success: function (htmlContent) {
                $('.date-detail-room-change').html('');
                $('.date-detail-room-change').html(htmlContent);
            }
        })
    });

    $('body').on('click', '.save-room-change', function () {
        var ReservationHeaderId = $('.data-reservation-no:checked').val();
        var RoomChangedReasonId = $('#RoomChangeId').val();
        var changedRoomId = $('.room-check-box:checked').val();
        var Remark = $('.Remark').val();

        if (changedRoomId === undefined || RoomChangedReasonId == '' || Remark == '') {
            if (changedRoomId === undefined) {
                ShowWarningMessage('Please select a room to change.');
            } else if (RoomChangedReasonId == '') {
                ShowWarningMessage('Please select change reason.');
            } else {
                ShowWarningMessage('Please type a remark.');
            }
        } else {
            $.ajax({
                method: 'post',
                datatype: 'json',
                data: { ReservationHeaderId: ReservationHeaderId, RoomChangedReasonId: RoomChangedReasonId, changedRoomId: changedRoomId, Remark: Remark },
                url: '/reservation/roomchange/SaveRoomChange',
                success: function (data) {
                    if (data == 'success') {
                        ShowSuccessMessage('Room changed');
                        $('input[type=checkbox]').prop('checked', false);
                        var EventCode = "RC";
                        var ReservationNo = $('#ReservationNumber').val();
                        var propertyId = $('#PropertyId').val();
                        var userId = $('#UserId').val();
                        var printURL = $('#DirectPrintURL').val();
                        var FromRoom = $('#roomNo').val();
                        var ToRoom = changedRoomId;
                        var GuestName = $('#GuestName').val();
                        var ajaxUrl = printURL + 'PABX/' + EventCode + '/' + ReservationNo + '/' + propertyId + '/' + userId + '/' + FromRoom + '/' + ToRoom + '/' + GuestName + '/'
                        console.log(ajaxUrl);
                        PABXAjaxRequest(ajaxUrl);
                        LoadInhouseReservationGrid();

                    } else {
                        ShowErrorMessage(data.split('-')[1]);
                        LoadInhouseReservationGrid();
                    }

                    //LoadInhouseReservationGrid();

                    //setTimeout(function () {

                    //    location.reload()

                    //}, 2500);
                    //setTimeout(function () {

                    //    //Update Uuid
                    //    window.location.href = "/reservation/reservations/list/" + $('#hidden-Uuid').val();
                    //    console.log("Uuid");

                    //}, 2500);

                }
            });
        }
    });

    $('body').on('change', '.data-reservation-no', function () {
        $(this).prop('checked', true);
        $('.data-reservation-no').not($(this)).prop('checked', false);
    });

    $('body').on('change', '.room-check-box', function () {
        $(this).prop('checked', true);
        $('.room-check-box').not($(this)).prop('checked', false);
    });

    $('body').on('click', '.success-popup-ok', function () {
        location.reload();
    });

    $('body').on('click', '.clear-alls', function () {
        $('.date-detail-room-change').html('');
        $('input[type=checkbox]').prop('checked', false);
    });

    @*@item.Name split*@

    var x = [{}];



</script>
