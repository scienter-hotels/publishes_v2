@model IEnumerable<Scienter.HotelERP.Common.Domain.GuestProfile>

@{
    ViewBag.Title = "GuestProfile";
}

<div class="col-md-12 pad-l-r-0">
    <div class="row">
        <div id="main-grid-content" class="col-md-12">
            <div class="table-responsive">
                <table class="table font-size-12px table-striped">
                    <thead>
                        <tr>
                            <th class="col-sm-2 text-primary">

                            </th>
                            <th class="col-sm-2 text-primary">
                                Name
                            </th>
                            <th class="col-sm-3 text-primary">
                                NIC/Passport
                            </th>
                            <th class="col-sm-2 text-primary">
                                Email
                            </th>
                            <th class="col-sm-2 text-primary">
                                Mobile
                            </th>
                         
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="form-group checkbox">
                                        <label>
                                            <input id="guestprofile-checkBox" class="guestprofile-checkBox" type="checkbox" value="@item.Id" />
                                        </label>
                                    </div>
                                </td>
                                <td>
                                    @item.FullName
                                </td>
                                <td>
                                    @item.IdNum
                                </td>

                                <td>
                                    @item.Email
                                </td>

                                <td>
                                    @item.Mobile
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

   

</div>

