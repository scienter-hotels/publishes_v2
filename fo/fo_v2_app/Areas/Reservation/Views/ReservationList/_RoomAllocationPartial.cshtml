                    </div>
                    <div class="row" style="margin-top:10px;" id="hkstatus"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $('body').off('keyup', '#roomSearchBy').on('keyup', '#roomSearchBy', function () {
        FilterRooms();
    });

    $('body').off('click', '.searchByBtn').on('click', '.searchByBtn', function () {
        FilterRooms();
    });

    function FilterRooms() {
        debugger;
        $('.room-block').hide();
        $('.room-block').each(function (index, item) {
            if ($(item).attr('data-room-text').toLowerCase().includes($('#roomSearchBy').val().toLowerCase())) {
                $(item).fadeIn();
            }
        });
    }

    $('body').off('click', '.deallocate-button, .allocate-button').on('click', '.deallocate-button, .allocate-button', function () {

        if ($(this).hasClass('deallocate-button')) {
            $.ajax({
                method: 'post',
                url: '/Reservation/ReservationList/RoomWisePopUp?RoomId=' + $(this).closest('.well').find('.hidden-roomId').val() + '&IsAllocatedForReservation=true' + '&Uuid=' + $('#hidden-Uuid').val(),
                datatype: 'html',
                success: function (data) {
                    $('#contentLoadingAreaRooms').addClass('hide').fadeOut();
                    $('#contentLoadingAreaForRoomWisePopUp').html(data).removeClass('hide').fadeIn();
                },
            })
        } else if ($(this).hasClass('allocate-button')) {
            $.ajax({
                method: 'post',
                url: '/Reservation/ReservationList/RoomWisePopUp?RoomId=' + $(this).closest('.well').find('.hidden-roomId').val() + '&IsAllocatedForReservation=false' + '&Uuid=' + $('#hidden-Uuid').val(),
                datatype: 'html',
                success: function (data) {
                    $('#contentLoadingAreaRooms').addClass('hide').fadeOut();
                    $('#contentLoadingAreaForRoomWisePopUp').html(data).removeClass('hide').fadeIn();
                },
            })
        }
    })

    $(function () {
        $.ajax({
            url: '/HKChange/HKHouseKeepingRoomStatusSelect',
            type: 'POST',
            dataType: 'json',
            success: function (data) {
                console.log(data);

                data.forEach(function (item) {

                    $(
                        '<div class="col-md-2">' +
                        '<img src="' + item.Icon + '" alt="' + item.Name + '" style="width:18px;"/>' +
                        '<span style="margin-left:5px;">' + item.Name + '</span>' +
                        '</div >'
                    ).appendTo('#hkstatus');

                });

            },
            error: function (error) {
                console.error('Error:', error);
            }
        });
        if ($('input[value=True].isAllocatedforReservation').length > 0) {
            $('.allocate-button.same-cat').addClass('disabled');
        } else if ($('input[value=True].isAllocatedforReservation').length = 0) {
            $('.allocate-button.same-cat').removeClass('disabled');
        }

        $('.floor-name-check-all').prop('checked', true);
    });

    $('.floor-name-check-all').change(function () {
        if ($(this).is(':checked')) {
            $('.floor-name-check').prop('checked', true);
        } else {
            $('.floor-name-check').prop('checked', false);
        }
    });
</script>
