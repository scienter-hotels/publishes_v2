@model Scienter.HotelERP.Common.Domain.ViewModels.PreventiveMaintenanceSceduleViewModel

@foreach (var item in Model.StaffDetails)
{
    <div class="col-md-4">
        @if (Model.SelectedStaffs.Count(x => x.Id == item.Id)> 0)
        {
            <div class="row" style="margin-left:1px;">
                <div class="col-md-12">
                    <div class="checkbox">
                        <label>
                            <input type="checkbox" value="@item.Id" checked name="SelectedMarketsIds" class="data-selected-staff" />
                            @item.Name
                        </label>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row" style="margin-left:1px;">
                <div class="col-md-12">
                    <div class="checkbox">
                        <label>
                            <input type="checkbox" value="@item.Id" name="SelectedMarketIds" class="data-selected-staff" />
                            @item.Name
                        </label>
                    </div>
                </div>
            </div>

        }
    </div>
}
