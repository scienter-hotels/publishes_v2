@model Scienter.HotelERP.FrontOffice.WebUIMvc.Areas.CashieringAndPosting.Models.ProfitCenterViewModel

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    .form-group {
        padding-bottom: 0px;
    }
</style>

<form id="ProfitCenterPostingForm" class="hidden-print">
    <input type="hidden" value="" name="Id" id="Id" />
    <div class="row" style="margin-top: -35px;">
        <div class="col-md-12">
            @if (ViewBag.postingType == "walkin")
            {
                <div class="form-group label-floating">
                    <label class="control-label">Company</label>
                    <div id="PostingCompanyComboContainer">
                        @{Html.RenderAction("CompaniesCombo", "Companies", new { area = "Administration", name = "CompanyId", required = true, value = Model.CompanyId }); }
                    </div>
                    @*@Html.ValidationMessageFor(model => model.BillTypeId, "", new { @class = "text-danger" })*@
                </div>
                @*--------Name-------*@
                <div class="row">
                    <div class="form-group label-floating col-md-6" style="margin-left:7px;">
                        @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label" })
                        @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control font-size-16px", required = true, autocomplete = "off" } })
                        @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                    </div>
                    @*--------Address-------*@
                    <div class="form-group label-floating col-md-5" style="margin-left:20px;">
                        @Html.LabelFor(model => model.Address, htmlAttributes: new { @class = "control-label" })
                        @Html.EditorFor(model => model.Address, new { htmlAttributes = new { @class = "form-control font-size-16px", required = true, autocomplete = "off" } })
                        @Html.ValidationMessageFor(model => model.Address, "", new { @class = "text-danger" })
                    </div>
                </div>
            }

            @if (ViewBag.postingType == "guest")
            {
                <div class="form-group label-floating">
                    @Html.LabelFor(model => model.RoomId, "Room Code", htmlAttributes: new { @class = "control-label" })
                    @{Html.RenderAction("GetInHouseRooms", "RoomDetails", new { area = "Administration", name = "RoomId", requiered = true, value = Model.RoomId });}
                    @Html.ValidationMessageFor(model => model.RoomId, "", new { @class = "text-danger" })
                </div>
            }
            <div class="row">
                @*--------Profit Center Combo box-------*@
                <div class="form-group label-floating col-md-3" style="padding-left:15px">
                    <label class="control-label">Profit Centers</label>
                    <select name="ProfitCenters" id="ProfitCenterId" class="select2 form-control Profit-Centers" required>
                        <option>----Select----</option>
                    </select>
                </div>

                @*--------Items Combo box-------*@
                <div class="form-group label-floating col-md-5" style="padding-left:15px">
                    <label class="control-label">Items</label>
                    <select name="Item" id="ItemId" class="select2 form-control Profit-Center_item" required>
                        <option>----Select----</option>
                    </select>
                </div>

                @*--------Price Type Combo box-------*@
                <div class="col-md-4">
                    <div class="form-group label-floating">
                        <label class="control-label">Price Type</label>
                        <select name="PriceType" id="PriceType" class="select2 form-control price-type" required></select>
                    </div>
                </div>
            </div>

            @*--------Item Category Combo box-------*@
            @*<div class="form-group label-floating">
            <label class="control-label">Profit Center Item Category</label>
            <select name="Item_Category" id="ItemCategoryId" class="select2 form-control Item_Category" required>
                <option>----Select----</option>
            </select>
        </div>*@


            @*--------Charge Type Combo box-------*@
            @*<div class="form-group label-floating">
            <label class="control-label">Profit Center Charge Type</label>
            <select name="ChargeTypeId" id="ChargeTypeId" class="select2 form-control ChargeType" required>
                <option></option>
            </select>
        </div>*@

            <div class="row" style="margin-top:-7px;">
                <div class="col-md-12">
                    @*--------Price Type Combo box-------*@
                    @*<div class="col-md-6">
            <div class="form-group label-floating">
                <label class="control-label">Price Type</label>
                <select name="PriceType" id="PriceType" class="select2 form-control price-type" required></select>
            </div>
        </div>*@
                    <div class="col-md-6">
                        @*--------Rate-------*@
                        <div class="form-group label-floating">
                            <label class="control-label">Rate</label>
                            <input class="form-control text-box single-line number" id="RateId" name="Rate" type="text" value="@Model.Rate" required disabled>
                        </div>
                    </div>
                    @*<div class="col-md-4">
            <div class="form-group label-floating">
                <label class="control-label">Discount</label>
                <input class="form-control text-box single-line number Discount" id="Discount" name="Rate" type="text" value="@Model.Rate" required>
            </div>
        </div>*@
                    <div class="col-md-6">
                        @*--------Quantity-------*@
                        <div class="form-group label-floating">

                            <label class="control-label">Quantity</label>
                            <input class="form-control text-box single-line number Quantity" min="0" max="100000000000" id="Quantity" name="Quantity" step="1" type="number" required>

                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-left:0px;margin-right: 0px;">
                <fieldset class="the-fieldset">
                    <legend class="the-legend" style="font-size:12px;">Note : Add discount per item here.</legend>
                    <div class="col-md-12">
                        <div class="row" style="margin:-30px -5px;">
                            <div class="col-md-4">
                                <div class="form-group label-floating">
                                    <label class="control-label">Type</label>
                                    <select class="select2 form-control" id="DiscountType">
                                        <option value="V" data-max-val="10000000000">Amount</option>
                                        <option value="P" data-max-val="100">Percentage</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-4">
                                @*--------Discount-------*@
                                <div class="form-group label-floating">
                                    <label class="control-label discount-type-text">By Value</label>
                                    <input class="form-control number" type="text" required id="DiscountBy">
                                </div>
                            </div>

                            <div class="col-md-4">
                                @*--------Discount-------*@
                                <div class="form-group label-floating">
                                    <label class="control-label">Discount</label>
                                    <input class="form-control Discount number" readonly id="Discount" name="Discount" min="0" step="0.01" type="text" value="0.00" required>
                                </div>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>


            <style>
                .remark-margin {
                    margin-top: -24px;
                    margin-left: 10px;
                }
            </style>

            <div class="row">
                <div class="col-md-12 remark-margin">
                    @*--------Remarks-------*@
                    <div class="form-group label-floating">
                        @Html.LabelFor(model => model.Remarks, htmlAttributes: new { @class = "control-label" })
                        <textarea id="Remarks" class="form-control" autocomplete="off"></textarea>
                        @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "text-danger" })
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div style="position:absolute; width:86%; bottom:9px; margin-left:-2px;" id="btnDiv2">
        <div class="row" style="margin-bottom:-12px;margin-left:-12px;">
            <div class="col-md-12">
                <div class="form-group checkbox IsComplementarychkbox">
                    <label style="color:#000000">
                        @Html.CheckBoxFor(model => model.IsComplementary)
                        Complementary
                    </label>
                    @Html.ValidationMessageFor(model => model.IsComplementary, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <input type="submit" id="btnAdd" value="Add" class="btn btn-primary" style="width:100%;" />
            </div>
            <div class="col-md-6">
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" style="width:100%;" />
            </div>
        </div>
    </div>
    <input type="hidden" name="FIT" value="" id="FITId" />
</form>

<style>
    /*#ProfitCenterWisePostingForm .form-group {
        margin: 15px 0 0 0;
    }*/
</style>

<script>
    $(document).ready(function () {
        //2023-08-16--------------------------------------------------------------------------
        $('#CompanyId').addClass('select2')
        $('#RoomId').addClass('select2')
        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });

    $('body').on('change', '#DiscountType', function () {
        if ($(this).val() == "V") {
            $('.discount-type-text').text('By Value');
        } else {
            $('.discount-type-text').text('By Perc.');
        }
        CalculateDiscount();
    });

    $('body').on('change', '#DiscountBy', function () {
        CalculateDiscount();
    });

    $('body').on('change', '#Quantity', function () {
        CalculateDiscount();
    });

    $('body').on('keyup', '#DiscountBy', function () {
        //alert('tset');
        CalculateDiscount();
    });


    function CalculateDiscount() {

        var itemValue = Number($('#RateId').val().replace(',', ''));
        var discountByValue = Number($('#DiscountBy').val().replace(',', ''));
        var disountCalc = 0;

        if ($('#DiscountType').val() == "P") {
            if (discountByValue > 100) {
                $('#DiscountBy').val('0.00');
                ShowWarningMessage('Discount by percentage should less than or equal to 100.');
            }
            else {
                disountCalc = itemValue / 100 * discountByValue;
            }
        } else {
            disountCalc = discountByValue;
        }
       
        $('#Discount').val(disountCalc);

        if (itemValue < disountCalc) {
            ShowWarningMessage('Items value is less than discount value');
        }
    }

    function LoadItemPriceTypeCombo() {
        debugger;
        $.ajax({
            url: '/Administration/ProfitCenter/Select_ProfitCenter_ItemPriceTypesForCombo',
            dataType: 'json',
            success: function (modules) {
                console.log(modules);
                if ($('#PriceType').length > 0) {
                    $('#PriceType option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#PriceType'));
                        console.log(index);
                    });
                }
            }
        });
    }

    $('#CompanyId').change(function () {//----*
        //debugger;
        let CompanyId = $('#CompanyId').val();
        var Name = $('option:selected', this).attr('data-Name');
        var Address = $('option:selected', this).attr('data-Address');
        var FITProfile = $('option:selected', this).attr('data-FIT');

        $('#Name').val(Name);
        $('#Address').val(Address);
        $('#FITId').val(FITProfile);
        console.log(Name);
        console.log(Address);
        console.log(FITProfile);

        if (FITProfile == 'False') {
            $("#Name").attr("disabled", "disabled");
            $("#Address").attr("disabled", "disabled");
        } else {
            $("#Name").removeAttr("disabled");
            $("#Address").removeAttr("disabled");
        }
    });
</script>


