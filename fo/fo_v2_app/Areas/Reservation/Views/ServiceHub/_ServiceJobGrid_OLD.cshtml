
@model  IEnumerable<Scienter.HotelERP.Common.Domain.ServiceJob>

@{
    /**/

    ViewBag.Title = "Existing Service Jobs";
}

<div class="table-responsive serviceJobGrid">
    <table class="table table-striped"
           id="existingServiceHubJobGrid">
        <thead>
            <tr>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.ReservationNo)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.ServiceCategory)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.ServiceType)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.ServiceLocation)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.ServiceAction)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.AssignDepartment)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.AssignEmployee)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.RoomNo)
                </th>
                <th class="  text-primary">
                    @Html.DisplayNameFor(model => model.GuestName)
                </th>
                <th class="hidden-print"></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.ReservationNo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceCategory)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceLocation)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceAction)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.AssignDepartment)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.AssignEmployee)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RoomNo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.GuestName)
                </td>

                <td class="hidden-print text-right">
                    <a class="btn btn-theme-color-2 btn-sm btn-edit" id="btnEdit" @*data-id="@item.Id"*@ data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content"  href="/reservation/servicehub/ServiceJobEdit/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-success btn-sm call-popup-model btn-Take" id="btnTake" data-job-id="@item.Id" @*data-href="/reservation/servicehub/ServiceJobEdit/@item.Id"*@>
                        <span class="glyphicon glyphicon-arrow-up"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete btn-delete" id="btnDelete" data-href="/reservation/servicehub/ServiceJobDelete/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

