            // Function Search ROOM from ROOM list
            function searchRoom() {
                ;
                
                var input, filter, count, tt, b, i, li;

                input = document.getElementById("txtSearch");
                filter = input.value.toUpperCase();
                ul = document.getElementById("inHouseRoomList");
                li = $('.room-list-btn');

                for (i = 0; i < li.length; i++) {
                    b = li.eq(i).val();
                    if (b.indexOf(filter) <= -1) {
                        li.eq(i).hide()
                    } else {
                        li.eq(i).show()
                    }
                }

                if (filter = "") { $('.room-list-btn').show() }
            }

            $.fn.digits = function () {
