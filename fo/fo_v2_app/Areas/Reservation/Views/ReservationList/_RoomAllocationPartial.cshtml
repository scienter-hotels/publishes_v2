@model Scienter.HotelERP.Common.Domain.ViewModels.RoomsAndFloorsView

<style>
    h3 {
        font-weight: bold;
    }

    .custom-top-padding {
        padding-top: 5px;
    }

    .well {
        font-size: 12px;
    }

    .override-from-group-margin {
        margin-top: 0px;
    }

    .colorBox {
        height: 12px;
        width: 12px;
    }

    .box1 {
        background-color: #FE0101;
    }

    .box2 {
        background-color: #038959;
    }

    .box3 {
        background-color: #ff9800;
    }

    .row-height {
        padding-top: 5px;
        height: 25px;
    }

    .well-height {
        padding-top: 10px;
        height: 142px;
    }

    .col-padding-overide {
        padding: 1px !important;
    }

    .room-number-height {
        height: 50px;
    }

    .content-align-center {
        text-align: center;
    }

    .allocatedWellColor {
        border: solid 1px #e74c3c;
        background-color: #e74c3c;
    }

        .allocatedWellColor h2 {
            color: white;
        }

        .allocatedWellColor .deallocate-button {
            background-color: #e74c3c;
            opacity: 0.8;
            border-color: #e74c3c;
            cursor: pointer;
        }

            .allocatedWellColor .deallocate-button:hover, .allocatedWellColor .deallocate-button:focus {
                background-color: transparent;
                box-shadow: none;
                opacity: 1;
                cursor: pointer;
            }

    .list-group-style {
        height: 480px;
    }

    .reservedWellColor {
        background-color: #eaba00;
        border-color: #eaba00;
        opacity: 0.8;
    }

        .reservedWellColor .reservedButton, .reservedWellColor .reservedButton:hover, .reservedWellColor .reservedButton:focus {
            background-color: #eaba00;
            box-shadow: none;
            opacity: 1;
            cursor: pointer;
        }

    .outOfOrderWellColor {
        background-color: #ff9800;
        border-color: #ff9800;
        opacity: 0.5;
    }

    .outOfOrderButton {
        background-color: #ff9800;
        color: #ffffff;
    }

    .allocateWellColor {
        background-color: #00a727 !important;
        cursor: pointer;
        border-color: #00a727 !important;
    }

        .allocateWellColor .allocate-button {
            opacity: 0.8;
            cursor: pointer;
        }

            .allocateWellColor .allocate-button:hover, .allocateWellColor .allocate-button:focus {
                opacity: 1;
                cursor: pointer;
            }

            .allocateWellColor .allocate-button, .allocateWellColor .allocate-button:hover, .allocateWellColor .allocate-button:focus {
                background-color: transparent;
                box-shadow: none;
                cursor: pointer;
            }

    .disabled-well {
        background-color: #094F70;
        border-color: #094F70;
    }

    .btn-primary1 {
        background-color: transparent !important;
    }

    .primary1WellColor {
        background-color: #094F70;
        border-color: #094F70;
        opacity: 0.7;
    }
</style>
