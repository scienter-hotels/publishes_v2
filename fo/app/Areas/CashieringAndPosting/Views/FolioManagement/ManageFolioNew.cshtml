                $('#txtGuest').val(data.Name)
                $('#txtFolio').val(1)
                $('#txtName').val(data.Name)
                $('#GuestName').val(data.Name)
                $('#GuestProfileId').val(data.GuestProfileId)
                //set guest name and address
                if (data.Name.length <= 22) {
                    $('.res-guest-name').text(data.Name)
                } else {
                    $('.res-guest-name').text(data.Name.substring(0, 21) + '...')
                }

                if (data.Name.length <= 22) {
                    $('.guest-name').text(data.Name);
                } else {
                    $('.guest-name').text(data.Name.substring(0, 21) + '...')
                }

                $('.guest-stay').text(data.Stay);

                $('.res-room-no').text(selectedRoom)
                $('.res-no').text(data.ResNo);

                $('#txtGuest').prop('readOnly', true)
                $('#txtFolio').prop('readOnly', true)
                $('#txtName').prop('readOnly', true)

                reservationHeaderId = data.ReservationHeaderId;
                SelectedFolioNumber = 0

                //load data to table
                LoadAllTransactions(roomNo, ResID)
                GetAllFoliosNumbers(roomNo, ResID)

                //Alert Function
                ReservationAlert(reservationHeaderId, 'FOL')
            }
        });

    })

    //Create New folio [3]
    $('#newFolioBtn').on('click', function (e) {
        CallPasswordModel(function (e) {
            //Check if there are any charge under FOLIO 1
            //Atleast one chareg should be under FOLIO 1
            var chargersArray = [];
            var folioOneCount = 0
            $('.td-folio-nos').each(function (index, item) {
                if ($('.td-folio-nos').eq(index).text() == 1) {
                    folioOneCount++;
                }
            });

            if ($('#tbl-all-transactions tr').length > 1) {
                folioOneCount = $('#tbl-all-transactions tr').not(':first').length;
            }

            $('.folio-detail-id').each(function (index, item) {
                if ($(item).prop('checked')) {
                    chargersArray.push({ "FolioDetailID": Number($(item).val()) });
                }
            });

            if (chargersArray != null && chargersArray.length > 0) {
                if (folioOneCount > 1) {
                    // post selected folio detail id to update to new folio number
                    $.ajax({
                        url: '/CashieringAndPosting/FolioManagement/ChangeFolioNumber',
                        dataType: 'json',
                        data: { FolioDetailIdsJson: JSON.stringify(chargersArray), ReservationHeaderId: reservationHeaderId },
                        success: function (data) {
                            if (data.startsWith('success')) {
                                $('.all-transaction').html('')
                                $('.all-transferred-transactions').html('') //R2R Modification tbl-summary
                                $('.all-transaction-summary').html('')
                                $('.tbl-folioWiseTable').html('')
                                $('.btn-folio-numbers').html('')
                                LoadAllTransactions(roomNo, reservationHeaderId);
                                GetAllFoliosNumbers(roomNo, reservationHeaderId)
                            } else {
                                ShowWarningMessage(data);
                            }

                        }
                    })
                } else {
                    ShowWarningMessage('Atleast Two Charges should be places under FOLIO 1')
                }
            } else {
                if (chargersArray != null) {
                    ShowWarningMessage('Select at-least one folio item.');
                }
            }
        });
    });

