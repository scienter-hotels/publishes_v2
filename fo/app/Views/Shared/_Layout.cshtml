    <style>

        #reservationNumbersLoadingArea .radio, #reservationNumbersLoadingArea .checkbox {
            margin-bottom: 2px;
            margin-top: 2px;
        }

        #myUL {
            line-height: 11px;
        }

        #reservationNumbersLoadingArea table:not(.table-striped) tr:first-child {
            background-color: white !important;
        }
        /*2023-08-09--------------------------------------------------------------------------------------*/
        .card {
            border-radius: 3px;
        }

        .card-header {
            border-radius: 3px;
        }

        .btn {
            border-radius: 3px !important;
        }

        button.dt-button, div.dt-button, a.dt-button {
            border-radius: 3px !important;
        }

        table .btn-theme-color-2 {
            border-radius: 3px !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current, .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            border-radius: 3px !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            border-radius: 3px !important;
        }

        .modal-content {
            border-radius: 3px !important;
        }

        .room-well {
            border-radius: 3px !important;
        }

        .well {
            border-radius: 3px !important;
        }

        .actualAvailability {
            border-radius: 3px;
        }

        .totalAvailability {
            border-radius: 3px;
        }

        .checkbox .checkbox-material .check {
            border-radius: 3px;
        }

        input, select, textarea {
            border-radius: 3px;
        }

        .nav-tabs {
            border-radius: 3px;
        }

        .the-fieldset {
            border-radius: 3px !important;
        }

        .top-sticky {
            border-radius: 3px;
        }

        .panel-heading {
            border-radius: 3px !important;
        }
        /*-------------------------------------------------------------------------------------*/

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            /*overflow: hidden;*/
        }

        .loader-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.8);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1050;
            display: none; /* Hidden by default */
        }

        .loader {
            background-image: url(/Images/loading_pot.gif);
            width: 100px;
            height: 100px;
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
            justify-content: center;
            align-items: center;
            display: flex;
        }


        /*@@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }*/

        /*#guestportal-action-model .modal-header {
                padding: 15px 25px;
                padding-bottom: 0;
            }*/

        #guestportalactionForm .form-group {
            padding-bottom: 10px;
            margin: 0;
        }

        #guestportal-action-model .modal-header {
            padding: 15px;
        }

        #guestportal-action-model .modal-content .modal-body {
            padding-top: 0px;
            padding-right: 15px;
            padding-bottom: 4px;
            padding-left: 14px;
        }

        #guestportal-action-model .modal-header .close {
            margin-top: -35px;
            font-size: 30px;
        }

        /*start fixed header in table*/

        .fixed-header-table thead th {
            background-color: #f2f2f2;
            position: sticky;
            top: 0;
            z-index: 10;
            padding: 8px;
            text-align: left;
            border-bottom: 2px solid #ccc;
        }

        /*end fixed header in table*/

        .show-popup-image {
            cursor: zoom-in;
        }

        /*end fixed header in table*/
        .cd-notification-btn {
            padding-top: 8px;
            padding-right: 8px;
        }

        .notification-count-show {
            color: #fff !important;
            font-size: 12px;
            font-weight: 600;
            position: absolute;
            top: 0;
            left: 8px;
            background-color: #f00;
            padding: 3px 5px;
            border-radius: 50%;
            line-height: 16px;
            z-index: 104299;
        }

        .notification-count-show-number {
            color: #fff !important;
            font-size: 12px;
            font-weight: 600;
        }
    </style>

</head>
<body style="min-width:1360px;">

    <header class="cd-main-header hidden-print">
        <div class="theme-bg-color-1" style="height:46px;">

            <div class="cd-logo" style="left:30px; width:225px;">
                <div class="row">
                    <div class="col-xs-2" style="padding-right:10px; padding-left:0px; padding-top:10px;">
                        @if (System.Web.HttpContext.Current.Request.UrlReferrer != null)
                        {
                            <a href="@System.Web.HttpContext.Current.Request.UrlReferrer.ToString()"> <img src="~/Images/back-button.png" style="width:25px !important; display:inline-block;" /></a>

                        }
                        else
                        {
                            <a href="/administration/dashboard/landing"> <img src="~/Images/back-button.png" style="width:25px !important; display:inline-block;" /></a>

                        }
                    </div>
                    <div class="col-xs-9" style="padding-left:0px; padding-top:5px;">
                        <a href="~/administration/dashboard/landing" style="padding-top:7px;display:block;  display:inline-block;">
                            <img src="~/Images/destinity-inspire-logo-full.png" alt="Logo">
                        </a>
                        <span style="padding-bottom: 8px;
                        color: white;
                        padding-bottom: -0px;
                        color: white;
                        font-size: 10px;
                        text-align: left;
                        margin-top: -10px;
                        display: block;">
                            @Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Name
                        </span>



                    </div>
                </div>
            </div>


            <ul class="cd-header-buttons">

                <input type="hidden" id="IsEnableGuestPortal" name="IsEnableGuestPortal" value="@Scienter.HotelERP.Common.Domain.SessionObjects.SystemSettingsWiseProperties.Find(x => x.Code == "GPSS001" && x.PropertyId == Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id).Value" />

                @if (Scienter.HotelERP.Common.Domain.SessionObjects.SystemSettingsWiseProperties.Find(x => x.Code == "GPSS001" && x.PropertyId == Scienter.HotelERP.Common.Domain.SessionObjects.LoggedUser.LoggedProperty.Id)?.IsEnable == true)
                {
                    <li onclick="$('#gusetPortalNotificationModalPopup').modal('show')" style="text-align:left;">
                        <a class="cd-notification-btn" href="#" title="Notification" data-toggle="tooltip" data-placement="bottom">
                            <img src="~/Images/bell.png" style="width:20px" />
                            <div class="notification-count-show">
                                <span class="notification-count-show-number" id="notification-count" style="color:#fff">0</span>
                            </div>

                        </a>
                    </li>
                }


                @if (Scienter.HotelERP.Common.Utility.Configs.GetAppSettingBoolValue("IsCentralLoginEnabled"))
                {
                    <li>
                        <a class="cd-logout-btn" href="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("LoginPortalUrl")/modules/index" title="Change Module" data-toggle="tooltip" data-placement="bottom">
                            <img src="~/Images/property-change-icon.png" style="width:25px" />
                        </a>
                    </li>
                    @*<li>
                            <a class="cd-logout-btn module-Switch" title="Change Module" data-toggle="tooltip" data-placement="bottom">
                                <img src="~/Images/property-change-icon.png" style="width:25px" />
                            </a>
                        </li>*@
                }



                <li>
                    <a class="cd-logout-btn pop-right-side-area-prop-change" href="#" title="Change Property" data-toggle="tooltip" data-placement="bottom">
                        <img src="~/Images/module-change-icon.png" style="width:25px" />
                    </a>
                </li>
                <li>
                    <a style="padding-top:3px;" class="cd-logout-btn pop-right-side-area-user-options" href="#" title="User Options" data-toggle="tooltip" data-placement="bottom">
                        <img src="~/Images/user.png" style="width:15px" />
                    </a>
                    <span id="countdownsasasasasas" style="float:right; font-size:10px; font-weight:bold; margin-top:-10px;margin-right:-6px; color:#fff;"></span>
                </li>

            </ul>


        </div>
    </header>

    <input type="hidden" value="@Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("DirectPrintMethod")" id="DirectPrintMethod" />

    <main class="cd-main-content">

        <div style="height:100%; width:100%; position:absolute; background-color:#7373731c; z-index:100000" class="loading-screen-without-gif" hidden></div>
        <div class="w3-sidebar w3-bar-block w3-card w3-animate-left" style="display:none" id="leftMenu">
            <button onclick="closeLeftMenu()" class="w3-bar-item w3-button w3-large">Close &times;</button>
            <div class="col-md-12 left-menu-content-area">

            </div>
        </div>

        <div class="w3-sidebar w3-bar-block w3-card w3-animate-right" style="display:none;right:0;" id="rightMenu">
            <button onclick="closeRightMenu()" class="w3-bar-item w3-button w3-large close-right close-btn">Close &times;</button>
            <div class="col-md-12 right-menu-content-area" style="height:100%; overflow-y:scroll">
                <br />
                Please wait ...
            </div>
        </div>

        <div class="messagealert" id="alert_container"></div>
        <div>
            <div class="container w3-container">
                <div id="viewLoadingArea">
                    <div id="main">
                        @RenderBody()
                    </div>
                </div>
                <input type="hidden" id="hotelCurrentDate" value="@Scienter.HotelERP.Common.Domain.SessionObjects.FOSettings.CurrentDate" />
                <input type="hidden" id="hotelDate" value="@Scienter.HotelERP.Common.Domain.SessionObjects.FOSettings.CurrentDate.ToString("yyyy-MM-dd")" />
            </div>
        </div>
    </main>

    <div class="hidden-print">
        @Html.Partial("_NavigationAjax")
    </div>

