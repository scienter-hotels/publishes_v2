@model List<Scienter.HotelERP.Common.Domain.User>


<form id="propertyForm">
    <div class="col-md-4"></div>
    <div class="col-md-4">
        <div class="card" style="margin-top:90px; height:250px;">
            <div class="card-header card-header-icon" style="padding-bottom:5px; ">
                <div class="row">
                    <div class="col-md-12" style="padding-top:11px; text-align:right;">
                        <span href="http://www.scienter.lk" target="_blank">
                            <img src="~/Images/destinity-horizon-logo.png" width="300px" />
                        </span>
                    </div>
                </div>
            </div>
            <div class="row" @*style="padding-left:10px; padding-right:10px;*@ ">
                <div class="col-md-1"> </div>
                <div class="col-md-10">

                    @*<div class="form-group label-floating">
                            <label class="control-label">Property *</label>
                            @{Html.RenderAction("UserWisePropertyCombo", "Properties", new { name = "PropertyId", requiered = true });}
                        </div>*@

                    <div class="form-group label-floating">
                        <label class="control-label">Property</label>
                        <select id="propertyCombo" name="Id" class="form-control @*font-size-16px*@" required>
                            <option value=""></option>
                        </select>

                    </div>


                    <div class="form-group text-center">
                        <input type="submit" id="btnSave" value="Select" class="btn btn-primary" />
                    </div>
                </div>
                <div class="col-md-1"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4"> </div>
</form>

<script>
    //--------------------------------------------------------------------------------------------------------
