                }
            }, complete: function () {

            }
        });
    }

    function dateCalculation(event) {
        var arrdate = new Date(event.start.format());
        var arrdateformat = arrdate.toISOString().slice(0, 10);
        $('#change_arr').val(arrdateformat);

        var depdate = new Date(event.end.format());
        var depdateformat = depdate.toISOString().slice(0, 10);
        $('#change_dep').val(depdateformat);
    }

