
@model  IEnumerable<Scienter.HotelERP.Common.Domain.GuestPortal_RoomRequest>
@{


    ViewBag.Title = "Guest Portal Room Request";
}
<input type="hidden" name="text" id="type" value="@ViewBag.Type" />

<style>
    .form-group {
        margin: 0;
    }
</style>

<div class="row">
    <div class="col-md-4" style="position:absolute;z-index:10000;">
        <select id="customSelect" class="custom-select form-control">
            <option value="A">All</option>
            @*<option value="R">Reservation</option>*@
            <option value="I">In House</option>
            <option value="C">Checked Out</option>
        </select>
    </div>
</div>


<div class="table-responsive">
    <table class="table table-striped" id="GuestPortalRoomRequest">
        <thead>
            <tr>
                <th hidden></th>
                <th class="col-md-1 text-primary">
                    Res / No
                </th>
                <th class="col-md-1 text-primary">
                    Room No
                </th>
                <th class="col-md-1 text-primary">
                    Date
                </th>
                <th class="col-md-1 text-primary">
                    Time
                </th>
                <th class="col-md-1 text-primary">
                    Note
                </th>
                <th class="col-md-1 text-primary">
                    Type
                </th>
                <th class="col-md-1 text-primary">
                    ActionName
                </th>
                <th class="col-md-1 text-primary">

                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr style="height: 36px !important;" data-reservation_level="@Html.DisplayFor(modelItem => item.ReservationLevel)">
                <th hidden></th>
                <td>
                    @Html.DisplayFor(modelItem => item.ReservationNo)
                    <input type="hidden" name="text" id="guestPoratlRoomRequestReservationHeaderId" value="@item.ReservationHeaderId" />
                    <input type="hidden" name="text" id="roomRequestId" value="@item.RoomRequestId" />
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RoomName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DateFormatted)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TimeFormatted)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.AdditionalNotes)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RequestType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ActionName)
                </td>
                <td style="text-align:right !important;">
                    <a class="btn btn-theme-color-2 btn-sm call-popup-model" id="activityLog" data-guestPoratlRoomRequestReservationHeaderId="@item.ReservationHeaderId" data-ActionTypeId="@item.ActionTypeId" data-id="@item.RoomRequestId" data-title="Reservation Activity Log" data-href="" title="Activity Log" data-toggle="modal" data-target="" data-width="500">
                        <span class="glyphicon glyphicon-plus"></span>
                    </a>
                    <a class="btn btn-theme-color-2 btn-sm call-popup-model viewactivityLog" id="viewactivityLog" data-guestPoratlRoomRequestReservationHeaderId="@item.ReservationHeaderId" data-id="@item.RoomRequestId" data-title="Reservation Activity Log" data-href="" title="View Activity" data-toggle="modal" data-target="" data-width="500">
                        <span class="glyphicon glyphicon-tags"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

