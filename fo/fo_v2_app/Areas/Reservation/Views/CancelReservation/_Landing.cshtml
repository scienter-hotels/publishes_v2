@model Scienter.HotelERP.Common.Domain.ViewModels.CancelReservationView

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-15---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/ 
</style>

<input type="hidden" id="hidden-Uuid" value="@ViewBag.Uuid" />
<div class="col-md-12">
    <form id="cancelReservationForm">
        <input type="hidden" id="hiddenReservationHeaderId" value="@Model.ReservationHeaderId" />
        <input type="hidden" name="hiddenReservationNo" id="hiddenReservationNo" value="@ViewBag.ReservationNo" />
        <div class="row">
            <div class="col-md-6">
                <div class="guestname-combo form-group label-floating" style="margin-top:8px;">
                    @Html.LabelFor(model => model.CancellationReasonId, "Reason", htmlAttributes: new { @class = "control-label" })
                    @{Html.RenderAction("CancellationReasonsCombo", "CancellationReasons", new { area = "Administration", name = "CancellationReasonId", requiered = true, value = Model?.CancellationReasonId });}
                    @Html.ValidationMessageFor(model => model.CancellationReasonId, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <div class="row">
            <div class="form-group label-floating col-md-12" style="margin-top:10px;">
                <label class="control-label">
                    Remark
                </label>
                <textarea rows="5" cols="50" name="Message" id="Message" class="form-control" required></textarea>
            </div>
        </div>



        <div class="row">
            <div class="form-group col-md-12 text-right">
                <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                &nbsp;
                <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
            </div>
        </div>
    </form>

</div>

<script>
    $(document).ready(function () {
        //2023-08-15--------------------------------------------------------------------------
        $('#CancellationReasonId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        //-------------------------------------------------------------------------------------------
    });
    $('body').off('submit').on('submit', '#cancelReservationForm', function (e) {
        e.preventDefault();
        var selectedReservation = [];
        var cancelReservation = {
            CancellationReasonId: $('#CancellationReasonId').val(),
            Remark: $('#Message').val(),
            ReservationHeaderId: $('#hiddenReservationHeaderId').val(),
        };

        selectedReservation.push(cancelReservation);
        $.ajax({
            url: '/Reservation/CancelReservation/save',
            dataType: 'json',
            data: { selectedReservation: selectedReservation },
            method: 'POST',
            success: function (response) {
                ShowSuccessMessage('Reservation Cancelled Successfully.');

                $('#Search_StatusId').val(-1);
                $('#Search_StatusId').trigger('change');

                var selectedReservationNo = $('#hiddenReservationNo').val();
                $('#Search_ReservationNo').val(selectedReservationNo);

                setTimeout(function () {
                    LoadReservationGrid();
                }, 500);
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in cancelling this reservation.');
            }
        });
    });

</script>
