@model IEnumerable<Scienter.HotelERP.Common.Domain.AdvancePaymentLink>

@{
    ViewBag.Title = "Exising Payment Links";
}
<div class="table-responsive">
    <table id="existingpaymentlinksGrid" class="table table-striped">
        <thead>
            <tr>
                <th class=" col-md-1 text-primary">
                    Doc Id
                </th>
                <th class="col-md-2 text-primary">
                    Name
                </th>
                <th class="col-md-2 hidden-print">
                    Email
                </th>
                <th class="col-md-2 hidden-print"> Link Status
                </th>
                <th class="col-md-1 hidden-print"></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.DocNo)
                    </td>
                    <td class="text-right">                    
                                @Html.DisplayFor(modelItem => item.GuestName)                                
                     </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Email)
                    </td>
                    
                        @if (item.ActiveForPayment)
	                    {
                        <td> Active for payment </td>
                        }
                        else
                        {
                           <td>Inctive</td>     
                        }
                        
                  
                    <td class="hidden-print text-right">
                        @*<a class="btn btn-theme-color-2 btn-sm call-popup-model" id="btnPrint" data-title="Bed Type - @item.Name"  data-href="/administration/bedtypes/print/@item.Id">
                                <span class="glyphicon glyphicon-print"></span>
                            </a>*@

                        <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/administration/AdvancedPayment/edit?docNo=@item.DocNo">
                            <span class="glyphicon glyphicon-pencil"></span>
                        </a>

                        <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/AdvancedPayment/delete?docNo=@item.DocNo">
                            <span class="glyphicon glyphicon-trash"></span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>

<script>
    $(document).ready(function () {
        $('#existingpaymentlinksGrid').DataTable(
            {
                "order": [[0, "desc"]],
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                            'copy',
                            'excel',
                            'csv',
                            'pdf',
                            'print'
                ],
                scrollY: '58vh',
            } );
    });
</script>
