<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                            <hr class="visible-print" />
                        </h4>
                    </div>
                </div>
            </div>
            <div class="card-content" id="contentLoadingArea">
                <div class="col-md-4" id="dateWiseDiv">
                    <div class="form-group label-floating">
                        <label class="control-label">Date Range</label>
                        <div class='input-group date' id='dateWiseCalender'>
                            <input type='text' class="form-control dateRangePicker datepicker" name="daterange" />
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-calendar"></span>
                            </span>
                        </div>
                    </div>
                </div>
                <div>
                    <div class="panel-body">
                        <div class="" style="margin-top:10px; overflow-x:scroll; width: 1166px; white-space: nowrap;">
                            @*<div class="" style="margin-top:10px; overflow-x:scroll; white-space: nowrap;">*@
                            <table id="RoomAvailabilityGrid" class=""></table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    $(function () {
       
        var todayDateFormatted = dateFormatChanger($('.dateRangePicker').val().split('-')[0].trim());
        fromDate = getDateforHeader(parseDate(todayDateFormatted), 'withdash');
        toDate = getDateforHeader(parseDate(todayDateFormatted).addDays(15), 'withdash');
        GetOccupancyOnDateChange(fromDate, toDate);
    });

    function dateFormatChanger(d) {
        var splitedDate = d.split('/');
        var changedDate = splitedDate[1] + "/" + splitedDate[0] + "/" + splitedDate[2];
        return changedDate;
    }

    $('body').on('click', '.applyBtn', function () {
        $('#RoomAvailabilityGrid').html('');
        var toDate = dateFormatChanger($('.dateRangePicker').val().split('-')[0].trim());
        var fromDate = dateFormatChanger($('.dateRangePicker').val().split('-')[1].trim());
        GetOccupancyOnDateChange(toDate, fromDate);
    })

    function GetOccupancyOnDateChange(fromDate, toDate) {
        $.ajax({
            method: 'get',
            url: '/reservation/Inquiry/InqueryInformation?fromDate=' + fromDate + '&todate=' + toDate + '&area=' + 'RC',
            datatype: 'json',
            success: function (InqueryInformation) {

                $('#RoomAvailabilityGrid').append('<tr class="first-tr"><th class="col-md-2 summary-th t-head" style="padding:0px">RATE CODE</th></tr>');

                var dateDifference = datediff(parseDate(fromDate), parseDate(toDate));
                //
                for (var i = 0; i < dateDifference; i++) {
                    $('#RoomAvailabilityGrid .first-tr').append('<th class="occupancy-th t-head">' + getDateforHeader(new Date(fromDate).addDays(i), 'th')
                        + '<input type="hidden" value="' + getDateforHeader(new Date(fromDate).addDays(i), 'hid') + '" id="hidden-th-date" class="hidden-th-date" />'
                        + '</th>');
                    colClass = '';
                }

                $('#RoomAvailabilityGrid').append('<tr class="blank-tr" style="height:10px; background-color:white;"></tr>');

                occupancyObj = JSON.parse(InqueryInformation.RoomAvailabilityWithOccupancyAsJson);

                $(occupancyObj).each(function (index, eachRow) {


                    $('tr').not('.blank-tr').addClass('lightgray');



                    if (eachRow.itemname != "EMPTY") {
                        $('#RoomAvailabilityGrid').append('<tr class=' + eachRow.code.toLowerCase().replace('.', '').trim().replace(/\s/g, '-') + '><td class="t-data">' + eachRow.itemname + '</td></tr>');
                    }
                    var valueTd = '';
                    var hiddenThDate, cellValue;


                    if (eachRow.itemname == "EMPTY") {
                        $('#RoomAvailabilityGrid').append('<tr class="blank-tr" style="height:10px"></tr>');
                    }
                    else {
                        $('th .hidden-th-date').each(function (index, eachHiddenDate) {
                            hiddenThDate = $(eachHiddenDate).val();
                            cellValue = eachRow[hiddenThDate];
                            if (cellValue == null || cellValue == 'undefined') {
                                cellValue = 0;
                            }
                            valueTd = valueTd + '<td class="t-data"> <span class="">' + cellValue + '</span> </td>'
                        });

                        var className = '.' + eachRow.code.toLowerCase().replace('.', '').trim().replace(/\s/g, '-');
                        $(className).append(valueTd);
                    }
                });

                TimeOutFunctionForGridDesign();

                $('#RoomAvailabilityGrid').append('<tr class="last-tr"><th class="col-md-2 summary-th t-head" style="padding:0px"></th></tr>');


                for (var i = 0; i < dateDifference; i++) {
                    $('#RoomAvailabilityGrid .last-tr').append('<th class="occupancy-th t-head">' + getDateforHeader(new Date(fromDate).addDays(i), 'th')
                        + '<input type="hidden" value="' + getDateforHeader(new Date(fromDate).addDays(i), 'hid') + '" id="hidden-th-date" class="hidden-th-date" />'
                        + '</th>');
                    colClass = '';
                }

            }
        });
    }

    function TimeOutFunctionForGridDesign() {
        setTimeout(function () {
           
            $('.summary-th').addClass('first-th')

            $('.occupancy-th').each(function (index, thisTh) {
                $(thisTh).addClass('date-th');
            })


            $('tr .t-data').each(function (index, eachTd) {
               
                var tdVal = parseFloat($(eachTd).find('span').text());

                if (tdVal > 0) {
                    $(eachTd).addClass('daily-occ-batch5070');
                }
            })

            //$('.total .t-data').each(function (index, eachTd) {
            //   
            //    var tdVal = parseFloat($(eachTd).find('span').text());

            //    if (tdVal > 0) {
            //        $(eachTd).addClass('daily-occ-batch5070');
            //    }
            //})


            $('.first-tr').css('background-color', '#6a89cc', 'important');
            $('.summary-th').css('background-color', '#86d0e6', 'important');


        }, 1000);
    }


    function getDateforHeader(date, thOrHidden) {

        var weekday = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
        var monthsArr = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var returnDate;
        var year, dayName, dayNumStr = '';

        dayName = weekday[date.getDay()];

        var dateVar = new Date(date).getDate();
        if (dateVar.toString().length <= 1) {
            ;
            dayNumStr = '0' + dateVar.toString();
        } else {
            dayNumStr = dateVar.toString();
        }

        var month = new Date(date).getMonth() + 1
        if (month.toString().length <= 1) {
            month = '0' + month.toString();
        }

        year = new Date(date).getFullYear().toString();
        if (thOrHidden == 'hid') {
            returnDate = dayNumStr + '/' + month + '/' + year;
        } else if (thOrHidden == 'th') {
            returnDate = dayName + '<br />' + '<p style="font-size:24px">' + dayNumStr + '<p>' + monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'ywm') {
            returnDate = monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'mon') {
            returnDate = month;
        } else if (thOrHidden == 'withdash') {
            returnDate = month + '/' + dateVar + '/' + year;
        }

        return returnDate;
    }

    // new Date("dateString") is browser-dependent and discouraged, so we'll write
    // a simple parse function for U.S. date format (which does no error checking)
    function parseDate(str) {
        var mdy = str.split('/');
        return new Date(mdy[2], mdy[0] - 1, mdy[1]);
    }

    // Take the difference between the dates and divide by milliseconds per day.
    // Round to nearest whole number to deal with DST.
    function datediff(first, second) {
        return Math.round((second - first) / (1000 * 60 * 60 * 24));
    }

    Date.prototype.addDays = function (days) {
        var dat = new Date(this.valueOf());
        dat.setDate(dat.getDate() + days);
        return dat;
    }
</script>

