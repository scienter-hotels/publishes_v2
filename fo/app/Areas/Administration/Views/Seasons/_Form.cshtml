
@model Scienter.HotelERP.Common.Domain.Season
<script src="~/Scripts/ui/common/scienter.common.datatimepicker.js"></script>

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="season">
        @Html.AntiForgeryToken()
        <div class="">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />


            <div class="row">
                <div class="col-md-5">
                    <div class="row">
                        <div class="form-group label-floating col-md-12">
                            <label class="control-label">Name *</label>
                            <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                        </div>
                    </div>
                    @*<div class="form-group input-group date">
                            <label class="control-label">From Date *</label>
                            <input autocomplete="off" class="form-control datetimepicker text-box single-line" maxlength="100" id="FromDate" name="FromDate" type="text" value="@Model.FromDate" required>
                        </div>*@
                    <div class="row">
                        <div class="form-group label-floating col-md-5">
                            <label class="control-label">From Date*</label>
                            <div id="dobContainerInSeasons" class='input-group date'>
                                <input autocomplete="off" class="form-control datePicker text-box single-line" maxlength="100" id="FromDate" name="FromDate" type="text" value="@Model.FromDate" required>
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-calendar"></span>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-2"></div>
                        <div class="form-group label-floating col-md-5">
                            <label class="control-label">To Date*</label>
                            <div id="dobContainerInSeasons" class='input-group date'>
                                <input autocomplete="off" class="form-control datePicker text-box single-line" maxlength="100" id="ToDate" name="ToDate" type="text" value="@Model.ToDate" required>
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-calendar"></span>
                                </span>
                            </div>
                        </div>
                    </div>


                    @*<div class="form-group input-group date">
                            <label class="control-label">To Date *</label>
                            <input autocomplete="off" class="form-control datetimepicker text-box single-line" maxlength="100" id="ToDate" name="ToDate" type="text" value="@Model.ToDate" required>
                        </div>*@
                    <div class="row">
                        <div class="form-group checkbox">
                            <label>
                                @Html.CheckBoxFor(model => model.IsActive)
                                @*<input type="checkbox" checked name="IsActive" value="True" />*@ Active
                            </label>
                            @Html.ValidationMessageFor(model => model.IsActive, "", new { @class = "text-danger" })

                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group">
                            <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                            &nbsp;
                            <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                        </div>
                    </div>
                </div>
                <div class="col-md-2"></div>
                <div class="col-md-5">
                    @{Html.RenderAction("ListVertical", "Properties", new { selectedPoperties = Model.Properties }); }
                </div>
            </div>
        </div>
    </form>

    <input type="hidden" value="@Model.PropertiesJson" name="selectedProperties" id="selectedProperties" />
</div>


<script>
    $(document).ready(function () {
        var seelctedProperties = $.parseJSON($('#selectedProperties').val());
        $('.data-property-checkbox').prop('checked', false)

        $.each(seelctedProperties, function (index, item1) {
            var Property = 'input.data-property-checkbox[value=' + item1.PropertyId + ' ]'
            $(Property).prop('checked', true);
        });
    });
</script>



