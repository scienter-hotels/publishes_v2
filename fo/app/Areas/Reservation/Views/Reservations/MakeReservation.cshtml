        if ($('#LastName').val() == '') {
            $('#LastName').focus();
            isValid = false;
        }

        if ($('#CountryId').val() == '') {
            $('#CountryId').focus();
            isValid = false;
        }
        if ($('#NationalityId').val() == '') {
            $('#NationalityId').focus();
            isValid = false;
        }

        //if ($('#Email').val() == '') {
        //    $('#Email').focus();
        //    isValid = false;
        //}

        //if (!validateEmail($('#Email').val())) {
        //    $('#Email').focus();
        //    isValid = false;
        //    ShowWarningMessage('Invalid email address.');
        //}

        if (!validateEmail($('#Email').val())) {
            $('#Email').focus();
            isValid = false;
            ShowWarningMessage('Invalid email address.');
        }

        //if ($('#ContactNo').val() == '') {
        //    $('#ContactNo').focus();
        //    isValid = false;
        //}

        if (isValid) {
            var guestId = -1;
            $('.guest-checkBox').each(function (index, element) {
                if ($(element).prop('checked')) {
                    guestId = $(element).val();
                    return false;
                }
            });

            var SelectedGuest = {
                Id: guestId,
                SalutationId: $('#SalutationId').val(),
                FirstName: $('#FirstName').val(),
                LastName: $('#LastName').val(),
                NICPassport: $('#NICPassport').val(),
                CountryId: $('#CountryId').val(),
                NationalityId: $('#NationalityId').val(),
                Email: $('#Email').val(),
                ContactNo: $('#ContactNo').val()
            }

            $('.hidden-stringify-json-guest').val(JSON.stringify(SelectedGuest));

        }
        else {
            ShowWarningMessage('You have missed some mandatory fields.');
        }
        return isValid;
    }


