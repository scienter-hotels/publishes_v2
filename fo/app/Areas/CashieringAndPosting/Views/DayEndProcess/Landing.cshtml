                                                    <div class="table-responsive">
                                                        <p>
                                                            <br />
                                                            No inhouse rooms found.
                                                        </p>
                                                    </div>
                                                }

                                                <button type="button" class="btn-primary btn btn-block save-room-change next action-button btn-get-dayend-summary" name="next" value="Next Step" style="width: 10em;float: right;">
                                                    Next Step
                                                    <div class="ripple-container"></div>
                                                </button>
                                                <button type="button" next class="btn-danger btn btn-block previous action-button-previous" name="previous" style="width: 10em;float: right;">
                                                    Previous
                                                </button>
                                            </div>
                                        </div>

                                    </fieldset>
                                    <fieldset>
                                        <div class="form-card">

                                            <div class="day-end-summry-container" style="padding:0px 20px;">
                                            </div>
                                        </div>
                                    </fieldset>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>




<script>
    $(document).ready(function () {
        $('.btn-complete-day-end').prop('disabled', true);
        $('.stepContent').hide();
        AnimatePercentage("#firstStepLoading", "#firstStepContent");
        $('#noShow').attr('disabled', true);
    });

    $('body').off('change', '.isBillPaymentFromLKR').on('change', '.isBillPaymentFromLKR', function (e) {
        var IsBillPaymentFromLKR = "";
        var ReservationNo = $(this).val();
        if ($(this).prop('checked')) {
            IsBillPaymentFromLKR = true
        } else {
            IsBillPaymentFromLKR = false
        }
        if (confirm('Are you sure you want to proceed?')) {
            $.ajax({
                url: '/CashieringAndPosting/DayEndProcess/BillPaymentLKRUpdate',
                dataType: 'json',
                method: 'POST',
                data: { IsBillPaymentFromLKR: IsBillPaymentFromLKR, ReservationNo: ReservationNo },
                success: function (response) {
                    if (response == "OK") {
                        ShowSuccessMessage("Updated succsessfully.");
                    }
                    else {
                        ShowWarningMessage(response);
                        if ($(this).prop('checked')) {
                            $(this).prop('checked', false);
                        } else {
                            $(this).prop('checked', true);
                        }
                    }
                },
                error: function (error) {
                    if ($(this).prop('checked')) {
                        $(this).prop('checked', false);
                    } else {
                        $(this).prop('checked', true);
                    }
                },
                complete: function () { }
            });
        } else {
            if ($(this).prop('checked')) {
                $(this).prop('checked', false);
            } else {
                $(this).prop('checked', true);
            }
        }

    });

    function AnimatePercentage(stepLoading, stepContent) {
        var percContainer = $(stepLoading).find('h3');
        var perContainerVal = percContainer.html();
        var perc = 0;
        setInterval(function () {
            perc = perc + 5;
            percContainer.html(perc + '%');
            if (perc >= 100) {
                $(stepLoading).hide();
                $(stepContent).fadeIn();
                perc = 0;
                return false;
            }
        }, 100);
    }

    // NO SHOW EXPECTED ARRIVALS
    $('.no-show-expected-arrivals').change(function () {
        //alert($('.no-show-expected-arrivals:checked').length);
        if ($('.no-show-expected-arrivals:checked').length > 0) {
            $('#noShow').attr('disabled', false); // enable input
        } else {
            $('#noShow').attr('disabled', true); //disable input
        }
    });

    $('body').on('click', '.btn-get-dayend-summary', function () {
        $('.day-end-summry-container').html('');
        $.ajax({
            url: '/CashieringAndPosting/DayEndProcess/CheckValidations',
            dataType: 'html',
            method: 'POST',
            beforeSend: function () {
                $('.day-end-summry-container').html('');
                $('.day-end-summry-container').html('<center><br /><p> Please wait.. <br /> </p> <img src="/Images/work-process-gif.gif" /></center><br/>');


            },
            success: function (data) {
                $('.day-end-summry-container').html('');
                $(data).appendTo($('.day-end-summry-container'));
            },
            error: function (error) {
                ShowErrorMessage('There is an error in processing day end.')
            }
        });
    });

    // btn btn-block no-show
    $('body').on('click', '.no-show', function () {
        alert("Are you sure,You want to continue !!");
        var selectedRecords = [];
        var record = {};
        $('.no-show-expected-arrivals').each(function (index, checkbox) {
            //if ($(checkbox).prop('checked')) {
            //    record = {};
            //    record.ReservationNo = $(checkbox).attr('data-reservation-no');
            //    selectedRecords.push(record);
            //}
            if ($(checkbox).is(':checked')) {
                record = {};
                record.ReservationNo = $(checkbox).attr('data-reservation-no');
                selectedRecords.push(record);
            }
        });

        if (selectedRecords.length == 0) {
            ShowWarningMessage("Please select at least one reservartion to proceed.");
        } else {
            //console.log(selectedRecords);
            $.ajax({
                url: '/CashieringAndPosting/DayEndProcess/UpdateNoShows',
                dataType: 'json',
                method: 'POST',
                data: { updateNoShow: selectedRecords },
                success: function (data) {
                    if (data.startsWith("ERR-")) {
                        ShowErrorMessage(data.replace("ERR-", ""));
                    } else {
                        ShowSuccessMessage("No shows updated successfully.");
                        setTimeout(function () {
                            window.location.reload();
                        }, 3000);

                    }
                },
                error: function (error) {
                    ShowErrorMessage('There is an error in processing day end.')
                }
            });
        }
    });

    //btn-complete-day-end

    $('body').off('click', '.btn-complete-day-end').on('click', '.btn-complete-day-end', function () {
        $('.day-end-summry-container').html('');
        $.ajax({
            url: '/CashieringAndPosting/DayEndProcess/CompleteDayEnd',
            dataType: 'json',
            method: 'POST',
            beforeSend: function () {
                $('.day-end-summry-container').html('');
                $('.day-end-summry-container').html('<center><br /><p> Please wait.. <br /> </p> <img src="/Images/work-process-gif.gif" /></center><br/>');


            },
            success: function (data) {
                if (data.startsWith('ERR-')) {
                    if (data.startsWith('ERR-Currently')) {
                        ShowWarningMessage(data.replace("ERR-", ""));
                    } else {
                        ShowErrorMessage(data)
                    }

                } else {
                    ShowSuccessMessage('Day end completed succesfully. Please wait, you will redirected to dashboard soon.');
                    setTimeout(function () {
                        window.location.href = '/administration/dashboard';
                    }, 3000);
                }
            },
            error: function (error) {
                ShowErrorMessage('There is an error in processing day end.')
            }
        });
    });



    $(document).ready(function () {

        var current_fs, next_fs, previous_fs; //fieldsets
        var opacity;

        $(".next").click(function () {

            current_fs = $(this).closest('fieldset');
            next_fs = $(this).closest('fieldset').next();

            AnimatePercentage(next_fs.find('.stepLoading'), next_fs.find('.stepContent'));

            //Add Class Active
            $("#progressbar li").eq($("fieldset").index(next_fs)).addClass("active");

            //show the next fieldset
            next_fs.show();
            //hide the current fieldset with style
            current_fs.animate({ opacity: 0 }, {
                step: function (now) {
                    // for making fielset appear animation
                    opacity = 1 - now;

                    current_fs.css({
                        'display': 'none',
                        'position': 'relative'
                    });
                    next_fs.css({ 'opacity': opacity });
                },
                duration: 600
            });
        });

        $(".previous").click(function () {

            current_fs = $(this).closest('fieldset');
            previous_fs = $(this).closest('fieldset').prev();

            AnimatePercentage(previous_fs.find('.stepLoading'), previous_fs.find('.stepContent'));

            //Remove class active
            $("#progressbar li").eq($("fieldset").index(current_fs)).removeClass("active");

            //show the previous fieldset
            previous_fs.show();

            //hide the current fieldset with style
            current_fs.animate({ opacity: 0 }, {
                step: function (now) {
                    // for making fielset appear animation
                    opacity = 1 - now;

                    current_fs.css({
                        'display': 'none',
                        'position': 'relative'
                    });
                    previous_fs.css({ 'opacity': opacity });
                },
                duration: 600
            });
        });

        $('.radio-group .radio').click(function () {
            $(this).parent().find('.radio').removeClass('selected');
            $(this).addClass('selected');
        });

        $(".submit").click(function () {
            return false;
        })

    });
</script>

