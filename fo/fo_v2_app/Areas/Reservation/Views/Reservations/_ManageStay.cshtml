    function LoadReservationCategoriesInMakeReservationManageStay() {
        var dataJson = localStorage.getItem("ReservationCategories");
        var data = JSON.parse(dataJson);
        $('#ReservationType option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Code + '" >' + item.Name + '</optoin>').appendTo($('#ReservationType'));
        });
    }

    function LoadCountriesInMakeReservationManageStay() {
        var dataJson = localStorage.getItem("Countries");
        var data = JSON.parse(dataJson);
        $('#CountryCombo option').remove();
        $(data).each(function (index, country) {
            if (country.Id == 217) {
                $('<option value="' + country.Id + '" selected>' + country.Name + '</option>').appendTo($('#CountryCombo'));  // Bangaladesh Modification
            } else {
                $('<option value="' + country.Id + '">' + country.Name + '</option>').appendTo($('#CountryCombo'));
            }
        });
    }

