
@{
    ViewBag.Title = "Staff Details";
}


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" data-background-color="purple">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="title">
                            @ViewBag.Title
                        <hr class="visible-print" />
                    </h4>
                </div>
                <div class="col-md-4 text-right hidden-print">
                    <button type="button" class="btn btn-sm btn-theme-color-2 showForm">
                        <span class="glyphicon glyphicon-plus"></span>
                    </button>

                    <button type="button" class="btn btn-sm  btn-theme-color-2 showGrid">
                        <span class="glyphicon glyphicon-th-list"></span>
                    </button>

                </div>
            </div>
        </div>
        <div class="card-content" id="contentLoadingArea">
            <div id="content">

            </div>
            @Html.Partial("_Loading")
        </div>
    </div>
</div>
</div>

<script src="~/Scripts/ui/common/scienter.grid2.js"></script>
<script>
         // form load --------------------------------
        $(document).ready(function () {
            FillGrid();
        });

        // show form --------------------------------
        $('body').on('click', '.showForm', function (e) {
            $.ajax({
                url: '/administration/staffdetails/form',
                dataType: 'html',
                method: 'POST',
                success: function (response) {
                   
                    $('#contentLoadingArea #content').html('').fadeOut();
                    $('#contentLoadingArea #content').html(response).fadeIn();
                }
               
            });
        });

        // show grid --------------------------------

        $('body').on('click', '.showGrid', function (e) {
            FillGrid();
        });


        // save --------------------------------------
        $('body').on('submit', '#staffDetails', function (e) {
            RemoveFormatNumber();
            
            e.preventDefault();
            var staffDetail = {
                __RequestVerificationToken: $('__RequestVerificationToken').val(),
                Id:             $('#Id').val(),
                Name:           $('#Name').val(),
                Code:           $('#Code').val(),
                StaffCategoryId: $('#StaffCategoryId').val(),
                DepartmentId: $('#departmentId').val(),
                DailyCredits: $('#DailyCredits').val(),
                IsActive: $('#IsActive').prop("checked"),
                Properties: selectedProperties
            };
            //if (selectedProperties.length > 0) {
                $.ajax({
                    url: '/administration/staffdetails/save',
                    dataType: 'json',
                    data: staffDetail,
                    method: 'POST',
                    success: function (response) {

                        if (response.message.startsWith("ERR-")) {
                            ShowWarningMessage(response.message);
                        } else {
                            ShowSuccessMessage('Record has been saved successfully.');
                            FillGrid();
                        }

                        
                    }
                   
                });
            //}
            //else {
            //    ShowErrorMessage('Please select at least one property to continue.');
            //}
        });


        // fill grid -----------------------------------
        function FillGrid() {
            var gridId = "#existingStaffDetailGrid"; // change this - relevent grid id
            var paginations = {
                PageIndex: $(gridId).attr('data-page-index'),
                PageSize: $(gridId).attr('data-page-size'),
                FilterType: $(gridId).attr('data-filter-type'),
                SearchKeyword: $(gridId).attr('data-search-keyword')
            }
            $.ajax({
                url: '/administration/staffdetails/selectforgrid',
                dataType: 'html',
                data: paginations,
                method: 'POST',
                success: function (response) {
                    if ($('.grid-container').length > 0) {
                        $('#contentLoadingArea #content').find($('.grid-container')).html('').fadeOut();
                        $('#contentLoadingArea #content').find($('.grid-container')).html(response).fadeIn();
                    } else {
                        $('#contentLoadingArea #content').html('').fadeOut();
                        $('#contentLoadingArea #content').html(response).fadeIn();
                    }

                }
                
            });
    }

    function LoadDepartments() {
        debugger;
        $.ajax({
            url: '/administration/staffdetails/selectalldepartments',
            dataType: 'json',
            success: function (data) {
                if ($('#departmentId').length > 0) {
                    $('#departmentId option').not(':first').remove();
                    $.each(data, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#departmentId'));
                    });
                }
            },
            complete: function (data) {
                var selectedDepartmentId = $('#hdnDepartmentId').val();
                if (selectedDepartmentId > 0) {
                    $('#departmentId').val(selectedDepartmentId);
                    $('#departmentId').trigger('change');
                }
            }
        });
    }

</script>

