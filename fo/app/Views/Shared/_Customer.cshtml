<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Scienter Hotel Team | SNK">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <title>@ViewBag.Title - Destinity Hotel Management Platform</title>

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">

    <script src="~/Scripts/jquery-3.2.1.min.js"></script>
    @*<script src="~/Scripts/modernizr-2.6.2.js"></script>*@
    <script src="~/Scripts/moment.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/bootstrap-datetimepicker.js"></script>
    <script src="~/Scripts/jquery-editable-select.js"></script>

    <link href="~/Content/bootstrap.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/mega-menu/css/reset.css" rel="stylesheet" />
    <link href="~/Content/mega-menu/css/style.css" rel="stylesheet" />

    <link href="~/Content/material-dashboard.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/Theme.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-daterangepicker.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-datetimepicker.css" rel="stylesheet" />
    <link href="~/Content/FaIcons/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Content/w3.css" rel="stylesheet" />
    <link href="~/Content/scienter-print.css" rel="stylesheet" />
    <link href="~/Content/jquery-editable-select.css" rel="stylesheet" />

    <!--DATA TABLES -->
    <link href="~/datatable/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="~/datatable/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="~/datatable/scienter.datatables.css" rel="stylesheet" />
    <!--DATA TABLES -->
    @*<script src="~/Scripts/jquery-3.2.1.min.js"></script>*@

    <script>
        var selectedProperties = [];
        var Billtotal;
        var billpaymentArray = [];
    </script>

    @if (Scienter.HotelERP.Common.Utility.Configs.GetAppSettingValue("ThemeColor") == "blue")
    {
        <link href="~/Content/scienter.theme.blue.css" rel="stylesheet" />
    }

</head>
<body>

    <header class="cd-main-header hidden-print">
        <div class="theme-bg-color-1" style="height:45px;">

            @*<button class="w3-button w3-teal w3-xlarge w3-left" onclick="openLeftMenu()">&#9776;</button>*@

            @*<button class="w3-button w3-teal w3-xlarge w3-right" onclick="openRightMenu()">&#9776;</button>*@
            <ul class="cd-header-buttons">
                @*<li><a class="cd-search-trigger" title="Search" data-toggle="tooltip" data-placement="bottom" href="#cd-search"><span></span></a></li>
                    <li><a class="cd-nav-trigger" href="#cd-primary-nav"><span></span></a></li>*@
            </ul> <!-- cd-header-buttons -->
        </div>
    </header>


    <main class="cd-main-content">


        <div class="messagealert" id="alert_container"></div>
        <div>
            <div class="container w3-container">
                <div id="viewLoadingArea" style="padding-top:10px;">
                    @RenderBody()
                </div>

            </div>
        </div>
    </main>
    <div class="hidden-print">
        @Html.Partial("_NavigationAjax")
    </div>
    @*<div class="doc-menu">
            @Html.Partial("_Dock_Menu")
        </div>*@

    <!-- DATA TABLES -->
    <script src="~/datatable/jquery.dataTables.min.js"></script>
    <script src="~/datatable/dataTables.buttons.min.js"></script>
    <script src="~/datatable/buttons.flash.min.js"></script>
    <script src="~/datatable/jszip.min.js"></script>
    <script src="~/datatable/pdfmake.min.js"></script>
    <script src="~/datatable/vfs_fonts.js"></script>
    <script src="~/datatable/buttons.html5.min.js"></script>
    <script src="~/datatable/buttons.print.min.js"></script>
    <script src="~/datatable/scienter.datatables.js"></script>

    <!-- END OF DATA TABLES -->
    <script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
    @*<script src="~/Scripts/moment.min.js"></script>
        <script src="~/Scripts/bootstrap.min.js"></script>*@
    <script src="~/Content/mega-menu/js/main.js"></script>

    <script src="~/Scripts/material.min.js"></script>
    <script src="~/Scripts/chartist.min.js"></script>
    <script src="~/Scripts/arrive.min.js"></script>
    <script src="~/Scripts/perfect-scrollbar.jquery.min.js"></script>
    <script src="~/Scripts/bootstrap-notify.js"></script>
    <script src="~/Scripts/material-dashboard.js"></script>
    <script src="~/Scripts/bootstrap-daterangepicker.js"></script>
    <script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
    <script src="~/Scripts/ui/common/scienter.common.datatimepicker.js"></script>

    <!-- Modal For details -->
    <div id="grid-record-detail-model" class="modal fade" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content" id="grid-detail-popup-container">
                <div class="modal-body">
                    <div data-dismiss="modal" style="float: right;margin-top: -35px;margin-right: -35px;background-color: #fff;border-radius: 50px;padding: 4px; cursor:pointer;" id="grid-record-detail-model-close">
                        <img src="~/Images/close-btn.png" class="hidden-print" style="width:28px;" />
                    </div>
                    <div class="model-popup-title">
                        <h4 id="grid-record-detail-header" class="hidden-print" style="margin-bottom:10px;"></h4>
                    </div>
                    <div id="grid-record-detail-body">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="add-new-record-window-model" class="modal fade" role="dialog">
        <div class="modal-dialog modal-md">
            <!-- Modal content-->
            <div class="modal-content" id="add-new-record-window-container">
                <div class="modal-body">
                    <div data-dismiss="modal" style="float: right;margin-top: -35px;margin-right: -35px;background-color: #fff;border-radius: 50px;padding: 4px; cursor:pointer;">
                        <img src="~/Images/close-btn.png" style="width:28px;" />
                    </div>
                    <div class="model-popup-title">
                        <h4 id="add-new-record-window-header" style="margin-bottom:10px;"></h4>
                        <hr />
                    </div>
                    <div id="add-new-record-window-body">
                    </div>
                </div>
            </div>
        </div>
    </div>



    <div id="message-success-model" class="modal fade" role="dialog">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-body">
                    <div data-dismiss="modal" class="success-popup-ok model-popup-close-btn">
                        <img src="~/Images/close-btn.png" />
                    </div>

                    <div class="row">
                        <div class="col-sm-2 icon-holder">
                            <img src="~/Images/success-icon.png" />
                        </div>
                        <div class="col-sm-10">
                            <div class="model-popup-title">
                                <h4>Success !</h4>
                            </div>
                            <div>
                                <p style="font-size:14px;" id="message-success-model-msg"></p>
                                <br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="message-error-model" class="modal fade" role="dialog">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-body">
                    <div data-dismiss="modal" class="error-popup-ok  model-popup-close-btn">
                        <img src="~/Images/close-btn.png" />
                    </div>

                    <div class="row">
                        <div class="col-sm-2 icon-holder">
                            <img src="~/Images/error-icon.png" />
                        </div>
                        <div class="col-sm-10">
                            <div class="model-popup-title">
                                <h4>Error !</h4>
                            </div>
                            <div>
                                <p style="font-size:14px;" id="message-error-model-msg"></p>
                                <br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="message-warning-model" class="modal fade" role="dialog">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-body">
                    <div data-dismiss="modal" class="model-popup-close-btn">
                        <img src="~/Images/close-btn.png" />
                    </div>
                    <div class="row">
                        <div class="col-sm-2 icon-holder">
                            <img src="~/Images/waring-icon.png" />
                        </div>
                        <div class="col-sm-10">
                            <div class="model-popup-title">
                                <h4>Warning !</h4>
                            </div>
                            <div>
                                <p style="font-size:14px;" id="message-warning-model-msg"></p>
                                <br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openLeftMenu() {
            document.getElementById("leftMenu").style.display = "block";
        }
        function closeLeftMenu() {
            document.getElementById("leftMenu").style.display = "none";
        }

        function openRightMenu() {
            document.getElementById("rightMenu").style.display = "block";
        }
        function closeRightMenu() {
            document.getElementById("rightMenu").style.display = "none";
        }

        $(document).ready(function () {
            $('.card .card-content').css('min-height', ($(window).height() - 125));
            $('.card .card-content').css('height', ($(window).height() - 125));
            $('.card .card-content').css('overflow-y', 'scroll');

            $('.card .card-content').css('min-width', ($(window).width() - 700));
        });

    </script>
    <script src="~/Scripts/ui/common/scienter.number.formatting.js"></script>
    <script src="~/Scripts/ui/common/scienter.lablefloating.override.js"></script>

</body>
</html>
