            <img src="~/Images/destinity_logo.png" alt="Destinity Logo" />
        </div>
        <div class="loader">
            <p>Checking </p>
            <div class="words">
                <span class="word">master files</span>
                <span class="word">hotel details</span>
                <span class="word">access</span>
                <span class="word">reservations</span>
                <span class="word">master files</span>
            </div>
        </div>
    </div>


</body>
</html>
