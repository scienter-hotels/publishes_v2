    function parseDate(str) {

        var mdy = str.split('/');
        return new Date(mdy[2], mdy[0] - 1, mdy[1]);
    }

    function datediff(first, second) {
        return Math.round((second - first) / (1000 * 60 * 60 * 24));
    }

    Date.prototype.addDays = function (days) {
        var dat = new Date(this.valueOf());
        dat.setDate(dat.getDate() + days);
        return dat;
    }


    function getDateforHeader(date, thOrHidden) {

        var weekday = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
        var monthsArr = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        var returnDate;
        var year, dayName, dayNumStr = '';

        dayName = weekday[date.getDay()];

        var dateVar = new Date(date).getDate();

        if (dateVar.toString().length <= 1) {
            ;
            dayNumStr = '0' + dateVar.toString();
        } else {
            dayNumStr = dateVar.toString();
        }

        var month = new Date(date).getMonth() + 1
        if (month.toString().length <= 1) {
            month = '0' + month.toString();
        }

        year = new Date(date).getFullYear().toString();

        if (thOrHidden == 'hid') {
            returnDate = dayNumStr + '/' + month + '/' + year;
        } else if (thOrHidden == 'th') {
            returnDate = dayName + '<br />' + '<p style="font-size:24px">' + dayNumStr + '<p>' + monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'ywm') {
            returnDate = monthsArr[new Date(date).getMonth()] + '/ ' + year;
        } else if (thOrHidden == 'mon') {
            returnDate = month;
        } else if (thOrHidden == 'withdash') {
            returnDate = dateVar + '/' + month + '/' + year;
        }

        return returnDate;
    }

    function dateFormatChanger(d) {
        var splitedDate = d.split('/');
        var changedDate = splitedDate[1] + "/" + splitedDate[0] + "/" + splitedDate[2];
        return changedDate;
    }
