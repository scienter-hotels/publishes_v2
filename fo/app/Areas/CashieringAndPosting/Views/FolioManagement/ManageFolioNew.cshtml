    function CheckoutGuest(qCheckOutsList, ckOutRemark, ajaxUrl) {
        if (qCheckOutsList[0].id == undefined) {
            qCheckOutsList = [];
            qCheckOutsList.push({
                Id: $('.reservation-header-id').val(),
                ReservationNo: $('.res-no').html().trim()
            });
            ckOutRemark = "Checked out from Folio";
        }
        $.ajax({
            url: '/reservation/QuickCheckOut/QuickCheckOut',
            dataType: 'JSON',
            data: { qCheckOut: qCheckOutsList, CheckOutRemark: ckOutRemark },
            method: 'POST',
            success: function (response) {
                if (response.startsWith('UnsettledBills')) {
                    ShowErrorMessage('There are unsettled bills for this reservation');
                } else if (response.startsWith('success')) {
                    //ShowSuccessMessage('Guest checked out successfully.');
                    var EventCode = "CO";
                    var propertyId = $('#PropertyId').val();
                    var userId = $('#UserId').val();
                    var printURL = $('#DirectPrintURL').val();
                    var FromRoom = $('.res-room-no').html().trim();

                    var ToRoom = "-1";
                    var GuestName = $('#GuestName').val();
                    var ReservationNo = $('.res-no').html().trim();
                    var ajaxUrlFinal = printURL + 'PABX/' + EventCode + '/' + ReservationNo + '/' + propertyId + '/' + userId + '/' + FromRoom + '/' + ToRoom + '/' + GuestName + '/'
                    var ajaxUrl = ajaxUrlFinal
                    PABXAjaxRequest(ajaxUrl);
                    //$.ajax({
                    //    url: ajaxUrlFinal,
                    //    method: 'POST',
                    //    beforeSend: function () {

                    //    },
                    //    complete: function () {

                    //    },
                    //    success: function (data) {

                    //    },
                    //    error: function (data) {
                    //        ShowErrorMessage('Sorry there is an error.');
                    //    }
                    //});
                    setTimeout(function () {
                        var reservationHeaderId = $('.reservation-header-id').val();

                        var url = '/reservation/reservations/PrintInvoiceCopy?resNo=' + ReservationNo + '&reservationHeaderId=' + reservationHeaderId;
                        CallDetailModelSimple('Print Copies', url, 600);
                    }, 2000);
                } else {
                    ShowErrorMessage(response);
                }
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error in checkout.');
            }
        });

    }
