@model Scienter.HotelERP.Common.Domain.ViewModels.RoomsAndFloorsView

<style>
    h3 {
        font-weight: bold;
    }

    /*.custom-top-padding {
        padding-top: 5px;
    }*/

    .well {
        font-size: 16px;
    }

    .override-from-group-margin {
        margin-top: 0px;
        margin-bottom: -4px;
    }

    .colorBox {
        height: 12px;
        width: 12px;
    }

    .box1 {
        background-color: #FE0101;
    }

    .box2 {
        background-color: #038959;
    }

    .box3 {
        background-color: #ff9800;
    }

    .row-height {
        padding-top: 5px;
        height: 25px;
    }

    .well-height {
        /*padding: 9px 0px 0px 0px;
        height: 5em;*/
    }

    .col-padding-overide {
        padding: 1px !important;
    }

    .room-number-height {
        height: 50px;
    }

    .content-align-center {
        text-align: center;
    }

    .allocatedWellColor {
