                    AmountFC: parseFloat($("#Amount").val().trim().replace(/,/g, '')).toFixed(2),
                    ConvertionRate: parseFloat(currRate),
                    CurrencyId: currencyTypeId
                }
                $.ajax({
                    url: '/CashieringAndPosting/Posting/RebatePosting',
                    dataType: 'json',
                    data: rebateposting,
                    method: 'POST',
                    success: function (response) {

                        if (response.toString().startsWith('ERR-')) {
                            ShowErrorMessage("Sorry, There is an error in saving this record.");
                        } else {
                            ShowSuccessMessage('Record has been saved successfully.');
                            $('#btnprint').removeClass('disabled');
                            ShowInvoiceReportInhouse(response);
                            $('#btnSave').prop('disabled', true);
                            $('#preview').text('');
                            $('.ribbon').addClass('hidden');
                            $('#BillTypeId').prop('selectedIndex', 0);
                            $('#Posting-inhouse div').addClass('is-empty');
                            $('#FolioText').val('');
                            $("#Amount").val('');
                            $("#Remarks").val('');
                            $('#amountField').removeClass('is-focused');
                            $('#btnbillpayment').addClass('disabled');
                            $('#btnbillpaymentLater').addClass('disabled');
                            $('#btnAdd').addClass('hidden');
                            $('#BillTypeId').prop("disabled", true);
                            $('#FolioText').prop("disabled", true);
                            $("#Amount").prop("disabled", true);
                            $("#Remarks").prop("disabled", true);
                        }

                    },
                    error: function (xhr, status, error) {
                        ShowErrorMessage('Sorry, There is an error in saving this record.');
                    },
                    complete: function () {
                        if ($('#PrintingMethod').val() == 'F') {
                            var invoiceNo = $('#ReportHeader .table-posting td .RptinvoiceNo').text().replace('Receipt#:', '').trim();
                            var docno = $('#ReportHeader .table-posting td .RptinvoiceNo').text().replace('Receipt#:', '').trim();
                            var docType = "RBT";
                            CreateFiscalPrinterRequestUrl(invoiceNo, docno, docType);
                        }
                    }
                });
            }
            //-----------------------------End rebate posting--------------------------------------------

            ClearCheckBoxes();
            $('#btnClear').val('New');
            $("div .checkbox").prop("disabled", true);     
    }


