                                </a>
                            </div>
                        </div>
                                //}
                                @*else
                                {

                                    <div class="row" style="margin-top:-10px;margin-bottom:-5px;">
                                        <div class="col-md-12">
                                            <p style="color: #333; font-size: 16px; text-align: center;">
                                                You are logged in as <strong><span id="EntraIDUserName"></span></strong>.
                                            </p>
                                           
                                        </div>
                                    </div>
                                    <br/>
                                    <div class="row" style="margin-top:-10px;margin-bottom:-5px;">
                                        <div class="col-md-12">
                                            <a class="btn btn-primary" style="width:100%;height: 30px;font-size: 11px;background-color:#000 !important;" href="/claim/index">Continue</a>
                                        </div>
                                        <div class="col-md-12">
                                            <a class="btn btn-default" style="width:100%;height: 30px;font-size: 11px;background-color:#4b4747 !important;" href="/login/SignOut">Signout</a>
                                        </div>
                                    </div>
                                }*@
                            }
