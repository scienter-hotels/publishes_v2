@model IEnumerable<Scienter.HotelERP.Common.Domain.FrontOfficeInventory>

<table class="table table-striped">
    <thead>
        <tr>
            <th class="col-md-1">Inventory Item</th>
            <th class="col-md-1">Availale Count</th>
            <th class="col-md-1">Allocation Count</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var frontOfficeInventory in Model)
        {    
            <tr class="inventory-tr" data-inventoryId="@frontOfficeInventory.Id">
                <td>
                    @frontOfficeInventory.Name
                </td>
                <td>
                    @frontOfficeInventory.AvailableQty
                </td>
                <td><input type="number" class="form-control room-inventory-count" max="@frontOfficeInventory.AvailableQty" value="0" min="0" id="room-inventory-count" /></td>
            </tr>
        }
    </tbody>
</table>