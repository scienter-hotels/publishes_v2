    function LoadNoOfPages(noOfPages, totalNoOfRows) {
      
        var Nos = '';
        
        $('#pageNoLine').html('');
        $('.data-page-no-btn').remove();

        $('#hdn-noOfPages').val(noOfPages);
        var currentPage = $('#hdn-index').val();

       

        for (var i = 1; i <= noOfPages; i++) {
            if (i == 4) {
                i = (noOfPages - 2);
                Nos = Nos + '<button class="data-page-no-btn btn btn-default btn-sm data-index-' + i + '" data-noOfPages="' + noOfPages + '" data-val="' + i + '">...</button>';
            }
            Nos = Nos + '<button class="data-page-no-btn btn btn-default btn-sm  data-index-' + i + '" data-noOfPages="' + noOfPages + '" data-val="' + i + '">' + i + '</button>';
        }
        $(
            '<span style=" float: left;margin-top: 9px;font-size: 12px;text-transform: uppercase;font-weight: bold;">Total Reservations : ' + totalNoOfRows+ '</span>'+
            '<span class="current-page-no"><span id="current-index">1</span>/' + noOfPages + '</span>' +
            '<button class="data-page-previous-btn data-page-no-btn btn btn-default btn-sm" data-noOfPages="' + noOfPages + '" data-val="1">PREVIOUS</button>' +
            Nos +
            '<button class="data-page-next-btn data-page-no-btn btn btn-default btn-sm" data-noOfPages="' + noOfPages + '" data-val="2">NEXT</button>'
        ).appendTo('#pageNoLine');
    }

    $('body').on('click', '.data-page-no-btn', function (e) {
        var index = 1;
        index = Number($(this).attr('data-val'));
        var noOfPages = Number($(this).attr('data-noOfPages'));
        var paginations = Paginations(index);
        var previous = index;
        var next = index;
        if (index>1) {
            previous = index - 1;
        }
        if (noOfPages > index) {
            next = index + 1;
        }


        FillGrid(paginations);
        $('.data-page-previous-btn').attr('data-val', previous);
        $('.data-page-next-btn').attr('data-val', next);
        $('.data-page-no-btn').removeClass('highlight');
        $(this).addClass('highlight');
        $('#hdn-index').val(index);
        $('#current-index').text(index.toString());

        var redirectUrl = window.location.href.slice(window.location.href.indexOf('?') + 1).split('&') + '?index=' + index;
        //alert(redirectUrl);
    });

