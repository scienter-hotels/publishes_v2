                        ).appendTo('#alergicsTable');

                    })
                }
            },
            error: function (xhr, status, error) {
                ShowErrorMessage('Sorry, There is an error loading existing setups.');
            }
        });
    }

    //Notes Tab
    function FillNotes() {
        $.ajax({
            url: '/Administration/GuestHistory/GuestNote?GuestProfileId=' + guestid,
            dataType: 'HTML',
            method: 'POST',
            beforeSend: function () {
                $('#note .loader-load').show();
                $('#note .show-hide').hide();
