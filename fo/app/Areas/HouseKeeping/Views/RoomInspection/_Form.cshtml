@{
    ViewBag.Title = "Room Inspection";
}
<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>

<style>
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
    .form-group {
        margin-top: 5px !important;
    }
</style>
<form id="roomInspection">
    <div class="row">
        <div class="col-md-4">
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="required control-label">Inspection Time</label>
                        @{Html.RenderAction("RoomInspectionTimesCombo", "RoomInspection", new { name = "RoomInspectionId", requiered = true });}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="required control-label">Room</label>
                        @{Html.RenderAction("RoomDetailCombo", "RoomDetails", new { area = "Administration", name = "RoomId", requiered = true });}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="required control-label">Room Type</label>
                        @{Html.RenderAction("RoomTypeCombo", "RoomTypes", new { area = "Administration", name = "RoomTypeId", requiered = true });}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="required control-label">Room Status</label>
                        @{Html.RenderAction("AllRoomStatusCombo", "RoomStatus", new { name = "RoomStatusId", requiered = true });}
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group label-floating">
                        <label class="required control-label">Remark</label>
                        <input type="text" id="Remarks" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <input type="submit" id="btnAdd" value="Add" class="btn btn-primary" />
                        &nbsp;
                        <input type="button" id="btnSave" value="Save" class="btn btn-primary" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="row" style="height:300px; border:1px solid #bdc3c7; margin-left: 0px !important; overflow-y:scroll">
                <div class="table-responsive">
                    <table id="" class="table table-striped">
                        <thead>
                            <tr>
                                <th class="col-md-1 text-primary">
                                    Inspection Time
                                </th>
                                <th class="col-md-1 text-primary">
                                    Room
                                </th>
                                <th class="col-md-1 text-primary">
                                    Room Type
                                </th>
                                <th class="col-md-1 text-primary">
                                    Room Status
                                </th>
                                <th class="col-md-1 text-primary">
                                    Remark
                                </th>
                                <th class="col-md-1 text-primary"></th>
                            </tr>
                        </thead>

                        <tbody class="inspection-save-grid-tbody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    //2023-08-16--------------------------------------------------------------------------
    $(document).ready(function () {

        $('#RoomStatusId').addClass('select2');
        $('#RoomTypeId').addClass('select2');
        $('#RoomId').addClass('select2');
        $('#RoomInspectionId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });
    });

        //-------------------------------------------------------------------------------------------

</script>