    $('body').on('click', '#activityLog', function () {
        debugger;

        var code = $('#type').val();
        $(".guestportal-action-model").modal('show');
        $('#code').val(code);
        //$('#hdnreservationHeaderId').val($('#guestPoratlRoomRequestReservationHeaderId').val());
        $('#requestId').val($(this).attr('data-Id'));
        $('#hdnactionType').val($(this).attr('data-ActionTypeId'));
        $('#hdnreservationHeaderId').val($(this).attr('data-guestPoratlRoomRequestReservationHeaderId'));
        if (code === "r") {
            $('#hdnlabel').val("Room Request Status");
        } else {
            $('#hdnlabel').val("Laundry Request Status");
        }

        LoadActionType(code);
    });

    $('body').on('click', '.viewactivityLog', function (e) {
        debugger;
        var code = $('#type').val();
        var requestId = $(this).attr('data-id');
        var reservationHeaderId = $(this).attr('data-guestPoratlRoomRequestReservationHeaderId');
        //var reservationHeaderId = $('#reservationHeaderId').val();
        var GuestPortalActivityLogURL = '/GuestPortal/Action/ActivityLog?code=' + code + '&requestId=' + requestId + '&reservationHeaderId=' + reservationHeaderId;
        if (code === "r") {
            var title = 'Room Request Status Activity Log ';
        } else {
            var title = 'Laundry Request Status Activity Log';
        }

        //'&guestName=' + guestName + '&guestProfileId=' + GuestProfileId + '&Uuid=' + ResUuid + '';

