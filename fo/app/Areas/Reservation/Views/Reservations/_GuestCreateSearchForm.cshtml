    $('#resetBtn').click(function (e) {

        $('#FirstName').val('');
        $('#LastName').val('');
        $('#NICPassport').val('');
        $('#Email').val('');
        $('#ContactNo').val('');
        $('#SalutationId').val('');
        $('#NationalityId').val('');
        $('#CountryId').val('');
        $('.guest-checkBox').each(function (index, element) {
            $(element).prop('checked', false);
        });
        SearchCustomer();
    });


    function LoadVipLevelsInMakeReservationGuestDetails() {
        var dataJson = localStorage.getItem("VIPLevels");
        var data = JSON.parse(dataJson);
        $('#VipLevelId option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#VipLevelId'));
        });
        $('#VipLevelId').val($('#VipLevelId').attr('data-select-vip'));
    }

    function LoadSalutationsInMakeReservationGuestDetails() {
        var dataJson = localStorage.getItem("Salutations");
        var data = JSON.parse(dataJson);
        $('#SalutationId option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#SalutationId'));
        });
        $('#SalutationId').val($('#SalutationId').attr('data-select-salutation'));
    }

    function LoadCountriesInMakeReservationGuestDetails() {
        var dataJson = localStorage.getItem("Countries");
        var data = JSON.parse(dataJson);
        $('#CountryId option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#CountryId'));
        });
        $('#CountryId').val($('#CountryId').attr('data-select-country'));
    }

    function LoadNationalitiesInMakeReservationGuestDetails() {
        var dataJson = localStorage.getItem("Nationalities");
        var data = JSON.parse(dataJson);
        $('#NationalityId option').remove();
        $(data).each(function (index, item) {
            $('<option value="' + item.Id + '" selected>' + item.Name + '</option>').appendTo($('#NationalityId'));
        });
        $('#NationalityId').val($('#NationalityId').attr('data-select-nationality'));
    }

