
@model  IEnumerable<Scienter.HotelERP.Common.Domain.RoomTypes>

@{
    ViewBag.Title = "Exising Room Types";
}

<div class="table-responsive">
    <table class="table table-striped"
           id="existingRoomTypesGrid">
        <thead>
            <tr>
                <th class="col-md-2 text-primary">
                    Code
                </th>
                <th class="text-primary">
                    Name
                </th>
                <th title="Max Head Count"  data-toggle="tooltip" class="col-md-1 text-primary">
                    MHC.
                </th>
                <th class="col-md-1 align left text-primary">
                    BE.
                </th>
                <th class="col-md-1 text-primary">
                    Active
                </th>
                <th class="col-md-1 hidden-print"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Prefix)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MaxHeadCount)
                </td>
                <td>
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsApplicableForIBE)
                            <span class="hidden">
                                @if (item.IsApplicableForIBE)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>

                </td>
                <td>
                    <div class="form-group checkbox">
                        <label>
                            @Html.DisplayFor(modelItem => item.IsActive)
                            <span class="hidden">
                                @if (item.IsActive)
                                {
                                    @:Active
                                }
                                else
                                {
                                    @:Inactive
                                }
                            </span>
                        </label>
                    </div>

                </td>
                <td class="hidden-print text-right">
                    @*<a class="btn btn-theme-color-2 btn-sm call-popup-model" id="btnPrint" data-title="Bed Type - @item.Name" data-href="/administration/roomtypes/print/@item.Id">
                <span class="glyphicon glyphicon-print"></span>
            </a>*@

                    <a class="btn btn-theme-color-2 btn-sm" id="btnEdit" data-ajax="true" data-ajax-mode="replace" data-ajax-update="#content" href="/administration/roomtypes/edit/@item.Id">
                        <span class="glyphicon glyphicon-pencil"></span>
                    </a>

                    <a class="btn btn-danger btn-sm call-popup-model-delete" id="btnDelete" data-href="/administration/roomtypes/delete/@item.Id">
                        <span class="glyphicon glyphicon-trash"></span>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

<script>
    $(document).ready(function () {
        $('#existingRoomTypesGrid').DataTable(
            {
                //"dom": '<"top"ifb>rt<"bottom"lp><"clear">',
                searching: true,
                ordering: true,
                //"lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
                dom: 'Bfrtipl',
                select: true,
                buttons: [
                            'copy',
                            'excel',
                            'csv',
                            'pdf',
                            'print'
                ],
                scrollY: '58vh',
            } );
    });
</script>