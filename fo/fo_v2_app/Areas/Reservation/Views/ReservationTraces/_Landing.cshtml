        LoadReservationNumbers(reservationHeaderId, Type);
    });


    $('#tab4').click(function () {
        $('#ReservationTracesForm').hide();
        $('#tab2').show();
        $('#tab4').addClass('active');
        $('#tab3').removeClass('active');
    });

    $('#tab3').click(function () {
        $('#ReservationTracesForm').show();
        $('#tab1').show();
        $('#tab2').hide();
        $('#tab4').removeClass('active');
        $('#tab3').addClass('active');

    })
