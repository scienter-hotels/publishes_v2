@model Scienter.DestinityHorizon.Common.Domain.ReportInfos

@*@if (!string.IsNullOrEmpty(ViewBag.Masterfile) && ViewBag.Masterfile == "0")*@

@{
   // Layout = "~/Views/Shared/_Layout.cshtml";
    // ViewBag.paddingLeft = "padding-left:250px; height:1000px";
}

@{
    var widthClass = "col-md-12";
}

<div class="row">
    <div class="@widthClass">
        <div class="card">
            <div class="card-content2" id="contentLoadingArea">
                <div class="row">
                    <div class="col-md-12">
                        <div class="row">
                            <iframe id="frmReport"
                                    src="@Model.ReportURL"
                                    frameborder="0"
                                    style="@String.Format("width:{0}px; height:{1}px;{2}", "1250", Model.Height, ViewBag.paddingLeft);"
                                    scrolling="yes"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

