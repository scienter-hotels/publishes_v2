    // fill grid -----------------------------------
    function FillGrid() {
        var gridId = "#existingReservationHeaderGridCheckOut"; // change this - relevent grid id
        var paginations = {

            PageIndex: $(gridId).attr('data-page-index'),
            PageSize: $(gridId).attr('data-page-size'),
            FilterType: $(gridId).attr('data-filter-type'),
            SearchKeyword: $(gridId).attr('data-search-keyword')
        }
        $.ajax({
            url: '/reservation/QuickCheckOut/SelectForGrid',
            dataType: 'html',
            data: paginations,
            method: 'POST',
            success: function (response) {

                $('.grid-area').html('').fadeOut();
                $('.grid-area').html(response).fadeIn();
                GridFunctionalities();
            },
            error: function (error) {

            }
        });
    }

