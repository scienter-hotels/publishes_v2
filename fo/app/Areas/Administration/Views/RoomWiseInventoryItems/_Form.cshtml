@model Scienter.HotelERP.Common.Domain.RoomWiseInventoryItem

@{
    ViewBag.Title = "Create / Edit";
}

<div class="col-md-12">

    <form id="roomWiseInventoryItems">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <input type="hidden" value="@Model.Id" name="Id" id="Id" />
        <div class="row">
            <div class="col-md-6">
                <div class="form-group label-floating">
                    @Html.LabelFor(model => model.RoomId, htmlAttributes: new { @class = "control-label " })

                    @{Html.RenderAction("RoomDetailCombo", "RoomDetails", new { name = "RoomId", requiered = true, value = Model?.RoomId });}
                    @* @Html.EditorFor(model => model.RoomId, new { htmlAttributes = new { @class = "form-control" } })*@
                    @Html.ValidationMessageFor(model => model.RoomId, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <fieldset class="the-fieldset">
                    <legend class="the-legend"> Items</legend>
                    <div class="form-group label-floating">
                        <div id="roomWiseInventoryContainer">
                            @{Html.RenderAction("LoadRoomWiseInventoryItems", "RoomWiseInventoryItems", new { roomId = 0 });}
                        </div>
                        @Html.ValidationMessageFor(model => model.InventoryItemId, "", new { @class = "text-danger" })
                    </div>
                </fieldset>
                <div class="form-group">
                    <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                    &nbsp;
                    <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                </div>
            </div>
        </div>

    </form>


</div>


<script>
    $('#RoomId').change(function () {
        if ($(this).val().length) {

            $.ajax({
                url: '/Administration/RoomWiseInventoryItems/LoadRoomWiseInventoryItems?roomId=' + $(this).val(),
                dataType: 'html',
                success: function (data) {
                    $('#roomWiseInventoryContainer').html(data);
                },

            });
        } else {
            $('input:checkbox').removeAttr('checked');
        }
    });
</script>
