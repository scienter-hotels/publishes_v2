@model IEnumerable<Scienter.HotelERP.Common.Domain.ViewModels.ReservationView>


<div class="row">
    <div class="col-md-12">
        <div class="table-responsive div-scroll" style="max-height:480px; overflow-y:scroll; overflow-x:hidden;">
            <table class="table table-striped"
                   id="existingBedTypeGrid" 
                   data-page-index="1"  
                   data-page-size="5"                   
                   data-page-count="@Model.FirstOrDefault().PageCount"
                   data-filter-type="2" 
                   data-search-keyword="" 
                   data-grid-top-functionalities ="true"  
                   data-grid-pageable="true" 
                   data-grid-sortable="true">
                <tr>
                    <th class="text-primary col-md-1">
                        Stay From
                    </th>

                    <th class="text-primary col-md-1">
                        Stay To
                    </th>
                    <th class="text-primary col-md-1">
                        Group #
                    </th>

                    <th class="text-primary col-md-1">
                        Res. #
                    </th>

                    <th class="text-primary">
                        Guest
                    </th>

                    <th class="text-primary col-md-1">
                        Category
                    </th>

                    <th class="text-primary col-md-1">
                        Room #
                    </th>
                    <th></th>
                </tr>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="arrival-date">
                            @Html.DisplayFor(modelItem => item.Arrival)
                            <input type="hidden" class="arrival-date-hidden" value="@item.Arrival"/>
                        </td>

                        <td class="depature-date">
                            @Html.DisplayFor(modelItem => item.Departure)
                            <input type="hidden" class="departure-date-hidden" value="@item.Departure" />
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.GResNo)
                        </td>

                        <td class="res-no">
                            @Html.DisplayFor(modelItem => item.ResNo)
                        </td>

                        <td class="guest-name">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.RoomCat)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.RoomNo)
                        </td>
                        <td>
                            <div class="form-group checkbox">
                                <label>
                                    <input class="data-reservation-no" type="checkbox" data-assinged-room-rank="@item.Rank" value="@item.ReservationHeaderId" />
                                </label>
                            </div>
                        </td>
                    </tr>
                }

            </table>
        </div>
    </div>
</div>