    function getRooms(filters) {

        var rooms = { RoomsJson: RoomCountJson };

        return rooms.RoomsJson.filter(function (o) {
            return Object.keys(filters).every(function (k) {
                return o[k].split(',').some(function (v) {
                    return v === filters[k];
                });
            });
        });
    }



    //Room Count-------------------------------------
    $('body').on('input', '.room-count', function (e) {
        var thisController = $(this);
        var roomCategoryId = $(this).closest('tr').find('.hidden-room-cat-name').val();
        var roomTypeId = $(this).siblings('.data-room-type').val();
        var roomCatMaximumAvailability = $(this).data('max-availability');
        var roomCountToCatAndType = $(this).val();
        var roomsCountForFilteration = getRooms({ RoomTypeId: roomTypeId, RoomCatId: roomCategoryId }).length;

        // by sachth--------------------------------------------------
        var maxAvailability = $(this).attr('data-max-availability');
        var currentRow = $(this).closest('tr');
        var currrentRoomSelectedCount = 0;
        $.each(currentRow.find('.room-count'), function (index, item) {
            currrentRoomSelectedCount = currrentRoomSelectedCount + Number($(item).val());
        });

        if (maxAvailability < currrentRoomSelectedCount) {
            $(thisController).val(Number($(thisController).val()) - 1);
            ShowWarningMessage('You have selected maximum available rooms.');
            return false;
        } else {


            // by sachth--------------------------------------------------
            if ($(this).val() > roomCatMaximumAvailability) {
                $(this).val(roomCatMaximumAvailability);
            } else {
                if (roomCountToCatAndType > roomsCountForFilteration) {

                    ShowRoomCountGrid()
                    var previousRoomNumberValue = typeof $('.room-wise-counts tbody tr:last').find('.room-number').val() === 'undefined' ? 0 : parseInt($('.room-wise-counts tbody tr:last').find('.room-number').val());
                    var newRoomNumber = previousRoomNumberValue + 1;

                    RoomCountJson.push({
                        RoomNo: parseInt(newRoomNumber),
                        RoomCatId: roomCategoryId,
                        roomCatName: $(this).closest('tr').find('.hidden-room-cat-name').data('itrm-name'),
                        RoomTypeId: roomTypeId,
                        roomTypeName: $(this).siblings('.data-room-type').data('room-type-name'),
                        AdultCount: $(this).data('max-adult-count'),
                        ChildCount: $(this).data('max-child-count')
                    });
                } else {
                    var deleteRoomNo = [];

                    var rooms = getRooms({ RoomTypeId: roomTypeId, RoomCatId: roomCategoryId });
                    deleteRoomNo.push(parseInt(rooms[0].RoomNo));

                    DeleteRooms(deleteRoomNo);
                    RoomCountGridSetRoomNumber();
                }

                DrawRoomCountGrid();
                HideGrid();
            }
        }


    });

    function DrawRoomCountGrid() {
        ShowRoomCountGrid();
        $('.room-wise-counts tbody tr').remove();

        $.each(RoomCountJson, function (index, roomDetails) {
            $(
