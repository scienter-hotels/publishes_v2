@model Scienter.HotelERP.Common.Domain.ProfitCenter
@{
    ViewBag.Title = "Create / Edit";
}

<link href="~/Select2/css/select2.min.css" rel="stylesheet" />
<script src="~/Select2/js/select2.full.min.js"></script>
<style>
    .select2-container .select2-selection--single {
        height: 34px !important;
        /*width:50px!important;*/
    }
    /*2023-08-16---------------------------------------------------------------------*/
    .select2-results {
        line-height: 12px !important;
        font-size: 12px !important;
    }

        .select2-results ul li {
            color: black !important;
            font-family: 'Roboto', sans-serif !important;
            font-weight: 200 !important;
            cursor: auto;
        }

    .select2-container--default .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: #0078D4 !important;
        color: white !important;
    }

    .select2-selection__rendered {
        color: #0a1324;
    }

    .select2-search--dropdown .select2-search__field {
        height: 26px;
        font-size: 14px;
    }

    .select2-container--default .select2-results > .select2-results__options {
        overflow-x: hidden;
    }

    .control-label {
        z-index: 1 !important;
    }

    .select2-container {
        width: 100% !important;
    }
    /*-------------------------------------------------------------------------------*/
</style>
<div class="col-md-12">

    <form id="ProfitCenter">
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <input type="hidden" value="@Model.Id" name="Id" id="Id" />
            <input type="hidden" value="@Model.ChargeCodeId" name="Id" id="hdn-ChargeCodeId" />
            <input type="hidden" value="@Model.PostingTypeId" name="Id" id="hdn-PostingTypeId" />

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group label-floating">
                        <label class="control-label">Name *</label>
                        <input autocomplete="off" class="form-control text-box single-line" maxlength="100" id="Name" name="Name" type="text" value="@Model.Name" required>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Charge Code *</label>
                        <select name="ChargeCodeId" id="ChargeCodeId" class="form-control ChargeCodeId select2" required></select>
                    </div>

                    <div class="form-group label-floating">
                        <label class="control-label">Posting Type*</label>
                        <select name="PostingTypeId" id="PostingTypeId" class="form-control PostingTypeId select2" required></select>
                    </div>

                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsActive)
                            Is Active
                        </label>
                    </div>
                    <div class="form-group checkbox">
                        <label>
                            @Html.CheckBoxFor(model => model.IsNeedToShowWarkingBillTaxes)  @*Is need to show warking bill taxes*@
                            Is need to show warking bill taxes
                        </label>
                    </div>
                    <div class="form-group">
                        <input type="submit" id="btnSave" value="Save" class="btn btn-primary" />
                        &nbsp;
                        <input type="reset" id="btnClear" value="Clear" class="btn btn-default" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        debugger;

        $('.select2').select2();
         //2023-08-16--------------------------------------------------------------------------
        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });
        //-------------------------------------------------------------------------------------------
        LoadChargeCodeCombo();
        LoadPostingTypeCombo();
    });
    function LoadChargeCodeCombo() {
        debugger;
        $.ajax({
            url: '/Administration/ProfitCenter/ChargeCodeCombo',
            dataType: 'json',
            success: function (modules) {
                if ($('#ChargeCodeId').length > 0) {
                    $('#ChargeCodeId option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#ChargeCodeId'));
                        console.log(index);
                    });
                }
            },
            complete: function () {
                debugger;
                $('#ChargeCodeId').val($('#hdn-ChargeCodeId').val());
            }
        });
    }
    function LoadPostingTypeCombo() {
        debugger;
        $.ajax({
            url: '/Administration/ProfitCenter/PostingTypeCombo',
            dataType: 'json',
            success: function (modules) {
                if ($('#PostingTypeId').length > 0) {
                    $('#PostingTypeId option').not(':first').remove();

                    $.each(modules, function (index, type) {
                        $(' <option value="' + type.Id + '"> ' + type.Name + ' </option>').appendTo($('#PostingTypeId'));
                        console.log(index);
                    });
                }
            },
            complete: function () {
                debugger;
                $('#PostingTypeId').val($('#hdn-PostingTypeId').val());
            }
        });
    }
</script>

