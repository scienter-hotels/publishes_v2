@model Scienter.HotelERP.Common.Domain.ViewModels.SpaReservationViewModel
<style>
    .form-group-date {
        margin: 0px;
    }

    #contentLoadingArea {
        padding-left: 20px;
    }

    .padding-left-form {
        padding-left: 7px !important;
    }

    .rescheckbox {
        font-size: 10px;
        line-height: 12px;
        border-color: #a0613d;
        /*color: #000000;*/
        font-weight: 400;
    }
</style>

<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-timepicker/1.3.5/jquery.timepicker.min.css" />
<script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery-timepicker/1.3.5/jquery.timepicker.min.js"></script>

<div class="col-md-12">
    <div class="" id="spaReservationDataLoadingArea">
        <form action="/" method="post" id="spaReservationForm">
            <input type="hidden" name="name" id="resId" value="@ViewBag.SpaResId" class="resId" />
            <input type="hidden" name="name" id="spaRoomId" value="@ViewBag.SpaRoomName" class="" />
            <input type="hidden" name="name" id="guestProfileId" value="" />
            <input type="hidden" name="name" id="packageHeaderId" value="" />
            <input type="hidden" name="name" id="spaVenueId" value="@ViewBag.VenueId" />
            <input type="hidden" name="name" id="spaTherapistId" value="@ViewBag.TherapistId" />
            <input type="hidden" name="name" id="spaGenderId" value="@ViewBag.Gender" />
            <input type="hidden" name="name" id="spaTo" value="@ViewBag.To" />
            <input type="hidden" name="name" id="spaFrom" value="@ViewBag.From" />
            <input type="hidden" name="name" id="spareservationHeaderId" value="@ViewBag.ReservationHeaderId" />
            <input type="hidden" name="name" id="spaStatusId" value="@ViewBag.StatusId" />

            <fieldset class="the-fieldset wizard" style="margin:20px 0;">
                <legend class="the-legend">Availability</legend>
                <div class="row">

                    <div class="col-md-3 padding-left-form">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">Date *</label>
                            <input autocomplete="off" class="form-control text-box single-line datePicker" id="date" name="Date" required>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">From *</label>
                            <select id="from">
                                @foreach (var timeSlot in Model.TimeSlots)
                                {
                                    <option value="@timeSlot.Id">@timeSlot.From</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <label class="required control-label">To *</label>
                            <select id="to">
                                @foreach (var timeSlot in Model.TimeSlots)
                                {
                                    <option value="@timeSlot.Id">@timeSlot.From</option>
                                }

                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                            <div class="form-group">
                                <input type="button" id="btnCheckAvailability" value="Check Availability" class="btn btn-primary" />
                            </div>
                        </div>
                    </div>
                </div>
            </fieldset>

            <fieldset class="the-fieldset wizard" style="margin:20px 0;" id="contentLoadingSpaReservationDetails">
                <legend class="the-legend">Reservation Details</legend>
                <div class="row">
                    <div class="">
                        <div class="col-md-4 padding-left-form" id="">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Venue *</label>
                                <select id="venueId" class="contentLoadingSpaEditVenue" disabled>
                                    @foreach (var venue in Model.Venues)
                                    {
                                        <option value="@venue.Id">@venue.Name</option>
                                    }
                                </select>

                            </div>
                        </div>

                        <div class="col-md-4 padding-left-form">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Therapist Gender *</label>
                                <select id="genderId">
                                    @foreach (var gender in Model.Genders)
                                    {
                                        <option value="@gender.Id">@gender.Name</option>
                                    }

                                </select>
                            </div>
                        </div>

                        <div class="col-md-4" id="contentLoadingSpaTherapist">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Therapist *</label>
                                <select id="employeeId">
                                    @foreach (var therapist in Model.Therapists)
                                    {
                                        <option value="@therapist.Id">@therapist.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="">
                        <div class="col-md-4" id="contentLoadingSpaRoomNo">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Room No *</label>
                                <input type="text" class="form-control" value="@ViewBag.SpaRoomName" disabled />
                            </div>
                        </div>

                        <div class="col-md-4" id="contentLoadingSpaPackage">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Package Name *</label>
                                <input type="text" class="form-control" value="@ViewBag.Package" disabled />
                            </div>
                        </div>

                        <div class="col-md-4" id="contentLoadingSpaPackage">
                            <div class="form-group form-group-margin-override label-floating" required style="padding:0 20px">
                                <label class="required control-label">Status *</label>
                                <select id="statusId">
                                    <option value="C">Confirm</option>
                                    <option value="X">Cancel</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="content" hidden>
                    <table class="col-md-12 table table-striped" id="" style="width:97.7%;margin-left:11px;">
                        <thead style="border-bottom: 1px solid #eee; background-color:#f0f8ff;">
                            <tr style="width:100%;">
                                <th style="width:40%; padding-left:10px;">ITEM</th>
                                <th style="width:40%; padding-left:10px;">Qty</th>
                                <th style="width:20%; text-align:right"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.SpaItems)
                            {
                                <tr>
                                    <td>
                                        @item.Name
                                    </td>
                                    <td>
                                        @item.Quantity
                                    </td>
                                    <td>
                                        <button type="button" class="hidden-print btn btn-danger btn-sm"><span class="glyphicon glyphicon-minus"></span></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group" style="padding:0 10px">
                            <input type="button" id="btnSave" value="Update Reservation" class="btn btn-primary" />
                        </div>
                    </div>
                </div>

            </fieldset>
        </form>

    </div>
</div>

<script>

    $(document).ready(function () {

        $('#venueId').val($('#spaVenueId').val());
        $('#employeeId').val($('#spaTherapistId').val());
        $('#roomId').val($('#spaRoomId').val());
        $('#genderId').val($('#spaGenderId').val());
        $('#from').val($('#spaFrom').val());
        $('#to').val($('#spaTo').val());
        $('#reservationHeaderId').val($('#spareservationHeaderId').val());
        $('#statusId').val($('#spaStatusId').val());

        //$('#contentLoadingSpaTherapist').removeAttr('hidden');
        //$('#contentLoadingSpaRoomNo').removeAttr('hidden');
        //$('#contentLoadingSpaPackage').removeAttr('hidden');

        $('#quantity').val(1);

        $('.datePicker').val($('#hotelDate').val());
        $('#contentLoadingSpaReservationItemGrid').addClass('hidden');


        $('#venueId').addClass('select2');
        $('#itemId').addClass('select2');
        $('#employeeId').addClass('select2');
        $('#from').addClass('select2');
        $('#to').addClass('select2');
        $('#genderId').addClass('select2');
        $('#roomId').addClass('select2');
        $('#packageId').addClass('select2');
        $('#statusId').addClass('select2');

        $('.select2').select2();

        setTimeout(function () {
            $('.select2.select2-container').addClass('form-control');
            $('.select2-container--default .select2-selection--single').css({ 'border': 'none', 'border-radius': '0px', 'border-bottom': '1px solid #d2d2d2' });
            $('.select2-selection__arrow').css('display', 'none');
            $('#select2-DocNo-container').css({ 'margin-top': '-1px', 'cursor': 'auto' });
        }, 900);

        $('body').off('click', '.select2').on('click', '.select2', function () {
            setTimeout(function () {
                $('.select2-results ul li').removeClass('select2-results__option--selected');
            }, 200);
        });

        $('.datePicker').daterangepicker({
            "showDropdowns": true,
            singleDatePicker: true,
            "showWeekNumbers": true,
            "showISOWeekNumbers": true,
            "minDate": $('#hotelCurrentDate').val(),
            "startDate": $('#hotelCurrentDate').val(),
            "endDate": moment().add(1, 'days'),
            "opens": "right",
            "applyClass": "btn-primary",
            locale: {
                format: 'DD/MM/YYYY'
            }
        }, function (start, end, label) {
            $('input[name="From"]').val(start.format('DD/MM/YYYY'));
            $('input[name="To"]').val(end.format('DD/MM/YYYY'));
        });

    });

</script>