<input type="hidden" id="hdnAdvanceSearch" value="0" />

@{
    List<SideButtonDetails> lst = Model;
    string childButtonAttr = "";
    string isParantButtonClass = "";
}

<style>
    .backToList {
        display: block;
        padding: 6px 10px;
        padding-bottom: 4px;
        background-color: rgb(9, 79, 112);
        color: rgb(255, 255, 255);
        margin: 30px 3px 3px;
        border-radius: 3px;
        font-size: 12px;
        letter-spacing: 1px;
        text-align: center;
        transition: all 0.2s;
        color: #fff;
    }

    .parentButton, .childButton, .btn-theme-color-2 {
        transition: all 0.2s;
    }


        .parentButton:hover, .childButton:hover, .btn-theme-color-2:hover {
            letter-spacing: 1px;
        }

    .backToList:hover {
        letter-spacing: 8px;
        color: #fff;
    }
</style>

<div id="leftSideContent" class="sidenavLeft">
    <div style="padding:10px; padding-top: 0px;">
        <a href="javascript:void(0)" class="closebtn" onclick="closePushContentLeft()" style="display:block; margin-bottom:10px;">&times;</a>

        <div id="buttons" class="col-md-12" style="margin-top:-20px">
            <div class="row" id="reservationLevel" style="overflow-y:auto; overflow-x:hidden;">

                @foreach (SideButtonDetails item in lst)
                {
                    isParantButtonClass = "parentButton";
                    var isShow = (item.IsShow) ? "" : "hidden";
                    if (item.HasChildButtons)
                    {
                        childButtonAttr = "buttonDetail_" + item.Id;
                    }
                    else
                    {
                        childButtonAttr = "";
                    }

                    if (item.IsParantButton)
                    {
                        <div class="col-md-6 border-margin parentButtonContainer">
                            <a data-detailButton="@childButtonAttr" style="background-color:@item.ButtonColor; color:@item.IconColor; display: flex; justify-content: center; align-items: center;" class="@isParantButtonClass btn-parent btn btn-defaultfull-width-100perc @item.ExtraClass" id="@item.BtnId" data-title="@item.DataTitle" data-width="@item.DataWidth" @isShow target="_blank">
                                <div style="text-align: center;">
                                    <i class="fi @item.IconName" style="font-size:20px;"></i>
                                    <br />
                                    @Html.Raw(item.BtnName)
                                </div>
                            </a>
                        </div>
                    }
                    else
                    {
                        childButtonAttr = "buttonDetail_" + item.ParantButtonId;
                        <div class="col-md-6 border-margin childButtonContainer @childButtonAttr" style="display:none;">
                            <a style="background-color:@item.ButtonColor; color:@item.IconColor; display: flex; justify-content: center; align-items: center;" class="childButton btn btn-defaultfull-width-100perc @item.ExtraClass" id="@item.BtnId" data-title="@item.DataTitle" data-width="@item.DataWidth" @isShow target="_blank">
                                <div style="text-align: center;">
                                    <i class="fi @item.IconName" style="font-size:20px;"></i>
                                    <br />
                                    @Html.Raw(item.BtnName)
                                </div>
                            </a>
                        </div>
                    }



                }



            </div>
        </div>



        <div class="row">
            <div class="col-md-12">
                <a href="javascript:void(0)" class="backToList" onclick="backToList()">BACK TO LIST</a>
            </div>
        </div>


    </div>
</div>



<script src="~/Scripts/ui/common/reservation-list-pagination.js"></script>
<script src="~/Scripts/ui/checkedout-reservation-list/checkedout-reservation-list.js"></script>
<script src="~/Scripts/ui/checkedout-reservation-list/side-buttons/checkedout-side-buttons.js"></script>

<script>
    $(document).ready(function () {
        setTimeout(function () {
            LoadCheckedOutReservationGrid();
        }, 200);

        $('.backToList').hide();
    });
</script>
